{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Journal comptable{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Journal comptable',
        subtitle: current_school.name,
        icon: 'fa-book',
        color: 'primary',
        breadcrumb: [
            { label: 'Comptabilité', path: path('admin_accounting_dashboard') },
            { label: 'Journal' }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_accounting_journal_pdf', app.request.query.all) }}" target="_blank" rel="noopener" class="btn btn-outline-danger"><i class="fas fa-file-pdf me-1"></i> PDF</a>
            <a href="{{ path('admin_accounting_journal_xlsx', app.request.query.all) }}" class="btn btn-outline-success"><i class="fas fa-file-excel me-1"></i> Excel</a>
            <a href="{{ path('admin_accounting_entry_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Écriture manuelle</a>
            <a href="{{ path('admin_accounting_dashboard') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    {# ── Filtres ── #}
    <div class="card mb-3">
        <div class="card-body">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small">Du</label>
                    <input type="date" name="from" value="{{ filters.from }}" class="form-control">
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Au</label>
                    <input type="date" name="to" value="{{ filters.to }}" class="form-control">
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Type</label>
                    <select name="type" class="form-select">
                        <option value="">Tous</option>
                        <option value="recette" {{ filters.type == 'recette' ? 'selected' }}>Recettes</option>
                        <option value="depense" {{ filters.type == 'depense' ? 'selected' }}>Dépenses</option>
                        <option value="versement" {{ filters.type == 'versement' ? 'selected' }}>Versements</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Compte</label>
                    <select name="account" class="form-select">
                        <option value="">Tous</option>
                        {% for a in accounts %}
                            <option value="{{ a.id }}" {{ filters.account == a.id ? 'selected' }}>{{ a.code }} — {{ a.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-2 d-grid">
                    <button class="btn btn-primary"><i class="fas fa-filter me-1"></i> Filtrer</button>
                </div>
            </form>
        </div>
    </div>

    {# ── Totaux ── #}
    <div class="row g-2 mb-3">
        <div class="col"><div class="alert alert-success mb-0 py-2 small">Recettes : <strong>{{ sum_recette|number_format(0, ',', ' ') }} F</strong></div></div>
        <div class="col"><div class="alert alert-danger mb-0 py-2 small">Dépenses : <strong>{{ sum_depense|number_format(0, ',', ' ') }} F</strong></div></div>
        <div class="col"><div class="alert alert-info mb-0 py-2 small">Versements : <strong>{{ sum_versement|number_format(0, ',', ' ') }} F</strong></div></div>
        <div class="col"><div class="alert alert-primary mb-0 py-2 small">Résultat : <strong>{{ (sum_recette - sum_depense)|number_format(0, ',', ' ') }} F</strong></div></div>
    </div>

    <div class="card table-card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Réf.</th><th>Date</th><th>Libellé</th><th>Compte</th><th>Type</th>
                            <th class="text-end">Montant</th><th>Méthode</th><th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for e in entries %}
                            <tr>
                                <td><span class="badge badge-soft secondary">{{ e.reference }}</span></td>
                                <td class="text-muted">{{ e.entryDate|date('d/m/Y') }}</td>
                                <td>{{ e.label }}{% if e.notes %}<br><small class="text-muted">{{ e.notes }}</small>{% endif %}</td>
                                <td>{% if e.account %}<small>{{ e.account.code }}</small>{% else %}<span class="text-muted">—</span>{% endif %}</td>
                                <td><span class="badge bg-{{ e.typeColor }}">{{ e.typeLabel }}</span></td>
                                <td class="text-end fw-bold text-{{ e.typeColor }}">{{ e.cashSign > 0 ? '+' : '-' }}{{ e.amount|number_format(0, ',', ' ') }} F</td>
                                <td>{% if e.paymentMethod %}<span class="badge badge-soft secondary">{{ e.paymentMethod }}</span>{% else %}—{% endif %}</td>
                                <td class="text-end">
                                    {% if e.manual %}
                                        <form method="post" action="{{ path('admin_accounting_entry_delete', {'id': e.id}) }}" class="d-inline"
                                              data-confirm="Supprimer l'écriture manuelle <strong>{{ e.reference }}</strong> ?"
                                              data-confirm-title="Confirmer la suppression" data-confirm-btn="Oui, supprimer">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_entry' ~ e.id) }}">
                                            <button class="btn btn-sm btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                        </form>
                                    {% else %}
                                        <span class="badge badge-soft info" title="Générée automatiquement depuis {{ e.sourceType }}"><i class="fas fa-robot"></i> auto</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="8">{{ empty_state('fa-book', 'Journal vide', 'Aucune écriture ne correspond à ces critères.') }}</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% include '_pagination.html.twig' with { pagination: entries } %}
        </div>
    </div>
</div>
{% endblock %}
