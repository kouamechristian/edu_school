<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <style>
        @page { margin: 20px 22px; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 8px; color: #000; }
        .header { width: 100%; border-bottom: 1px solid #999; padding-bottom: 6px; margin-bottom: 8px; }
        .header td { vertical-align: middle; }
        .header .logo { width: 70px; }
        .header .logo img { max-height: 58px; max-width: 66px; }
        .header .school { text-align: center; }
        .header .school .name { font-weight: bold; font-size: 13px; }
        .header .school .ministry { font-size: 9px; }
        .title-main { text-align: center; font-weight: bold; font-size: 12px; margin: 4px 0; }
        .period { text-align: center; font-size: 9px; margin-bottom: 8px; }
        .acc-title { font-weight: bold; font-size: 10px; background: #eef2f7; padding: 3px 6px; margin-top: 8px; border: 1px solid #cbd5e1; }
        table.list { width: 100%; border-collapse: collapse; }
        table.list th, table.list td { border: 1px solid #000; padding: 2px 4px; font-size: 7.5px; }
        table.list th { background: #f2f2f2; font-weight: bold; text-align: center; }
        td.num { text-align: right; }
        td.center { text-align: center; }
        tr.tot td { font-weight: bold; background: #f7f7f7; }
        .green { color: #15803d; } .red { color: #b91c1c; }
        .grand { margin-top: 10px; border: 1.5px solid #000; padding: 5px 8px; font-weight: bold; font-size: 10px;
                 display: flex; justify-content: space-between; }
    </style>
</head>
<body>
    <table class="header">
        <tr>
            <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
            <td class="school">
                <div class="name">{{ school ? school.name|upper : '' }}</div>
                <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                <div class="ministry">Tel: {{ school ? school.phone : '' }}</div>
            </td>
            <td class="logo"></td>
        </tr>
    </table>

    <div class="title-main">GRAND LIVRE PAR COMPTE</div>
    <div class="period">
        {% if from and to %}Période du {{ from|date('d/m/Y') }} au {{ to|date('d/m/Y') }}{% else %}Toutes périodes{% endif %}
        — édité le {{ generated_at|date('d/m/Y H:i') }}
    </div>

    {% for group in groups %}
        <div class="acc-title">
            {% if group.account %}{{ group.account.code }} — {{ group.account.name }}{% else %}Non ventilé (versements){% endif %}
        </div>
        <table class="list">
            <thead>
                <tr>
                    <th style="width:12%">Référence</th>
                    <th style="width:9%">Date</th>
                    <th>Libellé</th>
                    <th style="width:13%">Débit</th>
                    <th style="width:13%">Crédit</th>
                    <th style="width:14%">Solde progressif</th>
                </tr>
            </thead>
            <tbody>
                {% for r in group.rows %}
                    <tr>
                        <td>{{ r.entry.reference }}</td>
                        <td class="center">{{ r.entry.entryDate|date('d/m/Y') }}</td>
                        <td>{{ r.entry.label }}</td>
                        <td class="num red">{{ r.entry.type != 'recette' ? (r.entry.amount|number_format(0, ',', ' ')) : '' }}</td>
                        <td class="num green">{{ r.entry.type == 'recette' ? (r.entry.amount|number_format(0, ',', ' ')) : '' }}</td>
                        <td class="num">{{ r.cumul|number_format(0, ',', ' ') }}</td>
                    </tr>
                {% endfor %}
                <tr class="tot">
                    <td colspan="5" class="num">Total du compte</td>
                    <td class="num">{{ group.total|number_format(0, ',', ' ') }}</td>
                </tr>
            </tbody>
        </table>
    {% else %}
        <p>Aucune écriture.</p>
    {% endfor %}

    <div class="grand">
        <span>CUMUL GÉNÉRAL DES MOUVEMENTS</span>
        <span>{{ grand_total|number_format(0, ',', ' ') }} F CFA</span>
    </div>
</body>
</html>
