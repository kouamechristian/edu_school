<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <style>
        @page { margin: 24px 26px; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 9px; color: #000; }
        .header { width: 100%; border-bottom: 1px solid #999; padding-bottom: 6px; margin-bottom: 10px; }
        .header td { vertical-align: middle; }
        .header .logo { width: 74px; }
        .header .logo img { max-height: 60px; max-width: 68px; }
        .header .school { text-align: center; }
        .header .school .name { font-weight: bold; font-size: 14px; }
        .header .school .ministry { font-size: 9px; }
        .title-main { text-align: center; font-weight: bold; font-size: 13px; margin: 4px 0; }
        .period { text-align: center; font-size: 9px; margin-bottom: 10px; }
        .cols { width: 100%; }
        .cols td { vertical-align: top; width: 50%; padding: 0 6px; }
        h6.sec { font-size: 11px; font-weight: bold; margin: 2px 0 4px; padding-bottom: 2px; border-bottom: 1px solid #999; }
        table.acc { width: 100%; border-collapse: collapse; margin-bottom: 4px; }
        table.acc td { border: 1px solid #000; padding: 3px 5px; font-size: 8.5px; }
        td.num { text-align: right; }
        .subtotal td { font-weight: bold; background: #f2f2f2; }
        .diff { margin-top: 4px; border: 1.4px solid #000; padding: 5px 8px; font-size: 10px; font-weight: bold;
                display: flex; justify-content: space-between; }
        .ok { background: #eafaf0; } .ko { background: #fdecec; }
        .green { color: #15803d; } .red { color: #b91c1c; }
        .signatures { width: 100%; margin-top: 40px; }
        .signatures td { width: 50%; text-align: center; font-size: 9px; padding-top: 30px; border-top: 1px dotted #666; }
    </style>
</head>
<body>
    <table class="header">
        <tr>
            <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
            <td class="school">
                <div class="name">{{ school ? school.name|upper : '' }}</div>
                <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                <div class="ministry">Tel: {{ school ? school.phone : '' }}</div>
            </td>
            <td class="logo"></td>
        </tr>
    </table>

    <div class="title-main">ÉTAT DE RAPPROCHEMENT CAISSE / BANQUE</div>
    <div class="period">
        Mouvements {% if period_from %}du {{ period_from|date('d/m/Y') }}{% else %}depuis l'origine{% endif %}
        au {{ statement_date|date('d/m/Y') }} — édité le {{ generated_at|date('d/m/Y H:i') }}
    </div>

    <table class="cols">
        <tr>
            <td>
                <h6 class="sec">Banque</h6>
                <table class="acc">
                    <tr><td>Versements en banque</td><td class="num green">+ {{ summary.versement|number_format(0, ',', ' ') }}</td></tr>
                    <tr><td>Encaissements par banque</td><td class="num green">+ {{ summary.bank_in|number_format(0, ',', ' ') }}</td></tr>
                    <tr><td>Dépenses réglées par banque</td><td class="num red">− {{ summary.bank_out|number_format(0, ',', ' ') }}</td></tr>
                    <tr class="subtotal"><td>Solde banque théorique</td><td class="num">{{ summary.bank_theoretical|number_format(0, ',', ' ') }}</td></tr>
                    <tr><td>Solde du relevé bancaire</td><td class="num">{{ statement_balance is not null ? (statement_balance|number_format(0, ',', ' ')) : '—' }}</td></tr>
                </table>
                {% if bank_difference is not null %}
                    <div class="diff {{ bank_difference|abs < 0.01 ? 'ok' : 'ko' }}">
                        <span>Écart banque</span><span>{{ bank_difference|number_format(0, ',', ' ') }} F</span>
                    </div>
                {% endif %}
            </td>
            <td>
                <h6 class="sec">Caisse (espèces)</h6>
                <table class="acc">
                    <tr><td>Encaissements espèces</td><td class="num green">+ {{ summary.cash_in|number_format(0, ',', ' ') }}</td></tr>
                    <tr><td>Dépenses espèces</td><td class="num red">− {{ summary.cash_out|number_format(0, ',', ' ') }}</td></tr>
                    <tr><td>Versements en banque</td><td class="num red">− {{ summary.versement|number_format(0, ',', ' ') }}</td></tr>
                    <tr class="subtotal"><td>Espèces théoriques en caisse</td><td class="num">{{ summary.cash_theoretical|number_format(0, ',', ' ') }}</td></tr>
                    <tr><td>Espèces comptées</td><td class="num">{{ cash_counted is not null ? (cash_counted|number_format(0, ',', ' ')) : '—' }}</td></tr>
                </table>
                {% if cash_difference is not null %}
                    <div class="diff {{ cash_difference|abs < 0.01 ? 'ok' : 'ko' }}">
                        <span>Écart de caisse</span><span>{{ cash_difference|number_format(0, ',', ' ') }} F</span>
                    </div>
                {% endif %}
            </td>
        </tr>
    </table>

    <table class="signatures">
        <tr>
            <td>Le Caissier / La Caissière</td>
            <td>Le Fondateur / La Direction</td>
        </tr>
    </table>
</body>
</html>
