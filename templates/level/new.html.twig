{% extends 'base.html.twig' %}

{% block title %}Nouveau Niveau{% endblock %}
{% block heading %}Nouveau Niveau{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-xl-8">
            {% embed 'components/page_header.html.twig' with {
                title: block('heading'),
                icon: 'fa-layer-group',
                color: 'primary',
                breadcrumb: [
                    { label: 'Niveaux', path: path('admin_level_index') },
                    { label: block('heading') }
                ]
            } %}
                {% block actions %}
                    <a href="{{ path('admin_level_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
                {% endblock %}
            {% endembed %}

            {% include '_flash.html.twig' %}

            <div class="card">
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="mb-3">{{ form_row(form.name) }}</div>
                        {% if level.id %}
                            <div class="mb-3">
                                <label class="form-label">Ordre d'affichage</label>
                                <input type="text" class="form-control" value="{{ level.orderNumber }}" disabled>
                                <div class="form-text">L'ordre est attribué automatiquement.</div>
                            </div>
                        {% endif %}
                        <div class="mb-3">{{ form_row(form.description) }}</div>
                        <div class="mb-3">{{ form_row(form.cycle) }}</div>
                        <div class="mb-3">{{ form_row(form.isActive) }}</div>
                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a href="{{ path('admin_level_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
                            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Enregistrer</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
