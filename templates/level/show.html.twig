{% extends 'base.html.twig' %}

{% block title %}{{ level.name }}{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4 class="mb-0">
                <i class="fas fa-layer-group me-2"></i> {{ level.name }}
            </h4>
            {% if level.isActive %}
                <span class="badge bg-success">Actif</span>
            {% else %}
                <span class="badge bg-danger">Inactif</span>
            {% endif %}
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6">
                    <strong><i class="fas fa-tag me-2"></i> Catégorie :</strong><br>
                    <span class="badge bg-secondary">{{ level.categoryLabel }}</span>
                </div>
                <div class="col-md-6">
                    <strong><i class="fas fa-sort-numeric-down me-2"></i> Ordre d'affichage :</strong><br>
                    <span class="text-muted">{{ level.orderNumber }}</span>
                </div>
            </div>

            {% if level.description %}
            <div class="mb-3">
                <strong><i class="fas fa-info-circle me-2"></i> Description :</strong><br>
                <span class="text-muted">{{ level.description|nl2br }}</span>
            </div>
            {% endif %}

            <div class="mt-4 d-flex justify-content-between">
                <a href="{{ path('admin_level_index') }}" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-2"></i> Retour
                </a>
                <a href="{{ path('admin_level_edit', {'id': level.id}) }}" class="btn btn-warning">
                    <i class="fas fa-edit me-2"></i> Modifier
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

