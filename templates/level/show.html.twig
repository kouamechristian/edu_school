{% extends 'base.html.twig' %}

{% block title %}{{ level.name }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-xl-9">
            {% embed 'components/page_header.html.twig' with {
                title: level.name,
                subtitle: 'Niveau scolaire',
                icon: 'fa-layer-group',
                color: 'primary',
                breadcrumb: [
                    { label: 'Niveaux', path: path('admin_level_index') },
                    { label: level.name }
                ]
            } %}
                {% block actions %}
                    <a href="{{ path('admin_level_edit', {'id': level.id}) }}" class="btn btn-warning"><i class="fas fa-edit me-1"></i> Modifier</a>
                    <a href="{{ path('admin_level_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
                {% endblock %}
            {% endembed %}

            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="m-0 fw-bold text-primary"><i class="fas fa-layer-group me-2"></i>{{ level.name }}</h6>
                    <span class="badge badge-soft {{ level.isActive ? 'success' : 'danger' }}">{{ level.isActive ? 'Actif' : 'Inactif' }}</span>
                </div>
                <div class="card-body">
                    <div class="info-list">
                        <div class="info-row"><div class="info-label">Catégorie</div><div class="info-value"><span class="badge badge-soft secondary">{{ level.categoryLabel }}</span></div></div>
                        <div class="info-row"><div class="info-label">Ordre d'affichage</div><div class="info-value">{{ level.orderNumber }}</div></div>
                        {% if level.description %}<div class="info-row"><div class="info-label">Description</div><div class="info-value">{{ level.description|nl2br }}</div></div>{% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
