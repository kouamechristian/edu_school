{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Niveaux Scolaires{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Gestion des Niveaux Scolaires',
        subtitle: 'Niveaux et ordre d\'affichage',
        icon: 'fa-layer-group',
        color: 'primary',
        breadcrumb: [ { label: 'Niveaux' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_level_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouveau Niveau</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des niveaux <span class="badge badge-soft ms-1">{{ levels|length }}</span></h6></div>
        <div class="card-body">
            {% if levels is empty %}
                {{ empty_state('fa-layer-group', 'Aucun niveau', 'Cliquez sur « Nouveau Niveau » pour commencer.') }}
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr><th width="90">Ordre</th><th>Nom</th><th>Cycle</th><th>Description</th><th>Statut</th><th class="text-end" width="200">Actions</th></tr>
                        </thead>
                        <tbody>
                            {% for level in levels %}
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-1">
                                        <span class="badge badge-soft secondary">{{ level.orderNumber }}</span>
                                        <div class="btn-group btn-group-sm">
                                            <form method="post" action="{{ path('admin_level_move', {'id': level.id, 'direction': 'up'}) }}" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('move' ~ level.id) }}">
                                                <button type="submit" class="btn btn-outline-secondary px-1 py-0" title="Monter"{{ loop.first ? ' disabled' : '' }}><i class="fas fa-arrow-up"></i></button>
                                            </form>
                                            <form method="post" action="{{ path('admin_level_move', {'id': level.id, 'direction': 'down'}) }}" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('move' ~ level.id) }}">
                                                <button type="submit" class="btn btn-outline-secondary px-1 py-0" title="Descendre"{{ loop.last ? ' disabled' : '' }}><i class="fas fa-arrow-down"></i></button>
                                            </form>
                                        </div>
                                    </div>
                                </td>
                                <td><strong>{{ level.name }}</strong></td>
                                <td>{% if level.cycle %}<span class="badge badge-soft info">{{ level.cycle.libelle }}</span>{% else %}<span class="text-muted">—</span>{% endif %}</td>
                                <td class="text-muted">{% if level.description %}{{ level.description|length > 50 ? level.description|slice(0, 50) ~ '...' : level.description }}{% else %}—{% endif %}</td>
                                <td><span class="badge badge-soft {{ level.isActive ? 'success' : 'danger' }}">{{ level.isActive ? 'Actif' : 'Inactif' }}</span></td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a href="{{ path('admin_level_show', {'id': level.id}) }}" class="btn btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a>
                                        <a href="{{ path('admin_level_edit', {'id': level.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                        <form method="post" action="{{ path('admin_level_toggle', {'id': level.id}) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ level.id) }}">
                                            <button type="submit" class="btn btn-outline-secondary" title="{{ level.isActive ? 'Désactiver' : 'Activer' }}"><i class="fas fa-{{ level.isActive ? 'ban' : 'check' }}"></i></button>
                                        </form>
                                        {% if is_granted('ROLE_ADMIN') %}
                                        <form method="post" action="{{ path('admin_level_delete', {'id': level.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce niveau ?');" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ level.id) }}">
                                            <button type="submit" class="btn btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                        </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% include '_pagination.html.twig' with { pagination: levels } %}
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
