{% extends 'base.html.twig' %}

{% block title %}Niveaux Scolaires{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h3 mb-3">
                <i class="fas fa-layer-group me-2"></i> Gestion des Niveaux Scolaires
            </h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="{{ path('admin_level_new') }}" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i> Nouveau Niveau
            </a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

        <div class="card mb-3">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Ordre</th>
                                <th>Nom</th>
                                <th>Description</th>
                                <th>Statut</th>
                                <th width="180">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for level in levels %}
                            <tr>
                                <td><span class="badge bg-secondary">{{ level.orderNumber }}</span></td>
                                <td><strong>{{ level.name }}</strong></td>
                                <td>
                                    {% if level.description %}
                                        {{ level.description|length > 50 ? level.description|slice(0, 50) ~ '...' : level.description }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                                <td>
                                    {% if level.isActive %}
                                        <span class="badge bg-success">Actif</span>
                                    {% else %}
                                        <span class="badge bg-danger">Inactif</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a href="{{ path('admin_level_show', {'id': level.id}) }}" 
                                           class="btn btn-info" title="Voir">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="{{ path('admin_level_edit', {'id': level.id}) }}" 
                                           class="btn btn-warning" title="Modifier">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form method="post" action="{{ path('admin_level_toggle', {'id': level.id}) }}" 
                                              style="display:inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ level.id) }}">
                                            <button type="submit" class="btn btn-secondary" 
                                                    title="{{ level.isActive ? 'Désactiver' : 'Activer' }}">
                                                <i class="fas fa-{{ level.isActive ? 'ban' : 'check' }}"></i>
                                            </button>
                                        </form>
                                        <form method="post" action="{{ path('admin_level_delete', {'id': level.id}) }}" 
                                              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce niveau ?');"
                                              style="display:inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ level.id) }}">
                                            <button type="submit" class="btn btn-danger" title="Supprimer">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
</div>
{% endblock %}

