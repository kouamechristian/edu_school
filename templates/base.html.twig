                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_student_archive') }}" class="nav-link {{ app.request.get('_route') == 'admin_student_archive' ? 'active' : '' }}">
                    <i class="fas fa-archive"></i>
                    <span>Archives</span>
                </a>
            </li>
