                    <i class="fas fa-calendar"></i>
                    <span>Mon Emploi du Temps</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('student_absences') }}" class="nav-link {{ app.request.get('_route') == 'student_absences' ? 'active' : '' }}">
                    <i class="fas fa-calendar-times"></i>
                    <span>Mes Absences</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-chart-line"></i>
                    <span>Ma Progression</span>
                </a>
            </li>
            {% endif %}

            {# Section Administration #}
            {% if is_granted('ROLE_ADMIN') %}
            <div class="nav-section">Administration</div>
            
            <li class="nav-item">
                <a href="{{ path('admin_school_group_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_school_group' ? 'active' : '' }}">
                    <i class="fas fa-sitemap"></i>
                    <span>Groupes d'Établissements</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_school_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_school' and not (app.request.get('_route') starts with 'admin_school_group') ? 'active' : '' }}">
                    <i class="fas fa-school"></i>
                    <span>Établissements</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_school_year_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_school_year' ? 'active' : '' }}">
                    <i class="fas fa-calendar-alt"></i>
                    <span>Années Scolaires</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_level_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_level' ? 'active' : '' }}">
                    <i class="fas fa-layer-group"></i>
                    <span>Niveaux</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_user_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_user' ? 'active' : '' }}">
                    <i class="fas fa-users"></i>
                    <span>Utilisateurs</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_document_type_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_document_type' ? 'active' : '' }}">
                    <i class="fas fa-file-alt"></i>
                    <span>Types de Documents</span>
                </a>
            </li>

            {# Section Gestion des Élèves #}
            <div class="nav-section">Gestion des Élèves</div>
            
            <li class="nav-item">
                <a href="{{ path('admin_student_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_student' ? 'active' : '' }}">
                    <i class="fas fa-user-graduate"></i>
                    <span>Liste des Élèves</span>
                </a>
            </li>


            <li class="nav-item">
                <a href="{{ path('admin_pre_registration_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_pre_registration' ? 'active' : '' }}">
                    <i class="fas fa-clipboard-list"></i>
                    <span>Préinscriptions</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_student_enrollment') }}" class="nav-link {{ app.request.get('_route') == 'admin_student_enrollment' ? 'active' : '' }}">
                    <i class="fas fa-graduation-cap"></i>
