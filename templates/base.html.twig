                    <i class="fas fa-clipboard-list"></i>
                    <span>Évaluations</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_bulletin_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_bulletin' ? 'active' : '' }}">
                    <i class="fas fa-file-alt"></i>
                    <span>Bulletins</span>
                </a>
            </li>

            {# Section Gestion #}
            <div class="nav-section">Gestion</div>

            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-clipboard-list"></i>
                    <span>Notes</span>
                </a>
            </li>

            {# Absences - Menu déroulant #}
            <li class="nav-item">
                <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="collapse" data-bs-target="#absenceSubmenu" aria-expanded="false">
                    <i class="fas fa-calendar-check"></i>
                    <span>Absences</span>
                </a>
                <ul class="collapse" id="absenceSubmenu">
                    <li class="nav-item">
                        <a href="{{ path('admin_absence_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_absence_index' ? 'active' : '' }}">
                            <i class="fas fa-list"></i>
                            <span>Liste des absences</span>
