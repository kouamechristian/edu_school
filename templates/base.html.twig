<!DOCTYPE html>
<html lang="fr" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>{% block title %}EDU-SCHOOL{% endblock %} - Système de Gestion Scolaire</title>
    
    {# Favicon #}
    <link rel="icon" type="image/x-icon" href="{{ asset('favicon.ico') }}">
    
    {# Bootstrap CSS #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    {# Font Awesome Icons #}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    
    {# Google Fonts #}
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    {# ================================================================
       STYLES INLINE DU LAYOUT
       Conservés en inline pour le rendu initial rapide (sidebar/topbar)
       ================================================================ #}
    <style>
        :root {
            --primary-color: #4e73df;
            --secondary-color: #858796;
            --success-color: #1cc88a;
            --info-color: #36b9cc;
            --warning-color: #f6c23e;
            --danger-color: #e74a3b;
            --sidebar-width: 260px;
            --topbar-height: 60px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f8f9fc;
            overflow-x: hidden;
        }

        [data-bs-theme="dark"] body {
            background-color: var(--es-body-bg, #1a1d21);
        }

        /* ── Sidebar ── */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            width: var(--sidebar-width);
            background: linear-gradient(180deg, #4e73df 0%, #224abe 100%);
            color: white;
            transition: all 0.3s;
            z-index: 1000;
            overflow-y: auto;
        }

        .sidebar.collapsed {
            width: 80px;
        }

        .sidebar-brand {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
            font-size: 1.3rem;
            font-weight: 600;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .sidebar-brand i {
            margin-right: 0.5rem;
            font-size: 1.5rem;
        }

        .sidebar.collapsed .sidebar-brand-text {
            display: none;
        }

        .sidebar-nav {
            padding: 1rem 0;
        }

        .nav-item {
            list-style: none;
            position: relative;
        }

        .nav-link {
            display: flex;
            align-items: center;
            padding: 0.75rem 1.5rem;
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            transition: all 0.3s;
        }

        .nav-link:hover {
            color: white;
            background-color: rgba(255,255,255,0.1);
        }

        .nav-link.active {
            color: white;
            background-color: rgba(255,255,255,0.15);
            border-left: 3px solid white;
        }

        .nav-link i {
            margin-right: 1rem;
            font-size: 1.1rem;
            width: 20px;
            text-align: center;
        }

        .sidebar.collapsed .nav-link span:not(.sidebar-badge) {
            display: none;
        }

        .nav-section {
            padding: 1rem 1.5rem 0.5rem;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            color: rgba(255,255,255,0.4);
        }

        .sidebar.collapsed .nav-section {
            display: none;
        }

        /* ── Topbar ── */
        .topbar {
            position: fixed;
            top: 0;
            left: var(--sidebar-width);
            right: 0;
            height: var(--topbar-height);
            background: white;
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58,59,69,0.15);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 1.5rem;
            transition: all 0.3s;
            z-index: 999;
        }

        .sidebar.collapsed ~ .topbar {
            left: 80px;
        }

        .topbar-toggle {
            background: none;
            border: none;
            font-size: 1.5rem;
            color: var(--secondary-color);
            cursor: pointer;
        }

        .topbar-search {
            flex: 1;
            max-width: 500px;
            margin: 0 2rem;
        }

        .topbar-nav {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .topbar-item {
            position: relative;
        }

        .topbar-link {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            color: var(--secondary-color);
            text-decoration: none;
            border-radius: 0.35rem;
            transition: all 0.3s;
        }

        .topbar-link:hover {
            background-color: #f8f9fc;
            color: var(--primary-color);
        }

        .notification-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background-color: var(--danger-color);
            color: white;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            font-size: 0.7rem;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .user-avatar {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            background: var(--primary-color);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
        }

        /* ── Content ── */
        .content-wrapper {
            margin-left: var(--sidebar-width);
            margin-top: var(--topbar-height);
            padding: 2rem;
            min-height: calc(100vh - var(--topbar-height));
            transition: all 0.3s;
        }

        .sidebar.collapsed ~ .content-wrapper {
            margin-left: 80px;
        }

        /* ── Footer ── */
        .footer {
            background: white;
            padding: 1.5rem;
            text-align: center;
            color: var(--secondary-color);
            font-size: 0.875rem;
            border-top: 1px solid #e3e6f0;
        }

        /* ── Dropdown ── */
        .dropdown-menu {
            border: none;
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58,59,69,0.15);
        }

        /* ── Sous-menus sidebar ── */
        .nav-item ul {
            list-style: none;
            padding: 0;
            margin: 0;
            background-color: rgba(0,0,0,0.1);
        }

        .nav-item ul .nav-link {
            padding-left: 3rem;
            font-size: 0.9rem;
            border-left: none;
        }

        .nav-item ul .nav-link:hover {
            background-color: rgba(255,255,255,0.05);
        }

        .nav-item ul .nav-link.active {
            background-color: rgba(255,255,255,0.1);
            border-left: 3px solid rgba(255,255,255,0.5);
        }

        .nav-item ul .nav-link i {
            font-size: 0.9rem;
            width: 16px;
        }

        .sidebar.collapsed .nav-item ul {
            display: none;
        }

        .collapse {
            transition: height 0.3s ease;
        }

        .nav-link.dropdown-toggle::after {
            margin-left: auto;
            transition: transform 0.3s ease;
        }

        .nav-link.dropdown-toggle[aria-expanded="true"]::after {
            transform: rotate(90deg);
        }

        /* ── Scrollbar sidebar ── */
        .sidebar::-webkit-scrollbar {
            width: 6px;
        }

        .sidebar::-webkit-scrollbar-track {
            background: rgba(0,0,0,0.1);
        }

        .sidebar::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.3);
            border-radius: 3px;
        }

        /* ── Responsive ── */
        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
            }

            .sidebar.show {
                transform: translateX(0);
            }

            .topbar {
                left: 0;
            }

            .content-wrapper {
                margin-left: 0;
            }

            .topbar-search {
                display: none;
            }
        }
    </style>
    
    {# CSS externe (thème sombre, skeleton, toasts, etc.) #}
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
    
    {% block stylesheets %}{% endblock %}

    {# Application du thème sauvegardé avant le rendu pour éviter le flash blanc #}
    <script>
        (function(){
            var t = localStorage.getItem('edu-school-theme');
            if (t) document.documentElement.setAttribute('data-bs-theme', t);
        })();
    </script>
</head>
<body>
    {# ================================================================
       OVERLAY MOBILE (fermer la sidebar en cliquant à côté)
       ================================================================ #}
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    {# ================================================================
       SIDEBAR DYNAMIQUE PAR RÔLE
       Sections affichées selon is_granted() et app.user.userType
       ================================================================ #}
    <nav class="sidebar" id="sidebar">
        {# ── Brand ── #}
        <div class="sidebar-brand">
            <i class="fas fa-graduation-cap"></i>
            <span class="sidebar-brand-text">EDU-SCHOOL</span>
        </div>

        <ul class="sidebar-nav">
            {# ── Dashboard (commun à tous) ── #}
            <li class="nav-item">
                <a href="{{ path('app_home') }}" class="nav-link {{ app.request.get('_route') starts with 'app_home' ? 'active' : '' }}">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Tableau de bord</span>
                </a>
            </li>

            {# ==============================================================
               ESPACE ÉLÈVE
               Visible uniquement pour les utilisateurs de type "eleve"
               ============================================================== #}
            {% if app.user and app.user.userType == 'eleve' %}
            <div class="nav-section">Mon Espace Élève</div>

            <li class="nav-item">
                <a href="{{ path('student_dashboard') }}" class="nav-link {{ app.request.get('_route') == 'student_dashboard' ? 'active' : '' }}">
                    <i class="fas fa-home"></i>
                    <span>Mon Tableau de Bord</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('student_grades') }}" class="nav-link {{ app.request.get('_route') == 'student_grades' ? 'active' : '' }}">
                    <i class="fas fa-book"></i>
                    <span>Mes Notes</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('student_schedule') }}" class="nav-link {{ app.request.get('_route') == 'student_schedule' ? 'active' : '' }}">
                    <i class="fas fa-calendar"></i>
                    <span>Mon Emploi du Temps</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('student_absences') }}" class="nav-link {{ app.request.get('_route') == 'student_absences' ? 'active' : '' }}">
                    <i class="fas fa-calendar-times"></i>
                    <span>Mes Absences</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-chart-line"></i>
                    <span>Ma Progression</span>
                </a>
            </li>
            {% endif %}

            {# ==============================================================
               ESPACE PARENT
               Visible pour les utilisateurs de type "parent"
               ============================================================== #}
            {% if app.user and app.user.userType == 'parent' %}
            <div class="nav-section">Espace Parent</div>

            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-child"></i>
                    <span>Mes Enfants</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-chart-bar"></i>
                    <span>Suivi Scolaire</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-money-check-alt"></i>
                    <span>Paiements</span>
                </a>
            </li>
            {% endif %}

            {# ==============================================================
               ESPACE ENSEIGNANT
               Visible pour les enseignants (userType == 'enseignant')
               ============================================================== #}
            {% if app.user and app.user.userType == 'enseignant' %}
            <div class="nav-section">Espace Enseignant</div>

            <li class="nav-item">
                <a href="{{ path('admin_course_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_course' ? 'active' : '' }}">
                    <i class="fas fa-calendar-alt"></i>
                    <span>Mes Cours</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="{{ path('admin_evaluation_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_evaluation' ? 'active' : '' }}">
                    <i class="fas fa-clipboard-list"></i>
                    <span>Évaluations</span>
                </a>
            </li>
            <li class="nav-item">
                <a href="{{ path('admin_absence_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_absence_index' ? 'active' : '' }}">
                    <i class="fas fa-calendar-check"></i>
                    <span>Absences</span>
                    <span class="badge bg-warning sidebar-badge">3</span>
                </a>
            </li>
            {% endif %}

            {# ==============================================================
               ADMINISTRATION
               Visible pour ROLE_ADMIN (admins, super admins)
               ============================================================== #}
            {% if is_granted('ROLE_ADMIN') %}
            <div class="nav-section">Administration</div>
            
            <li class="nav-item">
                <a href="{{ path('admin_school_group_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_school_group' ? 'active' : '' }}">
                    <i class="fas fa-sitemap"></i>
                    <span>Groupes d'Établissements</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_school_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_school' and not (app.request.get('_route') starts with 'admin_school_group') and not (app.request.get('_route') starts with 'admin_school_year') ? 'active' : '' }}">
                    <i class="fas fa-school"></i>
                    <span>Établissements</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_school_year_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_school_year' ? 'active' : '' }}">
                    <i class="fas fa-calendar-alt"></i>
                    <span>Années Scolaires</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_level_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_level' ? 'active' : '' }}">
                    <i class="fas fa-layer-group"></i>
                    <span>Niveaux</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_user_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_user' ? 'active' : '' }}">
                    <i class="fas fa-users"></i>
                    <span>Utilisateurs</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_document_type_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_document_type' ? 'active' : '' }}">
                    <i class="fas fa-file-alt"></i>
                    <span>Types de Documents</span>
                </a>
            </li>

            {# ── Section Gestion des Élèves (admin) ── #}
            <div class="nav-section">Gestion des Élèves</div>
            
            <li class="nav-item">
                <a href="{{ path('admin_student_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_student' and app.request.get('_route') != 'admin_student_enrollment' and app.request.get('_route') != 'admin_student_transfer' and app.request.get('_route') != 'admin_student_archive' ? 'active' : '' }}">
                    <i class="fas fa-user-graduate"></i>
                    <span>Liste des Élèves</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_pre_registration_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_pre_registration' ? 'active' : '' }}">
                    <i class="fas fa-clipboard-list"></i>
                    <span>Préinscriptions</span>
                    <span class="badge bg-info sidebar-badge">Nouveau</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_student_enrollment') }}" class="nav-link {{ app.request.get('_route') == 'admin_student_enrollment' ? 'active' : '' }}">
                    <i class="fas fa-graduation-cap"></i>
                    <span>Inscriptions</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_student_transfer') }}" class="nav-link {{ app.request.get('_route') == 'admin_student_transfer' ? 'active' : '' }}">
                    <i class="fas fa-exchange-alt"></i>
                    <span>Transferts</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_student_archive') }}" class="nav-link {{ app.request.get('_route') == 'admin_student_archive' ? 'active' : '' }}">
                    <i class="fas fa-archive"></i>
                    <span>Archives</span>
                </a>
            </li>
            {% endif %}

            {# ==============================================================
               ACADÉMIQUE
               Visible pour admins, directeurs et enseignants
               ============================================================== #}
            {% if is_granted('ROLE_ADMIN') or (app.user and app.user.userType in ['directeur', 'enseignant']) %}
            <div class="nav-section">Académique</div>
            
            <li class="nav-item">
                <a href="{{ path('admin_classroom_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_classroom' ? 'active' : '' }}">
                    <i class="fas fa-door-open"></i>
                    <span>Classes</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_subject_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_subject' ? 'active' : '' }}">
                    <i class="fas fa-book"></i>
                    <span>Matières</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_time_slot_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_time_slot' ? 'active' : '' }}">
                    <i class="fas fa-clock"></i>
                    <span>Plages Horaires</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_room_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_room' ? 'active' : '' }}">
                    <i class="fas fa-door-open"></i>
                    <span>Salles</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_course_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_course' ? 'active' : '' }}">
                    <i class="fas fa-calendar-alt"></i>
                    <span>Emplois du Temps</span>
                </a>
            </li>
            {% endif %}

            {# ==============================================================
               NOTES & ÉVALUATIONS
               Visible pour admins, directeurs et enseignants
               ============================================================== #}
            {% if is_granted('ROLE_ADMIN') or (app.user and app.user.userType in ['directeur', 'enseignant']) %}
            <li class="nav-section">
                <span>Notes & Évaluations</span>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_period_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_period' ? 'active' : '' }}">
                    <i class="fas fa-calendar-alt"></i>
                    <span>Périodes</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_evaluation_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_evaluation' ? 'active' : '' }}">
                    <i class="fas fa-clipboard-list"></i>
                    <span>Évaluations</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="{{ path('admin_bulletin_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_bulletin' ? 'active' : '' }}">
                    <i class="fas fa-file-alt"></i>
                    <span>Bulletins</span>
                </a>
            </li>
            {% endif %}

            {# ==============================================================
               GESTION (Absences) - Menu déroulant
               Visible pour admins, directeurs et personnel
               ============================================================== #}
            {% if is_granted('ROLE_ADMIN') or (app.user and app.user.userType in ['directeur', 'personnel']) %}
            <div class="nav-section">Gestion</div>

            <li class="nav-item">
                <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="collapse" data-bs-target="#absenceSubmenu" aria-expanded="false">
                    <i class="fas fa-calendar-check"></i>
                    <span>Absences</span>
                    <span class="badge bg-danger sidebar-badge">5</span>
                </a>
                <ul class="collapse" id="absenceSubmenu">
                    <li class="nav-item">
                        <a href="{{ path('admin_absence_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_absence_index' ? 'active' : '' }}">
                            <i class="fas fa-list"></i>
                            <span>Liste des absences</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_absence_new') }}" class="nav-link {{ app.request.get('_route') == 'admin_absence_new' ? 'active' : '' }}">
                            <i class="fas fa-plus"></i>
                            <span>Nouvelle absence</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_absence_type_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_absence_type' ? 'active' : '' }}">
                            <i class="fas fa-cog"></i>
                            <span>Types d'absence</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_absence_attendance_report') }}" class="nav-link {{ app.request.get('_route') == 'admin_absence_attendance_report' ? 'active' : '' }}">
                            <i class="fas fa-chart-line"></i>
                            <span>Rapport d'assiduité</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_absence_critical_report') }}" class="nav-link {{ app.request.get('_route') == 'admin_absence_critical_report' ? 'active' : '' }}">
                            <i class="fas fa-exclamation-triangle"></i>
                            <span>Élèves à risque</span>
                        </a>
                    </li>
                </ul>
            </li>
            {% endif %}

            {# ==============================================================
               FINANCES - Menu déroulant
               Visible pour admins et directeurs
               ============================================================== #}
            {% if is_granted('ROLE_ADMIN') or (app.user and app.user.userType == 'directeur') %}
            {% set current_route = app.request.attributes.get('_route') %}
            {% set finance_active = current_route starts with 'admin_fee'
                or current_route starts with 'admin_payment'
                or current_route starts with 'admin_invoice'
                or current_route starts with 'admin_cash_register'
                or current_route starts with 'admin_scholarship'
                or current_route starts with 'admin_payment_plan'
                or current_route starts with 'admin_financial_transaction'
            %}
            <div class="nav-section">Finances</div>

            <li class="nav-item">
                <a href="#" class="nav-link dropdown-toggle {{ finance_active ? 'active' : '' }}"
                   data-bs-toggle="collapse"
                   data-bs-target="#financeSubmenu"
                   aria-expanded="{{ finance_active ? 'true' : 'false' }}">
                    <i class="fas fa-wallet"></i>
                    <span>Gestion Financière</span>
                </a>
                <ul class="collapse {{ finance_active ? 'show' : '' }}" id="financeSubmenu">
                    <li class="nav-item">
                        <a href="{{ path('admin_cash_register_open') }}" class="nav-link {{ current_route starts with 'admin_cash_register' ? 'active' : '' }}">
                            <i class="fas fa-cash-register"></i>
                            <span>Ma caisse</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_fee_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_fee' ? 'active' : '' }}">
                            <i class="fas fa-money-bill"></i>
                            <span>Frais de scolarité</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_payment_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_payment' ? 'active' : '' }}">
                            <i class="fas fa-credit-card"></i>
                            <span>Paiements</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_invoice_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_invoice' ? 'active' : '' }}">
                            <i class="fas fa-file-invoice"></i>
                            <span>Factures</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_scholarship_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_scholarship' ? 'active' : '' }}">
                            <i class="fas fa-graduation-cap"></i>
                            <span>Bourses</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_payment_plan_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_payment_plan' ? 'active' : '' }}">
                            <i class="fas fa-calendar-check"></i>
                            <span>Plans de paiement</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_financial_transaction_index') }}" class="nav-link {{ app.request.get('_route') starts with 'admin_financial_transaction' ? 'active' : '' }}">
                            <i class="fas fa-exchange-alt"></i>
                            <span>Transactions</span>
                        </a>
                    </li>
                </ul>
            </li>
            {% endif %}

            {# ==============================================================
               COMMUNICATION
               Visible pour tous les rôles connectés
               ============================================================== #}
            <div class="nav-section">Communication</div>

            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-envelope"></i>
                    <span>Messages</span>
                    <span class="badge bg-primary sidebar-badge">2</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-bell"></i>
                    <span>Notifications</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-bullhorn"></i>
                    <span>Annonces</span>
                </a>
            </li>

            {# ==============================================================
               RESSOURCES
               Visible pour admins, directeurs et enseignants
               ============================================================== #}
            {% if is_granted('ROLE_ADMIN') or (app.user and app.user.userType in ['directeur', 'enseignant']) %}
            <div class="nav-section">Ressources</div>

            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-book-open"></i>
                    <span>Bibliothèque</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-file-alt"></i>
                    <span>Documents</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-chart-bar"></i>
                    <span>Rapports</span>
                </a>
            </li>
            {% endif %}

            {# Section Intelligence Artificielle — visible pour les admins #}
            {% if is_granted('ROLE_ADMIN') %}
            <div class="nav-section">Intelligence Artificielle</div>
            <li class="nav-item">
                <a href="{{ path('ai_dashboard') }}" class="nav-link {% if app.request.attributes.get('_route') starts with 'ai_' %}active{% endif %}">
                    <i class="fas fa-robot"></i>
                    <span>Dashboard IA</span>
                </a>
            </li>
            {% endif %}
        </ul>
    </nav>

    {# ================================================================
       TOPBAR AMÉLIORÉE
       Avatar dynamique, indicateur établissement, thème toggle,
       notifications dropdown
       ================================================================ #}
    <nav class="topbar">
        {# Bouton toggle sidebar #}
        <button class="topbar-toggle" id="sidebarToggle">
            <i class="fas fa-bars"></i>
        </button>

        {# ── Indicateur établissement actuel ── #}
        {% if current_school is defined and current_school %}
        <div class="school-indicator d-none d-md-flex ms-3">
            <i class="fas fa-school"></i>
            <span>{{ current_school.name }}</span>
            {% if current_school_year is defined and current_school_year %}
                <span class="text-muted mx-1">|</span>
                <i class="fas fa-calendar-alt"></i>
                <span>{{ current_school_year.name }}</span>
            {% endif %}
        </div>
        {% endif %}

        {# ── Sélecteurs de contexte (dropdowns) ── #}
        <div class="context-selectors d-none d-lg-flex gap-2 ms-3">
            {% if current_school is defined and current_school %}
            <div class="dropdown">
                <button class="btn btn-outline-primary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="fas fa-school me-1"></i> Changer
                </button>
                <ul class="dropdown-menu">
                    <li><h6 class="dropdown-header">Changer d'établissement</h6></li>
                    {% if available_schools is defined %}
                    {% for school in available_schools %}
                    <li>
                        <a class="dropdown-item {{ current_school.id == school.id ? 'active' : '' }}" 
                           href="{{ path('context_switch_school', {'id': school.id}) }}">
                            <i class="fas fa-school me-2"></i> {{ school.name }}
                            {% if current_school.id == school.id %}
                                <i class="fas fa-check text-success ms-2"></i>
                            {% endif %}
                        </a>
                    </li>
                    {% endfor %}
                    {% endif %}
                </ul>
            </div>
            {% endif %}

            {% if current_school_year is defined and current_school_year %}
            <div class="dropdown">
                <button class="btn btn-outline-success btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="fas fa-calendar me-1"></i> {{ current_school_year.name }}
                </button>
                <ul class="dropdown-menu">
                    <li><h6 class="dropdown-header">Changer d'année scolaire</h6></li>
                    {% if available_school_years is defined %}
                    {% for year in available_school_years %}
                    <li>
                        <a class="dropdown-item {{ current_school_year.id == year.id ? 'active' : '' }}" 
                           href="{{ path('context_switch_year', {'id': year.id}) }}">
                            <i class="fas fa-calendar me-2"></i> {{ year.name }}
                            {% if year.isCurrent is defined and year.isCurrent %}
                                <span class="badge bg-primary ms-1">En cours</span>
                            {% endif %}
                            {% if current_school_year.id == year.id %}
                                <i class="fas fa-check text-success ms-2"></i>
                            {% endif %}
                        </a>
                    </li>
                    {% endfor %}
                    {% endif %}
                </ul>
            </div>
            {% endif %}
        </div>

       

        <div class="topbar-nav">
            {# ── Bouton thème clair/sombre ── #}
            <button class="theme-toggle" id="themeToggle" title="Basculer thème clair/sombre">
                <i class="fas fa-moon" id="themeIcon"></i>
            </button>

            {# ── Notifications dropdown ── #}
            <div class="topbar-item dropdown">
                <a href="#" class="topbar-link" data-bs-toggle="dropdown">
                    <i class="fas fa-bell fa-fw"></i>
                    <span class="notification-badge">3</span>
                </a>
                <div class="dropdown-menu dropdown-menu-end" style="min-width: 320px;">
                    <h6 class="dropdown-header d-flex justify-content-between align-items-center">
                        Notifications
                        <span class="badge bg-primary rounded-pill">3 nouvelles</span>
                    </h6>
                    {# Non lues en premier #}
                    <a class="dropdown-item py-2 border-start border-3 border-primary" href="#">
                        <div class="d-flex align-items-start">
                            <div class="flex-shrink-0">
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px;">
                                    <i class="fas fa-envelope fa-sm"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-2">
                                <div class="fw-bold small">Nouveau message reçu</div>
                                <div class="text-muted" style="font-size:0.75rem;">Il y a 5 min</div>
                            </div>
                        </div>
                    </a>
                    <a class="dropdown-item py-2 border-start border-3 border-success" href="#">
                        <div class="d-flex align-items-start">
                            <div class="flex-shrink-0">
                                <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px;">
                                    <i class="fas fa-user-plus fa-sm"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-2">
                                <div class="fw-bold small">Nouvelle inscription validée</div>
                                <div class="text-muted" style="font-size:0.75rem;">Il y a 2h</div>
                            </div>
                        </div>
                    </a>
                    <a class="dropdown-item py-2 border-start border-3 border-warning" href="#">
                        <div class="d-flex align-items-start">
                            <div class="flex-shrink-0">
                                <div class="bg-warning text-white rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px;">
                                    <i class="fas fa-exclamation fa-sm"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-2">
                                <div class="fw-bold small">Paiement en attente</div>
                                <div class="text-muted" style="font-size:0.75rem;">Hier</div>
                            </div>
                        </div>
                    </a>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item text-center small text-primary" href="#">
                        <i class="fas fa-bell me-1"></i>Voir toutes les notifications
                    </a>
                </div>
            </div>

            {# ── Messages ── #}
            <div class="topbar-item dropdown">
                <a href="#" class="topbar-link" data-bs-toggle="dropdown">
                    <i class="fas fa-envelope fa-fw"></i>
                    <span class="notification-badge">5</span>
                </a>
                <div class="dropdown-menu dropdown-menu-end" style="min-width: 300px;">
                    <h6 class="dropdown-header">Messages</h6>
                    <a class="dropdown-item" href="#">
                        <div class="d-flex align-items-center">
                            <div class="user-avatar me-2" style="background:#1cc88a;width:32px;height:32px;font-size:0.7rem;">JD</div>
                            <div>
                                <div class="small fw-bold">Jean Dupont</div>
                                <div class="small text-muted">Réunion parents...</div>
                            </div>
                        </div>
                    </a>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item text-center small text-primary" href="#">
                        <i class="fas fa-envelope me-1"></i>Voir tous les messages
                    </a>
                </div>
            </div>

            {# ── Menu utilisateur avec avatar dynamique coloré par rôle ── #}
            {% set avatar_colors = {
                'admin':      '#e74a3b',
                'directeur':  '#8b5cf6',
                'enseignant': '#36b9cc',
                'personnel':  '#f6c23e',
                'parent':     '#1cc88a',
                'eleve':      '#4e73df'
            } %}
            {% set user_bg = avatar_colors[app.user ? app.user.userType : 'admin'] | default('#4e73df') %}

            <div class="topbar-item dropdown">
                <a href="#" class="topbar-link" data-bs-toggle="dropdown">
                    <div class="user-avatar" style="background: {{ user_bg }};">
                        {{ app.user ? app.user.initials : 'AD' }}
                    </div>
                    <span class="d-none d-lg-inline ms-2">
                        {{ app.user ? app.user.fullName : 'Admin' }}
                    </span>
                </a>
                <div class="dropdown-menu dropdown-menu-end">
                    <h6 class="dropdown-header">
                        {{ app.user ? app.user.email : 'admin@edu-school.com' }}
                    </h6>
                    {% if app.user %}
                    <div class="dropdown-item-text">
                        {% set role_labels = {
                            'admin':      'Administrateur',
                            'directeur':  'Directeur',
                            'enseignant': 'Enseignant',
                            'personnel':  'Personnel',
                            'parent':     'Parent',
                            'eleve':      'Élève'
                        } %}
                        <span class="badge" style="background:{{ user_bg }};">
                            {{ role_labels[app.user.userType] | default('Utilisateur') }}
                        </span>
                    </div>
                    {% endif %}
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item" href="#">
                        <i class="fas fa-user fa-sm fa-fw me-2"></i>
                        Mon Profil
                    </a>
                    <a class="dropdown-item" href="#">
                        <i class="fas fa-cog fa-sm fa-fw me-2"></i>
                        Paramètres
                    </a>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item" href="{{ path('app_logout') }}">
                        <i class="fas fa-sign-out-alt fa-sm fa-fw me-2"></i>
                        Déconnexion
                    </a>
                </div>
            </div>
        </div>
    </nav>

    {# ================================================================
       CONTENEUR DE TOASTS (flash messages)
       Positionné en haut à droite, au-dessus de tout
       ================================================================ #}
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1090;">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                {% set toast_type = label == 'error' ? 'danger' : label %}
                {% set icon_map = {
                    'success': 'fa-check-circle',
                    'danger':  'fa-exclamation-circle',
                    'warning': 'fa-exclamation-triangle',
                    'info':    'fa-info-circle'
                } %}
                <div class="toast align-items-center text-bg-{{ toast_type }} border-0"
                     role="alert" aria-live="assertive" aria-atomic="true"
                     data-bs-autohide="true" data-bs-delay="5000">
                    <div class="d-flex">
                        <div class="toast-body">
                            <i class="fas {{ icon_map[toast_type] | default('fa-info-circle') }} me-2"></i>
                            {{ message }}
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto"
                                data-bs-dismiss="toast" aria-label="Fermer"></button>
                    </div>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    {# ================================================================
       MODALE DE CONFIRMATION DE SUPPRESSION
       ================================================================ #}
    <div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <h5 class="modal-title text-danger">
                        <i class="fas fa-exclamation-triangle me-2"></i>Confirmer la suppression
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    <p>Êtes-vous sûr de vouloir supprimer cet élément ? Cette action est irréversible.</p>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i>Annuler
                    </button>
                    <form id="deleteForm" method="post" style="display:inline">
                        <input type="hidden" name="_token" value="">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash-alt me-1"></i>Supprimer
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    {# ================================================================
       CONTENU PRINCIPAL
       ================================================================ #}
    <div class="content-wrapper">
        {% block body %}{% endblock %}

        {# Footer #}
        <footer class="footer mt-5">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-md-6 text-md-start">
                        &copy; {{ "now"|date("Y") }} EDU-SCHOOL - Système de Gestion Scolaire
                    </div>
                    <div class="col-md-6 text-md-end">
                        Version 1.0.0 | 
                        <a href="#" class="text-decoration-none">Documentation</a> | 
                        <a href="#" class="text-decoration-none">Support</a>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    {# Bootstrap JS #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    
    {# App JS (thème, compteurs, toasts, modales, sidebar) #}
    <script src="{{ asset('js/app.js') }}"></script>
    
    {% block javascripts %}{% endblock %}

    {# Widget Chatbot IA — disponible sur toutes les pages #}
    {% include 'ai/chatbot_widget.html.twig' %}
</body>
</html>
