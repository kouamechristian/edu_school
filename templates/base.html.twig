                    <span>Annonces</span>
                </a>
            </li>

            {# Section Ressources #}
            <div class="nav-section">Ressources</div>

            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-book-open"></i>
                    <span>Bibliothèque</span>
                </a>
            </li>

            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-file-alt"></i>
