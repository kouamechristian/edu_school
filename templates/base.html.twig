                </a>
            </li>

            <li class="nav-item">
                <a href="#" class="nav-link">
                    <i class="fas fa-chart-bar"></i>
                    <span>Rapports</span>
                </a>
            </li>
        </ul>
    </nav>

    {# Topbar #}
    <nav class="topbar">
        <button class="topbar-toggle" id="sidebarToggle">
            <i class="fas fa-bars"></i>
        </button>

        {# Context Selectors #}
        <div class="context-selectors d-flex gap-3 ms-3">
            {# École actuelle #}
            {% if current_school %}
            <div class="dropdown">
                <button class="btn btn-outline-primary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="fas fa-school me-1"></i> {{ current_school.name }}
                </button>
                <ul class="dropdown-menu">
                    <li><h6 class="dropdown-header">Changer d'établissement</h6></li>
                    {% for school in available_schools %}
                    <li>
                        <a class="dropdown-item {{ current_school.id == school.id ? 'active' : '' }}" 
                           href="{{ path('context_switch_school', {'id': school.id}) }}">
                            <i class="fas fa-school me-2"></i> {{ school.name }}
                            {% if current_school.id == school.id %}
                                <i class="fas fa-check text-success ms-2"></i>
                            {% endif %}
                        </a>
                    </li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}

            {# Année actuelle #}
            {% if current_school_year %}
            <div class="dropdown">
                <button class="btn btn-outline-success btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="fas fa-calendar me-1"></i> {{ current_school_year.name }}
                </button>
                <ul class="dropdown-menu">
                    <li><h6 class="dropdown-header">Changer d'année scolaire</h6></li>
                    {% for year in available_school_years %}
                    <li>
                        <a class="dropdown-item {{ current_school_year.id == year.id ? 'active' : '' }}" 
                           href="{{ path('context_switch_year', {'id': year.id}) }}">
                            <i class="fas fa-calendar me-2"></i> {{ year.name }}
                            {% if year.isCurrent %}
                                <span class="badge bg-primary ms-1">En cours</span>
                            {% endif %}
                            {% if current_school_year.id == year.id %}
                                <i class="fas fa-check text-success ms-2"></i>
                            {% endif %}
                        </a>
                    </li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}
        </div>

        <div class="topbar-search">
            <div class="input-group">
                <input type="text" class="form-control" placeholder="Rechercher...">
                <button class="btn btn-primary" type="button">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </div>

        <div class="topbar-nav">
            {# Notifications #}
            <div class="topbar-item dropdown">
                <a href="#" class="topbar-link" data-bs-toggle="dropdown">
                    <i class="fas fa-bell fa-fw"></i>
                    <span class="notification-badge">3</span>
                </a>
                <div class="dropdown-menu dropdown-menu-end">
                    <h6 class="dropdown-header">Notifications</h6>
                    <a class="dropdown-item" href="#">
                        <i class="fas fa-envelope text-primary me-2"></i>
                        Nouveau message reçu
                    </a>
                    <a class="dropdown-item" href="#">
                        <i class="fas fa-user text-success me-2"></i>
                        Nouvelle inscription
                    </a>
                    <a class="dropdown-item" href="#">
                        <i class="fas fa-exclamation-triangle text-warning me-2"></i>
                        Paiement en attente
                    </a>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item text-center small" href="#">Voir tout</a>
                </div>
            </div>

            {# Messages #}
            <div class="topbar-item dropdown">
                <a href="#" class="topbar-link" data-bs-toggle="dropdown">
                    <i class="fas fa-envelope fa-fw"></i>
                    <span class="notification-badge">5</span>
                </a>
                <div class="dropdown-menu dropdown-menu-end">
                    <h6 class="dropdown-header">Messages</h6>
                    <a class="dropdown-item" href="#">
                        <div class="d-flex align-items-center">
                            <div class="user-avatar me-2">JD</div>
                            <div>
                                <div class="small">Jean Dupont</div>
                                <div class="small text-muted">Réunion parents...</div>
                            </div>
                        </div>
                    </a>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item text-center small" href="#">Voir tout</a>
                </div>
            </div>

            {# User Menu #}
            <div class="topbar-item dropdown">
                <a href="#" class="topbar-link" data-bs-toggle="dropdown">
                    <div class="user-avatar">
                        {{ app.user ? app.user.username|slice(0,2)|upper : 'AD' }}
                    </div>
                    <span class="d-none d-lg-inline ms-2">
                        {{ app.user ? app.user.username : 'Admin' }}
                    </span>
                </a>
                <div class="dropdown-menu dropdown-menu-end">
                    <h6 class="dropdown-header">
                        {{ app.user ? app.user.email : 'admin@edu-school.com' }}
                    </h6>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item" href="#">
                        <i class="fas fa-user fa-sm fa-fw me-2"></i>
                        Mon Profil
                    </a>
                    <a class="dropdown-item" href="#">
                        <i class="fas fa-cog fa-sm fa-fw me-2"></i>
                        Paramètres
                    </a>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item" href="{{ path('app_logout') }}">
                        <i class="fas fa-sign-out-alt fa-sm fa-fw me-2"></i>
                        Déconnexion
                    </a>
                </div>
            </div>
        </div>
    </nav>

    {# Main Content #}
    <div class="content-wrapper">
        {% block body %}{% endblock %}

        {# Footer #}
        <footer class="footer mt-5">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-md-6 text-md-start">
                        &copy; {{ "now"|date("Y") }} EDU-SCHOOL - Système de Gestion Scolaire
                    </div>
                    <div class="col-md-6 text-md-end">
                        Version 1.0.0 | 
                        <a href="#" class="text-decoration-none">Documentation</a> | 
                        <a href="#" class="text-decoration-none">Support</a>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    {# Bootstrap JS #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    
    {# Custom JS #}
    <script>
        // Sidebar Toggle
        document.getElementById('sidebarToggle').addEventListener('click', function() {
            document.getElementById('sidebar').classList.toggle('collapsed');
        });

        // Mobile Sidebar Toggle
        if (window.innerWidth <= 768) {
            document.getElementById('sidebarToggle').addEventListener('click', function() {
                document.getElementById('sidebar').classList.toggle('show');
            });
        }

        // Animation on load
        document.addEventListener('DOMContentLoaded', function() {
            const cards = document.querySelectorAll('.card');
            cards.forEach((card, index) => {
                setTimeout(() => {
                    card.classList.add('animate-in');
                }, index * 100);
            });
        });

        // Auto-hide alerts
        const alerts = document.querySelectorAll('.alert');
        alerts.forEach(alert => {
            setTimeout(() => {
                const bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            }, 5000);
        });

        // Gestion des sous-menus déroulants
        document.querySelectorAll('[data-bs-toggle="collapse"]').forEach(function(element) {
            element.addEventListener('click', function(e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('data-bs-target'));
                const isExpanded = this.getAttribute('aria-expanded') === 'true';
                
                // Fermer tous les autres sous-menus
                document.querySelectorAll('[data-bs-toggle="collapse"]').forEach(function(otherElement) {
                    if (otherElement !== element) {
                        const otherTarget = document.querySelector(otherElement.getAttribute('data-bs-target'));
                        if (otherTarget && otherTarget.classList.contains('show')) {
                            otherTarget.classList.remove('show');
                            otherElement.setAttribute('aria-expanded', 'false');
                        }
                    }
                });
                
                // Toggle le sous-menu actuel
                if (isExpanded) {
                    target.classList.remove('show');
                    this.setAttribute('aria-expanded', 'false');
                } else {
                    target.classList.add('show');
                    this.setAttribute('aria-expanded', 'true');
                }
            });
        });

        // Ouvrir automatiquement le sous-menu si on est sur une page d'absence
        document.addEventListener('DOMContentLoaded', function() {
            const currentRoute = '{{ app.request.get('_route') }}';
            if (currentRoute.startsWith('admin_absence')) {
                const absenceSubmenu = document.getElementById('absenceSubmenu');
                const absenceToggle = document.querySelector('[data-bs-target="#absenceSubmenu"]');
                if (absenceSubmenu && absenceToggle) {
                    absenceSubmenu.classList.add('show');
                    absenceToggle.setAttribute('aria-expanded', 'true');
                }
            }
            
            // Ouvrir automatiquement le sous-menu si on est sur une page de finances
            if (currentRoute.startsWith('admin_fee') || currentRoute.startsWith('admin_payment') || 
                currentRoute.startsWith('admin_invoice') || currentRoute.startsWith('admin_scholarship') ||
                currentRoute.startsWith('admin_payment_plan') || currentRoute.startsWith('admin_financial_transaction')) {
                const financeSubmenu = document.getElementById('financeSubmenu');
                const financeToggle = document.querySelector('[data-bs-target="#financeSubmenu"]');
                if (financeSubmenu && financeToggle) {
                    financeSubmenu.classList.add('show');
                    financeToggle.setAttribute('aria-expanded', 'true');
                }
            }
        });
    </script>
    
    {% block javascripts %}{% endblock %}
</body>
</html>

