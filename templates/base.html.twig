<!DOCTYPE html>
<html lang="fr" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>{% block title %}EDU-SCHOOL{% endblock %} - Système de Gestion Scolaire</title>
    
    {# Favicon #}
    <link rel="icon" type="image/x-icon" href="{{ asset('favicon.ico') }}">
    
    {# Bootstrap CSS #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    {# Font Awesome Icons #}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    
    {# Google Fonts — Poppins (titres) + Inter (corps de texte) #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@500;600;700&display=swap" rel="stylesheet">
    
    {# ================================================================
       STYLES INLINE DU LAYOUT
       Conservés en inline pour le rendu initial rapide (sidebar/topbar)
       ================================================================ #}
    <style>
        :root {
            --primary-color: #1e3a5f;
            --secondary-color: #94a3b8;
            --success-color: #10b981;
            --info-color: #0ea5e9;
            --warning-color: #f59e0b;
            --danger-color: #ef4444;
            --sidebar-width: 264px;
            --topbar-height: 64px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background-color: #f4f6f9;
            overflow-x: hidden;
        }

        [data-bs-theme="dark"] body {
            background-color: var(--es-body-bg, #0f1729);
        }

        /* ── Sidebar ── */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            width: var(--sidebar-width);
            background: linear-gradient(190deg, #20436b 0%, #16293f 55%, #101f30 100%);
            color: white;
            transition: width 0.25s ease, transform 0.25s ease;
            z-index: 1000;
            /* Layout flexible : marque figée en haut, navigation défilante */
            display: flex;
            flex-direction: column;
            overflow: hidden;
            box-shadow: inset -1px 0 0 rgba(255,255,255,0.06);
        }

        .sidebar.collapsed {
            width: 80px;
        }

        .sidebar-brand {
            flex: 0 0 auto;
            display: flex;
            align-items: center;
            gap: 0.65rem;
            padding: 1.15rem 1.25rem;
            font-family: 'Poppins', sans-serif;
            font-size: 1.15rem;
            font-weight: 700;
            letter-spacing: 0.02em;
            border-bottom: 1px solid rgba(255,255,255,0.10);
        }

        .sidebar-brand i {
            font-size: 1.15rem;
            width: 38px;
            height: 38px;
            flex: 0 0 38px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            background: linear-gradient(135deg, #10b981, #0ea5e9);
            box-shadow: 0 4px 12px rgba(16,185,129,0.35);
        }

        .sidebar.collapsed .sidebar-brand {
            justify-content: center;
            padding: 1.15rem 0;
        }

        .sidebar.collapsed .sidebar-brand-text {
            display: none;
        }

        /* Navigation : prend l'espace restant et défile seule */
        .sidebar-nav {
            flex: 1 1 auto;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 0.75rem 0.5rem 1.5rem;
            margin: 0;
            list-style: none;
        }

        .nav-item {
            list-style: none;
            position: relative;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 0.85rem;
            padding: 0.6rem 0.85rem;
            margin: 2px 0;
            border-radius: 10px;
            color: rgba(255,255,255,0.72);
            text-decoration: none;
            font-size: 0.92rem;
            white-space: nowrap;
            transition: background-color 0.2s ease, color 0.2s ease;
        }

        .nav-link:hover {
            color: #fff;
            background-color: rgba(255,255,255,0.08);
        }

        .nav-link.active {
            color: #fff;
            background: linear-gradient(90deg, rgba(16,185,129,0.22), rgba(14,165,233,0.10));
            font-weight: 600;
            box-shadow: inset 3px 0 0 #10b981;
        }

        .nav-link i {
            font-size: 1rem;
            width: 22px;
            min-width: 22px;
            text-align: center;
        }

        .nav-link .sidebar-badge {
            margin-left: auto;
            font-size: 0.65rem;
            font-weight: 600;
            padding: 0.15rem 0.45rem;
            border-radius: 999px;
        }

        .sidebar.collapsed .nav-link {
            justify-content: center;
            gap: 0;
            padding: 0.7rem 0;
        }

        .sidebar.collapsed .nav-link span:not(.sidebar-badge) {
            display: none;
        }

        .sidebar.collapsed .nav-link .sidebar-badge {
            position: absolute;
            top: 4px;
            right: 10px;
            margin: 0;
        }

        .nav-section {
            padding: 1.1rem 1rem 0.4rem;
            margin-top: 0.25rem;
            font-size: 0.68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: rgba(255,255,255,0.38);
        }

        .sidebar.collapsed .nav-section {
            text-align: center;
            font-size: 0;
            padding: 0.75rem 0 0.25rem;
        }

        .sidebar.collapsed .nav-section::before {
            content: "•••";
            font-size: 0.7rem;
            letter-spacing: 0.1em;
            color: rgba(255,255,255,0.25);
        }

        /* ── Topbar ── */
        .topbar {
            position: fixed;
            top: 0;
            left: var(--sidebar-width);
            right: 0;
            height: var(--topbar-height);
            background: white;
            border-bottom: 1px solid #e5e9f0;
            box-shadow: 0 1px 3px rgba(15,23,42,0.04);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 1.5rem;
            transition: all 0.3s;
            z-index: 999;
        }

        .sidebar.collapsed ~ .topbar {
            left: 80px;
        }

        .topbar-toggle {
            background: none;
            border: none;
            font-size: 1.5rem;
            color: var(--secondary-color);
            cursor: pointer;
        }

        .topbar-search {
            flex: 1;
            max-width: 500px;
            margin: 0 2rem;
        }

        .topbar-nav {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .topbar-item {
            position: relative;
        }

        .topbar-link {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            color: var(--secondary-color);
            text-decoration: none;
            border-radius: 0.35rem;
            transition: all 0.3s;
        }

        .topbar-link:hover {
            background-color: #f8f9fc;
            color: var(--primary-color);
        }

        .notification-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background-color: var(--danger-color);
            color: white;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            font-size: 0.7rem;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .user-avatar {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            background: var(--primary-color);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
        }

        /* ── Content ── */
        .content-wrapper {
            margin-left: var(--sidebar-width);
            margin-top: var(--topbar-height);
            padding: 2rem;
            min-height: calc(100vh - var(--topbar-height));
            transition: all 0.3s;
        }

        .sidebar.collapsed ~ .content-wrapper {
            margin-left: 80px;
        }

        /* ── Footer ── */
        .footer {
            background: white;
            padding: 1.5rem;
            text-align: center;
            color: var(--secondary-color);
            font-size: 0.875rem;
            border-top: 1px solid #e3e6f0;
        }

        /* ── Dropdown ── */
        .dropdown-menu {
            border: none;
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58,59,69,0.15);
        }

        /* ── Sous-menus sidebar ── */
        .nav-item ul {
            list-style: none;
            padding: 0.15rem 0.25rem 0.2rem 1.7rem;
            margin: 0 0 0.25rem;
            position: relative;
        }

        .nav-item ul::before {
            content: "";
            position: absolute;
            left: 1.6rem;
            top: 0.1rem;
            bottom: 0.45rem;
            width: 2px;
            background: rgba(255,255,255,0.12);
            border-radius: 2px;
        }

        .nav-item ul .nav-link {
            padding: 0.48rem 0.7rem;
            font-size: 0.85rem;
            color: rgba(255,255,255,0.6);
        }

        .nav-item ul .nav-link:hover {
            background-color: rgba(255,255,255,0.06);
            color: #fff;
        }

        .nav-item ul .nav-link.active {
            background: rgba(16,185,129,0.18);
            color: #fff;
            box-shadow: inset 2px 0 0 #10b981;
        }

        .nav-item ul .nav-link i {
            font-size: 0.82rem;
            width: 18px;
            min-width: 18px;
        }

        .sidebar.collapsed .nav-item ul {
            display: none;
        }

        .collapse {
            transition: height 0.3s ease;
        }

        .nav-link.dropdown-toggle::after {
            margin-left: auto;
            transition: transform 0.3s ease;
        }

        .nav-link.dropdown-toggle[aria-expanded="true"]::after {
            transform: rotate(90deg);
        }

        /* ── Scrollbar sidebar ── */
        .sidebar-nav {
            scrollbar-width: thin;
            scrollbar-color: rgba(255,255,255,0.25) transparent;
        }

        .sidebar-nav::-webkit-scrollbar {
            width: 6px;
        }

        .sidebar-nav::-webkit-scrollbar-track {
            background: transparent;
        }

        .sidebar-nav::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.18);
            border-radius: 3px;
        }

        .sidebar-nav::-webkit-scrollbar-thumb:hover {
            background: rgba(255,255,255,0.32);
        }

        /* ── Responsive ── */
        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
            }

            .sidebar.show {
                transform: translateX(0);
            }

            .topbar {
                left: 0;
            }

            .content-wrapper {
                margin-left: 0;
            }

            .topbar-search {
                display: none;
            }
        }
    </style>
    
    {# Tom Select — rend tous les <select> recherchables (thème Bootstrap 5, hébergé en local) #}
    <link rel="stylesheet" href="{{ asset('vendor/tom-select/css/tom-select.bootstrap5.min.css') }}">

    {# CSS externe (thème sombre, skeleton, toasts, etc.) #}
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">

    {# Harmonisation de Tom Select avec la charte Navy + Émeraude #}
    <style>
        /* Le contrôle reprend l'apparence d'un .form-select Bootstrap */
        .ts-wrapper.form-select,
        .ts-wrapper.form-control {
            padding: 0;
        }
        .ts-wrapper .ts-control {
            border: 1px solid var(--es-border, #e5e9f0);
            border-radius: 0.5rem;
            min-height: calc(1.5em + 0.75rem + 2px);
            box-shadow: none;
        }
        .ts-wrapper.focus .ts-control {
            border-color: var(--es-accent, #10b981);
            box-shadow: 0 0 0 0.2rem rgba(var(--es-accent-rgb, 16,185,129), 0.20);
        }
        .ts-dropdown {
            border: 1px solid var(--es-border, #e5e9f0);
            border-radius: 0.5rem;
            box-shadow: 0 0.5rem 1.5rem rgba(15, 23, 42, 0.18);
            overflow: hidden;
            /* Rattachée au <body> : doit passer au-dessus des modales (1055),
               offcanvas et autres calques, mais sous les toasts (1090). */
            z-index: 1085;
            margin-top: 0.25rem;
        }
        /* Liste plus haute et options plus aérées pour une meilleure lisibilité */
        .ts-dropdown .ts-dropdown-content {
            max-height: 280px;
        }
        .ts-dropdown .option,
        .ts-dropdown .no-results,
        .ts-dropdown .optgroup-header,
        .ts-dropdown .create {
            padding: 0.5rem 0.85rem;
            font-size: 0.92rem;
        }
        .ts-dropdown .active {
            background-color: rgba(var(--es-accent-rgb, 16,185,129), 0.12);
            color: var(--es-text-dark, #1e293b);
        }
        .ts-dropdown .ts-dropdown-content .option:hover {
            background-color: rgba(var(--es-primary-rgb, 30,58,95), 0.06);
        }
        /* Champ de recherche en tête de liste */
        .ts-dropdown .dropdown-input-wrap input,
        .ts-dropdown-input {
            border-radius: 0.4rem;
        }
        /* Puces des selects multiples */
        .ts-wrapper.multi .ts-control > div.item {
            background: rgba(var(--es-primary-rgb, 30,58,95), 0.08);
            color: var(--es-primary, #1e3a5f);
            border-radius: 0.35rem;
        }
        /* État invalide (validation Symfony) */
        .is-invalid + .ts-wrapper .ts-control,
        .ts-wrapper.is-invalid .ts-control {
            border-color: var(--es-danger, #ef4444);
        }

        /* ── Mode sombre ── */
        [data-bs-theme="dark"] .ts-control,
        [data-bs-theme="dark"] .ts-dropdown {
            background-color: var(--es-card-bg, #1b2536);
            color: #e2e8f0;
            border-color: rgba(255, 255, 255, 0.12);
        }
        [data-bs-theme="dark"] .ts-dropdown .option,
        [data-bs-theme="dark"] .ts-control input {
            color: #e2e8f0;
        }
        [data-bs-theme="dark"] .ts-dropdown .active {
            background-color: rgba(var(--es-accent-rgb, 16,185,129), 0.22);
            color: #fff;
        }
    </style>

    {% block stylesheets %}{% endblock %}

    {# Application du thème sauvegardé avant le rendu pour éviter le flash blanc #}
    <script>
        (function(){
            var t = localStorage.getItem('edu-school-theme');
            if (t) document.documentElement.setAttribute('data-bs-theme', t);
        })();
    </script>
</head>
<body>
    {# ================================================================
       OVERLAY MOBILE (fermer la sidebar en cliquant à côté)
       ================================================================ #}
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    {# ================================================================
       SIDEBAR DYNAMIQUE PAR RÔLE
       Sections affichées selon is_granted() et app.user.userType
       ================================================================ #}
    <nav class="sidebar" id="sidebar">
        {# ── Brand ── #}
        <div class="sidebar-brand">
            <i class="fas fa-graduation-cap"></i>
            <span class="sidebar-brand-text">EDU-SCHOOL</span>
        </div>

        <ul class="sidebar-nav">
            {% set current_route = app.request.attributes.get('_route') ?? '' %}
            {# ── Dashboard (commun à tous) ── #}
            <li class="nav-item">
                <a href="{{ path('app_home') }}" class="nav-link {{ current_route starts with 'app_home' ? 'active' : '' }}">
                    <i class="fas fa-tachometer-alt"></i>
                    <span>Tableau de bord</span>
                </a>
            </li>

            {# ==============================================================
               ESPACE PARENT
               Visible pour les utilisateurs de type "parent"
               ============================================================== #}
            {% if app.user and app.user.userType == 'parent' %}
            {% set parent_active = current_route starts with 'parent_' %}
            <div class="nav-section">Espace Parent</div>
            <li class="nav-item">
                <a href="#" class="nav-link dropdown-toggle {{ parent_active ? 'active' : '' }}" data-bs-toggle="collapse" data-bs-target="#menuParent" aria-expanded="{{ parent_active ? 'true' : 'false' }}">
                    <i class="fas fa-user-friends"></i>
                    <span>Espace Parent</span>
                </a>
                <ul class="nav flex-column collapse {{ parent_active ? 'show' : '' }}" id="menuParent">
                    <li class="nav-item"><a href="{{ path('parent_dashboard') }}" class="nav-link {{ parent_active ? 'active' : '' }}"><i class="fas fa-child"></i><span>Mes Enfants</span></a></li>
                </ul>
            </li>
            {% endif %}

            {# ==============================================================
               ESPACE ENSEIGNANT
               Visible pour les enseignants (userType == 'enseignant')
               ============================================================== #}
            {% if app.user and app.user.userType == 'enseignant' %}
            {% set ens_active = current_route starts with 'admin_course' or current_route starts with 'admin_evaluation' or current_route starts with 'admin_absence' %}
            <div class="nav-section">Espace Enseignant</div>
            <li class="nav-item">
                <a href="#" class="nav-link dropdown-toggle {{ ens_active ? 'active' : '' }}" data-bs-toggle="collapse" data-bs-target="#menuEns" aria-expanded="{{ ens_active ? 'true' : 'false' }}">
                    <i class="fas fa-chalkboard-teacher"></i>
                    <span>Espace Enseignant</span>
                </a>
                <ul class="nav flex-column collapse {{ ens_active ? 'show' : '' }}" id="menuEns">
                    <li class="nav-item">
                        <a href="{{ path('admin_course_my_schedule') }}" class="nav-link {{ current_route == 'admin_course_my_schedule' ? 'active' : '' }}">
                            <i class="fas fa-calendar-week"></i><span>Mes Cours</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_course_my_students') }}" class="nav-link {{ current_route == 'admin_course_my_students' ? 'active' : '' }}">
                            <i class="fas fa-users"></i><span>Mes élèves</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_evaluation_index') }}" class="nav-link {{ current_route starts with 'admin_evaluation' ? 'active' : '' }}">
                            <i class="fas fa-clipboard-list"></i><span>Évaluations</span>
                        </a>
                    </li>
                    {% if is_granted('ROLE_EDUCATEUR') %}
                    <li class="nav-item">
                        <a href="{{ path('admin_absence_index') }}" class="nav-link {{ current_route starts with 'admin_absence_index' ? 'active' : '' }}">
                            <i class="fas fa-calendar-check"></i><span>Absences</span>
                            <span class="badge bg-warning sidebar-badge">3</span>
                        </a>
                    </li>
                    {% endif %}
                </ul>
            </li>
            {% endif %}

             {# ==============================================================
               ESPACE FONDATEUR — visible uniquement par les fondateurs
               ============================================================== #}
            {% if is_granted('ROLE_FONDATEUR') %}
            {% set fondateur_active = (app.request.attributes.get('_route') ?? '') starts with 'fondateur_' %}
            <div class="nav-section">Fondateur</div>
            <li class="nav-item">
                <a href="#" class="nav-link dropdown-toggle {{ fondateur_active ? 'active' : '' }}" data-bs-toggle="collapse" data-bs-target="#menuFondateur" aria-expanded="{{ fondateur_active ? 'true' : 'false' }}">
                    <i class="fas fa-crown"></i>
                    <span>Espace Fondateur</span>
                </a>
                <ul class="nav flex-column collapse {{ fondateur_active ? 'show' : '' }}" id="menuFondateur">
                    <li class="nav-item">
                        <a href="{{ path('fondateur_index') }}" class="nav-link {{ app.request.get('_route') == 'fondateur_index' ? 'active' : '' }}">
                            <i class="fas fa-gauge"></i><span>Tableau de bord</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('fondateur_validations') }}" class="nav-link {{ app.request.get('_route') == 'fondateur_validations' ? 'active' : '' }}">
                            <i class="fas fa-cash-register"></i><span>Valider les caisses</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('fondateur_autorisations') }}" class="nav-link {{ app.request.get('_route') == 'fondateur_autorisations' ? 'active' : '' }}">
                            <i class="fas fa-key"></i><span>Autorisations</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('fondateur_versements') }}" class="nav-link {{ app.request.get('_route') == 'fondateur_versements' ? 'active' : '' }}">
                            <i class="fas fa-money-bill-transfer"></i><span>Versements</span>
                        </a>
                    </li>
                </ul>
            </li>
            {% endif %}


            {# ==============================================================
               ADMINISTRATION
               Visible pour ROLE_ADMIN (admins, super admins)
               ============================================================== #}
            {% if is_granted('ROLE_ADMIN') %}
            {% set admin_active = current_route starts with 'admin_school' or current_route starts with 'admin_user' or current_route starts with 'admin_subject_type' or current_route starts with 'admin_mobile_money_log' or current_route starts with 'admin_mobile_money_config' %}
            <div class="nav-section">Administration</div>
            <li class="nav-item">
                <a href="#" class="nav-link dropdown-toggle {{ admin_active ? 'active' : '' }}" data-bs-toggle="collapse" data-bs-target="#menuAdmin" aria-expanded="{{ admin_active ? 'true' : 'false' }}">
                    <i class="fas fa-cogs"></i>
                    <span>Administration</span>
                </a>
                <ul class="nav flex-column collapse {{ admin_active ? 'show' : '' }}" id="menuAdmin">
                    <li class="nav-item">
                        <a href="{{ path('admin_school_group_index') }}" class="nav-link {{ current_route starts with 'admin_school_group' ? 'active' : '' }}">
                            <i class="fas fa-sitemap"></i><span>Groupes d'Établissements</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_school_index') }}" class="nav-link {{ current_route starts with 'admin_school' and not (current_route starts with 'admin_school_group') and not (current_route starts with 'admin_school_year') ? 'active' : '' }}">
                            <i class="fas fa-school"></i><span>Établissements</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_school_year_index') }}" class="nav-link {{ current_route starts with 'admin_school_year' ? 'active' : '' }}">
                            <i class="fas fa-calendar-alt"></i><span>Années Scolaires</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_user_index') }}" class="nav-link {{ current_route starts with 'admin_user' ? 'active' : '' }}">
                            <i class="fas fa-users"></i><span>Utilisateurs</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_mobile_money_config_index') }}" class="nav-link {{ current_route starts with 'admin_mobile_money_config' ? 'active' : '' }}">
                            <i class="fas fa-key"></i><span>Identifiants Mobile Money</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('admin_mobile_money_log_index') }}" class="nav-link {{ current_route starts with 'admin_mobile_money_log' ? 'active' : '' }}">
                            <i class="fas fa-mobile-screen-button"></i><span>Logs Mobile Money</span>
                        </a>
                    </li>
                </ul>
            </li>
