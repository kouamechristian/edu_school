    {# ================================================================
       TOPBAR AMÉLIORÉE
       Avatar dynamique, indicateur établissement, thème toggle,
       notifications dropdown
       ================================================================ #}
    <nav class="topbar">
        {# Bouton toggle sidebar #}
        <button class="topbar-toggle" id="sidebarToggle">
            <i class="fas fa-bars"></i>
        </button>

        {# ── Indicateur établissement actuel ── #}
        {% if current_school is defined and current_school and not (app.user and app.user.userType == 'parent') %}
        <div class="school-indicator d-none d-md-flex ms-3">
            <i class="fas fa-school"></i>
            <span>{{ current_school.name }}</span>
            {% if current_school_year is defined and current_school_year %}
                <span class="text-muted mx-1">|</span>
                <i class="fas fa-calendar-alt"></i>
                <span>{{ current_school_year.name }}</span>
            {% endif %}
        </div>
        {% endif %}

        {# ── Sélecteurs de contexte (dropdowns) — masqués pour les parents ── #}
        <div class="context-selectors d-none {{ app.user and app.user.userType == 'parent' ? '' : 'd-lg-flex' }} gap-2 ms-3">
            {% if current_school is defined and current_school %}
            <div class="dropdown">
                <button class="btn btn-outline-primary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="fas fa-school me-1"></i> Changer
                </button>
                <ul class="dropdown-menu">
                    <li><h6 class="dropdown-header">Changer d'établissement</h6></li>
                    {% if available_schools is defined %}
                    {% for school in available_schools %}
                    <li>
                        <a class="dropdown-item {{ current_school.id == school.id ? 'active' : '' }}" 
                           href="{{ path('context_switch_school', {'id': school.id}) }}">
                            <i class="fas fa-school me-2"></i> {{ school.name }}
                            {% if current_school.id == school.id %}
                                <i class="fas fa-check text-success ms-2"></i>
                            {% endif %}
                        </a>
                    </li>
                    {% endfor %}
                    {% endif %}
                </ul>
            </div>
            {% endif %}

            {# Le sélecteur d'année s'affiche dès qu'au moins une année scolaire existe,
               même si aucune n'est encore sélectionnée (permet d'en choisir une). #}
            {% if available_school_years is defined and available_school_years|length > 0 %}
            <div class="dropdown">
                <button class="btn btn-outline-success btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="fas fa-calendar me-1"></i>
                    {{ current_school_year is defined and current_school_year ? current_school_year.name : 'Année scolaire' }}
                </button>
                <ul class="dropdown-menu">
                    <li><h6 class="dropdown-header">Changer d'année scolaire</h6></li>
                    {% for year in available_school_years %}
                    {% set is_selected = current_school_year is defined and current_school_year and current_school_year.id == year.id %}
                    <li>
                        <a class="dropdown-item {{ is_selected ? 'active' : '' }}"
                           href="{{ path('context_switch_year', {'id': year.id}) }}">
                            <i class="fas fa-calendar me-2"></i> {{ year.name }}
                            {% if year.isCurrent is defined and year.isCurrent %}
                                <span class="badge bg-primary ms-1">En cours</span>
                            {% endif %}
                            {% if is_selected %}
                                <i class="fas fa-check text-success ms-2"></i>
                            {% endif %}
                        </a>
                    </li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}
        </div>

       

        <div class="topbar-nav">
            {# ── Bouton thème clair/sombre ── #}
            <button class="theme-toggle" id="themeToggle" title="Basculer thème clair/sombre">
                <i class="fas fa-moon" id="themeIcon"></i>
            </button>

            {# ── Notifications dropdown ── #}
            {% set unread_notifs = unread_notifications_count() %}
            {% set recent_notifs = recent_notifications(8) %}
            <div class="topbar-item dropdown">
                <a href="#" class="topbar-link" data-bs-toggle="dropdown">
                    <i class="fas fa-bell fa-fw"></i>
                    {% if unread_notifs > 0 %}<span class="notification-badge">{{ unread_notifs > 9 ? '9+' : unread_notifs }}</span>{% endif %}
                </a>
                <div class="dropdown-menu dropdown-menu-end" style="min-width: 340px;">
                    <h6 class="dropdown-header d-flex justify-content-between align-items-center">
                        Notifications
                        {% if unread_notifs > 0 %}<span class="badge bg-primary rounded-pill">{{ unread_notifs }} nouvelle{{ unread_notifs > 1 ? 's' : '' }}</span>{% endif %}
                    </h6>
                    {% for n in recent_notifs %}
                        <a class="dropdown-item py-2 {{ not n.isRead ? 'border-start border-3 border-primary bg-light' : '' }}" href="{{ path('notification_read', {'id': n.id}) }}">
                            <div class="d-flex align-items-start">
                                <div class="flex-shrink-0">
                                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px;">
                                        <i class="fas {{ n.icon ?: 'fa-bell' }} fa-sm"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1 ms-2" style="white-space: normal;">
                                    <div class="fw-bold small">{{ n.title }}</div>
                                    <div class="text-muted" style="font-size:0.75rem;">{{ n.message|length > 70 ? n.message|slice(0, 70) ~ '…' : n.message }}</div>
                                    <div class="text-muted" style="font-size:0.7rem;">{{ n.createdAt|date('d/m/Y H:i') }}</div>
                                </div>
                            </div>
                        </a>
                    {% else %}
                        <div class="dropdown-item-text text-center text-muted small py-3">
                            <i class="fas fa-bell-slash me-1"></i> Aucune notification
                        </div>
                    {% endfor %}
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item text-center small text-primary" href="{{ path('notification_index') }}">
                        <i class="fas fa-bell me-1"></i>Voir toutes les notifications
                    </a>
                </div>
            </div>

            {# ── Messages ── 
            <div class="topbar-item dropdown">
                <a href="#" class="topbar-link" data-bs-toggle="dropdown">
                    <i class="fas fa-envelope fa-fw"></i>
                    <span class="notification-badge">5</span>
                </a>
                <div class="dropdown-menu dropdown-menu-end" style="min-width: 300px;">
                    <h6 class="dropdown-header">Messages</h6>
                    <a class="dropdown-item" href="#">
                        <div class="d-flex align-items-center">
                            <div class="user-avatar me-2" style="background:#1cc88a;width:32px;height:32px;font-size:0.7rem;">JD</div>
                            <div>
                                <div class="small fw-bold">Jean Dupont</div>
                                <div class="small text-muted">Réunion parents...</div>
                            </div>
                        </div>
                    </a>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item text-center small text-primary" href="#">
                        <i class="fas fa-envelope me-1"></i>Voir tous les messages
                    </a>
                </div>
            </div> #}

            {# ── Menu utilisateur avec avatar dynamique coloré par rôle ── #}
            {% set avatar_colors = {
                'admin':      '#ef4444',
                'directeur':  '#7c3aed',
                'enseignant': '#0ea5e9',
                'personnel':  '#f59e0b',
                'parent':     '#10b981',
                'eleve':      '#1e3a5f'
            } %}
            {% set user_bg = avatar_colors[app.user ? app.user.userType : 'admin'] | default('#4e73df') %}

            <div class="topbar-item dropdown">
                <a href="#" class="topbar-link" data-bs-toggle="dropdown">
                    <div class="user-avatar" style="background: {{ user_bg }};">
                        {{ app.user ? app.user.initials : 'AD' }}
                    </div>
                    <span class="d-none d-lg-inline ms-2">
                        {{ app.user ? app.user.fullName : 'Admin' }}
                    </span>
                </a>
                <div class="dropdown-menu dropdown-menu-end">
                    <h6 class="dropdown-header">
                        {{ app.user ? app.user.email : 'admin@edu-school.com' }}
                    </h6>
                    {% if app.user %}
                    <div class="dropdown-item-text">
                        {% set role_labels = {
                            'admin':      'Administrateur',
                            'directeur':  'Directeur',
                            'enseignant': 'Enseignant',
                            'personnel':  'Personnel',
                            'parent':     'Parent',
                            'eleve':      'Élève'
                        } %}
                        <span class="badge" style="background:{{ user_bg }};">
                            {{ role_labels[app.user.userType] | default('Utilisateur') }}
                        </span>
                    </div>
                    {% endif %}
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item" href="#">
                        <i class="fas fa-user fa-sm fa-fw me-2"></i>
                        Mon Profil
                    </a>
                    <a class="dropdown-item" href="#">
                        <i class="fas fa-cog fa-sm fa-fw me-2"></i>
                        Paramètres
                    </a>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item" href="{{ path('app_logout') }}">
                        <i class="fas fa-sign-out-alt fa-sm fa-fw me-2"></i>
                        Déconnexion
                    </a>
                </div>
            </div>
        </div>
    </nav>

    {# ================================================================
       CONTENEUR DE TOASTS (flash messages)
       Positionné en haut à droite, au-dessus de tout
       ================================================================ #}
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1090;">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                {% set toast_type = label == 'error' ? 'danger' : label %}
                {% set icon_map = {
                    'success': 'fa-check-circle',
                    'danger':  'fa-exclamation-circle',
                    'warning': 'fa-exclamation-triangle',
                    'info':    'fa-info-circle'
                } %}
                <div class="toast align-items-center text-bg-{{ toast_type }} border-0"
                     role="alert" aria-live="assertive" aria-atomic="true"
                     data-bs-autohide="true" data-bs-delay="5000">
                    <div class="d-flex">
                        <div class="toast-body">
                            <i class="fas {{ icon_map[toast_type] | default('fa-info-circle') }} me-2"></i>
                            {{ message }}
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto"
                                data-bs-dismiss="toast" aria-label="Fermer"></button>
                    </div>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    {# ================================================================
       MODALE DE CONFIRMATION DE SUPPRESSION
       ================================================================ #}
    <div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <h5 class="modal-title text-danger">
                        <i class="fas fa-exclamation-triangle me-2"></i>Confirmer la suppression
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    <p>Êtes-vous sûr de vouloir supprimer cet élément ? Cette action est irréversible.</p>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i>Annuler
                    </button>
                    <form id="deleteForm" method="post" style="display:inline">
                        <input type="hidden" name="_token" value="">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash-alt me-1"></i>Supprimer
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    {# ================================================================
       CONTENU PRINCIPAL
       ================================================================ #}
    <div class="content-wrapper">
        {% block body %}{% endblock %}

        {# Footer #}
        <footer class="footer mt-5">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-md-6 text-md-start">
                        &copy; {{ "now"|date("Y") }} EDU-SCHOOL - Système de Gestion Scolaire
                    </div>
                    <div class="col-md-6 text-md-end">
                        Version 1.0.0 | 
                        <a href="#" class="text-decoration-none">Documentation</a> | 
                        <a href="#" class="text-decoration-none">Support</a>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    {# Bootstrap JS #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    
    {# App JS (thème, compteurs, toasts, modales, sidebar) #}
    <script src="{{ asset('js/app.js') }}"></script>

    {# Tom Select : rend tous les <select> recherchables (hébergé en local) #}
    <script src="{{ asset('vendor/tom-select/js/tom-select.complete.min.js') }}"></script>
    <script>
        (function () {
            /**
             * Initialise un select recherchable.
             * Échappatoire : ajouter `data-no-search` (ou la classe `no-search`)
             * sur un <select> pour le laisser en select natif.
             */
            function enhanceSelect(el) {
                if (el.tomselect) return;                         // déjà initialisé
                if (el.dataset.noSearch !== undefined) return;    // opt-out : data-no-search
                if (el.classList.contains('no-search')) return;   // opt-out : class no-search

                // Conserve l'option vide comme placeholder (ex. « Choisir... »)
                var placeholder = el.getAttribute('placeholder');
                if (!placeholder) {
                    var first = el.options[0];
                    if (first && first.value === '') {
                        placeholder = first.textContent.trim();
                    }
                }

                var settings = {
                    create: false,
                    allowEmptyOption: true,
                    placeholder: placeholder || 'Rechercher...',
                    // La liste déroulante est rattachée au <body> : elle échappe
                    // ainsi à tout conteneur en overflow (card, .table-responsive,
                    // modale) qui sinon la tronquerait ou la masquerait derrière
                    // les éléments situés en dessous.
                    dropdownParent: 'body',
                    render: {
                        no_results: function () {
                            return '<div class="no-results px-2 py-1 text-muted">Aucun résultat</div>';
                        }
                    }
                };

                try {
                    new TomSelect(el, settings);
                } catch (e) {
                    /* select incompatible : on le laisse natif */
                }
            }

            function enhanceAll(root) {
                (root || document).querySelectorAll('select').forEach(enhanceSelect);
            }

            if (typeof TomSelect !== 'undefined') {
                if (document.readyState !== 'loading') {
                    enhanceAll();
                } else {
                    document.addEventListener('DOMContentLoaded', function () { enhanceAll(); });
                }
                // Re-init après une navigation Turbo éventuelle
                document.addEventListener('turbo:load', function () { enhanceAll(); });
                // Expose pour ré-initialiser les selects ajoutés dynamiquement (ex. modales AJAX)
                window.enhanceSelects = enhanceAll;
            }
        })();
    </script>

    {% block javascripts %}{% endblock %}

    {# Widget Chatbot IA — disponible sur toutes les pages #}
    {% include 'ai/chatbot_widget.html.twig' %}
