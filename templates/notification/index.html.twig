{% extends 'base.html.twig' %}

{% block title %}Notifications{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Notifications',
        subtitle: 'Vos notifications récentes',
        icon: 'fa-bell',
        color: 'primary',
        breadcrumb: [ { label: 'Notifications' } ]
    } %}
        {% block actions %}
            {% if notifications|length > 0 %}
            <form method="post" action="{{ path('notification_read_all') }}" class="d-inline">
                <input type="hidden" name="_token" value="{{ csrf_token('read_all') }}">
                <button type="submit" class="btn btn-light"><i class="fas fa-check-double me-1"></i> Tout marquer comme lu</button>
            </form>
            {% endif %}
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card">
        <div class="card-body p-0">
            {% if notifications|length > 0 %}
                <div class="list-group list-group-flush">
                    {% for n in notifications %}
                        <a href="{{ path('notification_read', {'id': n.id}) }}" class="list-group-item list-group-item-action d-flex gap-3 py-3 {{ not n.isRead ? 'bg-light' : '' }}">
                            <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white" style="width:42px;height:42px;flex:0 0 42px;">
                                <i class="fas {{ n.icon ?: 'fa-bell' }}"></i>
                            </span>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between">
                                    <span class="fw-bold">{{ n.title }}{% if not n.isRead %} <span class="badge bg-primary ms-1">Nouveau</span>{% endif %}</span>
                                    <small class="text-muted">{{ n.createdAt|date('d/m/Y H:i') }}</small>
                                </div>
                                <div class="text-muted small">{{ n.message }}</div>
                            </div>
                        </a>
                    {% endfor %}
                </div>
                <div class="p-3">{% include '_pagination.html.twig' with { pagination: notifications } %}</div>
            {% else %}
                <div class="text-center text-muted py-5">
                    <i class="fas fa-bell-slash fa-2x mb-2"></i>
                    <div>Aucune notification.</div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
