{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Types de transaction{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Types de transaction',
        subtitle: 'Liste personnalisable des types de transaction financière',
        icon: 'fa-tags',
        color: 'primary',
        breadcrumb: [
            { label: 'Transactions', path: path('admin_financial_transaction_index') },
            { label: 'Types' }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_transaction_type_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouveau type</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card table-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des types</h6>
            <span class="badge bg-primary">{{ transaction_types|length }}</span>
        </div>
        <div class="card-body">
            {% if transaction_types|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr><th>Nom</th><th>Sens</th><th>Description</th><th>Statut</th><th class="text-end">Actions</th></tr>
                        </thead>
                        <tbody>
                            {% for type in transaction_types %}
                                <tr>
                                    <td class="fw-bold">{{ type.name }}</td>
                                    <td><span class="badge badge-soft {{ type.directionColor }}">{{ type.directionLabel }}</span></td>
                                    <td class="text-muted">{{ type.description ?: '—' }}</td>
                                    <td><span class="badge badge-soft {{ type.isActive ? 'success' : 'danger' }}">{{ type.isActive ? 'Actif' : 'Inactif' }}</span></td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a href="{{ path('admin_transaction_type_edit', {'id': type.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                            <form method="post" action="{{ path('admin_transaction_type_toggle', {'id': type.id}) }}" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ type.id) }}">
                                                <button type="submit" class="btn btn-outline-secondary" title="{{ type.isActive ? 'Désactiver' : 'Activer' }}"><i class="fas fa-{{ type.isActive ? 'ban' : 'check' }}"></i></button>
                                            </form>
                                            <form method="post" action="{{ path('admin_transaction_type_delete', {'id': type.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer ce type de transaction ?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ type.id) }}">
                                                <button type="submit" class="btn btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                {{ empty_state('fa-tags', 'Aucun type', 'Cliquez sur « Nouveau type » pour en créer un.') }}
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
