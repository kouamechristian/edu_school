{# Formulaire de préinscription réutilisable.
   Paramètres :
   - form         : la vue de formulaire (PreRegistrationType)
   - action       : URL de soumission (optionnel ; défaut = route courante)
   - submit_label : libellé du bouton de soumission (optionnel) #}
{{ form_start(form, action is defined and action ? { action: action } : {}) }}
    <div class="row">
        <div class="col-md-6">{{ form_row(form.lastName) }}</div>
        <div class="col-md-6">{{ form_row(form.firstName) }}</div>
    </div>
    <div class="row">
        <div class="col-md-6">{{ form_row(form.matriculeNational) }}</div>
    </div>
    <div class="row">
        <div class="col-md-6">{{ form_row(form.dateOfBirth) }}</div>
        <div class="col-md-6">{{ form_row(form.gender) }}</div>
    </div>
    <div class="row">
        <div class="col-md-6">{{ form_row(form.phone) }}</div>
        <div class="col-md-6">{{ form_row(form.email) }}</div>
    </div>
    {{ form_row(form.address) }}

    <hr class="my-4">
    <h6 class="text-muted mb-3"><i class="fas fa-id-card me-2"></i>État civil</h6>
    <div class="row">
        <div class="col-md-6">{{ form_row(form.placeOfBirth) }}</div>
        <div class="col-md-6">{{ form_row(form.nationality) }}</div>
    </div>
    <div class="row">
        <div class="col-md-6">{{ form_row(form.birthCertificateNumber) }}</div>
        <div class="col-md-6">{{ form_row(form.cmuNumber) }}</div>
    </div>
    {{ form_row(form.photoFile) }}

    <hr class="my-4">
    <h6 class="text-muted mb-3"><i class="fas fa-user-friends me-2"></i>Informations du parent/tuteur</h6>
    <div class="row">
        <div class="col-md-6">{{ form_row(form.parentName) }}</div>
        <div class="col-md-6">{{ form_row(form.parentPhone) }}</div>
    </div>
    <div class="row">
        <div class="col-md-6">{{ form_row(form.parentEmail) }}</div>
        <div class="col-md-6">{{ form_row(form.parentFunction) }}</div>
    </div>
    {{ form_row(form.parentAddress) }}

    <hr class="my-4">
    <h6 class="text-muted mb-3"><i class="fas fa-phone-alt me-2"></i>Contact d'urgence</h6>
    <div class="row">
        <div class="col-md-6">{{ form_row(form.emergencyContact) }}</div>
        <div class="col-md-6">{{ form_row(form.emergencyPhone) }}</div>
    </div>

    <hr class="my-4">
    <h6 class="text-muted mb-3"><i class="fas fa-school me-2"></i>Informations scolaires</h6>
    <div class="row">
        <div class="col-md-6">{{ form_row(form.requestedLevel) }}</div>
        <div class="col-md-6">{{ form_row(form.schoolYear) }}</div>
    </div>
    <div class="row">
        <div class="col-md-6">{{ form_row(form.isRepeating) }}</div>
    </div>
    {{ form_row(form.lastSchoolAttended) }}

    <hr class="my-4">
    <h6 class="text-muted mb-3"><i class="fas fa-notes-medical me-2"></i>Informations supplémentaires</h6>
    {{ form_row(form.medicalInfo) }}
    {{ form_row(form.notes) }}

    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
        <a href="{{ path('admin_pre_registration_index') }}" class="btn btn-light">Annuler</a>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> {{ submit_label|default('Créer la préinscription') }}</button>
    </div>
{{ form_end(form) }}
