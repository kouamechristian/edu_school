{% extends 'base.html.twig' %}

{% block title %}Nouvelle Préinscription{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Nouvelle Préinscription',
        icon: 'fa-clipboard-list',
        color: 'primary',
        breadcrumb: [
            { label: 'Préinscriptions', path: path('admin_pre_registration_index') },
            { label: 'Nouvelle' }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_pre_registration_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-user me-2"></i>Informations de l'élève</h6></div>
                <div class="card-body">
                    {{ include('pre_registration/_form_fields.html.twig', { submit_label: 'Créer la préinscription' }) }}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            {# Processus #}
            <div class="card mb-4">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-route me-2"></i>Processus de préinscription</h6></div>
                <div class="card-body">
                    <div class="activity-timeline">
                        <div class="timeline-item">
                            <span class="timeline-dot bg-primary"></span>
                            <h6 class="mb-1">1. Préinscription</h6>
                            <p class="text-muted small mb-0">Saisie des informations de base de l'élève</p>
                        </div>
                        <div class="timeline-item">
                            <span class="timeline-dot bg-soft-info" style="background:var(--es-info);"></span>
                            <h6 class="mb-1">2. Documents requis</h6>
                            <p class="text-muted small mb-0">Upload des documents nécessaires</p>
                        </div>
                        <div class="timeline-item">
                            <span class="timeline-dot" style="background:var(--es-warning);"></span>
                            <h6 class="mb-1">3. Validation</h6>
                            <p class="text-muted small mb-0">Vérification et validation des documents</p>
                        </div>
                        <div class="timeline-item">
                            <span class="timeline-dot" style="background:var(--es-success);"></span>
                            <h6 class="mb-1">4. Inscription</h6>
                            <p class="text-muted small mb-0">Inscription définitive en classe</p>
                        </div>
                    </div>
                </div>
            </div>

            {# Documents requis #}
            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list-check me-2"></i>Documents requis</h6></div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Certificat de naissance</li>
                        <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Bulletin de notes</li>
                        <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Photo d'identité</li>
                        <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Autorisation parentale</li>
                        <li class="mb-2"><i class="fas fa-minus text-muted me-2"></i>Carnet de vaccination <small class="text-muted">(optionnel)</small></li>
                        <li><i class="fas fa-minus text-muted me-2"></i>Attestation de scolarité <small class="text-muted">(optionnel)</small></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
