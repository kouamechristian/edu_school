{% extends 'base.html.twig' %}

{% block title %}Nouvelle Préinscription{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0">Nouvelle Préinscription</h1>
                <a href="{{ path('admin_pre_registration_index') }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Retour à la liste
                </a>
            </div>

            <div class="row">
                <div class="col-lg-8">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Informations de l'élève</h5>
                        </div>
                        <div class="card-body">
                            {{ form_start(form) }}
                                <div class="row">
                                    <div class="col-md-6">
                                        {{ form_row(form.firstName) }}
                                    </div>
                                    <div class="col-md-6">
                                        {{ form_row(form.lastName) }}
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        {{ form_row(form.dateOfBirth) }}
                                    </div>
                                    <div class="col-md-6">
                                        {{ form_row(form.gender) }}
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        {{ form_row(form.phone) }}
                                    </div>
                                    <div class="col-md-6">
                                        {{ form_row(form.email) }}
                                    </div>
                                </div>

                                {{ form_row(form.address) }}

                                <hr class="my-4">
                                <h6 class="text-muted">Informations du parent/tuteur</h6>

                                <div class="row">
                                    <div class="col-md-6">
                                        {{ form_row(form.parentName) }}
                                    </div>
                                    <div class="col-md-6">
                                        {{ form_row(form.parentPhone) }}
                                    </div>
                                </div>

                                {{ form_row(form.parentEmail) }}

                                <hr class="my-4">
                                <h6 class="text-muted">Contact d'urgence</h6>

                                <div class="row">
                                    <div class="col-md-6">
                                        {{ form_row(form.emergencyContact) }}
                                    </div>
                                    <div class="col-md-6">
                                        {{ form_row(form.emergencyPhone) }}
                                    </div>
                                </div>

                                <hr class="my-4">
                                <h6 class="text-muted">Informations scolaires</h6>

                                <div class="row">
                                    <div class="col-md-6">
                                        {{ form_row(form.requestedLevel) }}
                                    </div>
                                    <div class="col-md-6">
                                        {{ form_row(form.schoolYear) }}
                                    </div>
                                </div>

                                <hr class="my-4">
                                <h6 class="text-muted">Informations supplémentaires</h6>

                                {{ form_row(form.medicalInfo) }}
                                {{ form_row(form.notes) }}

                                <div class="d-flex justify-content-end gap-2">
                                    <a href="{{ path('admin_pre_registration_index') }}" class="btn btn-outline-secondary">
                                        Annuler
                                    </a>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-save"></i> Créer la préinscription
                                    </button>
                                </div>
                            {{ form_end(form) }}
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Processus de préinscription</h5>
                        </div>
                        <div class="card-body">
                            <div class="timeline">
                                <div class="timeline-item">
                                    <div class="timeline-marker bg-primary"></div>
                                    <div class="timeline-content">
                                        <h6>1. Préinscription</h6>
                                        <p class="text-muted small">Saisie des informations de base de l'élève</p>
                                    </div>
                                </div>
                                <div class="timeline-item">
                                    <div class="timeline-marker bg-secondary"></div>
                                    <div class="timeline-content">
                                        <h6>2. Documents requis</h6>
                                        <p class="text-muted small">Upload des documents nécessaires</p>
                                    </div>
                                </div>
                                <div class="timeline-item">
                                    <div class="timeline-marker bg-secondary"></div>
                                    <div class="timeline-content">
                                        <h6>3. Validation</h6>
                                        <p class="text-muted small">Vérification et validation des documents</p>
                                    </div>
                                </div>
                                <div class="timeline-item">
                                    <div class="timeline-marker bg-secondary"></div>
                                    <div class="timeline-content">
                                        <h6>4. Inscription</h6>
                                        <p class="text-muted small">Inscription définitive en classe</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card mt-3">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Documents requis</h5>
                        </div>
                        <div class="card-body">
                            <ul class="list-unstyled mb-0">
                                <li><i class="fas fa-check text-success"></i> Certificat de naissance</li>
                                <li><i class="fas fa-check text-success"></i> Bulletin de notes</li>
                                <li><i class="fas fa-check text-success"></i> Photo d'identité</li>
                                <li><i class="fas fa-check text-success"></i> Autorisation parentale</li>
                                <li><i class="fas fa-times text-muted"></i> Carnet de vaccination (optionnel)</li>
                                <li><i class="fas fa-times text-muted"></i> Attestation de scolarité (optionnel)</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.timeline {
    position: relative;
    padding-left: 30px;
}

.timeline::before {
    content: '';
    position: absolute;
    left: 15px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: #dee2e6;
}

.timeline-item {
    position: relative;
    margin-bottom: 20px;
}

.timeline-marker {
    position: absolute;
    left: -22px;
    top: 5px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid #fff;
    box-shadow: 0 0 0 2px #dee2e6;
}

.timeline-content h6 {
    margin-bottom: 5px;
    font-size: 14px;
}

.timeline-content p {
    margin-bottom: 0;
    font-size: 12px;
}
</style>
{% endblock %}
