{% extends 'base.html.twig' %}

{% block title %}Gestion des Préinscriptions{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0">Gestion des Préinscriptions</h1>
                <div>
                    <a href="{{ path('admin_student_enrollment') }}" class="btn btn-success me-2">
                        <i class="fas fa-user-graduate"></i> Inscription
                    </a>
                    <a href="{{ path('admin_pre_registration_new') }}" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Nouvelle Préinscription
                    </a>
                </div>
            </div>

            {% if current_school %}
                <div class="alert alert-info">
                    <i class="fas fa-school"></i> Établissement sélectionné : <strong>{{ current_school.name }}</strong>
                </div>
            {% endif %}

            <!-- Statistiques -->
            <div class="row mb-4">
                <div class="col-md-2">
                    <div class="card text-center">
                        <div class="card-body">
                            <h5 class="card-title text-warning">{{ stats.pending|default(0) }}</h5>
                            <p class="card-text">En attente</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="card text-center">
                        <div class="card-body">
                            <h5 class="card-title text-info">{{ stats.documents_required|default(0) }}</h5>
                            <p class="card-text">Documents requis</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="card text-center">
                        <div class="card-body">
                            <h5 class="card-title text-primary">{{ stats.documents_received|default(0) }}</h5>
                            <p class="card-text">Documents reçus</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="card text-center">
                        <div class="card-body">
                            <h5 class="card-title text-success">{{ stats.validated|default(0) }}</h5>
                            <p class="card-text">Validées</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="card text-center">
                        <div class="card-body">
                            <h5 class="card-title text-danger">{{ stats.rejected|default(0) }}</h5>
                            <p class="card-text">Rejetées</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="card text-center">
                        <div class="card-body">
                            <h5 class="card-title text-success">{{ stats.enrolled|default(0) }}</h5>
                            <p class="card-text">Inscrites</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Filtres -->
            <div class="card mb-4">
                <div class="card-body">
                    <form method="GET" class="row g-3">
                        <div class="col-md-4">
                            <label for="status" class="form-label">Statut</label>
                            <select name="status" id="status" class="form-select">
                                <option value="">Tous les statuts</option>
                                <option value="pending" {{ current_status == 'pending' ? 'selected' : '' }}>En attente</option>
                                <option value="documents_required" {{ current_status == 'documents_required' ? 'selected' : '' }}>Documents requis</option>
                                <option value="documents_received" {{ current_status == 'documents_received' ? 'selected' : '' }}>Documents reçus</option>
                                <option value="validated" {{ current_status == 'validated' ? 'selected' : '' }}>Validées</option>
                                <option value="rejected" {{ current_status == 'rejected' ? 'selected' : '' }}>Rejetées</option>
                                <option value="enrolled" {{ current_status == 'enrolled' ? 'selected' : '' }}>Inscrites</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="search" class="form-label">Recherche</label>
                            <input type="text" name="search" id="search" class="form-control" 
                                   placeholder="Nom ou prénom..." value="{{ search_term }}">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">&nbsp;</label>
                            <div class="d-grid">
                                <button type="submit" class="btn btn-outline-primary">
                                    <i class="fas fa-search"></i> Filtrer
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Liste des préinscriptions -->
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Liste des Préinscriptions</h5>
                </div>
                <div class="card-body">
                    {% if pre_registrations|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Nom</th>
                                        <th>Date de naissance</th>
                                        <th>Niveau demandé</th>
                                        <th>Statut</th>
                                        <th>Date de création</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for pre_registration in pre_registrations %}
                                        <tr>
                                            <td>
                                                <strong>{{ pre_registration.fullName }}</strong>
                                                {% if pre_registration.parentName %}
                                                    <br><small class="text-muted">Parent: {{ pre_registration.parentName }}</small>
                                                {% endif %}
                                            </td>
                                            <td>{{ pre_registration.dateOfBirth|date('d/m/Y') }}</td>
                                            <td>
                                                {% if pre_registration.requestedLevel %}
                                                    {{ pre_registration.requestedLevel.name }}
                                                {% else %}
                                                    <span class="text-muted">Non spécifié</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                <span class="badge bg-{{ pre_registration.statusColor }}">
                                                    {{ pre_registration.statusLabel }}
                                                </span>
                                            </td>
                                            <td>{{ pre_registration.createdAt|date('d/m/Y H:i') }}</td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a href="{{ path('admin_pre_registration_show', {'id': pre_registration.id}) }}" 
                                                       class="btn btn-sm btn-outline-primary" title="Voir">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a href="{{ path('admin_pre_registration_edit', {'id': pre_registration.id}) }}" 
                                                       class="btn btn-sm btn-outline-secondary" title="Modifier">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    
                                                    <!-- Boutons de changement de statut -->
                                                    {% if pre_registration.isPending() %}
                                                        <form method="post" action="{{ path('admin_pre_registration_change_status', {'id': pre_registration.id, 'status': 'documents_required'}) }}" 
                                                              class="d-inline" onsubmit="return confirm('Demander des documents ?')">
                                                            <button type="submit" class="btn btn-sm btn-outline-info" title="Demander des documents">
                                                                <i class="fas fa-file-upload"></i>
                                                            </button>
                                                        </form>
                                                    {% endif %}
                                                    
                                                    {% if pre_registration.isDocumentsRequired() %}
                                                        <form method="post" action="{{ path('admin_pre_registration_change_status', {'id': pre_registration.id, 'status': 'documents_received'}) }}" 
                                                              class="d-inline" onsubmit="return confirm('Marquer documents reçus ?')">
                                                            <button type="submit" class="btn btn-sm btn-outline-primary" title="Documents reçus">
                                                                <i class="fas fa-check-circle"></i>
                                                            </button>
                                                        </form>
                                                    {% endif %}
                                                    
                                                    <!-- Boutons d'action principaux -->
                                                    {% if pre_registration.canBeValidated() %}
                                                        <form method="post" action="{{ path('admin_pre_registration_validate', {'id': pre_registration.id}) }}" 
                                                              class="d-inline" onsubmit="return confirm('Valider cette préinscription ?')">
                                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Valider">
                                                                <i class="fas fa-check"></i>
                                                            </button>
                                                        </form>
                                                    {% endif %}
                                                    {% if pre_registration.canBeEnrolled() %}
                                                        <form method="post" action="{{ path('admin_pre_registration_enroll', {'id': pre_registration.id}) }}" 
                                                              class="d-inline" onsubmit="return confirm('Inscrire cet élève ?')">
                                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Inscrire">
                                                                <i class="fas fa-user-plus"></i>
                                                            </button>
                                                        </form>
                                                    {% endif %}
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="text-center py-5">
                            <i class="fas fa-clipboard-list fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">Aucune préinscription trouvée</h5>
                            <p class="text-muted">
                                {% if current_school %}
                                    Aucune préinscription pour l'établissement {{ current_school.name }}.
                                {% else %}
                                    Veuillez sélectionner un établissement pour voir les préinscriptions.
                                {% endif %}
                            </p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
