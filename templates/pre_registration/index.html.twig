{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Gestion des Préinscriptions{% endblock %}

{% block body %}
<div class="container-fluid">
    {# ── En-tête ── #}
    {% embed 'components/page_header.html.twig' with {
        title: 'Gestion des Préinscriptions',
        subtitle: current_school ? current_school.name : 'Suivi des demandes d\'inscription',
        icon: 'fa-clipboard-list',
        color: 'primary',
        breadcrumb: [ { label: 'Préinscriptions' } ]
    } %}
        {% block actions %}
           {% if is_granted('ROLE_INSCRIPTION') %}
            <a href="{{ path('admin_registration_index') }}" class="btn btn-success"><i class="fas fa-user-graduate me-1"></i> Inscription</a>
           {% endif %}
            <a href="{{ path('admin_pre_registration_choose') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouvelle Préinscription</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    {# ── Statistiques ── #}
    <div class="row g-3 mb-4">
        {% set cards = [
            { label: 'En attente',       value: stats.pending|default(0),            icon: 'fa-hourglass-half', color: 'warning' },
            { label: 'Documents requis', value: stats.documents_required|default(0), icon: 'fa-file-upload',     color: 'info' },
            { label: 'Documents reçus',  value: stats.documents_received|default(0), icon: 'fa-file-circle-check', color: 'primary' },
            { label: 'Validées',         value: stats.validated|default(0),          icon: 'fa-check',          color: 'success' },
            { label: 'Rejetées',         value: stats.rejected|default(0),           icon: 'fa-times',          color: 'danger' },
            { label: 'Inscrites',        value: stats.enrolled|default(0),           icon: 'fa-user-check',     color: 'success' }
        ] %}
        {% for c in cards %}
            <div class="col-6 col-md-4 col-xl-2">
                <div class="stat-card {{ c.color }} h-100">
                    <div class="card-body d-flex align-items-center justify-content-between">
                        <div><div class="stat-label mb-1">{{ c.label }}</div><div class="stat-value">{{ c.value }}</div></div>
                        <div class="stat-icon"><i class="fas {{ c.icon }}"></i></div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    {# ── Filtres ── #}
    <div class="card filter-card mb-4">
        <div class="card-body">
            <form method="GET" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label for="status" class="form-label">Statut</label>
                    <select name="status" id="status" class="form-select">
                        <option value="">Tous les statuts</option>
                        <option value="pending" {{ current_status == 'pending' ? 'selected' : '' }}>En attente</option>
                        <option value="documents_required" {{ current_status == 'documents_required' ? 'selected' : '' }}>Documents requis</option>
                        <option value="documents_received" {{ current_status == 'documents_received' ? 'selected' : '' }}>Documents reçus</option>
                        <option value="validated" {{ current_status == 'validated' ? 'selected' : '' }}>Validées</option>
                        <option value="rejected" {{ current_status == 'rejected' ? 'selected' : '' }}>Rejetées</option>
                        <option value="enrolled" {{ current_status == 'enrolled' ? 'selected' : '' }}>Inscrites</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label for="search" class="form-label">Recherche</label>
                    <input type="text" name="search" id="search" class="form-control" placeholder="Nom ou prénom..." value="{{ search_term }}">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100"><i class="fas fa-filter me-1"></i> Filtrer</button>
                </div>
            </form>
        </div>
    </div>

    {# ── Liste ── #}
    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des préinscriptions</h6></div>
        <div class="card-body">
            {% if pre_registrations|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Nom</th>
                                <th>Date de naissance</th>
                                <th>Niveau demandé</th>
                                <th>Statut</th>
                                <th>Date de création</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for pre_registration in pre_registrations %}
                                <tr>
                                    <td>
                                        <strong>{{ pre_registration.fullName }}</strong>
                                        {% if pre_registration.parentName %}<br><small class="text-muted">Parent : {{ pre_registration.parentName }}</small>{% endif %}
                                    </td>
                                    <td class="text-muted">{{ pre_registration.dateOfBirth|date('d/m/Y') }}</td>
                                    <td>{% if pre_registration.requestedLevel %}{{ pre_registration.requestedLevel.name }}{% else %}<span class="text-muted">Non spécifié</span>{% endif %}</td>
                                    <td><span class="badge bg-{{ pre_registration.statusColor }}">{{ pre_registration.statusLabel }}</span></td>
                                    <td class="text-muted">{{ pre_registration.createdAt|date('d/m/Y H:i') }}</td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a href="{{ path('admin_pre_registration_fiche', {'id': pre_registration.id}) }}" target="_blank" rel="noopener" class="btn btn-outline-danger" title="Fiche d'inscription (lire / télécharger)"><i class="fas fa-file-pdf"></i></a>
                                            <a href="{{ path('admin_pre_registration_edit', {'id': pre_registration.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                            {% if pre_registration.isPending() %}
                                                <form method="post" action="{{ path('admin_pre_registration_change_status', {'id': pre_registration.id, 'status': 'documents_required'}) }}" class="d-inline" onsubmit="return confirm('Demander des documents ?')">
                                                    <button type="submit" class="btn btn-outline-info" title="Demander des documents"><i class="fas fa-file-upload"></i></button>
                                                </form>
                                            {% endif %}
                                            {% if pre_registration.isDocumentsRequired() %}
                                                <form method="post" action="{{ path('admin_pre_registration_change_status', {'id': pre_registration.id, 'status': 'documents_received'}) }}" class="d-inline" onsubmit="return confirm('Marquer documents reçus ?')">
                                                    <button type="submit" class="btn btn-outline-primary" title="Documents reçus"><i class="fas fa-check-circle"></i></button>
                                                </form>
                                            {% endif %}
                                            {% if pre_registration.canBeValidated() %}
                                                <form method="post" action="{{ path('admin_pre_registration_validate', {'id': pre_registration.id}) }}" class="d-inline" onsubmit="return confirm('Valider cette préinscription ?')">
                                                    <button type="submit" class="btn btn-outline-success" title="Valider"><i class="fas fa-check"></i></button>
                                                </form>
                                            {% endif %}
                                            {% if is_granted('ROLE_ADMIN') and not pre_registration.isEnrolled() %}
                                                <form method="post" action="{{ path('admin_pre_registration_delete', {'id': pre_registration.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer cette préinscription ?')">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ pre_registration.id) }}">
                                                    <button type="submit" class="btn btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                                </form>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% include '_pagination.html.twig' with { pagination: pre_registrations } %}
            {% else %}
                {{ empty_state('fa-clipboard-list', 'Aucune préinscription trouvée', current_school ? 'Aucune préinscription pour l\'établissement ' ~ current_school.name ~ '.' : 'Veuillez sélectionner un établissement pour voir les préinscriptions.') }}
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
