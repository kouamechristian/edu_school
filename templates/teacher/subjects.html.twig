{% extends 'base.html.twig' %}

{% block title %}Matières — {{ teacher.fullName }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.bootstrap5.min.css">
{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-xl-8">
            {% embed 'components/page_header.html.twig' with {
                title: 'Matières enseignées',
                subtitle: teacher.fullName,
                icon: 'fa-chalkboard-user',
                color: 'primary',
                breadcrumb: [
                    { label: 'Académique' },
                    { label: 'Enseignants', path: path('admin_teacher_index') },
                    { label: teacher.fullName }
                ]
            } %}
                {% block actions %}
                    <a href="{{ path('admin_teacher_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
                {% endblock %}
            {% endembed %}

            {% include '_flash.html.twig' %}

            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-book me-2"></i>Sélectionnez les matières</h6></div>
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="mb-2">
                            {{ form_label(form.teachingSubjects) }}
                            {{ form_widget(form.teachingSubjects) }}
                            <div class="form-text">Cliquez pour ouvrir la liste, tapez pour rechercher, sélectionnez une ou plusieurs matières.</div>
                        </div>

                        <div class="d-flex justify-content-between mt-3 pt-3 border-top">
                            <a href="{{ path('admin_teacher_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
                            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Enregistrer</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var el = document.querySelector('.js-subject-select');
            if (el && !el.tomselect) {
                new TomSelect(el, {
                    plugins: ['remove_button'],
                    create: false,
                    persist: false,
                    placeholder: el.getAttribute('data-placeholder') || 'Rechercher...',
                    hideSelected: true,
                    dropdownParent: 'body',
                });
            }
        });
    </script>
{% endblock %}
