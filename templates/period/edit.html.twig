{% extends 'period/new.html.twig' %}

{% block title %}Modifier la Période{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3">Modifier la Période</h1>
                <a href="{{ path('admin_period_index') }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>

            {% include '_flash.html.twig' %}

            <div class="card shadow-sm">
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="row">
                            <div class="col-md-8 mb-3">
                                {{ form_row(form.name) }}
                            </div>
                            <div class="col-md-4 mb-3">
                                {{ form_row(form.code) }}
                            </div>
                        </div>

                        <div class="mb-3">
                            {{ form_row(form.orderNumber) }}
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.startDate) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.endDate) }}
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                {{ form_widget(form.isActive) }}
                                {{ form_label(form.isActive) }}
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="{{ path('admin_period_index') }}" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Annuler
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Enregistrer les modifications
                            </button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>

            <div class="card shadow-sm mt-3">
                <div class="card-body">
                    <h5 class="card-title text-danger">
                        <i class="fas fa-exclamation-triangle"></i> Zone dangereuse
                    </h5>
                    <p class="card-text text-muted">
                        La suppression de cette période supprimera également toutes les évaluations et notes associées.
                    </p>
                    <form method="post" action="{{ path('admin_period_delete', {'id': period.id}) }}" onsubmit="return confirm('Êtes-vous vraiment sûr ? Cette action est irréversible !');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ period.id) }}">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash"></i> Supprimer la période
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

