{% extends 'base.html.twig' %}

{% block title %}Gestion des Périodes{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-2">Gestion des Périodes</h1>
            {% if current_school and current_year %}
                <p class="text-muted mb-0">
                    <i class="fas fa-school"></i> {{ current_school.name }}
                    <span class="mx-2">|</span>
                    <i class="fas fa-calendar"></i> {{ current_year.name }}
                    <span class="badge bg-primary ms-2">{{ periods|length }} période(s)</span>
                </p>
            {% endif %}
        </div>
        <a href="{{ path('admin_period_new') }}" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nouvelle Période
        </a>
    </div>

    {% include '_flash.html.twig' %}

    {% if not current_school or not current_year %}
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle"></i>
            Veuillez sélectionner un établissement et une année scolaire pour voir les périodes.
        </div>
    {% else %}
        <div class="card shadow-sm">
            <div class="card-body p-0">
                {% if periods is empty %}
                    <div class="text-center py-5">
                        <i class="fas fa-calendar-alt fa-3x text-muted mb-3"></i>
                        <p class="text-muted">Aucune période trouvée.</p>
                        <a href="{{ path('admin_period_new') }}" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Créer la première période
                        </a>
                    </div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Ordre</th>
                                    <th>Nom</th>
                                    <th>Code</th>
                                    <th>Période</th>
                                    <th>Statut</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for period in periods %}
                                    <tr>
                                        <td>
                                            <span class="badge bg-secondary">{{ period.orderNumber }}</span>
                                        </td>
                                        <td>
                                            <strong>{{ period.name }}</strong>
                                        </td>
                                        <td>
                                            <code>{{ period.code }}</code>
                                        </td>
                                        <td>
                                            <small>
                                                <i class="fas fa-calendar-day"></i>
                                                {{ period.dateRange }}
                                            </small>
                                        </td>
                                        <td>
                                            {% if period.isActive %}
                                                <span class="badge bg-success">Active</span>
                                            {% else %}
                                                <span class="badge bg-danger">Inactive</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-end">
                                            <div class="btn-group btn-group-sm">
                                                <a href="{{ path('admin_period_show', {'id': period.id}) }}" 
                                                   class="btn btn-outline-info" 
                                                   title="Détails">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a href="{{ path('admin_period_edit', {'id': period.id}) }}" 
                                                   class="btn btn-outline-warning" 
                                                   title="Modifier">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <form method="post" 
                                                      action="{{ path('admin_period_delete', {'id': period.id}) }}" 
                                                      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette période ?');"
                                                      style="display: inline;">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ period.id) }}">
                                                    <button type="submit" 
                                                            class="btn btn-outline-danger btn-sm" 
                                                            title="Supprimer">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}

