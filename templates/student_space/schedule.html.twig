{% extends 'base.html.twig' %}

{% block title %}Mon Emploi du Temps{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-2"><i class="fas fa-calendar"></i> Mon Emploi du Temps</h1>
            {% if classroom %}
                <p class="text-muted mb-0">{{ classroom.fullName }}</p>
            {% endif %}
        </div>
        <a href="{{ path('student_dashboard') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Retour au tableau de bord
        </a>
    </div>

    {% include '_flash.html.twig' %}

    {% if not classroom %}
        <div class="alert alert-warning text-center">
            <i class="fas fa-exclamation-triangle fa-2x mb-3"></i><br>
            <strong>Aucune classe assignée</strong><br>
            <p class="mb-0">Contactez votre administration pour être affecté(e) à une classe.</p>
        </div>
    {% else %}
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="fas fa-calendar-week"></i> Emploi du Temps - {{ classroom.name }}
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 12%;">Horaires</th>
                                <th style="width: 17.6%;">Lundi</th>
                                <th style="width: 17.6%;">Mardi</th>
                                <th style="width: 17.6%;">Mercredi</th>
                                <th style="width: 17.6%;">Jeudi</th>
                                <th style="width: 17.6%;">Vendredi</th>
                            </tr>
                        </thead>
                        <tbody>
                            {# Récupérer toutes les plages horaires distinctes #}
                            {% set time_slots = [] %}
                            {% for day, courses in schedule %}
                                {% for course in courses %}
                                    {% if course.timeSlot and course.timeSlot not in time_slots %}
                                        {% set time_slots = time_slots|merge([course.timeSlot]) %}
                                    {% endif %}
                                {% endfor %}
                            {% endfor %}

                            {# Trier les plages horaires par orderNumber #}
                            {% set time_slots = time_slots|sort((a, b) => a.orderNumber <=> b.orderNumber) %}

                            {# Afficher une ligne par plage horaire #}
                            {% for time_slot in time_slots %}
                                <tr>
                                    <td class="bg-light text-center">
                                        <strong>{{ time_slot.name }}</strong><br>
                                        <small class="text-muted">{{ time_slot.timeRange }}</small>
                                    </td>
                                    
                                    {# Pour chaque jour de la semaine #}
                                    {% for day in ['lundi', 'mardi', 'mercredi', 'jeudi', 'vendredi'] %}
                                        <td style="padding: 8px; vertical-align: middle;">
                                            {% set found = false %}
                                            {% for course in schedule[day]|default([]) %}
                                                {% if course.timeSlot and course.timeSlot.id == time_slot.id %}
                                                    {% set found = true %}
                                                    <div class="p-2 rounded" style="background-color: {{ course.subject.color ?? '#6c757d' }}15; border-left: 3px solid {{ course.subject.color ?? '#6c757d' }};">
                                                        <strong class="d-block" style="color: {{ course.subject.color ?? '#6c757d' }};">
                                                            {{ course.subject.name }}
                                                        </strong>
                                                        <small class="text-muted">
                                                            <i class="fas fa-user"></i> {{ course.teacher ? course.teacher.fullName : 'Non assigné' }}
                                                        </small>
                                                        {% if course.room %}
                                                            <br>
                                                            <small class="text-muted">
                                                                <i class="fas fa-door-closed"></i> {{ course.room.code }}
                                                            </small>
                                                        {% endif %}
                                                    </div>
                                                {% endif %}
                                            {% endfor %}
                                            {% if not found %}
                                                <div class="text-center text-muted">
                                                    -
                                                </div>
                                            {% endif %}
                                        </td>
                                    {% endfor %}
                                </tr>
                            {% endfor %}

                            {# Si aucune plage horaire #}
                            {% if time_slots is empty %}
                                <tr>
                                    <td colspan="6" class="text-center py-5">
                                        <i class="fas fa-info-circle fa-2x text-muted mb-3"></i><br>
                                        <p class="text-muted mb-0">Aucun cours dans l'emploi du temps</p>
                                    </td>
                                </tr>
                            {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Légende des couleurs -->
        <div class="card shadow mt-3">
            <div class="card-header">
                <h6 class="mb-0"><i class="fas fa-palette"></i> Légende des Matières</h6>
            </div>
            <div class="card-body">
                <div class="row">
                    {% set all_subjects = [] %}
                    {% for day, courses in schedule %}
                        {% for course in courses %}
                            {% if course.subject and course.subject not in all_subjects %}
                                {% set all_subjects = all_subjects|merge([course.subject]) %}
                            {% endif %}
                        {% endfor %}
                    {% endfor %}

                    {% for subject in all_subjects %}
                        <div class="col-md-3 mb-2">
                            <div class="d-flex align-items-center">
                                <div style="width: 20px; height: 20px; background-color: {{ subject.color ?? '#6c757d' }}; border-radius: 3px;" class="me-2"></div>
                                <span>{{ subject.name }}</span>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="text-center mt-4">
            <a href="{{ path('student_dashboard') }}" class="btn btn-primary btn-lg">
                <i class="fas fa-home"></i> Retour au Tableau de Bord
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}

