{% extends 'base.html.twig' %}

{% block title %}Mes Absences{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box">
                <div class="page-title-right">
                    <ol class="breadcrumb m-0">
                        <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                        <li class="breadcrumb-item"><a href="{{ path('student_dashboard') }}">Mon Espace</a></li>
                        <li class="breadcrumb-item active">Mes Absences</li>
                    </ol>
                </div>
                <h4 class="page-title">Mes Absences</h4>
            </div>
        </div>
    </div>

    {% if absences is empty %}
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body text-center py-5">
                        <i class="mdi mdi-calendar-check display-4 text-success"></i>
                        <h5 class="mt-3">Aucune absence enregistrée</h5>
                        <p class="text-muted">Félicitations ! Vous n'avez aucune absence enregistrée.</p>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <!-- Statistiques rapides -->
        <div class="row">
            <div class="col-md-3">
                <div class="card text-white bg-primary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4 class="mb-0">{{ absences|length }}</h4>
                                <p class="mb-0">Total absences</p>
                            </div>
                            <div class="align-self-center">
                                <i class="mdi mdi-calendar-remove display-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-success">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4 class="mb-0">{{ absences|filter(a => a.justificationStatus == 'justified')|length }}</h4>
                                <p class="mb-0">Justifiées</p>
                            </div>
                            <div class="align-self-center">
                                <i class="mdi mdi-check-circle display-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-warning">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4 class="mb-0">{{ absences|filter(a => a.justificationStatus == 'pending')|length }}</h4>
                                <p class="mb-0">En attente</p>
                            </div>
                            <div class="align-self-center">
                                <i class="mdi mdi-clock display-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-danger">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4 class="mb-0">{{ absences|filter(a => a.justificationStatus == 'unjustified')|length }}</h4>
                                <p class="mb-0">Non justifiées</p>
                            </div>
                            <div class="align-self-center">
                                <i class="mdi mdi-close-circle display-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Liste des absences -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Historique de mes absences</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Type</th>
                                        <th>Durée</th>
                                        <th>Statut</th>
                                        <th>Motif</th>
                                        <th>Justification</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for absence in absences %}
                                        <tr>
                                            <td>
                                                <strong>{{ absence.date|date('d/m/Y') }}</strong>
                                                {% if absence.startTime and absence.endTime %}
                                                    <br><small class="text-muted">
                                                        {{ absence.startTime|date('H:i') }} - {{ absence.endTime|date('H:i') }}
                                                    </small>
                                                {% endif %}
                                            </td>
                                            <td>
                                                <span class="badge" style="background-color: {{ absence.absenceType.color ?? '#6c757d' }}">
                                                    {{ absence.absenceType.name }}
                                                </span>
                                            </td>
                                            <td>
                                                {% if absence.startTime and absence.endTime %}
                                                    {{ absence.durationInHours|number_format(1) }}h
                                                {% else %}
                                                    <span class="text-muted">-</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% set statusClass = match(absence.justificationStatus) {
                                                    'justified': 'success',
                                                    'unjustified': 'danger',
                                                    'pending': 'warning',
                                                    default: 'secondary'
                                                } %}
                                                <span class="badge bg-{{ statusClass }}">
                                                    {{ absence.justificationStatusLabel }}
                                                </span>
                                            </td>
                                            <td>
                                                {% if absence.reason %}
                                                    <span class="text-truncate d-inline-block" style="max-width: 200px;" title="{{ absence.reason }}">
                                                        {{ absence.reason }}
                                                    </span>
                                                {% else %}
                                                    <span class="text-muted">-</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if absence.justification %}
                                                    <span class="text-truncate d-inline-block" style="max-width: 200px;" title="{{ absence.justification }}">
                                                        {{ absence.justification }}
                                                    </span>
                                                {% else %}
                                                    <span class="text-muted">-</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}

    <!-- Informations -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Informations importantes</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <h6 class="alert-heading">À propos des absences</h6>
                        <ul class="mb-0">
                            <li><strong>Absence justifiée :</strong> Votre absence est légitime et documentée</li>
                            <li><strong>Absence en attente :</strong> Votre justificatif est en cours d'évaluation</li>
                            <li><strong>Absence non justifiée :</strong> Votre absence nécessite une justification</li>
                        </ul>
                    </div>
                    
                    <div class="alert alert-warning">
                        <h6 class="alert-heading">Règlement des absences</h6>
                        <p class="mb-0">
                            Toute absence doit être justifiée dans les 48h suivant votre retour en classe. 
                            Les justificatifs doivent être transmis à la vie scolaire.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

