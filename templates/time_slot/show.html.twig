{% extends 'base.html.twig' %}

{% block title %}{{ time_slot.name }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-xl-9">
            {% embed 'components/page_header.html.twig' with {
                title: time_slot.name,
                subtitle: 'Plage horaire',
                icon: 'fa-clock',
                color: 'primary',
                breadcrumb: [
                    { label: 'Plages horaires', path: path('admin_time_slot_index') },
                    { label: time_slot.name }
                ]
            } %}
                {% block actions %}
                    <a href="{{ path('admin_time_slot_edit', {'id': time_slot.id}) }}" class="btn btn-warning"><i class="fas fa-edit me-1"></i> Modifier</a>
                    <a href="{{ path('admin_time_slot_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
                {% endblock %}
            {% endembed %}

            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="m-0 fw-bold text-primary"><i class="fas fa-clock me-2"></i>{{ time_slot.name }}</h6>
                    <span class="badge badge-soft {{ time_slot.isActive ? 'success' : 'danger' }}">{{ time_slot.isActive ? 'Active' : 'Inactive' }}</span>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Établissement</div><div class="info-value"><a href="{{ path('admin_school_show', {'id': time_slot.school.id}) }}">{{ time_slot.school.name }}</a></div></div>
                            <div class="info-row"><div class="info-label">Type</div><div class="info-value"><span class="badge bg-{{ time_slot.type == 'cours' ? 'primary' : (time_slot.type == 'pause' ? 'info' : (time_slot.type == 'dejeuner' ? 'warning' : 'success')) }}">{{ time_slot.typeLabel }}</span></div></div>
                            <div class="info-row"><div class="info-label">Ordre</div><div class="info-value">{{ time_slot.orderNumber }}</div></div>
                        </div></div>
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Début</div><div class="info-value">{{ time_slot.startTime|date('H:i') }}</div></div>
                            <div class="info-row"><div class="info-label">Fin</div><div class="info-value">{{ time_slot.endTime|date('H:i') }}</div></div>
                            <div class="info-row"><div class="info-label">Durée</div><div class="info-value">{{ time_slot.duration }} minutes</div></div>
                            <div class="info-row"><div class="info-label">Couleur</div><div class="info-value">{% if time_slot.color %}<span class="badge" style="background-color: {{ time_slot.color }}; color: #fff;">{{ time_slot.color }}</span>{% else %}<span class="text-muted">Non définie</span>{% endif %}</div></div>
                        </div></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
