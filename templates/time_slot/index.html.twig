{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Plages Horaires{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Gestion des Plages Horaires',
        subtitle: current_school ? current_school.name : 'Horaires de l\'établissement',
        icon: 'fa-clock',
        color: 'primary',
        breadcrumb: [ { label: 'Plages horaires' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_time_slot_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouvelle Plage Horaire</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des plages horaires <span class="badge badge-soft ms-1">{{ time_slots|length }}</span></h6></div>
        <div class="card-body">
            {% if time_slots is empty %}
                {{ empty_state('fa-clock', 'Aucune plage horaire', 'Cliquez sur « Nouvelle Plage Horaire » pour définir les horaires de votre établissement.') }}
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr><th>Ordre</th><th>Nom</th><th>Type</th><th>Horaire</th><th>Durée</th><th>Couleur</th><th>Statut</th><th class="text-end" width="160">Actions</th></tr>
                        </thead>
                        <tbody>
                            {% for timeSlot in time_slots %}
                            <tr>
                                <td><span class="badge badge-soft secondary">{{ timeSlot.orderNumber }}</span></td>
                                <td><strong>{{ timeSlot.name }}</strong></td>
                                <td><span class="badge bg-{{ timeSlot.type == 'cours' ? 'primary' : (timeSlot.type == 'pause' ? 'info' : (timeSlot.type == 'dejeuner' ? 'warning' : 'success')) }}">{{ timeSlot.typeLabel }}</span></td>
                                <td>{{ timeSlot.startTime|date('H:i') }} – {{ timeSlot.endTime|date('H:i') }}</td>
                                <td>{{ timeSlot.duration }} min</td>
                                <td>{% if timeSlot.color %}<span class="badge" style="background-color: {{ timeSlot.color }}; color: #fff;">{{ timeSlot.color }}</span>{% else %}—{% endif %}</td>
                                <td><span class="badge badge-soft {{ timeSlot.isActive ? 'success' : 'danger' }}">{{ timeSlot.isActive ? 'Active' : 'Inactive' }}</span></td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a href="{{ path('admin_time_slot_show', {'id': timeSlot.id}) }}" class="btn btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a>
                                        <a href="{{ path('admin_time_slot_edit', {'id': timeSlot.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                        <form method="post" action="{{ path('admin_time_slot_toggle', {'id': timeSlot.id}) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ timeSlot.id) }}">
                                            <button type="submit" class="btn btn-outline-secondary" title="{{ timeSlot.isActive ? 'Désactiver' : 'Activer' }}"><i class="fas fa-{{ timeSlot.isActive ? 'ban' : 'check' }}"></i></button>
                                        </form>
                                        {% if is_granted('ROLE_ADMIN') %}
                                        <form method="post" action="{{ path('admin_time_slot_delete', {'id': timeSlot.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette plage horaire ?');" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ timeSlot.id) }}">
                                            <button type="submit" class="btn btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                        </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
