{% extends 'base.html.twig' %}

{% block title %}Détails de l'absence{% endblock %}

{% block body %}
<div class="container-fluid">
    {% set statusMap = {'justified': 'success', 'unjustified': 'danger', 'pending': 'warning'} %}
    {% embed 'components/page_header.html.twig' with {
        title: 'Absence — ' ~ absence.student.fullName,
        subtitle: absence.date|date('d/m/Y'),
        icon: 'fa-calendar-check',
        color: 'primary',
        breadcrumb: [
            { label: 'Absences', path: path('admin_absence_index') },
            { label: 'Détails' }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_absence_edit', {'id': absence.id}) }}" class="btn btn-warning"><i class="fas fa-edit me-1"></i> Modifier</a>
            {% if absence.isPendingJustification %}<a href="{{ path('admin_absence_justify', {'id': absence.id}) }}" class="btn btn-success"><i class="fas fa-check-circle me-1"></i> Justifier</a>{% endif %}
            <a href="{{ path('admin_absence_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-info-circle me-2"></i>Informations de l'absence</h6></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Élève</div><div class="info-value"><strong>{{ absence.student.fullName }}</strong>{% if absence.student.classroom %}<br><small class="text-muted">{{ absence.student.classroom.name }}</small>{% endif %}</div></div>
                            <div class="info-row"><div class="info-label">Type</div><div class="info-value"><span class="badge" style="background-color: {{ absence.absenceType.color ?? '#6c757d' }}; color:#fff;">{{ absence.absenceType.name }}</span></div></div>
                            <div class="info-row"><div class="info-label">Date</div><div class="info-value"><strong>{{ absence.date|date('d/m/Y') }}</strong>{% if absence.startTime and absence.endTime %}<br><small class="text-muted">{{ absence.startTime|date('H:i') }} – {{ absence.endTime|date('H:i') }}</small>{% endif %}</div></div>
                            {% if absence.durationInHours %}<div class="info-row"><div class="info-label">Durée</div><div class="info-value">{{ absence.durationInHours|number_format(1) }} heure(s)</div></div>{% endif %}
                        </div></div>
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Statut</div><div class="info-value"><span class="badge badge-soft {{ statusMap[absence.justificationStatus] ?? 'secondary' }}">{{ absence.justificationStatusLabel }}</span></div></div>
                            <div class="info-row"><div class="info-label">Période</div><div class="info-value">{% if absence.period %}{{ absence.period.name }}{% else %}<span class="text-muted">Non spécifiée</span>{% endif %}</div></div>
                            <div class="info-row"><div class="info-label">Enregistrée par</div><div class="info-value">{{ absence.recordedBy ? absence.recordedBy.fullName : '—' }}</div></div>
                            <div class="info-row"><div class="info-label">Date d'enregistrement</div><div class="info-value">{{ absence.createdAt|date('d/m/Y H:i') }}</div></div>
                        </div></div>
                    </div>

                    {% if absence.reason %}<div class="mt-3"><h6 class="text-muted">Motif de l'absence</h6><p class="mb-0">{{ absence.reason }}</p></div>{% endif %}
                    {% if absence.justification %}
                        <div class="mt-3"><h6 class="text-muted">Justification</h6><p class="mb-1">{{ absence.justification }}</p>
                            {% if absence.justifiedBy %}<small class="text-muted">Justifiée par {{ absence.justifiedBy.fullName }} le {{ absence.justificationDate|date('d/m/Y H:i') }}</small>{% endif %}
                        </div>
                    {% endif %}
                    {% if absence.notes %}<div class="mt-3"><h6 class="text-muted">Notes</h6><p class="mb-0">{{ absence.notes }}</p></div>{% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-bolt me-2"></i>Actions rapides</h6></div>
                <div class="card-body d-grid gap-2">
                    <a href="{{ path('admin_absence_edit', {'id': absence.id}) }}" class="btn btn-warning"><i class="fas fa-edit me-1"></i> Modifier l'absence</a>
                    {% if absence.isPendingJustification %}<a href="{{ path('admin_absence_justify', {'id': absence.id}) }}" class="btn btn-success"><i class="fas fa-check-circle me-1"></i> Justifier l'absence</a>{% endif %}
                    <a href="{{ path('admin_absence_new') }}" class="btn btn-outline-primary"><i class="fas fa-plus me-1"></i> Nouvelle absence</a>
                    <a href="{{ path('admin_absence_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour à la liste</a>
                </div>
            </div>

            {% if absence.absenceType.description %}
                <div class="card">
                    <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-tag me-2"></i>Type d'absence</h6></div>
                    <div class="card-body">
                        <p class="text-muted">{{ absence.absenceType.description }}</p>
                        <div class="d-flex flex-wrap gap-1">
                            {% if absence.absenceType.requiresJustification %}<span class="badge badge-soft warning">Nécessite une justification</span>{% endif %}
                            {% if absence.absenceType.countsAsAbsence %}<span class="badge badge-soft info">Compte comme absence</span>{% endif %}
                            {% if absence.absenceType.penaltyPoints %}<span class="badge badge-soft danger">{{ absence.absenceType.penaltyPoints }} pts de pénalité</span>{% endif %}
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
