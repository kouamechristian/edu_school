{% extends 'base.html.twig' %}

{% block title %}Justifier une absence{% endblock %}

{% block body %}
<div class="container-fluid">
    {% set statusMap = {'justified': 'success', 'unjustified': 'danger', 'pending': 'warning'} %}
    {% embed 'components/page_header.html.twig' with {
        title: 'Justifier une absence',
        subtitle: absence.student.fullName ~ '  ·  ' ~ absence.date|date('d/m/Y'),
        icon: 'fa-check-circle',
        color: 'success',
        breadcrumb: [
            { label: 'Absences', path: path('admin_absence_index') },
            { label: 'Détails', path: path('admin_absence_show', {'id': absence.id}) },
            { label: 'Justifier' }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_absence_show', {'id': absence.id}) }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-check-circle me-2"></i>Justification de l'absence</h6></div>
                <div class="card-body">
                    <form method="POST">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Élève</label>
                                <input type="text" class="form-control" value="{{ absence.student.fullName }}" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Date de l'absence</label>
                                <input type="text" class="form-control" value="{{ absence.date|date('d/m/Y') }}" readonly>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Type d'absence</label>
                                <input type="text" class="form-control" value="{{ absence.absenceType.name }}" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Statut actuel</label>
                                <div><span class="badge badge-soft {{ statusMap[absence.justificationStatus] ?? 'secondary' }} fs-6">{{ absence.justificationStatusLabel }}</span></div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="justification_status" class="form-label">Statut de justification <span class="text-danger">*</span></label>
                            <select name="justification_status" id="justification_status" class="form-select" required>
                                <option value="">Sélectionner un statut</option>
                                <option value="justified" {{ absence.justificationStatus == 'justified' ? 'selected' : '' }}>Justifiée</option>
                                <option value="unjustified" {{ absence.justificationStatus == 'unjustified' ? 'selected' : '' }}>Non justifiée</option>
                                <option value="pending" {{ absence.justificationStatus == 'pending' ? 'selected' : '' }}>En attente</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="justification" class="form-label">Justification</label>
                            <textarea name="justification" id="justification" class="form-control" rows="4" placeholder="Détails de la justification...">{{ absence.justification }}</textarea>
                        </div>
                        <div class="mb-3">
                            <label for="notes" class="form-label">Notes supplémentaires</label>
                            <textarea name="notes" id="notes" class="form-control" rows="3" placeholder="Notes additionnelles...">{{ absence.notes }}</textarea>
                        </div>
                        <div class="d-flex gap-2 pt-3 border-top">
                            <button type="submit" class="btn btn-success"><i class="fas fa-check me-1"></i> Enregistrer la justification</button>
                            <a href="{{ path('admin_absence_show', {'id': absence.id}) }}" class="btn btn-light"><i class="fas fa-times me-1"></i> Annuler</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-info-circle me-2"></i>Informations de l'absence</h6></div>
                <div class="card-body">
                    <div class="info-list">
                        <div class="info-row"><div class="info-label">Élève</div><div class="info-value">{{ absence.student.fullName }}</div></div>
                        <div class="info-row"><div class="info-label">Classe</div><div class="info-value">{% if absence.student.classroom %}{{ absence.student.classroom.name }}{% else %}<span class="text-muted">—</span>{% endif %}</div></div>
                        <div class="info-row"><div class="info-label">Type</div><div class="info-value"><span class="badge" style="background-color: {{ absence.absenceType.color ?? '#6c757d' }}; color:#fff;">{{ absence.absenceType.name }}</span></div></div>
                        <div class="info-row"><div class="info-label">Date</div><div class="info-value">{{ absence.date|date('d/m/Y') }}</div></div>
                        {% if absence.startTime and absence.endTime %}<div class="info-row"><div class="info-label">Heures</div><div class="info-value">{{ absence.startTime|date('H:i') }} – {{ absence.endTime|date('H:i') }}</div></div>{% endif %}
                        <div class="info-row"><div class="info-label">Enregistrée</div><div class="info-value">{{ absence.createdAt|date('d/m/Y H:i') }}</div></div>
                    </div>
                    {% if absence.reason %}<div class="mt-3"><h6 class="text-muted">Motif original</h6><p class="text-muted small mb-0">{{ absence.reason }}</p></div>{% endif %}
                </div>
            </div>

            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-lightbulb me-2"></i>Conseils</h6></div>
                <div class="card-body">
                    <div class="alert alert-info mb-0">
                        <h6 class="alert-heading">Statuts de justification</h6>
                        <ul class="mb-0">
                            <li><strong>Justifiée :</strong> l'absence est légitime et documentée.</li>
                            <li><strong>Non justifiée :</strong> l'absence n'est pas justifiée.</li>
                            <li><strong>En attente :</strong> justification en cours d'évaluation.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
