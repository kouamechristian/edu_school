{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Gestion des absences{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Gestion des absences',
        subtitle: 'Suivi de l\'assiduité des élèves',
        icon: 'fa-calendar-check',
        color: 'primary',
        breadcrumb: [ { label: 'Absences' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_absence_new') }}" class="btn btn-success"><i class="fas fa-plus me-1"></i> Nouvelle absence</a>
            <a href="{{ path('admin_absence_type_index') }}" class="btn btn-info"><i class="fas fa-cog me-1"></i> Types</a>
            <a href="{{ path('admin_absence_attendance_report') }}" class="btn btn-warning"><i class="fas fa-chart-line me-1"></i> Rapport</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    {# Filtres #}
    <div class="card filter-card mb-4">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-filter me-2"></i>Filtres</h6></div>
        <div class="card-body">
            <form method="GET" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label for="classroom" class="form-label">Classe</label>
                    <select name="classroom" id="classroom" class="form-select">
                        <option value="">Toutes les classes</option>
                        {% for classroom in classrooms %}<option value="{{ classroom.id }}" {{ selected_classroom == classroom.id ? 'selected' : '' }}>{{ classroom.name }}</option>{% endfor %}
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="period" class="form-label">Période</label>
                    <select name="period" id="period" class="form-select">
                        <option value="">Toutes les périodes</option>
                        {% for period in periods %}<option value="{{ period.id }}" {{ selected_period == period.id ? 'selected' : '' }}>{{ period.name }}</option>{% endfor %}
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="status" class="form-label">Statut</label>
                    <select name="status" id="status" class="form-select">
                        <option value="">Tous les statuts</option>
                        <option value="pending" {{ selected_status == 'pending' ? 'selected' : '' }}>En attente</option>
                        <option value="justified" {{ selected_status == 'justified' ? 'selected' : '' }}>Justifiées</option>
                        <option value="unjustified" {{ selected_status == 'unjustified' ? 'selected' : '' }}>Non justifiées</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="date" class="form-label">Date</label>
                    <input type="date" name="date" id="date" class="form-control" value="{{ selected_date }}">
                </div>
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-filter me-1"></i> Filtrer</button>
                    <a href="{{ path('admin_absence_index') }}" class="btn btn-light"><i class="fas fa-redo me-1"></i> Réinitialiser</a>
                </div>
            </form>
        </div>
    </div>

    {# Tableau #}
    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des absences <span class="badge badge-soft ms-1">{{ absences|length }}</span></h6></div>
        <div class="card-body">
            {% if absences is empty %}
                {{ empty_state('fa-calendar-check', 'Aucune absence trouvée', 'Aucune absence ne correspond aux critères de recherche.') }}
            {% else %}
                {% set statusMap = {'justified': 'success', 'unjustified': 'danger', 'pending': 'warning'} %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr><th>Date</th><th>Élève</th><th>Type</th><th>Durée</th><th>Statut</th><th>Motif</th><th class="text-end">Actions</th></tr>
                        </thead>
                        <tbody>
                            {% for absence in absences %}
                                <tr>
                                    <td>
                                        <strong>{{ absence.date|date('d/m/Y') }}</strong>
                                        {% if absence.startTime and absence.endTime %}<br><small class="text-muted">{{ absence.startTime|date('H:i') }} – {{ absence.endTime|date('H:i') }}</small>{% endif %}
                                    </td>
                                    <td>
                                        <strong>{{ absence.student.fullName }}</strong>
                                        {% if absence.student.classroom %}<br><small class="text-muted">{{ absence.student.classroom.name }}</small>{% endif %}
                                    </td>
                                    <td><span class="badge" style="background-color: {{ absence.absenceType.color ?? '#6c757d' }}; color: #fff;">{{ absence.absenceType.name }}</span></td>
                                    <td>{% if absence.startTime and absence.endTime %}{{ absence.durationInHours|number_format(1) }}h{% else %}<span class="text-muted">—</span>{% endif %}</td>
                                    <td><span class="badge badge-soft {{ statusMap[absence.justificationStatus] ?? 'secondary' }}">{{ absence.justificationStatusLabel }}</span></td>
                                    <td>{% if absence.reason %}<span class="text-truncate d-inline-block" style="max-width: 200px;" title="{{ absence.reason }}">{{ absence.reason }}</span>{% else %}<span class="text-muted">—</span>{% endif %}</td>
                                    <td class="text-end">
                                        <div class="d-inline-flex gap-1 justify-content-end btn-group-sm">
                                            <a href="{{ path('admin_absence_show', {'id': absence.id}) }}" class="btn btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a>
                                            <a href="{{ path('admin_absence_edit', {'id': absence.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                            {% if absence.isPendingJustification %}
                                                <form method="POST" action="{{ path('admin_absence_set_status', {'id': absence.id}) }}" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('set_status' ~ absence.id) }}">
                                                    <input type="hidden" name="justification_status" value="justified">
                                                    <button type="submit" class="btn btn-outline-success" title="Marquer comme justifiée"><i class="fas fa-check-circle"></i></button>
                                                </form>
                                                <form method="POST" action="{{ path('admin_absence_set_status', {'id': absence.id}) }}" class="d-inline" onsubmit="return confirm('Marquer cette absence comme non justifiée ?');">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('set_status' ~ absence.id) }}">
                                                    <input type="hidden" name="justification_status" value="unjustified">
                                                    <button type="submit" class="btn btn-outline-danger" title="Marquer comme non justifiée"><i class="fas fa-times-circle"></i></button>
                                                </form>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% include '_pagination.html.twig' with { pagination: absences } %}
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
