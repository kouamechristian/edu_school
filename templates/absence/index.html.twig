{% extends 'base.html.twig' %}

{% block title %}Gestion des absences{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box">
                <div class="page-title-right">
                    <ol class="breadcrumb m-0">
                        <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                        <li class="breadcrumb-item active">Absences</li>
                    </ol>
                </div>
                <h4 class="page-title">Gestion des absences</h4>
            </div>
        </div>
    </div>

    <!-- Filtres -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Filtres</h5>
                </div>
                <div class="card-body">
                    <form method="GET" class="row g-3">
                        <div class="col-md-3">
                            <label for="classroom" class="form-label">Classe</label>
                            <select name="classroom" id="classroom" class="form-select">
                                <option value="">Toutes les classes</option>
                                {% for classroom in classrooms %}
                                    <option value="{{ classroom.id }}" {{ selected_classroom == classroom.id ? 'selected' : '' }}>
                                        {{ classroom.name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="period" class="form-label">Période</label>
                            <select name="period" id="period" class="form-select">
                                <option value="">Toutes les périodes</option>
                                {% for period in periods %}
                                    <option value="{{ period.id }}" {{ selected_period == period.id ? 'selected' : '' }}>
                                        {{ period.name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="status" class="form-label">Statut</label>
                            <select name="status" id="status" class="form-select">
                                <option value="">Tous les statuts</option>
                                <option value="pending" {{ selected_status == 'pending' ? 'selected' : '' }}>En attente</option>
                                <option value="justified" {{ selected_status == 'justified' ? 'selected' : '' }}>Justifiées</option>
                                <option value="unjustified" {{ selected_status == 'unjustified' ? 'selected' : '' }}>Non justifiées</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="date" class="form-label">Date</label>
                            <input type="date" name="date" id="date" class="form-control" value="{{ selected_date }}">
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">
                                <i class="mdi mdi-filter"></i> Filtrer
                            </button>
                            <a href="{{ path('admin_absence_index') }}" class="btn btn-secondary">
                                <i class="mdi mdi-refresh"></i> Réinitialiser
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <h5 class="card-title mb-0">Liste des absences</h5>
                            <p class="text-muted mb-0">Total: {{ absences|length }} absence(s)</p>
                        </div>
                        <div class="col-md-6 text-end">
                            <a href="{{ path('admin_absence_new') }}" class="btn btn-success">
                                <i class="mdi mdi-plus"></i> Nouvelle absence
                            </a>
                            <a href="{{ path('admin_absence_type_index') }}" class="btn btn-info">
                                <i class="mdi mdi-cog"></i> Types d'absence
                            </a>
                            <a href="{{ path('admin_absence_attendance_report') }}" class="btn btn-warning">
                                <i class="mdi mdi-chart-line"></i> Rapport d'assiduité
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tableau des absences -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    {% if absences is empty %}
                        <div class="text-center py-5">
                            <i class="mdi mdi-calendar-remove-outline display-4 text-muted"></i>
                            <h5 class="mt-3">Aucune absence trouvée</h5>
                            <p class="text-muted">Aucune absence ne correspond aux critères de recherche.</p>
                            <a href="{{ path('admin_absence_new') }}" class="btn btn-primary">
                                <i class="mdi mdi-plus"></i> Enregistrer une absence
                            </a>
                        </div>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Élève</th>
                                        <th>Type</th>
                                        <th>Durée</th>
                                        <th>Statut</th>
                                        <th>Motif</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for absence in absences %}
                                        <tr>
                                            <td>
                                                <strong>{{ absence.date|date('d/m/Y') }}</strong>
                                                {% if absence.startTime and absence.endTime %}
                                                    <br><small class="text-muted">
                                                        {{ absence.startTime|date('H:i') }} - {{ absence.endTime|date('H:i') }}
                                                    </small>
                                                {% endif %}
                                            </td>
                                            <td>
                                                <strong>{{ absence.student.fullName }}</strong>
                                                {% if absence.student.classroom %}
                                                    <br><small class="text-muted">{{ absence.student.classroom.name }}</small>
                                                {% endif %}
                                            </td>
                                            <td>
                                                <span class="badge" style="background-color: {{ absence.absenceType.color ?? '#6c757d' }}">
                                                    {{ absence.absenceType.name }}
                                                </span>
                                            </td>
                                            <td>
                                                {% if absence.startTime and absence.endTime %}
                                                    {{ absence.durationInHours|number_format(1) }}h
                                                {% else %}
                                                    <span class="text-muted">-</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% set statusClass = match(absence.justificationStatus) {
                                                    'justified': 'success',
                                                    'unjustified': 'danger',
                                                    'pending': 'warning',
                                                    default: 'secondary'
                                                } %}
                                                <span class="badge bg-{{ statusClass }}">
                                                    {{ absence.justificationStatusLabel }}
                                                </span>
                                            </td>
                                            <td>
                                                {% if absence.reason %}
                                                    <span class="text-truncate d-inline-block" style="max-width: 200px;" title="{{ absence.reason }}">
                                                        {{ absence.reason }}
                                                    </span>
                                                {% else %}
                                                    <span class="text-muted">-</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a href="{{ path('admin_absence_show', {'id': absence.id}) }}" 
                                                       class="btn btn-sm btn-outline-primary" title="Voir">
                                                        <i class="mdi mdi-eye"></i>
                                                    </a>
                                                    <a href="{{ path('admin_absence_edit', {'id': absence.id}) }}" 
                                                       class="btn btn-sm btn-outline-warning" title="Modifier">
                                                        <i class="mdi mdi-pencil"></i>
                                                    </a>
                                                    {% if absence.isPendingJustification %}
                                                        <a href="{{ path('admin_absence_justify', {'id': absence.id}) }}" 
                                                           class="btn btn-sm btn-outline-info" title="Justifier">
                                                            <i class="mdi mdi-check-circle"></i>
                                                        </a>
                                                    {% endif %}
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
