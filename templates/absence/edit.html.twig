{% extends 'base.html.twig' %}

{% block title %}Modifier l'absence{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box">
                <div class="page-title-right">
                    <ol class="breadcrumb m-0">
                        <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                        <li class="breadcrumb-item"><a href="{{ path('admin_absence_index') }}">Absences</a></li>
                        <li class="breadcrumb-item"><a href="{{ path('admin_absence_show', {'id': absence.id}) }}">Détails</a></li>
                        <li class="breadcrumb-item active">Modifier</li>
                    </ol>
                </div>
                <h4 class="page-title">Modifier l'absence</h4>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Modifier les informations de l'absence</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    {{ form_label(form.student, 'Élève', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.student, {'attr': {'class': 'form-select'}}) }}
                                    {{ form_errors(form.student) }}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    {{ form_label(form.absenceType, 'Type d\'absence', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.absenceType, {'attr': {'class': 'form-select'}}) }}
                                    {{ form_errors(form.absenceType) }}
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    {{ form_label(form.date, 'Date', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.date, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(form.date) }}
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    {{ form_label(form.startTime, 'Heure de début', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.startTime, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(form.startTime) }}
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    {{ form_label(form.endTime, 'Heure de fin', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.endTime, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(form.endTime) }}
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    {{ form_label(form.period, 'Période', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.period, {'attr': {'class': 'form-select'}}) }}
                                    {{ form_errors(form.period) }}
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.reason, 'Motif', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.reason, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.reason) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.notes, 'Notes supplémentaires', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.notes, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.notes) }}
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="mdi mdi-check"></i> Enregistrer
                            </button>
                            <a href="{{ path('admin_absence_show', {'id': absence.id}) }}" class="btn btn-secondary">
                                <i class="mdi mdi-arrow-left"></i> Annuler
                            </a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Informations actuelles</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-5">Élève :</dt>
                        <dd class="col-sm-7">{{ absence.student.fullName }}</dd>

                        <dt class="col-sm-5">Type :</dt>
                        <dd class="col-sm-7">
                            <span class="badge" style="background-color: {{ absence.absenceType.color ?? '#6c757d' }}">
                                {{ absence.absenceType.name }}
                            </span>
                        </dd>

                        <dt class="col-sm-5">Date :</dt>
                        <dd class="col-sm-7">{{ absence.date|date('d/m/Y') }}</dd>

                        {% if absence.startTime and absence.endTime %}
                            <dt class="col-sm-5">Heures :</dt>
                            <dd class="col-sm-7">{{ absence.startTime|date('H:i') }} - {{ absence.endTime|date('H:i') }}</dd>
                        {% endif %}

                        <dt class="col-sm-5">Statut :</dt>
                        <dd class="col-sm-7">
                            {% set statusClass = match(absence.justificationStatus) {
                                'justified': 'success',
                                'unjustified': 'danger',
                                'pending': 'warning',
                                default: 'secondary'
                            } %}
                            <span class="badge bg-{{ statusClass }}">
                                {{ absence.justificationStatusLabel }}
                            </span>
                        </dd>

                        <dt class="col-sm-5">Enregistrée :</dt>
                        <dd class="col-sm-7">{{ absence.createdAt|date('d/m/Y H:i') }}</dd>
                    </dl>

                    {% if absence.reason %}
                        <div class="mt-3">
                            <h6>Motif actuel</h6>
                            <p class="text-muted">{{ absence.reason }}</p>
                        </div>
                    {% endif %}

                    {% if absence.justification %}
                        <div class="mt-3">
                            <h6>Justification actuelle</h6>
                            <p class="text-muted">{{ absence.justification }}</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}




