{% extends 'base.html.twig' %}

{% block title %}Modifier l'absence{% endblock %}

{% block body %}
<div class="container-fluid">
    {% set statusMap = {'justified': 'success', 'unjustified': 'danger', 'pending': 'warning'} %}
    {% embed 'components/page_header.html.twig' with {
        title: 'Modifier l\'absence',
        subtitle: absence.student.fullName ~ '  ·  ' ~ absence.date|date('d/m/Y'),
        icon: 'fa-calendar-check',
        color: 'primary',
        breadcrumb: [
            { label: 'Absences', path: path('admin_absence_index') },
            { label: 'Détails', path: path('admin_absence_show', {'id': absence.id}) },
            { label: 'Modifier' }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_absence_show', {'id': absence.id}) }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-edit me-2"></i>Modifier les informations</h6></div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.student, 'Élève', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.student, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.student) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.absenceType, 'Type d\'absence', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.absenceType, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.absenceType) }}
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                {{ form_label(form.date, 'Date', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.date, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.date) }}
                            </div>
                            <div class="col-md-4 mb-3">
                                {{ form_label(form.startTime, 'Heure de début', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.startTime, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.startTime) }}
                            </div>
                            <div class="col-md-4 mb-3">
                                {{ form_label(form.endTime, 'Heure de fin', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.endTime, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.endTime) }}
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.period, 'Période', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.period, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.period) }}
                            </div>
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.reason, 'Motif', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.reason, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.reason) }}
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.notes, 'Notes supplémentaires', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.notes, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.notes) }}
                        </div>
                        <div class="d-flex gap-2 pt-3 border-top">
                            <button type="submit" class="btn btn-success"><i class="fas fa-check me-1"></i> Enregistrer</button>
                            <a href="{{ path('admin_absence_show', {'id': absence.id}) }}" class="btn btn-light"><i class="fas fa-times me-1"></i> Annuler</a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-clock-rotate-left me-2"></i>Informations actuelles</h6></div>
                <div class="card-body">
                    <div class="info-list">
                        <div class="info-row"><div class="info-label">Élève</div><div class="info-value">{{ absence.student.fullName }}</div></div>
                        <div class="info-row"><div class="info-label">Type</div><div class="info-value"><span class="badge" style="background-color: {{ absence.absenceType.color ?? '#6c757d' }}; color:#fff;">{{ absence.absenceType.name }}</span></div></div>
                        <div class="info-row"><div class="info-label">Date</div><div class="info-value">{{ absence.date|date('d/m/Y') }}</div></div>
                        {% if absence.startTime and absence.endTime %}<div class="info-row"><div class="info-label">Heures</div><div class="info-value">{{ absence.startTime|date('H:i') }} – {{ absence.endTime|date('H:i') }}</div></div>{% endif %}
                        <div class="info-row"><div class="info-label">Statut</div><div class="info-value"><span class="badge badge-soft {{ statusMap[absence.justificationStatus] ?? 'secondary' }}">{{ absence.justificationStatusLabel }}</span></div></div>
                        <div class="info-row"><div class="info-label">Enregistrée</div><div class="info-value">{{ absence.createdAt|date('d/m/Y H:i') }}</div></div>
                    </div>
                    {% if absence.reason %}<div class="mt-3"><h6 class="text-muted">Motif actuel</h6><p class="text-muted small mb-0">{{ absence.reason }}</p></div>{% endif %}
                    {% if absence.justification %}<div class="mt-3"><h6 class="text-muted">Justification actuelle</h6><p class="text-muted small mb-0">{{ absence.justification }}</p></div>{% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
