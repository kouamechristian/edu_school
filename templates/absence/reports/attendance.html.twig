{% extends 'base.html.twig' %}

{% block title %}Rapport d'assiduité{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Rapport d\'assiduité',
        subtitle: 'Statistiques de présence par classe',
        icon: 'fa-chart-line',
        color: 'primary',
        breadcrumb: [
            { label: 'Absences', path: path('admin_absence_index') },
            { label: 'Rapport d\'assiduité' }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_absence_critical_report') }}" class="btn btn-warning"><i class="fas fa-triangle-exclamation me-1"></i> Élèves à risque</a>
            <a href="{{ path('admin_absence_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {# Paramètres #}
    <div class="card filter-card mb-4">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-sliders me-2"></i>Paramètres du rapport</h6></div>
        <div class="card-body">
            <form method="GET" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label for="classroom" class="form-label">Classe</label>
                    <select name="classroom" id="classroom" class="form-select" required>
                        <option value="">Sélectionner une classe</option>
                        {% for classroom in classrooms %}<option value="{{ classroom.id }}" {{ selected_classroom == classroom.id ? 'selected' : '' }}>{{ classroom.name }}</option>{% endfor %}
                    </select>
                </div>
                <div class="col-md-5">
                    <label for="period" class="form-label">Période</label>
                    <select name="period" id="period" class="form-select" required>
                        <option value="">Sélectionner une période</option>
                        {% for period in periods %}<option value="{{ period.id }}" {{ selected_period == period.id ? 'selected' : '' }}>{{ period.name }}</option>{% endfor %}
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100"><i class="fas fa-chart-line me-1"></i> Générer</button>
                </div>
            </form>
        </div>
    </div>

    {% if report %}
        {# Statistiques #}
        <div class="row g-3 mb-4">
            <div class="col-6 col-xl-3">
                <div class="stat-card primary h-100"><div class="card-body d-flex align-items-center justify-content-between">
                    <div><div class="stat-label mb-1">Élèves</div><div class="stat-value">{{ report.total_students }}</div></div>
                    <div class="stat-icon"><i class="fas fa-users"></i></div>
                </div></div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="stat-card info h-100"><div class="card-body d-flex align-items-center justify-content-between">
                    <div><div class="stat-label mb-1">Total absences</div><div class="stat-value">{{ report.total_absences }}</div></div>
                    <div class="stat-icon"><i class="fas fa-calendar-times"></i></div>
                </div></div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="stat-card success h-100"><div class="card-body d-flex align-items-center justify-content-between">
                    <div><div class="stat-label mb-1">Justifiées</div><div class="stat-value">{{ report.total_justified }}</div></div>
                    <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
                </div></div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="stat-card danger h-100"><div class="card-body d-flex align-items-center justify-content-between">
                    <div><div class="stat-label mb-1">Non justifiées</div><div class="stat-value">{{ report.total_unjustified }}</div></div>
                    <div class="stat-icon"><i class="fas fa-times-circle"></i></div>
                </div></div>
            </div>
        </div>

        {# Taux moyen #}
        <div class="card mb-4">
            <div class="card-body text-center">
                <h6 class="text-muted mb-3">Taux d'assiduité moyen de la classe</h6>
                {% set rateClass = report.average_attendance_rate >= 90 ? 'success' : (report.average_attendance_rate >= 75 ? 'warning' : 'danger') %}
                <div class="row justify-content-center">
                    <div class="col-md-6">
                        <div class="progress" style="height: 28px;">
                            <div class="progress-bar bg-{{ rateClass }}" role="progressbar" style="width: {{ report.average_attendance_rate }}%" aria-valuenow="{{ report.average_attendance_rate }}" aria-valuemin="0" aria-valuemax="100">{{ report.average_attendance_rate }}%</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Détail par élève #}
        <div class="card table-card">
            <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Détail par élève</h6></div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr><th>Élève</th><th class="text-center">Taux d'assiduité</th><th class="text-center">Total</th><th class="text-center">Justifiées</th><th class="text-center">Non justifiées</th><th class="text-center">En attente</th><th class="text-center">Statut</th></tr>
                        </thead>
                        <tbody>
                            {% for studentStat in report.student_stats %}
                                {% set rateClass = studentStat.attendance_rate >= 90 ? 'success' : (studentStat.attendance_rate >= 75 ? 'warning' : 'danger') %}
                                <tr>
                                    <td class="fw-semibold">{{ studentStat.student.fullName }}</td>
                                    <td class="text-center" style="min-width:140px;">
                                        <div class="progress" style="height: 18px;"><div class="progress-bar bg-{{ rateClass }}" role="progressbar" style="width: {{ studentStat.attendance_rate }}%" title="{{ studentStat.attendance_rate }}%"></div></div>
                                        <small class="text-muted">{{ studentStat.attendance_rate }}%</small>
                                    </td>
                                    <td class="text-center"><span class="badge badge-soft info">{{ studentStat.total_absences }}</span></td>
                                    <td class="text-center"><span class="badge badge-soft success">{{ studentStat.justified_absences }}</span></td>
                                    <td class="text-center"><span class="badge badge-soft danger">{{ studentStat.unjustified_absences }}</span></td>
                                    <td class="text-center"><span class="badge badge-soft warning">{{ studentStat.pending_absences }}</span></td>
                                    <td class="text-center">
                                        {% if studentStat.attendance_rate >= 90 %}<span class="badge badge-soft success">Excellent</span>
                                        {% elseif studentStat.attendance_rate >= 75 %}<span class="badge badge-soft warning">Attention</span>
                                        {% else %}<span class="badge badge-soft danger">Critique</span>{% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {% else %}
        <div class="card">
            <div class="card-body">
                <div class="empty-state">
                    <div class="empty-icon"><i class="fas fa-chart-line"></i></div>
                    <h6>Sélectionnez une classe et une période</h6>
                    <p class="mb-0">Choisissez une classe et une période pour générer le rapport d'assiduité.</p>
                </div>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
