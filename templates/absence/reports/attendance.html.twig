{% extends 'base.html.twig' %}

{% block title %}Rapport d'assiduité{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box">
                <div class="page-title-right">
                    <ol class="breadcrumb m-0">
                        <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                        <li class="breadcrumb-item"><a href="{{ path('admin_absence_index') }}">Absences</a></li>
                        <li class="breadcrumb-item active">Rapport d'assiduité</li>
                    </ol>
                </div>
                <h4 class="page-title">Rapport d'assiduité</h4>
            </div>
        </div>
    </div>

    <!-- Filtres -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Paramètres du rapport</h5>
                </div>
                <div class="card-body">
                    <form method="GET" class="row g-3">
                        <div class="col-md-6">
                            <label for="classroom" class="form-label">Classe</label>
                            <select name="classroom" id="classroom" class="form-select" required>
                                <option value="">Sélectionner une classe</option>
                                {% for classroom in classrooms %}
                                    <option value="{{ classroom.id }}" {{ selected_classroom == classroom.id ? 'selected' : '' }}>
                                        {{ classroom.name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="period" class="form-label">Période</label>
                            <select name="period" id="period" class="form-select" required>
                                <option value="">Sélectionner une période</option>
                                {% for period in periods %}
                                    <option value="{{ period.id }}" {{ selected_period == period.id ? 'selected' : '' }}>
                                        {{ period.name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-primary">
                                <i class="mdi mdi-chart-line"></i> Générer le rapport
                            </button>
                            <a href="{{ path('admin_absence_critical_report') }}" class="btn btn-warning">
                                <i class="mdi mdi-alert"></i> Élèves à risque
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    {% if report %}
        <!-- Statistiques générales -->
        <div class="row">
            <div class="col-md-3">
                <div class="card text-white bg-primary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4 class="mb-0">{{ report.total_students }}</h4>
                                <p class="mb-0">Élèves</p>
                            </div>
                            <div class="align-self-center">
                                <i class="mdi mdi-account-group display-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-info">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4 class="mb-0">{{ report.total_absences }}</h4>
                                <p class="mb-0">Total absences</p>
                            </div>
                            <div class="align-self-center">
                                <i class="mdi mdi-calendar-remove display-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-success">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4 class="mb-0">{{ report.total_justified }}</h4>
                                <p class="mb-0">Justifiées</p>
                            </div>
                            <div class="align-self-center">
                                <i class="mdi mdi-check-circle display-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-danger">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h4 class="mb-0">{{ report.total_unjustified }}</h4>
                                <p class="mb-0">Non justifiées</p>
                            </div>
                            <div class="align-self-center">
                                <i class="mdi mdi-close-circle display-4"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Taux d'assiduité moyen -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body text-center">
                        <h3 class="mb-3">Taux d'assiduité moyen de la classe</h3>
                        <div class="row justify-content-center">
                            <div class="col-md-6">
                                <div class="progress" style="height: 30px;">
                                    {% set rateClass = report.average_attendance_rate >= 90 ? 'success' : 
                                                      (report.average_attendance_rate >= 75 ? 'warning' : 'danger') %}
                                    <div class="progress-bar bg-{{ rateClass }}" 
                                         role="progressbar" 
                                         style="width: {{ report.average_attendance_rate }}%"
                                         aria-valuenow="{{ report.average_attendance_rate }}" 
                                         aria-valuemin="0" 
                                         aria-valuemax="100">
                                        {{ report.average_attendance_rate }}%
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Détail par élève -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Détail par élève</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Élève</th>
                                        <th class="text-center">Taux d'assiduité</th>
                                        <th class="text-center">Total absences</th>
                                        <th class="text-center">Justifiées</th>
                                        <th class="text-center">Non justifiées</th>
                                        <th class="text-center">En attente</th>
                                        <th class="text-center">Statut</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for studentStat in report.student_stats %}
                                        {% set rateClass = studentStat.attendance_rate >= 90 ? 'success' : 
                                                          (studentStat.attendance_rate >= 75 ? 'warning' : 'danger') %}
                                        <tr>
                                            <td>
                                                <strong>{{ studentStat.student.fullName }}</strong>
                                            </td>
                                            <td class="text-center">
                                                <div class="progress" style="height: 20px;">
                                                    <div class="progress-bar bg-{{ rateClass }}" 
                                                         role="progressbar" 
                                                         style="width: {{ studentStat.attendance_rate }}%"
                                                         title="{{ studentStat.attendance_rate }}%">
                                                    </div>
                                                </div>
                                                <small class="text-muted">{{ studentStat.attendance_rate }}%</small>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-info">{{ studentStat.total_absences }}</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-success">{{ studentStat.justified_absences }}</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-danger">{{ studentStat.unjustified_absences }}</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-warning">{{ studentStat.pending_absences }}</span>
                                            </td>
                                            <td class="text-center">
                                                {% if studentStat.attendance_rate >= 90 %}
                                                    <span class="badge bg-success">Excellent</span>
                                                {% elseif studentStat.attendance_rate >= 75 %}
                                                    <span class="badge bg-warning">Attention</span>
                                                {% else %}
                                                    <span class="badge bg-danger">Critique</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body text-center py-5">
                        <i class="mdi mdi-chart-line display-4 text-muted"></i>
                        <h5 class="mt-3">Sélectionnez une classe et une période</h5>
                        <p class="text-muted">Choisissez une classe et une période pour générer le rapport d'assiduité.</p>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
