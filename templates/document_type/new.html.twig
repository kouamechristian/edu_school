{% extends 'base.html.twig' %}

{% block title %}Nouveau Type de Document{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0">Nouveau Type de Document</h1>
                <a href="{{ path('admin_document_type_index') }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Retour à la liste
                </a>
            </div>

            <div class="row">
                <div class="col-lg-8">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Informations du type de document</h5>
                        </div>
                        <div class="card-body">
                            {{ form_start(form) }}
                                {{ form_row(form.name) }}
                                {{ form_row(form.description) }}
                                
                                <div class="row">
                                    <div class="col-md-6">
                                        {{ form_row(form.isRequired) }}
                                    </div>
                                    <div class="col-md-6">
                                        {{ form_row(form.isActive) }}
                                    </div>
                                </div>
                                
                                {{ form_row(form.maxFileSize) }}

                                <div class="d-flex justify-content-end gap-2">
                                    <a href="{{ path('admin_document_type_index') }}" class="btn btn-outline-secondary">
                                        Annuler
                                    </a>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-save"></i> Créer le type
                                    </button>
                                </div>
                            {{ form_end(form) }}
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Aide</h5>
                        </div>
                        <div class="card-body">
                            <h6>Types MIME autorisés :</h6>
                            <ul class="list-unstyled small">
                                <li><code>application/pdf</code> - Documents PDF</li>
                                <li><code>image/jpeg</code> - Images JPEG</li>
                                <li><code>image/png</code> - Images PNG</li>
                                <li><code>image/gif</code> - Images GIF</li>
                                <li><code>image/webp</code> - Images WebP</li>
                            </ul>
                            
                            <h6 class="mt-3">Tailles de fichier :</h6>
                            <ul class="list-unstyled small">
                                <li>1 MB = 1,048,576 octets</li>
                                <li>5 MB = 5,242,880 octets</li>
                                <li>10 MB = 10,485,760 octets</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
