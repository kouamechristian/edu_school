{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Types de Documents{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Types de Documents',
        subtitle: 'Pièces justificatives et contraintes',
        icon: 'fa-file-alt',
        color: 'primary',
        breadcrumb: [ { label: 'Types de documents' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_document_type_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouveau Type</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des types</h6></div>
        <div class="card-body">
            {% if document_types|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr><th>Nom</th><th>Description</th><th>Obligatoire</th><th>Statut</th><th>Taille max</th><th>Types MIME</th><th class="text-end">Actions</th></tr>
                        </thead>
                        <tbody>
                            {% for document_type in document_types %}
                                <tr>
                                    <td class="fw-semibold">{{ document_type.name }}</td>
                                    <td class="text-muted">{{ document_type.description ?: 'Aucune description' }}</td>
                                    <td>{% if document_type.isRequired %}<span class="badge badge-soft danger">Obligatoire</span>{% else %}<span class="badge badge-soft secondary">Optionnel</span>{% endif %}</td>
                                    <td>{% if document_type.isActive %}<span class="badge badge-soft success">Actif</span>{% else %}<span class="badge badge-soft warning">Inactif</span>{% endif %}</td>
                                    <td>{{ document_type.formattedMaxFileSize }}</td>
                                    <td><small class="text-muted">{{ document_type.allowedMimeTypes|join(', ') }}</small></td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a href="{{ path('admin_document_type_show', {'id': document_type.id}) }}" class="btn btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a>
                                            <a href="{{ path('admin_document_type_edit', {'id': document_type.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                            <form method="post" action="{{ path('admin_document_type_delete', {'id': document_type.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer ce type de document ?')">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ document_type.id) }}">
                                                <button type="submit" class="btn btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% include '_pagination.html.twig' with { pagination: document_types } %}
            {% else %}
                <div class="empty-state">
                    <div class="empty-icon"><i class="fas fa-file-alt"></i></div>
                    <h6>Aucun type de document</h6>
                    <p>Commencez par créer un nouveau type de document.</p>
                    <a href="{{ path('admin_document_type_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Créer le premier type</a>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
