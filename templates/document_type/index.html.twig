{% extends 'base.html.twig' %}

{% block title %}Types de Documents{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0">Types de Documents</h1>
                <a href="{{ path('admin_document_type_new') }}" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Nouveau Type
                </a>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Liste des Types de Documents</h5>
                </div>
                <div class="card-body">
                    {% if document_types|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Nom</th>
                                        <th>Description</th>
                                        <th>Obligatoire</th>
                                        <th>Actif</th>
                                        <th>Taille max</th>
                                        <th>Types MIME</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for document_type in document_types %}
                                        <tr>
                                            <td>
                                                <strong>{{ document_type.name }}</strong>
                                            </td>
                                            <td>{{ document_type.description ?: 'Aucune description' }}</td>
                                            <td>
                                                {% if document_type.isRequired %}
                                                    <span class="badge bg-danger">Obligatoire</span>
                                                {% else %}
                                                    <span class="badge bg-secondary">Optionnel</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if document_type.isActive %}
                                                    <span class="badge bg-success">Actif</span>
                                                {% else %}
                                                    <span class="badge bg-warning">Inactif</span>
                                                {% endif %}
                                            </td>
                                            <td>{{ document_type.formattedMaxFileSize }}</td>
                                            <td>
                                                <small class="text-muted">
                                                    {{ document_type.allowedMimeTypes|join(', ') }}
                                                </small>
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a href="{{ path('admin_document_type_show', {'id': document_type.id}) }}" 
                                                       class="btn btn-sm btn-outline-primary">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a href="{{ path('admin_document_type_edit', {'id': document_type.id}) }}" 
                                                       class="btn btn-sm btn-outline-secondary">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <form method="post" action="{{ path('admin_document_type_delete', {'id': document_type.id}) }}" 
                                                          class="d-inline" onsubmit="return confirm('Supprimer ce type de document ?')">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ document_type.id) }}">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="text-center py-5">
                            <i class="fas fa-file-alt fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">Aucun type de document trouvé</h5>
                            <p class="text-muted">Commencez par créer un nouveau type de document.</p>
                            <a href="{{ path('admin_document_type_new') }}" class="btn btn-primary">
                                <i class="fas fa-plus"></i> Créer le premier type
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
