{% extends 'base.html.twig' %}

{% block title %}Détails du Contrat{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: contract.reference,
        subtitle: contract.employee.fullName ~ '  ·  ' ~ contract.contractTypeLabel,
        icon: 'fa-file-contract',
        color: 'primary',
        breadcrumb: [
            { label: 'Contrats', path: path('admin_contract_index') },
            { label: contract.reference }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_contract_edit', {'id': contract.id}) }}" class="btn btn-warning"><i class="fas fa-edit me-1"></i> Modifier</a>
            <a href="{{ path('admin_contract_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold text-primary"><i class="fas fa-file-contract me-2"></i>{{ contract.reference }}</h6>
            <span class="badge badge-soft {{ contract.statusBadgeClass }}">{{ contract.statusLabel }}</span>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <h6 class="text-muted border-bottom pb-2 mb-3">Contrat</h6>
                    <div class="info-list">
                        <div class="info-row"><div class="info-label">Employé</div><div class="info-value"><a href="{{ path('admin_employee_show', {'id': contract.employee.id}) }}">{{ contract.employee.fullName }}</a></div></div>
                        <div class="info-row"><div class="info-label">Type</div><div class="info-value"><span class="badge badge-soft secondary">{{ contract.contractTypeLabel }}</span></div></div>
                        <div class="info-row"><div class="info-label">Poste</div><div class="info-value">{{ contract.jobTitle ?: '—' }}</div></div>
                        <div class="info-row"><div class="info-label">Statut</div><div class="info-value"><span class="badge badge-soft {{ contract.statusBadgeClass }}">{{ contract.statusLabel }}</span></div></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <h6 class="text-muted border-bottom pb-2 mb-3">Conditions</h6>
                    <div class="info-list">
                        <div class="info-row"><div class="info-label">Début</div><div class="info-value">{{ contract.startDate|date('d/m/Y') }}</div></div>
                        <div class="info-row"><div class="info-label">Fin</div><div class="info-value">{{ contract.endDate ? contract.endDate|date('d/m/Y') : 'Durée indéterminée' }}</div></div>
                        <div class="info-row"><div class="info-label">Fin période d'essai</div><div class="info-value">{{ contract.trialEndDate ? contract.trialEndDate|date('d/m/Y') : '—' }}</div></div>
                        <div class="info-row"><div class="info-label">Salaire de base</div><div class="info-value">{{ contract.baseSalary ? contract.baseSalary|number_format(2, ',', ' ') : '—' }}</div></div>
                        <div class="info-row"><div class="info-label">Heures hebdo.</div><div class="info-value">{{ contract.weeklyHours ? contract.weeklyHours|number_format(0) ~ ' h' : '—' }}</div></div>
                    </div>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-md-6">
                    <h6 class="text-muted border-bottom pb-2 mb-3">Situation personnelle</h6>
                    <div class="info-list">
                        <div class="info-row"><div class="info-label">Situation familiale</div><div class="info-value">{{ contract.maritalStatus ? contract.maritalStatusLabel : '—' }}</div></div>
                        <div class="info-row"><div class="info-label">Nombre d'enfants</div><div class="info-value">{{ contract.numberOfChildren is not null ? contract.numberOfChildren : '—' }}</div></div>
                        <div class="info-row"><div class="info-label">Enfants majeurs</div><div class="info-value">{{ contract.adultChildren is not null ? contract.adultChildren : '—' }}</div></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <h6 class="text-muted border-bottom pb-2 mb-3">Administratif</h6>
                    <div class="info-list">
                        <div class="info-row"><div class="info-label">Est déclaré</div><div class="info-value">{% if contract.isDeclared is not null %}<span class="badge badge-soft {{ contract.isDeclared ? 'success' : 'danger' }}">{{ contract.isDeclared ? 'Oui' : 'Non' }}</span>{% else %}—{% endif %}</div></div>
                        <div class="info-row"><div class="info-label">Régime</div><div class="info-value">{{ contract.regime ?: '—' }}</div></div>
                    </div>
                </div>
            </div>

            {% if contract.notes %}
                <div class="mt-4">
                    <h6 class="text-muted border-bottom pb-2 mb-3">Notes / Clauses</h6>
                    <div class="alert alert-info mb-0"><i class="fas fa-info-circle me-2"></i>{{ contract.notes|nl2br }}</div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
