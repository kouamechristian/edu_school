{% extends 'base.html.twig' %}

{# Import des macros réutilisables #}
{% from 'components/macros.html.twig' import card_stat, badge_role, avatar %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
<div class="container-fluid">
    {# ================================================================
       EN-TÊTE DE PAGE (composant réutilisable)
       ================================================================ #}
    {% embed 'components/page_header.html.twig' with {
        title: 'Tableau de bord',
        subtitle: 'Vue d\'ensemble de votre établissement',
        icon: 'fa-gauge-high',
        color: 'primary'
    } %}
       
    {% endembed %}

    {# ================================================================
       MESSAGE DE BIENVENUE
       ================================================================ #}
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        <i class="fas fa-info-circle me-2"></i>
        <strong>Bienvenue {{ app.user ? app.user.fullName : 'Administrateur' }} !</strong> 
        Vous êtes connecté au système de gestion scolaire EDU-SCHOOL.
        {% if current_school %}
            <span class="ms-2">
                <i class="fas fa-school me-1"></i> {{ current_school.name }}
                {% if current_school_year %} | <i class="fas fa-calendar me-1"></i> {{ current_school_year.name }}{% endif %}
            </span>
        {% endif %}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>

    {# ================================================================
       CARTES STATISTIQUES ANIMÉES (compteurs JS)
       Utilise la macro card_stat pour la cohérence
       ================================================================ #}
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            {{ card_stat(
                current_school ? 'Niveaux' : 'Établissements',
                current_school ? stats.levels : stats.schools,
                current_school ? 'fa-layer-group' : 'fa-school',
                'primary',
                null
            ) }}
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            {{ card_stat('Élèves Inscrits', students_count, 'fa-user-graduate', 'success', null) }}
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            {{ card_stat('Enseignants', user_types.enseignants, 'fa-chalkboard-teacher', 'info', null) }}
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            {{ card_stat('Personnel & Admins', user_types.personnel + user_types.admins, 'fa-users-cog', 'warning', null) }}
        </div>
    </div>

    {# ================================================================
       ÉLÈVES : classes + répartition par statut et par genre
       (établissement courant, année en cours) — graphiques cliquables
       ================================================================ #}
    {% if current_school %}
    {% set total_status = students_status.affecte + students_status.non_affecte %}
    <div class="card shadow-sm mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold text-primary">
                <i class="fas fa-user-graduate me-2"></i>Répartition des élèves
            </h6>
            <span class="badge bg-primary-subtle text-primary">
                {{ current_school.name }}{% if current_school_year %} — {{ current_school_year.name }}{% endif %}
            </span>
        </div>
        <div class="card-body">
            <div class="row g-4">
                {# Compteurs #}
                <div class="col-lg-3">
                    <div class="d-flex flex-column gap-3">
                        <div class="border rounded-3 p-3 text-center">
                            <i class="fas fa-chalkboard fa-2x text-primary mb-2"></i>
                            <div class="h3 mb-0">{{ classes_count }}</div>
                            <small class="text-muted text-uppercase">Classes</small>
                        </div>
                        <div class="border rounded-3 p-3 text-center">
                            <i class="fas fa-user-graduate fa-2x text-success mb-2"></i>
                            <div class="h3 mb-0">{{ total_status }}</div>
                            <small class="text-muted text-uppercase">Élèves</small>
                        </div>
                    </div>
                </div>
                {# Graphique : répartition par statut #}
                <div class="col-lg-4">
                    <h6 class="text-muted small text-uppercase mb-2">Élèves par statut</h6>
                    <div style="height: 220px;"><canvas id="studentStatusChart"></canvas></div>
                    <div class="d-flex justify-content-around small mt-2">
                        <a href="{{ path('admin_student_index', {status: 'affecte'}) }}" class="text-decoration-none text-reset"><i class="fas fa-square text-success"></i> Affectés : <strong>{{ students_status.affecte }}</strong></a>
                        <a href="{{ path('admin_student_index', {status: 'non_affecte'}) }}" class="text-decoration-none text-reset"><i class="fas fa-square text-warning"></i> Non affectés : <strong>{{ students_status.non_affecte }}</strong></a>
                    </div>
                </div>
                {# Graphique : répartition par genre #}
                <div class="col-lg-4">
                    <h6 class="text-muted small text-uppercase mb-2">Élèves par genre</h6>
                    <div style="height: 220px;"><canvas id="studentGenderChart"></canvas></div>
                    <div class="d-flex justify-content-around small mt-2">
                        <a href="{{ path('admin_student_index', {gender: 'M'}) }}" class="text-decoration-none text-reset"><i class="fas fa-square" style="color:#0ea5e9;"></i> Garçons : <strong>{{ students_gender.M }}</strong></a>
                        <a href="{{ path('admin_student_index', {gender: 'F'}) }}" class="text-decoration-none text-reset"><i class="fas fa-square" style="color:#ec4899;"></i> Filles : <strong>{{ students_gender.F }}</strong></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    {# ================================================================
       GRAPHIQUES Chart.js (présences, notes, finances)
       ================================================================ #}
    <div class="row mb-4">
        {# Graphique Présences / Absences #}
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header py-3">
                    <h6 class="m-0 fw-bold text-primary">
                        <i class="fas fa-chart-pie me-2"></i>Présences / Absences
                    </h6>
                </div>
                <div class="card-body">
                    <div class="chart-container">
                        <canvas id="attendanceChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        {# Graphique Notes Moyennes par matière #}
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header py-3">
                    <h6 class="m-0 fw-bold text-success">
                        <i class="fas fa-chart-bar me-2"></i>Notes Moyennes
                    </h6>
                </div>
                <div class="card-body">
                    <div class="chart-container">
                        <canvas id="gradesChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        {# Graphique Finances #}
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header py-3">
                    <h6 class="m-0 fw-bold text-warning">
                        <i class="fas fa-chart-line me-2"></i>Finances
                    </h6>
                </div>
                <div class="card-body">
                    <div class="chart-container">
                        <canvas id="financeChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ================================================================
       RÉPARTITION DES UTILISATEURS (graphiques existants conservés)
       ================================================================ #}
    <div class="row mb-4">
        <div class="col-lg-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-header py-3">
                    <h6 class="m-0 fw-bold text-primary">
                        <i class="fas fa-chart-pie me-2"></i> Répartition des Utilisateurs par Type
                    </h6>
                    {% if current_school %}
                    <small class="text-muted">{{ current_school.name }}</small>
                    {% endif %}
                </div>
                <div class="card-body">
                    <div class="chart-container">
                        <canvas id="pieChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-header py-3">
                    <h6 class="m-0 fw-bold text-primary">
                        <i class="fas fa-chart-bar me-2"></i> Utilisateurs par Type
                    </h6>
                    {% if current_school %}
                    <small class="text-muted">{{ current_school.name }}</small>
                    {% endif %}
                </div>
                <div class="card-body">
                    <div class="chart-container">
                        <canvas id="barChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ================================================================
       ACTIVITÉS RÉCENTES + ÉVÉNEMENTS
       ================================================================ #}
    <div class="row">
        {# Activités récentes sous forme de timeline #}
        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm">
                <div class="card-header py-3 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 fw-bold text-primary">
                        <i class="fas fa-history me-2"></i> Activités Récentes
                    </h6>
                    <a href="#" class="btn btn-sm btn-outline-primary">Voir tout</a>
                </div>
                <div class="card-body p-0">
                    {# Skeleton loading : affiché au chargement, masqué par JS #}
                    <div class="skeleton-loader p-3">
                        {% for i in 1..4 %}
                        <div class="d-flex mb-3">
                            <div class="skeleton skeleton-circle flex-shrink-0"></div>
                            <div class="flex-grow-1 ms-3">
                                <div class="skeleton skeleton-text" style="width:60%"></div>
                                <div class="skeleton skeleton-text" style="width:80%"></div>
                                <div class="skeleton skeleton-text" style="width:30%"></div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>

                    {# Contenu réel (masqué initialement, affiché par JS) #}
                    <div class="real-content">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:50px;"></th>
                                        <th>Activité</th>
                                        <th>Détails</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px;">
                                                <i class="fas fa-user-plus fa-sm"></i>
                                            </div>
                                        </td>
                                        <td class="fw-semibold">Nouvelle inscription</td>
                                        <td class="text-muted small">Marie DUPONT inscrite en 6ème A</td>
                                        <td><span class="text-muted small">Il y a 2h</span></td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px;">
                                                <i class="fas fa-check fa-sm"></i>
                                            </div>
                                        </td>
                                        <td class="fw-semibold">Notes saisies</td>
                                        <td class="text-muted small">M. MARTIN — Mathématiques 5ème B</td>
                                        <td><span class="text-muted small">Il y a 5h</span></td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="bg-warning text-white rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px;">
                                                <i class="fas fa-euro-sign fa-sm"></i>
                                            </div>
                                        </td>
                                        <td class="fw-semibold">Paiement reçu</td>
                                        <td class="text-muted small">500€ — Jean BERNARD</td>
                                        <td><span class="text-muted small">Hier 14:30</span></td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="bg-info text-white rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px;">
                                                <i class="fas fa-calendar fa-sm"></i>
                                            </div>
                                        </td>
                                        <td class="fw-semibold">Événement planifié</td>
                                        <td class="text-muted small">Réunion parents-professeurs</td>
                                        <td><span class="text-muted small">Il y a 2 jours</span></td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px;">
                                                <i class="fas fa-exclamation fa-sm"></i>
                                            </div>
                                        </td>
                                        <td class="fw-semibold">Absence signalée</td>
                                        <td class="text-muted small">3 élèves absents non justifiés — 4ème C</td>
                                        <td><span class="text-muted small">Il y a 3 jours</span></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Événements à venir #}
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm">
                <div class="card-header py-3">
                    <h6 class="m-0 fw-bold text-primary">
                        <i class="fas fa-calendar-alt me-2"></i> Événements à venir
                    </h6>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        <a href="#" class="list-group-item list-group-item-action border-0 px-0">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1">Réunion Parents</h6>
                                <span class="badge bg-primary rounded-pill">15 Nov</span>
                            </div>
                            <p class="mb-1 small text-muted">
                                <i class="fas fa-clock me-1"></i>18:00 — Salle polyvalente
                            </p>
                        </a>
                        <a href="#" class="list-group-item list-group-item-action border-0 px-0">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1">Conseil de Classe</h6>
                                <span class="badge bg-success rounded-pill">20 Nov</span>
                            </div>
                            <p class="mb-1 small text-muted">
                                <i class="fas fa-clock me-1"></i>14:00 — Classe 6ème A
                            </p>
                        </a>
                        <a href="#" class="list-group-item list-group-item-action border-0 px-0">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1">Sortie Scolaire</h6>
                                <span class="badge bg-warning rounded-pill">25 Nov</span>
                            </div>
                            <p class="mb-1 small text-muted">
                                <i class="fas fa-map-marker-alt me-1"></i>Musée des Sciences
                            </p>
                        </a>
                        <a href="#" class="list-group-item list-group-item-action border-0 px-0">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1">Examens Trimestriels</h6>
                                <span class="badge bg-danger rounded-pill">1 Déc</span>
                            </div>
                            <p class="mb-1 small text-muted">
                                <i class="fas fa-clock me-1"></i>08:00 — Toutes les classes
                            </p>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{# ================================================================
   CHART.JS : graphiques du dashboard
   ================================================================ #}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
(function() {
    'use strict';

    var isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
    var gridColor = isDark ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.05)';
    var textColor = isDark ? '#c7c8cc' : '#5a5c69';

    Chart.defaults.color = textColor;
    Chart.defaults.borderColor = gridColor;

    /* ── Graphique Présences / Absences (doughnut) ── */
    new Chart(document.getElementById('attendanceChart').getContext('2d'), {
        type: 'doughnut',
        data: {
            labels: ['Présents', 'Absents justifiés', 'Absents non justifiés'],
            datasets: [{
                data: [85, 10, 5],
                backgroundColor: ['#10b981', '#f59e0b', '#ef4444'],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '65%',
            plugins: {
                legend: { position: 'bottom', labels: { padding: 15, usePointStyle: true } }
            }
        }
    });

    /* ── Graphique Notes Moyennes (barres horizontales) ── */
    new Chart(document.getElementById('gradesChart').getContext('2d'), {
        type: 'bar',
        data: {
            labels: ['Maths', 'Français', 'Sciences', 'Histoire', 'Anglais', 'Sport'],
            datasets: [{
                label: 'Moyenne /20',
                data: [14.2, 12.8, 15.1, 13.5, 11.9, 16.3],
                backgroundColor: [
                    'rgba(30,58,95,0.85)', 'rgba(16,185,129,0.85)',
                    'rgba(14,165,233,0.85)', 'rgba(245,158,11,0.85)',
                    'rgba(239,68,68,0.85)', 'rgba(124,58,237,0.85)'
                ],
                borderRadius: 4,
                borderWidth: 0
            }]
        },
        options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                x: { beginAtZero: true, max: 20, grid: { color: gridColor } },
                y: { grid: { display: false } }
            },
            plugins: { legend: { display: false } }
        }
    });

    /* ── Graphique Finances (line chart) ── */
    new Chart(document.getElementById('financeChart').getContext('2d'), {
        type: 'line',
        data: {
            labels: ['Sep', 'Oct', 'Nov', 'Déc', 'Jan', 'Fév', 'Mar'],
            datasets: [
                {
                    label: 'Recettes',
                    data: [45000, 38000, 42000, 35000, 48000, 52000, 41000],
                    borderColor: '#10b981',
                    backgroundColor: 'rgba(16,185,129,0.1)',
                    fill: true,
                    tension: 0.4,
                    borderWidth: 2,
                    pointRadius: 3
                },
                {
                    label: 'Dépenses',
                    data: [32000, 28000, 35000, 30000, 33000, 36000, 29000],
                    borderColor: '#ef4444',
                    backgroundColor: 'rgba(239,68,68,0.1)',
                    fill: true,
                    tension: 0.4,
                    borderWidth: 2,
                    pointRadius: 3
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                y: {
                    beginAtZero: true,
                    grid: { color: gridColor },
                    ticks: {
                        callback: function(v) { return (v/1000) + 'k €'; }
                    }
                },
                x: { grid: { display: false } }
            },
            plugins: {
                legend: { position: 'bottom', labels: { usePointStyle: true } }
            }
        }
    });

    /* ── Graphique Répartition Utilisateurs (doughnut existant) ── */
    new Chart(document.getElementById('pieChart').getContext('2d'), {
        type: 'doughnut',
        data: {
            labels: ['Enseignants', 'Personnel', 'Parents', 'Admins'],
            datasets: [{
                data: [
                    {{ user_types.enseignants }},
                    {{ user_types.personnel }},
                    {{ user_types.parents }},
                    {{ user_types.admins }}
                ],
                backgroundColor: ['#10b981', '#0ea5e9', '#f59e0b', '#ef4444'],
                borderWidth: 0
            }]
        },
        options: {
            maintainAspectRatio: false,
            cutout: '60%',
            plugins: {
                legend: { position: 'bottom', labels: { padding: 15, usePointStyle: true } },
                title: {
                    display: true,
                    text: '{% if current_school %}{{ current_school.name }}{% else %}Tous les établissements{% endif %}'
                }
            }
        }
    });

    /* ── Graphique Utilisateurs par type (barres) ── */
    new Chart(document.getElementById('barChart').getContext('2d'), {
        type: 'bar',
        data: {
            labels: ['Enseignants', 'Personnel', 'Parents', 'Admins'],
            datasets: [{
                label: "Nombre d'utilisateurs",
                data: [
                    {{ user_types.enseignants }},
                    {{ user_types.personnel }},
                    {{ user_types.parents }},
                    {{ user_types.admins }}
                ],
                backgroundColor: ['#10b981', '#0ea5e9', '#f59e0b', '#ef4444'],
                borderRadius: 4,
                borderWidth: 0
            }]
        },
        options: {
            maintainAspectRatio: false,
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: gridColor } },
                x: { grid: { display: false } }
            },
            plugins: {
                legend: { display: false },
                title: {
                    display: true,
                    text: '{% if current_school %}{{ current_school.name }}{% else %}Tous les établissements{% endif %}'
                }
            }
        }
    });

{% if current_school %}
    /* ── Élèves par statut / genre (barres cliquables vers la liste filtrée) ── */
    var studentStatusUrls = [
        {{ path('admin_student_index', {status: 'affecte'})|json_encode|raw }},
        {{ path('admin_student_index', {status: 'non_affecte'})|json_encode|raw }}
    ];
    var studentGenderUrls = [
        {{ path('admin_student_index', {gender: 'M'})|json_encode|raw }},
        {{ path('admin_student_index', {gender: 'F'})|json_encode|raw }}
    ];

    function buildStudentBarOptions(urls) {
        return {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                y: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: gridColor } },
                x: { grid: { display: false } }
            },
            plugins: {
                legend: { display: false },
                tooltip: { callbacks: { footer: function () { return 'Cliquer pour voir la liste'; } } }
            },
            onClick: function (evt, elements) {
                if (elements.length) { window.location.href = urls[elements[0].index]; }
            },
            onHover: function (evt, elements) {
                evt.native.target.style.cursor = elements.length ? 'pointer' : 'default';
            }
        };
    }

    new Chart(document.getElementById('studentStatusChart').getContext('2d'), {
        type: 'bar',
        data: {
            labels: ['Affectés', 'Non affectés'],
            datasets: [{
                label: "Nombre d'élèves",
                data: [{{ students_status.affecte }}, {{ students_status.non_affecte }}],
                backgroundColor: ['#10b981', '#f59e0b'],
                borderRadius: 6, borderWidth: 0, maxBarThickness: 70
            }]
        },
        options: buildStudentBarOptions(studentStatusUrls)
    });

    new Chart(document.getElementById('studentGenderChart').getContext('2d'), {
        type: 'bar',
        data: {
            labels: ['Garçons', 'Filles'],
            datasets: [{
                label: "Nombre d'élèves",
                data: [{{ students_gender.M }}, {{ students_gender.F }}],
                backgroundColor: ['#0ea5e9', '#ec4899'],
                borderRadius: 6, borderWidth: 0, maxBarThickness: 70
            }]
        },
        options: buildStudentBarOptions(studentGenderUrls)
    });
{% endif %}
})();
</script>
{% endblock %}
