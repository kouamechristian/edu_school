{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Inscrire — {{ level.name }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Inscrire dans : ' ~ level.name,
        subtitle: current_school_year ? 'Année scolaire ' ~ current_school_year.name : 'Inscription en masse',
        icon: 'fa-users',
        color: 'success',
        breadcrumb: [ { label: 'Inscriptions', path: path('admin_registration_index') }, { label: level.name } ]
    } %}{% endembed %}

    {% include '_flash.html.twig' %}

    {# ── Classes du niveau et places disponibles ── #}
    <div class="card mb-3">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-chalkboard me-2"></i>Classes du niveau · {{ unlimited ? 'places illimitées' : total_seats ~ ' place(s) disponible(s)' }}</h6></div>
        <div class="card-body d-flex flex-wrap gap-2">
            {% if classes is empty %}
                <span class="text-danger"><i class="fas fa-exclamation-triangle me-1"></i> Aucune classe pour ce niveau : créez-en une avant d'inscrire.</span>
            {% else %}
                {% for c in classes %}
                    {% set full = c.remaining is not null and c.remaining <= 0 %}
                    <span class="badge badge-soft {{ full ? 'danger' : 'success' }} p-2">
                        <i class="fas fa-chalkboard me-1"></i>{{ c.classroom.name }} :
                        {{ c.count }}{% if c.capacity is not null %}/{{ c.capacity }} ({{ c.remaining }} libre{{ c.remaining > 1 ? 's' : '' }}){% else %} (illimité){% endif %}
                        {% if full %} · complète{% endif %}
                    </span>
                {% endfor %}
            {% endif %}
        </div>
    </div>

    {# ── Élèves en attente d'inscription (préinscriptions validées du niveau) ── #}
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold text-primary"><i class="fas fa-user-clock me-2"></i>Élèves à inscrire <span class="badge badge-soft ms-1">{{ pending|length }}</span></h6>
            <span class="text-muted small">Affectation automatique avec répartition équilibrée entre les classes.</span>
        </div>
        <div class="card-body">
            {% if pending is empty %}
                {{ empty_state('fa-user-check', 'Aucun élève en attente', 'Toutes les préinscriptions validées de ce niveau sont déjà inscrites.') }}
            {% else %}
                <form method="post" action="{{ path('admin_registration_level', {id: level.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('level_enroll' ~ level.id) }}">

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="checkAll">
                            <label class="form-check-label" for="checkAll">Tout sélectionner</label>
                        </div>
                        <button type="submit" class="btn btn-success" {{ classes is empty or (not unlimited and total_seats <= 0) ? 'disabled' : '' }}>
                            <i class="fas fa-wand-magic-sparkles me-1"></i> Inscrire les élèves sélectionnés
                        </button>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th width="40"></th>
                                    <th>Mle national</th>
                                    <th>Élève</th>
                                    <th>Date de naissance</th>
                                    <th class="text-center">Type</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for p in pending %}
                                <tr>
                                    <td><input class="form-check-input row-check" type="checkbox" name="pre_registrations[]" value="{{ p.id }}" checked></td>
                                    <td>{{ p.matriculeNational ?: '—' }}</td>
                                    <td class="fw-semibold">{{ p.lastName }} {{ p.firstName }}</td>
                                    <td>{{ p.dateOfBirth ? p.dateOfBirth|date('d/m/Y') : '—' }}</td>
                                    <td class="text-center">
                                        <span class="badge badge-soft {{ p.isReturning ? 'info' : 'secondary' }}">{{ p.isReturning ? 'Ancien' : 'Nouveau' }}</span>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </form>
            {% endif %}
        </div>
    </div>
</div>

<script>
    document.getElementById('checkAll')?.addEventListener('change', function () {
        document.querySelectorAll('.row-check').forEach(cb => { cb.checked = this.checked; });
    });
</script>
{% endblock %}
