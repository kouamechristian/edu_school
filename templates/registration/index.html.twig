{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Gestion des inscriptions{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Inscriptions par niveau',
        subtitle: current_school_year ? 'Année scolaire ' ~ current_school_year.name : 'Inscriptions des élèves',
        icon: 'fa-id-card-clip',
        color: 'success',
        breadcrumb: [ { label: 'Élèves', path: path('admin_student_index') }, { label: 'Inscriptions' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_registration_new') }}" class="btn btn-outline-success"><i class="fas fa-user-plus me-1"></i> Inscription unitaire</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    {% if level_groups is empty %}
        {{ empty_state('fa-layer-group', 'Aucun niveau', 'Créez des niveaux et des classes pour gérer les inscriptions.') }}
    {% endif %}

    {% for g in level_groups %}
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <h6 class="m-0 fw-bold text-primary"><i class="fas fa-layer-group me-2"></i>{{ g.level.name }}</h6>
                    <span class="badge badge-soft">{{ g.registrations|length }} inscrit(s)</span>
                    {% if g.pending > 0 %}<span class="badge bg-warning text-dark">{{ g.pending }} en attente</span>{% endif %}
                    <span class="badge badge-soft {{ g.unlimited or g.seats > 0 ? 'success' : 'danger' }}">
                        {{ g.unlimited ? 'Places illimitées' : g.seats ~ ' place(s)' }}
                    </span>
                </div>
                <a href="{{ path('admin_registration_level', {id: g.level.id}) }}"
                   class="btn btn-sm btn-success {{ g.pending == 0 ? 'disabled' : '' }}">
                    <i class="fas fa-users me-1"></i> Inscrire des élèves{% if g.pending > 0 %} ({{ g.pending }}){% endif %}
                </a>
            </div>
            <div class="card-body">
                {# Occupation des classes #}
                {% if g.classes is not empty %}
                    <div class="mb-3 d-flex flex-wrap gap-2">
                        {% for c in g.classes %}
                            {% set full = c.remaining is not null and c.remaining <= 0 %}
                            <span class="badge badge-soft {{ full ? 'danger' : 'secondary' }}" title="{{ c.classroom.name }}">
                                <i class="fas fa-chalkboard me-1"></i>{{ c.classroom.name }} :
                                {{ c.count }}{% if c.capacity is not null %}/{{ c.capacity }}{% else %} (illimité){% endif %}
                                {% if full %} · complète{% endif %}
                            </span>
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="text-muted small mb-3"><i class="fas fa-exclamation-triangle me-1"></i>Aucune classe pour ce niveau.</p>
                {% endif %}

                {% if g.registrations is empty %}
                    <p class="text-muted small mb-0">Aucun élève inscrit dans ce niveau.</p>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Mle interne</th><th>Élève</th><th>Classe</th>
                                    <th class="text-end">Reste dû</th>
                                    <th class="text-center">Statut</th>
                                    <th class="text-end" width="140">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for r in g.registrations %}
                                <tr>
                                    <td><span class="fw-semibold text-primary">{{ r.student.matriculeInterne ?: '—' }}</span></td>
                                    <td class="fw-semibold">{{ r.student.lastName }} {{ r.student.firstName }}</td>
                                    <td>{{ r.classroom ? r.classroom.name : '—' }}</td>
                                    <td class="text-end">{{ r.remainingTuition|number_format(0, ',', ' ') }}</td>
                                    <td class="text-center"><span class="badge bg-{{ r.student.getStatusColor() }}">{{ r.student.getStatusLabel() }}</span></td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a href="{{ path('admin_student_show', {'id': r.student.id}) }}" class="btn btn-outline-info" title="Voir l'élève"><i class="fas fa-eye"></i></a>
                                            <a href="{{ path('admin_registration_edit', {'id': r.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                            {% if is_granted('ROLE_ADMIN') %}
                                            <form method="post" action="{{ path('admin_registration_delete', {'id': r.id}) }}" onsubmit="return confirm('Supprimer définitivement cette inscription ?');" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ r.id) }}">
                                                <button type="submit" class="btn btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                            </form>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    {% endfor %}

    {# Inscriptions sans niveau (classe non affectée) #}
    {% if unassigned is not empty %}
        <div class="card mb-3 border-warning">
            <div class="card-header"><h6 class="m-0 fw-bold text-warning"><i class="fas fa-question-circle me-2"></i>Sans niveau / classe ({{ unassigned|length }})</h6></div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead><tr><th>Mle interne</th><th>Élève</th><th class="text-center">Statut</th><th class="text-end" width="140">Actions</th></tr></thead>
                        <tbody>
                            {% for r in unassigned %}
                            <tr>
                                <td>{{ r.student.matriculeInterne ?: '—' }}</td>
                                <td class="fw-semibold">{{ r.student.lastName }} {{ r.student.firstName }}</td>
                                <td class="text-center"><span class="badge bg-{{ r.student.getStatusColor() }}">{{ r.student.getStatusLabel() }}</span></td>
                                <td class="text-end">
                                    <a href="{{ path('admin_registration_edit', {'id': r.id}) }}" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></a>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
