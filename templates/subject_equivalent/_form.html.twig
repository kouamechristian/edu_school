{{ form_start(form) }}
    {{ form_errors(form) }}
    <div class="row">
        <div class="col-md-5 mb-3">{{ form_row(form.code) }}</div>
        <div class="col-md-7 mb-3">{{ form_row(form.libelle) }}</div>
    </div>
    {% if equivalent is defined and equivalent.numeroOrdre is not null %}
        <p class="text-muted small mb-3"><i class="fas fa-hashtag me-1"></i>Numéro d'ordre : <strong>{{ equivalent.numeroOrdre }}</strong> (attribué automatiquement)</p>
    {% else %}
        <p class="text-muted small mb-3"><i class="fas fa-info-circle me-1"></i>Le numéro d'ordre sera attribué automatiquement à l'enregistrement.</p>
    {% endif %}
    <div class="d-flex justify-content-between mt-3 pt-3 border-top">
        <a href="{{ path('admin_subject_equivalent_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Enregistrer</button>
    </div>
{{ form_end(form) }}
