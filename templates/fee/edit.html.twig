{% extends 'base.html.twig' %}

{% block title %}Modifier le Frais - {{ fee.name }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Modifier le Frais',
        subtitle: fee.name,
        icon: 'fa-money-bill',
        color: 'primary',
        breadcrumb: [
            { label: 'Frais', path: path('admin_fee_index') },
            { label: fee.name, path: path('admin_fee_show', {'id': fee.id}) },
            { label: 'Modifier' }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_fee_show', {'id': fee.id}) }}" class="btn btn-info"><i class="fas fa-eye me-1"></i> Détails</a>
            <a href="{{ path('admin_fee_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    {# Onglets #}
    <ul class="nav nav-tabs mb-0" id="feeEditTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link {{ active_tab != 'schedule' ? 'active' : '' }}" id="fee-tab" data-bs-toggle="tab" data-bs-target="#fee-pane" type="button" role="tab" aria-controls="fee-pane" aria-selected="{{ active_tab != 'schedule' ? 'true' : 'false' }}">
                <i class="fas fa-edit me-1"></i> Informations du Frais
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link {{ active_tab == 'schedule' ? 'active' : '' }}" id="schedule-tab" data-bs-toggle="tab" data-bs-target="#schedule-pane" type="button" role="tab" aria-controls="schedule-pane" aria-selected="{{ active_tab == 'schedule' ? 'true' : 'false' }}">
                <i class="fas fa-calendar-alt me-1"></i> Échéancier <span class="badge bg-primary ms-1">{{ fee.schedules|length }}</span>
            </button>
        </li>
    </ul>

    <div class="tab-content" id="feeEditTabContent">
        {# Onglet 1 #}
        <div class="tab-pane fade {{ active_tab != 'schedule' ? 'show active' : '' }}" id="fee-pane" role="tabpanel" aria-labelledby="fee-tab">
            <div class="card" style="border-top-left-radius:0;">
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="mb-3">
                            {{ form_label(form.name) }}
                            {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.name) }}
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.level) }}
                            {{ form_widget(form.level, {'attr': {'class': 'form-select'}}) }}
                            {{ form_errors(form.level) }}
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.amount) }}
                                {{ form_widget(form.amount, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.amount) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.category) }}
                                {{ form_widget(form.category, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.category) }}
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.type) }}
                                {{ form_widget(form.type, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.type) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.frequency) }}
                                {{ form_widget(form.frequency, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.frequency) }}
                            </div>
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.description) }}
                            {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 3}}) }}
                            {{ form_errors(form.description) }}
                        </div>
                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a href="{{ path('admin_fee_index') }}" class="btn btn-light"><i class="fas fa-times me-1"></i> Annuler</a>
                            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Enregistrer les modifications</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        {# Onglet 2 : Échéancier #}
        <div class="tab-pane fade {{ active_tab == 'schedule' ? 'show active' : '' }}" id="schedule-pane" role="tabpanel" aria-labelledby="schedule-tab">
            <div class="card" style="border-top-left-radius:0;">
                <div class="card-body">
                    {# Résumé #}
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="card-accent border rounded p-3 text-center">
                                <div class="text-muted small">Montant total du frais</div>
                                <div class="h4 mb-0 text-primary">{{ fee.amount|number_format(0, ',', ' ') }} F</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="border rounded p-3 text-center">
                                <div class="text-muted small">Total des échéances</div>
                                <div class="h4 mb-0 {% if fee.schedulesTotalAmount == fee.amount|number_format(2, '.', '') %}text-success{% else %}text-warning{% endif %}">{{ fee.schedulesTotalAmount|number_format(0, ',', ' ') }} F</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="border rounded p-3 text-center">
                                <div class="text-muted small">Différence</div>
                                {% set diff = fee.amount - fee.schedulesTotalAmount %}
                                <div class="h4 mb-0 {{ diff == 0 ? 'text-success' : 'text-danger' }}">{{ diff|number_format(0, ',', ' ') }} F</div>
                            </div>
                        </div>
                    </div>

                    {% if fee.schedulesTotalAmount != fee.amount and fee.schedules|length > 0 %}
                        <div class="alert alert-warning"><i class="fas fa-exclamation-triangle me-1"></i>Le total des échéances ({{ fee.schedulesTotalAmount|number_format(0, ',', ' ') }} F) ne correspond pas au montant du frais ({{ fee.amount|number_format(0, ',', ' ') }} F).</div>
                    {% endif %}

                    {% if fee.schedules|length > 0 %}
                        <div class="table-responsive mb-4">
                            <table class="table table-hover align-middle mb-0">
                                <thead><tr><th width="80" class="text-center">N° Ordre</th><th>Montant</th><th>Date d'échéance</th><th>Statut</th><th width="80" class="text-center">Actions</th></tr></thead>
                                <tbody>
                                    {% for schedule in fee.schedules %}
                                        <tr>
                                            <td class="text-center"><span class="badge badge-soft secondary">{{ schedule.orderNumber }}</span></td>
                                            <td class="fw-bold">{{ schedule.amount|number_format(0, ',', ' ') }} F</td>
                                            <td><i class="fas fa-calendar me-1 text-muted"></i>{{ schedule.dueDate|date('d/m/Y') }}</td>
                                            <td>
                                                {% if schedule.isOverdue %}<span class="badge badge-soft danger"><i class="fas fa-exclamation-circle me-1"></i>En retard</span>
                                                {% elseif schedule.isDueSoon %}<span class="badge badge-soft warning"><i class="fas fa-clock me-1"></i>Bientôt</span>
                                                {% else %}<span class="badge badge-soft success"><i class="fas fa-check me-1"></i>À venir</span>{% endif %}
                                            </td>
                                            <td class="text-center">
                                                <form method="post" action="{{ path('admin_fee_schedule_delete', {'id': fee.id, 'scheduleId': schedule.id}) }}" onsubmit="return confirm('Supprimer cette échéance ?');" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('schedule_delete' ~ schedule.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                                </form>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                                <tfoot>
                                    <tr><th class="text-center">Total</th><th colspan="4"><strong>{{ fee.schedulesTotalAmount|number_format(0, ',', ' ') }} F</strong> sur {{ fee.amount|number_format(0, ',', ' ') }} F</th></tr>
                                </tfoot>
                            </table>
                        </div>
                    {% else %}
                        <div class="alert alert-info mb-4"><i class="fas fa-info-circle me-2"></i>Aucune échéance définie pour ce frais. Ajoutez des échéances ci-dessous.</div>
                    {% endif %}

                    {# Ajout d'échéance #}
                    <div class="card" style="background:var(--es-muted-bg);">
                        <div class="card-header"><h6 class="mb-0 fw-bold"><i class="fas fa-plus-circle me-1"></i> Ajouter une échéance</h6></div>
                        <div class="card-body">
                            <form method="post" action="{{ path('admin_fee_schedule_add', {'id': fee.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('schedule_add' ~ fee.id) }}">
                                <div class="row g-3 align-items-end">
                                    <div class="col-md-3">
                                        <label for="order_number" class="form-label">N° d'ordre</label>
                                        <input type="number" class="form-control" id="order_number" name="order_number" min="1" value="{{ fee.schedules|length + 1 }}" required>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="schedule_amount" class="form-label">Montant (FCFA)</label>
                                        <input type="number" class="form-control" id="schedule_amount" name="amount" min="1" step="1" required placeholder="Ex : 50000">
                                    </div>
                                    <div class="col-md-3">
                                        <label for="due_date" class="form-label">Date d'échéance</label>
                                        <input type="date" class="form-control" id="due_date" name="due_date" required>
                                    </div>
                                    <div class="col-md-3">
                                        <button type="submit" class="btn btn-primary w-100"><i class="fas fa-plus me-1"></i> Ajouter</button>
                                    </div>
                                </div>
                                {% set remaining = fee.amount - fee.schedulesTotalAmount %}
                                {% if remaining > 0 and fee.schedules|length > 0 %}
                                    <div class="mt-2"><small class="text-muted">Montant restant à répartir : <strong>{{ remaining|number_format(0, ',', ' ') }} F</strong></small></div>
                                {% endif %}
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
