{% extends 'base.html.twig' %}

{% block title %}Affecter le frais - {{ fee.name }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-user-plus"></i> Affecter « {{ fee.name }} »
        </h1>
        <a href="{{ path('admin_fee_show', {'id': fee.id}) }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Retour
        </a>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card border-left-primary shadow h-100">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Montant du frais</div>
                    <div class="h5 mb-0 font-weight-bold">{{ fee.finalAmount|number_format(0, ',', ' ') }} FCFA</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-left-info shadow h-100">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Niveau</div>
                    <div class="h5 mb-0 font-weight-bold">{{ fee.level ? fee.level.name : 'Tous les niveaux' }}</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-left-success shadow h-100">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Déjà affecté à</div>
                    <div class="h5 mb-0 font-weight-bold">{{ assigned_student_ids|length }} élève(s)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">Sélectionner les élèves à affecter</h6>
            <div>
                <button type="button" class="btn btn-sm btn-outline-primary" id="selectAll">
                    <i class="fas fa-check-double"></i> Tout sélectionner
                </button>
            </div>
        </div>
        <div class="card-body">
            {% if students|length == 0 %}
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> Aucun élève trouvé pour ce niveau/établissement.
                </div>
            {% else %}
                <form method="post" action="{{ path('admin_fee_assign', {'id': fee.id}) }}">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th width="50"><input type="checkbox" id="checkAll"></th>
                                    <th>N° Élève</th>
                                    <th>Nom complet</th>
                                    <th>Niveau</th>
                                    <th>Statut</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for student in students %}
                                    <tr class="{{ student.id in assigned_student_ids ? 'table-light' : '' }}">
                                        <td>
                                            {% if student.id in assigned_student_ids %}
                                                <span class="badge bg-success"><i class="fas fa-check"></i></span>
                                            {% else %}
                                                <input type="checkbox" name="student_ids[]" value="{{ student.id }}" class="student-check">
                                            {% endif %}
                                        </td>
                                        <td>{{ student.studentNumber }}</td>
                                        <td><strong>{{ student.fullName }}</strong></td>
                                        <td>{{ student.level ? student.level.name : '-' }}</td>
                                        <td>
                                            <span class="badge bg-{{ student.statusColor }}">{{ student.statusLabel }}</span>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-end mt-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Affecter les élèves sélectionnés
                        </button>
                    </div>
                </form>
            {% endif %}
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const checkAll = document.getElementById('checkAll');
    const selectAll = document.getElementById('selectAll');
    const checks = document.querySelectorAll('.student-check');

    if (checkAll) {
        checkAll.addEventListener('change', function() {
            checks.forEach(c => c.checked = this.checked);
        });
    }

    if (selectAll) {
        selectAll.addEventListener('click', function() {
            checks.forEach(c => c.checked = true);
            if (checkAll) checkAll.checked = true;
        });
    }
});
</script>
{% endblock %}
