{% extends 'base.html.twig' %}

{% block title %}Affecter le frais - {{ fee.name }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Affecter « ' ~ fee.name ~ ' »',
        icon: 'fa-user-plus',
        color: 'primary',
        breadcrumb: [
            { label: 'Frais', path: path('admin_fee_index') },
            { label: fee.name, path: path('admin_fee_show', {'id': fee.id}) },
            { label: 'Affecter' }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_fee_show', {'id': fee.id}) }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    {# ── Résumé ── #}
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-card primary h-100"><div class="card-body d-flex align-items-center justify-content-between">
                <div><div class="stat-label mb-1">Montant du frais</div><div class="stat-value" style="font-size:1.2rem;">{{ fee.finalAmount|number_format(0, ',', ' ') }} <small class="text-muted">FCFA</small></div></div>
                <div class="stat-icon"><i class="fas fa-coins"></i></div>
            </div></div>
        </div>
        <div class="col-md-4">
            <div class="stat-card info h-100"><div class="card-body d-flex align-items-center justify-content-between">
                <div><div class="stat-label mb-1">Niveau</div><div class="stat-value" style="font-size:1.2rem;">{{ fee.level ? fee.level.name : 'Tous les niveaux' }}</div></div>
                <div class="stat-icon"><i class="fas fa-layer-group"></i></div>
            </div></div>
        </div>
        <div class="col-md-4">
            <div class="stat-card success h-100"><div class="card-body d-flex align-items-center justify-content-between">
                <div><div class="stat-label mb-1">Déjà affecté à</div><div class="stat-value">{{ assigned_student_ids|length }} <small class="text-muted" style="font-size:0.9rem;">élève(s)</small></div></div>
                <div class="stat-icon"><i class="fas fa-user-check"></i></div>
            </div></div>
        </div>
    </div>

    <div class="card table-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold text-primary"><i class="fas fa-list-check me-2"></i>Sélectionner les élèves à affecter</h6>
            <button type="button" class="btn btn-sm btn-outline-primary" id="selectAll"><i class="fas fa-check-double me-1"></i> Tout sélectionner</button>
        </div>
        <div class="card-body">
            {% if students|length == 0 %}
                <div class="alert alert-info mb-0"><i class="fas fa-info-circle me-2"></i>Aucun élève trouvé pour ce niveau/établissement.</div>
            {% else %}
                <form method="post" action="{{ path('admin_fee_assign', {'id': fee.id}) }}">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead><tr><th width="50"><input type="checkbox" id="checkAll" class="form-check-input"></th><th>N° Élève</th><th>Nom complet</th><th>Niveau</th><th>Statut</th></tr></thead>
                            <tbody>
                                {% for student in students %}
                                    <tr class="{{ student.id in assigned_student_ids ? 'table-light' : '' }}">
                                        <td>
                                            {% if student.id in assigned_student_ids %}
                                                <span class="badge badge-soft success"><i class="fas fa-check"></i></span>
                                            {% else %}
                                                <input type="checkbox" name="student_ids[]" value="{{ student.id }}" class="student-check form-check-input">
                                            {% endif %}
                                        </td>
                                        <td class="text-muted">{{ student.matriculeInterne }}</td>
                                        <td class="fw-semibold">{{ student.fullName }}</td>
                                        <td>{{ student.level ? student.level.name : '—' }}</td>
                                        <td><span class="badge bg-{{ student.statusColor }}">{{ student.statusLabel }}</span></td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    <div class="d-flex justify-content-end mt-3 pt-3 border-top">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Affecter les élèves sélectionnés</button>
                    </div>
                </form>
            {% endif %}
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const checkAll = document.getElementById('checkAll');
    const selectAll = document.getElementById('selectAll');
    const checks = document.querySelectorAll('.student-check');
    if (checkAll) checkAll.addEventListener('change', function() { checks.forEach(c => c.checked = this.checked); });
    if (selectAll) selectAll.addEventListener('click', function() { checks.forEach(c => c.checked = true); if (checkAll) checkAll.checked = true; });
});
</script>
{% endblock %}
