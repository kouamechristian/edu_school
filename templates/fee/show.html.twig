{% extends 'base.html.twig' %}

{% block title %}Détails du Frais{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: fee.name,
        subtitle: 'Frais — ' ~ fee.code,
        icon: 'fa-money-bill',
        color: 'primary',
        breadcrumb: [
            { label: 'Frais', path: path('admin_fee_index') },
            { label: fee.name }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_fee_edit', {'id': fee.id}) }}" class="btn btn-warning"><i class="fas fa-edit me-1"></i> Modifier</a>
            <a href="{{ path('admin_fee_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-info-circle me-2"></i>Informations du frais</h6></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Code</div><div class="info-value"><span class="badge badge-soft secondary">{{ fee.code }}</span></div></div>
                            <div class="info-row"><div class="info-label">Niveau</div><div class="info-value">{{ fee.level ? fee.level.name : 'Tous les niveaux' }}</div></div>
                            <div class="info-row"><div class="info-label">Catégorie</div><div class="info-value"><span class="badge bg-{{ fee.categoryColor }}">{{ fee.categoryLabel }}</span></div></div>
                            <div class="info-row"><div class="info-label">Montant</div><div class="info-value fw-bold text-primary">{{ fee.amount|number_format(0, ',', ' ') }} FCFA</div></div>
                        </div></div>
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Établissement</div><div class="info-value">{{ fee.school.name }}</div></div>
                            <div class="info-row"><div class="info-label">Type</div><div class="info-value"><span class="badge bg-{{ fee.type == 'pour_tous' ? 'primary' : (fee.type == 'affecte' ? 'success' : 'secondary') }}">{{ fee.typeLabel }}</span></div></div>
                            <div class="info-row"><div class="info-label">Fréquence</div><div class="info-value"><span class="badge badge-soft secondary">{{ fee.frequencyLabel }}</span></div></div>
                            <div class="info-row"><div class="info-label">Statut</div><div class="info-value"><span class="badge badge-soft {{ fee.isActive ? 'success' : 'danger' }}">{{ fee.isActive ? 'Actif' : 'Inactif' }}</span></div></div>
                        </div></div>
                    </div>
                    {% if fee.description %}
                        <div class="info-list mt-2"><div class="info-row"><div class="info-label">Description</div><div class="info-value">{{ fee.description }}</div></div></div>
                    {% endif %}
                    <div class="info-list">
                        <div class="info-row"><div class="info-label">Créé le</div><div class="info-value">{{ fee.createdAt|date('d/m/Y H:i') }}</div></div>
                        <div class="info-row"><div class="info-label">Modifié le</div><div class="info-value">{{ fee.updatedAt|date('d/m/Y H:i') }}</div></div>
                    </div>
                </div>
            </div>

            {# Échéancier #}
            {% if fee.schedules|length > 0 %}
                <div class="card table-card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h6 class="m-0 fw-bold text-primary"><i class="fas fa-calendar-alt me-2"></i>Échéancier ({{ fee.schedules|length }})</h6>
                        <a href="{{ path('admin_fee_edit', {'id': fee.id, 'tab': 'schedule'}) }}" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit me-1"></i> Gérer</a>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead><tr><th class="text-center" width="80">N°</th><th>Montant</th><th>Date d'échéance</th><th>Statut</th></tr></thead>
                                <tbody>
                                    {% for schedule in fee.schedules %}
                                        <tr>
                                            <td class="text-center"><span class="badge badge-soft secondary">{{ schedule.orderNumber }}</span></td>
                                            <td class="fw-bold">{{ schedule.amount|number_format(0, ',', ' ') }} F</td>
                                            <td>{{ schedule.dueDate|date('d/m/Y') }}</td>
                                            <td>
                                                {% if schedule.isOverdue %}<span class="badge badge-soft danger">En retard</span>
                                                {% elseif schedule.isDueSoon %}<span class="badge badge-soft warning">Bientôt</span>
                                                {% else %}<span class="badge badge-soft success">À venir</span>{% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                                <tfoot>
                                    <tr><th></th><th colspan="3">Total : <strong>{{ fee.schedulesTotalAmount|number_format(0, ',', ' ') }} F</strong> / {{ fee.amount|number_format(0, ',', ' ') }} F</th></tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>

        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-bolt me-2"></i>Actions</h6></div>
                <div class="card-body d-grid gap-2">
                    <a href="{{ path('admin_fee_edit', {'id': fee.id}) }}" class="btn btn-warning"><i class="fas fa-edit me-1"></i> Modifier le frais</a>
                    <a href="{{ path('admin_fee_edit', {'id': fee.id, 'tab': 'schedule'}) }}" class="btn btn-info"><i class="fas fa-calendar-alt me-1"></i> Gérer l'échéancier</a>
                    <form method="post" action="{{ path('admin_fee_toggle', {'id': fee.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ fee.id) }}">
                        <button type="submit" class="btn btn-{{ fee.isActive ? 'warning' : 'success' }} w-100"><i class="fas fa-{{ fee.isActive ? 'pause' : 'play' }} me-1"></i> {{ fee.isActive ? 'Désactiver' : 'Activer' }}</button>
                    </form>
                    <form method="post" action="{{ path('admin_fee_delete', {'id': fee.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce frais ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ fee.id) }}">
                        <button type="submit" class="btn btn-danger w-100"><i class="fas fa-trash me-1"></i> Supprimer</button>
                    </form>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-chart-pie me-2"></i>Statistiques</h6></div>
                <div class="card-body">
                    <div class="row text-center g-2">
                        <div class="col-6"><h4 class="text-info mb-0">{{ student_fees|length }}</h4><small class="text-muted">Élèves</small></div>
                        <div class="col-6"><h4 class="text-primary mb-0">{{ fee.payments|length }}</h4><small class="text-muted">Paiements</small></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Élèves affectés #}
    <div class="card table-card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold text-primary"><i class="fas fa-users me-2"></i>Élèves affectés ({{ student_fees|length }})</h6>
            {% if fee.type == 'affecte' %}
                <a href="{{ path('admin_fee_assign', {'id': fee.id}) }}" class="btn btn-sm btn-primary"><i class="fas fa-user-plus me-1"></i> Affecter des élèves</a>
            {% endif %}
        </div>
        <div class="card-body">
            {% if student_fees|length == 0 %}
                <div class="alert alert-info mb-0">
                    <i class="fas fa-info-circle me-2"></i>
                    {% if fee.type == 'non_affecte' %}Ce frais est de type « Non affecté » : il ne sera pas attribué automatiquement.
                    {% elseif fee.type == 'affecte' %}Aucun élève n'est encore affecté à ce frais. <a href="{{ path('admin_fee_assign', {'id': fee.id}) }}">Affecter maintenant</a>.
                    {% else %}Aucun élève n'est encore inscrit dans ce niveau.{% endif %}
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead><tr><th>Élève</th><th class="text-end">Montant</th><th class="text-end">Payé</th><th class="text-end">Reste</th><th>Statut</th><th width="80"></th></tr></thead>
                        <tbody>
                            {% for sf in student_fees %}
                                <tr>
                                    <td>
                                        <a href="{{ path('admin_student_show', {'id': sf.student.id}) }}" class="fw-semibold">{{ sf.student.fullName }}</a>
                                        <br><small class="text-muted">{{ sf.student.matriculeInterne }}</small>
                                    </td>
                                    <td class="text-end">{{ sf.amount|number_format(0, ',', ' ') }} F</td>
                                    <td class="text-end text-success">{{ sf.paidAmount|number_format(0, ',', ' ') }} F</td>
                                    <td class="text-end"><strong class="{{ sf.remainingAmount > 0 ? 'text-danger' : 'text-success' }}">{{ sf.remainingAmount|number_format(0, ',', ' ') }} F</strong></td>
                                    <td style="min-width:120px;">
                                        <span class="badge bg-{{ sf.statusColor }}">{{ sf.statusLabel }}</span>
                                        <div class="progress mt-1" style="height: 4px;"><div class="progress-bar bg-{{ sf.statusColor }}" style="width: {{ sf.paymentPercentage }}%"></div></div>
                                    </td>
                                    <td>
                                        {% if sf.status == 'non_paye' %}
                                            <form method="post" action="{{ path('admin_fee_unassign', {'id': fee.id, 'studentFeeId': sf.id}) }}" onsubmit="return confirm('Retirer ce frais pour cet élève ?');" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('unassign' ~ sf.id) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Retirer"><i class="fas fa-times"></i></button>
                                            </form>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
