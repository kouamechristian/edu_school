{% extends 'base.html.twig' %}

{% block title %}Nouveau Frais{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Nouveau Frais',
        icon: 'fa-money-bill',
        color: 'primary',
        breadcrumb: [
            { label: 'Frais', path: path('admin_fee_index') },
            { label: 'Nouveau' }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_fee_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="row justify-content-center">
        <div class="col-xl-9">
            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-money-bill me-2"></i>Créer un nouveau frais</h6></div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': true}}) }}
                        <div class="mb-3">
                            {{ form_label(form.name, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.name) }}
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.level, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.level, {'attr': {'class': 'form-select'}}) }}
                            {{ form_errors(form.level) }}
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.amount, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.amount, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.amount) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.category, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.category, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.category) }}
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.type, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.type, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.type) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.frequency, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.frequency, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.frequency) }}
                            </div>
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.description) }}
                        </div>

                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-1"></i>
                            Après la création du frais, vous pourrez configurer l'échéancier de paiement dans l'onglet « Échéancier » de la page de modification.
                        </div>

                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a href="{{ path('admin_fee_index') }}" class="btn btn-light"><i class="fas fa-times me-1"></i> Annuler</a>
                            <button type="submit" class="btn btn-primary"><i class="fas fa-check me-1"></i> Créer le Frais</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
