{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Gestion des Frais{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Gestion des Frais',
        subtitle: current_school ? current_school.name : 'Frais de scolarité et articles',
        icon: 'fa-money-bill',
        color: 'primary',
        breadcrumb: [ { label: 'Frais' } ]
    } %}
        {% block actions %}
            {% if current_school %}<a href="{{ path('admin_fee_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouveau Frais</a>{% endif %}
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    {% if current_school %}
        {# ── Statistiques ── #}
        <div class="row g-3 mb-4">
            <div class="col-6 col-xl-3">
                <div class="stat-card primary h-100"><div class="card-body d-flex align-items-center justify-content-between">
                    <div><div class="stat-label mb-1">Total Frais</div><div class="stat-value">{{ stats.total }}</div></div>
                    <div class="stat-icon"><i class="fas fa-money-bill"></i></div>
                </div></div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="stat-card success h-100"><div class="card-body d-flex align-items-center justify-content-between">
                    <div><div class="stat-label mb-1">Montant Total</div><div class="stat-value" style="font-size:1.1rem;">{{ stats.total_amount|number_format(0, ',', ' ') }} <small class="text-muted">FCFA</small></div></div>
                    <div class="stat-icon"><i class="fas fa-coins"></i></div>
                </div></div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="stat-card warning h-100"><div class="card-body d-flex align-items-center justify-content-between">
                    <div><div class="stat-label mb-1">Frais Actifs</div><div class="stat-value">{{ fees|filter(fee => fee.isActive)|length }}</div></div>
                    <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
                </div></div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="stat-card info h-100"><div class="card-body d-flex align-items-center justify-content-between">
                    <div><div class="stat-label mb-1">Avec Échéancier</div><div class="stat-value">{{ fees|filter(fee => fee.schedules|length > 0)|length }}</div></div>
                    <div class="stat-icon"><i class="fas fa-calendar-alt"></i></div>
                </div></div>
            </div>
        </div>

        {# ── Filtres ── #}
        <div class="card filter-card mb-4">
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label">Recherche</label>
                        <input type="text" class="form-control" id="searchInput" placeholder="Rechercher..." value="{{ search_term }}">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Type</label>
                        <select class="form-select" id="typeFilter">
                            <option value="">Tous les types</option>
                            <option value="pour_tous" {{ current_type == 'pour_tous' ? 'selected' : '' }}>Pour tous</option>
                            <option value="affecte" {{ current_type == 'affecte' ? 'selected' : '' }}>Affecté</option>
                            <option value="non_affecte" {{ current_type == 'non_affecte' ? 'selected' : '' }}>Non affecté</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Catégorie</label>
                        <select class="form-select" id="categoryFilter">
                            <option value="">Toutes catégories</option>
                            <option value="scolarite" {{ current_category == 'scolarite' ? 'selected' : '' }}>Scolarité</option>
                            <option value="article" {{ current_category == 'article' ? 'selected' : '' }}>Article</option>
                            <option value="autre_frais" {{ current_category == 'autre_frais' ? 'selected' : '' }}>Autre frais</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Fréquence</label>
                        <select class="form-select" id="frequencyFilter">
                            <option value="">Toutes fréquences</option>
                            <option value="unique" {{ current_frequency == 'unique' ? 'selected' : '' }}>Unique</option>
                            <option value="mensuel" {{ current_frequency == 'mensuel' ? 'selected' : '' }}>Mensuel</option>
                            <option value="trimestriel" {{ current_frequency == 'trimestriel' ? 'selected' : '' }}>Trimestriel</option>
                            <option value="annuel" {{ current_frequency == 'annuel' ? 'selected' : '' }}>Annuel</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-primary w-100" onclick="applyFilters()"><i class="fas fa-filter me-1"></i> Filtrer</button>
                    </div>
                </div>
            </div>
        </div>

        {# ── Tableau ── #}
        <div class="card table-card">
            <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des frais</h6></div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Code</th><th>Nom</th><th>Catégorie</th><th class="text-end">Montant</th>
                                <th class="text-center">Échéances</th><th>Statut</th><th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for fee in fees %}
                                <tr>
                                    <td><span class="badge badge-soft secondary">{{ fee.code }}</span></td>
                                    <td>
                                        <strong>{{ fee.name }}</strong>
                                        {% if fee.description %}<br><small class="text-muted">{{ fee.description|slice(0, 50) }}{% if fee.description|length > 50 %}...{% endif %}</small>{% endif %}
                                    </td>
                                    <td><span class="badge bg-{{ fee.categoryColor }}">{{ fee.categoryLabel }}</span></td>
                                    <td class="text-end fw-bold">{{ fee.amount|number_format(0, ',', ' ') }} FCFA</td>
                                    <td class="text-center">{% if fee.schedules|length > 0 %}<span class="badge badge-soft info">{{ fee.schedules|length }}</span>{% else %}<span class="text-muted">—</span>{% endif %}</td>
                                    <td><span class="badge badge-soft {{ fee.isActive ? 'success' : 'danger' }}">{{ fee.isActive ? 'Actif' : 'Inactif' }}</span></td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a href="{{ path('admin_fee_show', {'id': fee.id}) }}" class="btn btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a>
                                            <a href="{{ path('admin_fee_edit', {'id': fee.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                            <form method="post" action="{{ path('admin_fee_toggle', {'id': fee.id}) }}" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ fee.id) }}">
                                                <button type="submit" class="btn btn-outline-{{ fee.isActive ? 'warning' : 'success' }}" title="{{ fee.isActive ? 'Désactiver' : 'Activer' }}"><i class="fas fa-{{ fee.isActive ? 'pause' : 'play' }}"></i></button>
                                            </form>
                                            {% if is_granted('ROLE_ADMIN') %}
                                            <form method="post" action="{{ path('admin_fee_delete', {'id': fee.id}) }}" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce frais ?')">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ fee.id) }}">
                                                <button type="submit" class="btn btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                            </form>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr><td colspan="7">{{ empty_state('fa-money-bill', 'Aucun frais', 'Aucun frais ne correspond à vos critères.') }}</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% include '_pagination.html.twig' with { pagination: fees } %}
            </div>
        </div>
    {% else %}
        <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-school"></i></div>
            <h6>Sélectionnez un établissement</h6>
            <p>Veuillez sélectionner un établissement pour voir les frais.</p>
            <a href="{{ path('admin_school_index') }}" class="btn btn-primary"><i class="fas fa-school me-1"></i> Gérer les Établissements</a>
        </div>
    {% endif %}
</div>

<script>
function applyFilters() {
    const search = document.getElementById('searchInput').value;
    const type = document.getElementById('typeFilter').value;
    const category = document.getElementById('categoryFilter').value;
    const frequency = document.getElementById('frequencyFilter').value;
    let url = new URL(window.location.href);
    url.searchParams.set('search', search);
    url.searchParams.set('type', type);
    url.searchParams.set('category', category);
    url.searchParams.set('frequency', frequency);
    window.location.href = url.toString();
}
document.getElementById('searchInput')?.addEventListener('keypress', function(e) {
    if (e.key === 'Enter') applyFilters();
});
</script>
{% endblock %}
