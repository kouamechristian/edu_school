{% extends 'base.html.twig' %}

{% block title %}Détails de la Transaction{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Transaction ' ~ (financial_transaction.transactionNumber ?: ('#' ~ financial_transaction.id)),
        subtitle: financial_transaction.typeLabel ~ ' · ' ~ financial_transaction.categoryLabel,
        icon: 'fa-exchange-alt',
        color: 'primary',
        breadcrumb: [
            { label: 'Transactions', path: path('admin_financial_transaction_index') },
            { label: financial_transaction.reference }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_financial_transaction_edit', {'id': financial_transaction.id}) }}" class="btn btn-warning"><i class="fas fa-edit me-1"></i> Modifier</a>
            <a href="{{ path('admin_financial_transaction_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-info-circle me-2"></i>Informations</h6></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Type</div><div class="info-value"><span class="badge badge-soft {{ financial_transaction.type == 'entrée' ? 'success' : (financial_transaction.type == 'transfert' ? 'info' : 'danger') }}">{{ financial_transaction.typeLabel }}</span></div></div>
                            <div class="info-row"><div class="info-label">Catégorie</div><div class="info-value"><span class="badge badge-soft secondary">{{ financial_transaction.categoryLabel }}</span></div></div>
                            <div class="info-row"><div class="info-label">Montant</div><div class="info-value fw-bold {{ financial_transaction.type == 'entrée' ? 'text-success' : 'text-danger' }}">{{ financial_transaction.amount|number_format(0, ',', ' ') }} FCFA</div></div>
                            <div class="info-row"><div class="info-label">Statut</div><div class="info-value"><span class="badge badge-soft {{ financial_transaction.statusColor }}">{{ financial_transaction.statusLabel }}</span></div></div>
                        </div></div>
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Référence</div><div class="info-value">{{ financial_transaction.reference }}</div></div>
                            <div class="info-row"><div class="info-label">Date de transaction</div><div class="info-value">{{ financial_transaction.transactionDate ? financial_transaction.transactionDate|date('d/m/Y H:i') : 'Non définie' }}</div></div>
                            <div class="info-row"><div class="info-label">Créée le</div><div class="info-value">{{ financial_transaction.createdAt ? financial_transaction.createdAt|date('d/m/Y H:i') : 'Non définie' }}</div></div>
                        </div></div>
                    </div>
                    {% if financial_transaction.description %}
                        <div class="info-list mt-2"><div class="info-row"><div class="info-label">Description</div><div class="info-value">{{ financial_transaction.description }}</div></div></div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-bolt me-2"></i>Actions</h6></div>
                <div class="card-body d-grid gap-2">
                    <a href="{{ path('admin_financial_transaction_edit', {'id': financial_transaction.id}) }}" class="btn btn-warning"><i class="fas fa-edit me-1"></i> Modifier la transaction</a>
                    <form method="post" action="{{ path('admin_financial_transaction_delete', {'id': financial_transaction.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette transaction ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ financial_transaction.id) }}">
                        <button type="submit" class="btn btn-danger w-100"><i class="fas fa-trash me-1"></i> Supprimer</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
