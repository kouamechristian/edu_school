{% extends 'base.html.twig' %}

{% block title %}Détails de la Transaction{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-exchange-alt me-2"></i>Détails de la Transaction
        </h1>
        <div>
            <a href="{{ path('admin_financial_transaction_edit', {'id': financial_transaction.id}) }}" class="btn btn-warning">
                <i class="fas fa-edit me-2"></i>Modifier
            </a>
            <a href="{{ path('admin_financial_transaction_index') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-2"></i>Retour à la liste
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Transaction #{{ financial_transaction.reference }}</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <strong>Type de transaction:</strong>
                            <p>
                                <span class="badge badge-{{ financial_transaction.type == 'income' ? 'success' : 'danger' }}">
                                    {{ financial_transaction.type == 'income' ? 'Entrée' : 'Sortie' }}
                                </span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <strong>Montant:</strong>
                            <p>{{ financial_transaction.amount|number_format(0, ',', ' ') }} FCFA</p>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <strong>Statut:</strong>
                            <p>
                                <span class="badge badge-{{ financial_transaction.status == 'completed' ? 'success' : (financial_transaction.status == 'pending' ? 'warning' : 'secondary') }}">
                                    {{ financial_transaction.status|title }}
                                </span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <strong>Date de transaction:</strong>
                            <p>{{ financial_transaction.transactionDate ? financial_transaction.transactionDate|date('d/m/Y H:i') : 'Non définie' }}</p>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <strong>Référence:</strong>
                            <p>{{ financial_transaction.reference }}</p>
                        </div>
                        <div class="col-md-6">
                            <strong>Date de création:</strong>
                            <p>{{ financial_transaction.createdAt ? financial_transaction.createdAt|date('d/m/Y H:i') : 'Non définie' }}</p>
                        </div>
                    </div>

                    {% if financial_transaction.description %}
                        <div class="row">
                            <div class="col-12">
                                <strong>Description:</strong>
                                <p>{{ financial_transaction.description }}</p>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Actions</h6>
                </div>
                <div class="card-body">
                    <a href="{{ path('admin_financial_transaction_edit', {'id': financial_transaction.id}) }}" class="btn btn-warning btn-block mb-2">
                        <i class="fas fa-edit me-2"></i>Modifier la transaction
                    </a>
                    
                    <form method="post" action="{{ path('admin_financial_transaction_delete', {'id': financial_transaction.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette transaction ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ financial_transaction.id) }}">
                        <button type="submit" class="btn btn-danger btn-block">
                            <i class="fas fa-trash me-2"></i>Supprimer
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
