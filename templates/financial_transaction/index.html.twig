{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Transactions Financières{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Transactions Financières',
        subtitle: 'Entrées et sorties de trésorerie',
        icon: 'fa-exchange-alt',
        color: 'primary',
        breadcrumb: [ { label: 'Transactions' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_financial_transaction_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouvelle Transaction</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card filter-card mb-3">
        <div class="card-body">
            <form method="GET" class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label for="type" class="form-label">Filtrer par type</label>
                    <select name="type" id="type" class="form-select" onchange="this.form.submit()">
                        <option value="">Tous les types</option>
                        {% for t in types %}
                            <option value="{{ t.id }}" {{ current_type == t.id ? 'selected' : '' }}>{{ t.name }} ({{ t.directionLabel }})</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="direction" class="form-label">Filtrer par sens</label>
                    <select name="direction" id="direction" class="form-select" onchange="this.form.submit()">
                        <option value="">Tous les sens</option>
                        {% for value, label in directions %}
                            <option value="{{ value }}" {{ current_direction == value ? 'selected' : '' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100"><i class="fas fa-filter me-1"></i> Filtrer</button>
                </div>
                {% if current_type or current_direction %}
                    <div class="col-md-3">
                        <a href="{{ path('admin_financial_transaction_index') }}" class="btn btn-outline-secondary w-100"><i class="fas fa-times me-1"></i> Réinitialiser</a>
                    </div>
                {% endif %}
            </form>
        </div>
    </div>

    <div class="card table-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des transactions</h6>
            <span class="badge bg-primary">{{ financial_transactions|length }}</span>
        </div>
        <div class="card-body">
            {% if financial_transactions|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr><th>Type</th><th>Catégorie</th><th class="text-end">Montant</th><th>Description</th><th>Référence</th><th>Date</th><th>Statut</th><th class="text-end">Actions</th></tr>
                        </thead>
                        <tbody>
                            {% set typeMap = {
                                'entrée':    {color: 'success', icon: 'arrow-down'},
                                'sortie':    {color: 'danger',  icon: 'arrow-up'},
                                'transfert': {color: 'info',    icon: 'money-bill-transfer'}
                            } %}
                            {% for transaction in financial_transactions %}
                                {% set tinfo = typeMap[transaction.type] ?? {color: 'secondary', icon: 'circle'} %}
                                <tr>
                                    <td><span class="badge badge-soft {{ tinfo.color }}"><i class="fas fa-{{ tinfo.icon }} me-1"></i>{{ transaction.typeLabel }}</span></td>
                                    <td><span class="badge badge-soft secondary">{{ transaction.categoryLabel }}</span></td>
                                    <td class="text-end fw-bold {{ transaction.type == 'entrée' ? 'text-success' : 'text-danger' }}">{{ transaction.type == 'entrée' ? '+' : '-' }} {{ transaction.amount|number_format(0, ',', ' ') }} FCFA</td>
                                    <td>{{ transaction.description ? (transaction.description|slice(0, 50) ~ (transaction.description|length > 50 ? '...' : '')) : '—' }}</td>
                                    <td><span class="text-muted">{{ transaction.reference ?: '—' }}</span></td>
                                    <td class="text-muted">{{ transaction.transactionDate ? transaction.transactionDate|date('d/m/Y') : '—' }}</td>
                                    <td><span class="badge badge-soft {{ transaction.statusColor }}">{{ transaction.statusLabel }}</span></td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a href="{{ path('admin_financial_transaction_show', {'id': transaction.id}) }}" class="btn btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a>
                                            <a href="{{ path('admin_financial_transaction_edit', {'id': transaction.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="empty-state">
                    <div class="empty-icon"><i class="fas fa-exchange-alt"></i></div>
                    <h6>Aucune transaction</h6>
                    <p>Aucune transaction financière n'a encore été enregistrée.</p>
                    <a href="{{ path('admin_financial_transaction_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Créer la première transaction</a>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
