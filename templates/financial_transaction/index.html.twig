{% extends 'base.html.twig' %}

{% block title %}Transactions Financières{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-exchange-alt me-2"></i>Transactions Financières
        </h1>
        <a href="{{ path('admin_financial_transaction_new') }}" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Nouvelle Transaction
        </a>
    </div>

    <div class="card shadow">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Liste des Transactions Financières</h6>
        </div>
        <div class="card-body">
            {% if financial_transactions|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Type</th>
                                <th>Montant</th>
                                <th>Description</th>
                                <th>Référence</th>
                                <th>Date</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for transaction in financial_transactions %}
                                <tr>
                                    <td>
                                        <span class="badge badge-{{ transaction.type == 'income' ? 'success' : 'danger' }}">
                                            {{ transaction.type == 'income' ? 'Entrée' : 'Sortie' }}
                                        </span>
                                    </td>
                                    <td>{{ transaction.amount|number_format(0, ',', ' ') }} FCFA</td>
                                    <td>{{ transaction.description|slice(0, 50) }}{% if transaction.description|length > 50 %}...{% endif %}</td>
                                    <td>{{ transaction.reference }}</td>
                                    <td>{{ transaction.transactionDate ? transaction.transactionDate|date('d/m/Y H:i') : '' }}</td>
                                    <td>
                                        <span class="badge badge-{{ transaction.status == 'completed' ? 'success' : (transaction.status == 'pending' ? 'warning' : 'secondary') }}">
                                            {{ transaction.status|title }}
                                        </span>
                                    </td>
                                    <td>
                                        <a href="{{ path('admin_financial_transaction_show', {'id': transaction.id}) }}" class="btn btn-info btn-sm">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="{{ path('admin_financial_transaction_edit', {'id': transaction.id}) }}" class="btn btn-warning btn-sm">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-4">
                    <i class="fas fa-exchange-alt fa-3x text-muted mb-3"></i>
                    <p class="text-muted">Aucune transaction financière trouvée</p>
                    <a href="{{ path('admin_financial_transaction_new') }}" class="btn btn-primary">
                        <i class="fas fa-plus me-2"></i>Créer la première transaction
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
