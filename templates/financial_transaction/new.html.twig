{% extends 'base.html.twig' %}

{% block title %}Nouvelle Transaction Financière{% endblock %}
{% block heading %}Nouvelle Transaction Financière{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-xl-9">
            {% embed 'components/page_header.html.twig' with {
                title: block('heading'),
                icon: 'fa-exchange-alt',
                color: 'primary',
                breadcrumb: [
                    { label: 'Transactions', path: path('admin_financial_transaction_index') },
                    { label: block('heading') }
                ]
            } %}
                {% block actions %}
                    <a href="{{ path('admin_financial_transaction_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
                {% endblock %}
            {% endembed %}

            {% include '_flash.html.twig' %}

            <div class="card">
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="row">
                            <div class="col-md-6 mb-3">{{ form_row(form.transactionType) }}</div>
                            <div class="col-md-6 mb-3">{{ form_row(form.category) }}</div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">{{ form_row(form.amount) }}</div>
                            <div class="col-md-6 mb-3">{{ form_row(form.paymentMethod) }}</div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">{{ form_row(form.transactionDate) }}</div>
                            <div class="col-md-6 mb-3">{{ form_row(form.status) }}</div>
                        </div>
                        <div class="mb-3">{{ form_row(form.reference) }}</div>
                        <div class="mb-3">{{ form_row(form.description) }}</div>
                        <div class="mb-3">{{ form_row(form.notes) }}</div>
                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a href="{{ path('admin_financial_transaction_index') }}" class="btn btn-light"><i class="fas fa-times me-1"></i> Annuler</a>
                            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Enregistrer</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
