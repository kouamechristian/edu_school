{% extends 'base.html.twig' %}

{% block title %}{{ school_year.name }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-xl-9">
            {% embed 'components/page_header.html.twig' with {
                title: school_year.name,
                subtitle: 'Année scolaire — ' ~ school_year.school.name,
                icon: 'fa-calendar-alt',
                color: 'primary',
                breadcrumb: [
                    { label: 'Années scolaires', path: path('admin_school_year_index') },
                    { label: school_year.name }
                ]
            } %}
                {% block actions %}
                    <a href="{{ path('admin_school_year_edit', {'id': school_year.id}) }}" class="btn btn-warning"><i class="fas fa-edit me-1"></i> Modifier</a>
                    <a href="{{ path('admin_school_year_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
                {% endblock %}
            {% endembed %}

            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="m-0 fw-bold text-primary"><i class="fas fa-calendar-alt me-2"></i>{{ school_year.name }}</h6>
                    {% if school_year.isCurrent %}<span class="badge bg-primary">Année en cours</span>{% endif %}
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Établissement</div><div class="info-value">{{ school_year.school.name }}</div></div>
                            <div class="info-row"><div class="info-label">Année</div><div class="info-value">{{ school_year.name }}</div></div>
                        </div></div>
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Date de début</div><div class="info-value">{{ school_year.startDate|date('d/m/Y') }}</div></div>
                            <div class="info-row"><div class="info-label">Date de fin</div><div class="info-value">{{ school_year.endDate|date('d/m/Y') }}</div></div>
                        </div></div>
                    </div>

                    {% if school_year.periods is not empty %}
                        <hr>
                        <h6 class="text-muted mb-3"><i class="fas fa-clock me-2"></i>Périodes</h6>
                        <div class="list-group list-group-flush">
                            {% for period in school_year.periods %}
                            <div class="list-group-item px-0">
                                <strong>{{ period.name }}</strong> <span class="badge badge-soft secondary">{{ period.typeLabel }}</span><br>
                                <small class="text-muted">{{ period.startDate|date('d/m/Y') }} – {{ period.endDate|date('d/m/Y') }} (Coeff : {{ period.weight }})</small>
                            </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
