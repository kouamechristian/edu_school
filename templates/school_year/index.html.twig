{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Années Scolaires{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Gestion des Années Scolaires',
        subtitle: 'Années, périodes et année courante',
        icon: 'fa-calendar-alt',
        color: 'primary',
        breadcrumb: [ { label: 'Années scolaires' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_school_year_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouvelle Année Scolaire</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des années scolaires</h6></div>
        <div class="card-body">
            {% if school_years is empty %}
                {{ empty_state('fa-calendar-xmark', 'Aucune année scolaire', 'Cliquez sur « Nouvelle Année Scolaire » pour commencer.') }}
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr><th>Année</th><th>Date de début</th><th>Date de fin</th><th>Statut</th><th class="text-end" width="180">Actions</th></tr>
                        </thead>
                        <tbody>
                            {% for school_year in school_years %}
                            <tr class="{{ school_year.isCurrent ? 'table-light' : '' }}">
                                <td><strong>{{ school_year.name }}</strong></td>
                                <td class="text-muted">{{ school_year.startDate|date('d/m/Y') }}</td>
                                <td class="text-muted">{{ school_year.endDate|date('d/m/Y') }}</td>
                                <td>
                                    {% if school_year.isCurrent %}<span class="badge bg-primary">En cours</span>
                                    {% elseif school_year.isActive %}<span class="badge badge-soft success">Active</span>
                                    {% else %}<span class="badge badge-soft secondary">Terminée</span>{% endif %}
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a href="{{ path('admin_school_year_show', {'id': school_year.id}) }}" class="btn btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a>
                                        <a href="{{ path('admin_school_year_edit', {'id': school_year.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                        {% if not school_year.isCurrent %}
                                        <form method="post" action="{{ path('admin_school_year_set_current', {'id': school_year.id}) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('set-current' ~ school_year.id) }}">
                                            <button type="submit" class="btn btn-outline-primary" title="Définir comme année courante"><i class="fas fa-check-circle"></i></button>
                                        </form>
                                        {% endif %}
                                        <form method="post" action="{{ path('admin_school_year_delete', {'id': school_year.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette année scolaire ?');" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ school_year.id) }}">
                                            <button type="submit" class="btn btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
