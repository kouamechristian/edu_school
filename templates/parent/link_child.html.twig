{% extends 'parent/base.html.twig' %}

{% block title %}Rattacher un enfant{% endblock %}

{% block breadcrumb %}
    <div class="pp-breadcrumb"><a href="{{ path('parent_dashboard') }}">Tableau de bord</a> / Rattacher un enfant</div>
{% endblock %}
{% block page_title %}Rattacher un enfant{% endblock %}
{% block page_subtitle %}Reliez un élève à votre compte avec son matricule national.{% endblock %}

{% block body %}
<div class="pp-grid cols-2" style="align-items:start;">
    <section class="pp-card pp-reveal">
        <div class="pp-card-title" style="margin-bottom:1.25rem;"><i class="fas fa-link"></i> Informations de l'élève</div>

        <form method="post" action="{{ path('parent_link_child') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('parent_link_child') }}">

            <div style="margin-bottom:1.5rem;">
                <label for="matricule_national" class="pp-child-sub" style="display:block;margin-bottom:.4rem;font-weight:600;">
                    <i class="fas fa-id-card"></i> Matricule national de l'élève
                </label>
                <input type="text" id="matricule_national" name="matricule_national" required autofocus
                       placeholder="Matricule national de l'élève"
                       value="{{ app.request.request.get('matricule_national') }}"
                       style="width:100%;border:1px solid #e3e8f0;border-radius:12px;padding:.7rem 1rem;font-size:1rem;color:#1e3a5f;background:#fff;">
            </div>

            <button type="submit" class="pp-btn pp-btn-primary pp-btn-block">
                <i class="fas fa-user-plus"></i> Rattacher cet enfant
            </button>
        </form>
    </section>

    <section class="pp-card pp-reveal">
        <div class="pp-card-title" style="margin-bottom:1rem;"><i class="fas fa-circle-info"></i> Comment ça marche ?</div>
        <ul style="margin:0;padding-left:1.1rem;color:#475569;line-height:1.7;font-size:.95rem;">
            <li>Saisissez le <strong>matricule national</strong> de l'élève (figurant sur ses documents scolaires).</li>
            <li>S'il correspond à un élève actif, ce dernier apparaîtra immédiatement dans votre tableau de bord.</li>
        </ul>
        <p class="pp-child-sub" style="margin-top:1rem;">
            <i class="fas fa-shield-halved"></i> Vous pouvez rattacher plusieurs enfants. En cas de difficulté, contactez le secrétariat de l'établissement.
        </p>
    </section>
</div>
{% endblock %}
