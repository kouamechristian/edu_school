{% extends 'parent/base.html.twig' %}

{% block title %}{{ child.fullName }}{% endblock %}

{% block breadcrumb %}
    <div class="pp-breadcrumb"><a href="{{ path('parent_dashboard') }}">Tableau de bord</a> / {{ child.fullName }}</div>
{% endblock %}
{% block page_title %}{{ child.fullName }}{% endblock %}
{% block page_subtitle %}
    {% if child.school %}{{ child.school.name }} · {% endif %}
    {{ child.classroom ? child.classroom.name : 'Classe non affectée' }}
    {% set matricule = child.matriculeNational ?: child.matriculeInterne %}
    {% if matricule %} · Matricule {{ matricule }}{% endif %}
    {% if period %} · {{ period.name }}{% endif %}
{% endblock %}

{% block subnav %}{% include 'parent/_child_nav.html.twig' with {active: 'résumé'} %}{% endblock %}
{% block bottomnav %}{% include 'parent/_child_bottomnav.html.twig' %}{% endblock %}

{% block stylesheets %}
<style>
    .pp-steps { display:flex; gap:0; }
    .pp-step { flex:1; text-align:center; position:relative; padding:0 .25rem; }
    /* Trait de liaison entre les pastilles */
    .pp-step::before {
        content:""; position:absolute; top:20px; left:-50%; width:100%; height:3px;
        background:#e3e8f0; z-index:0;
    }
    .pp-step:first-child::before { display:none; }
    .pp-step.done::before { background:#10b981; }
    .pp-step-dot {
        position:relative; z-index:1; width:42px; height:42px; border-radius:50%;
        margin:0 auto .5rem; display:flex; align-items:center; justify-content:center;
        background:#eef2f8; color:#94a3b8; border:2px solid #e3e8f0; font-size:1rem;
        transition:all .25s ease;
    }
    .pp-step.done .pp-step-dot { background:linear-gradient(135deg,#10b981,#059669); color:#fff; border-color:#10b981; box-shadow:0 6px 14px -6px rgba(16,185,129,.7); }
    .pp-step.active .pp-step-dot { background:#fff; color:#1e3a5f; border-color:#1e3a5f; animation:pp-pulse-dot 1.6s ease-in-out infinite; }
    @keyframes pp-pulse-dot { 0%,100%{ box-shadow:0 0 0 0 rgba(30,58,95,.35);} 50%{ box-shadow:0 0 0 6px rgba(30,58,95,0);} }
    .pp-step-label { font-size:.82rem; font-weight:600; color:#1e3a5f; }
    .pp-step.active .pp-step-label { color:#1e3a5f; }
    .pp-step:not(.done):not(.active) .pp-step-label { color:#94a3b8; }
    .pp-step-date { font-size:.72rem; color:#94a3b8; min-height:1em; }
    @media (max-width:520px){ .pp-step-label { font-size:.72rem; } .pp-step-dot { width:36px; height:36px; } .pp-step::before{ top:17px; } }

    /* Détail des frais par échéancier */
    .pp-fee-block { border:1px solid #eef2f7; border-radius:14px; padding:.85rem 1rem; margin-bottom:.75rem; background:#fbfdff; }
    .pp-fee-head { display:flex; justify-content:space-between; align-items:center; gap:.75rem; flex-wrap:wrap; margin-bottom:.5rem; }
    .pp-fee-table { width:100%; border-collapse:collapse; font-size:.85rem; }
    .pp-fee-table th { text-align:left; font-size:.72rem; text-transform:uppercase; letter-spacing:.03em; color:#94a3b8; padding:.35rem .5rem; border-bottom:1px solid #eef2f7; }
    .pp-fee-table td { padding:.4rem .5rem; border-bottom:1px solid #f4f7fb; color:#1e3a5f; }
    .pp-fee-table tr:last-child td { border-bottom:none; }
    .pp-fee-table .r { text-align:right; }
</style>
{% endblock %}

{% block body %}
{% set avg = academic.general_average %}
{% set ring = avg is not null ? (avg / 20 * 100)|round : 0 %}
{% set ring_color = avg is null ? '#94a3b8' : (avg >= 14 ? '#10b981' : (avg >= 10 ? '#f59e0b' : '#ef4444')) %}

{# Préinscription : bouton si aucune demande en cours, sinon suivi (workflow). #}
{% set pre = pre_registration %}
{% if pre is null or pre.status == 'rejected' %}
    <section class="pp-card pp-reveal" style="margin-bottom:1.25rem;display:flex;align-items:center;gap:1rem;flex-wrap:wrap;justify-content:space-between;">
        <div style="display:flex;align-items:center;gap:.9rem;">
            <span class="pp-card-title" style="margin:0;"><i class="fas fa-user-graduate"></i> Préinscription</span>
            <span class="pp-child-sub" style="margin:0;">
                {% if pre and pre.status == 'rejected' %}
                    <span class="pp-badge red">Demande rejetée</span>
                    {% if pre.rejectionReason %} — {{ pre.rejectionReason }}{% endif %}
                {% else %}
                    Préinscrivez {{ child.firstName }} pour une nouvelle année scolaire.
                {% endif %}
            </span>
        </div>
        <a href="{{ path('parent_child_reenroll', {id: child.id}) }}" class="pp-btn pp-btn-primary" style="padding:.45rem 1rem;">
            <i class="fas fa-paper-plane"></i> {{ pre and pre.status == 'rejected' ? 'Refaire la demande' : 'Faire la préinscription' }}
        </a>
    </section>
{% else %}
    {% set st = pre.status %}
    {% set steps = [
        { key: 'sent',   label: 'Demande envoyée',  icon: 'fa-paper-plane',     done: true,                                            date: pre.createdAt },
        { key: 'docs',   label: 'Documents reçus',   icon: 'fa-folder-open',     done: st in ['documents_received','validated','enrolled'], date: null },
        { key: 'valid',  label: 'Validée',           icon: 'fa-clipboard-check', done: st in ['validated','enrolled'],                  date: pre.validatedAt },
        { key: 'enrol',  label: 'Inscrit(e)',        icon: 'fa-user-check',      done: st == 'enrolled',                                date: pre.enrolledAt }
    ] %}
    <section class="pp-card pp-reveal pp-workflow" style="margin-bottom:1.25rem;">
        {% set badge_color = {
            'pending': 'amber', 'documents_required': 'sky', 'documents_received': 'navy',
            'validated': 'green', 'rejected': 'red', 'enrolled': 'green'
        }[st]|default('navy') %}
        <div class="pp-card-header" style="margin-bottom:1rem;">
            <span class="pp-card-title"><i class="fas fa-user-graduate"></i> Suivi de la préinscription</span>
            <span class="pp-badge {{ badge_color }}">{{ pre.statusLabel }}</span>
        </div>
        <div class="pp-child-sub" style="margin-bottom:1rem;">
            {% if pre.requestedLevel %}Niveau demandé : <strong>{{ pre.requestedLevel.name }}</strong>{% endif %}
            {% if pre.schoolYear %} · Année : <strong>{{ pre.schoolYear.name }}</strong>{% endif %}
        </div>

        <div class="pp-steps">
            {% for s in steps %}
                {% set active = not s.done and (loop.first or steps[loop.index0 - 1].done) %}
                <div class="pp-step {{ s.done ? 'done' : (active ? 'active' : '') }}">
                    <div class="pp-step-dot"><i class="fas {{ s.done ? 'fa-check' : s.icon }}"></i></div>
                    <div class="pp-step-label">{{ s.label }}</div>
                    <div class="pp-step-date">{{ s.date ? s.date|date('d/m/Y') : '' }}</div>
                </div>
            {% endfor %}
        </div>

        {# Détail des frais à payer, rangés par échéancier (affiché dès la validation). #}
        {% if fee_detail is not empty %}
            <div style="margin-top:1.25rem;">
                <div class="pp-card-title" style="font-size:.95rem;margin-bottom:.6rem;"><i class="fas fa-file-invoice-dollar"></i> Frais à payer — détail par échéancier</div>
                {% for f in fee_detail %}
                    <div class="pp-fee-block">
                        <div class="pp-fee-head">
                            <span><strong>{{ f.name }}</strong> <span class="pp-badge navy">{{ f.category }}</span></span>
                            <span class="pp-child-sub">Total {{ f.total|number_format(0, ',', ' ') }} F · Payé {{ f.paid|number_format(0, ',', ' ') }} F · <strong>Reste {{ f.remaining|number_format(0, ',', ' ') }} F</strong></span>
                        </div>
                        <table class="pp-fee-table">
                            <thead><tr><th>N°</th><th>Échéance</th><th class="r">Montant</th><th class="r">Réglé</th><th class="r">Reste</th><th class="r">Action</th></tr></thead>
                            <tbody>
                                {% for s in f.schedules %}
                                <tr>
                                    <td>{{ s.order }}</td>
                                    <td>{{ s.due ? s.due|date('d/m/Y') : 'À l’inscription' }}</td>
                                    <td class="r">{{ s.amount|number_format(0, ',', ' ') }} F</td>
                                    <td class="r">{{ s.paid|number_format(0, ',', ' ') }} F</td>
                                    <td class="r">{% if s.remaining > 0 %}<span class="pp-badge red">{{ s.remaining|number_format(0, ',', ' ') }} F</span>{% else %}<span class="pp-badge green">Payé</span>{% endif %}</td>
                                    <td class="r">
                                        {% if s.remaining > 0 %}
                                            {% if s.payable %}
                                                <a href="{{ path('parent_child_finance', {id: child.id}) }}" class="pp-btn pp-btn-primary" style="padding:.25rem .7rem;font-size:.78rem;">
                                                    <i class="fas fa-mobile-screen-button"></i> Payer
                                                </a>
                                            {% else %}
                                                <span class="pp-child-sub" style="font-size:.75rem;">à venir</span>
                                            {% endif %}
                                        {% else %}
                                            <i class="fas fa-check" style="color:#10b981;"></i>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        {% if st == 'validated' %}
            <div style="margin-top:1rem;display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;justify-content:space-between;">
                <span class="pp-child-sub"><i class="fas fa-circle-info"></i> Réglez les frais en ligne, ou rendez-vous à l'établissement.</span>
                <a href="{{ path('parent_child_finance', {id: child.id}) }}" class="pp-btn pp-btn-primary" style="padding:.45rem 1rem;">
                    <i class="fas fa-credit-card"></i> Régler les frais
                </a>
            </div>
        {% elseif st == 'enrolled' %}
            <div style="margin-top:1rem;"><span class="pp-badge green"><i class="fas fa-check"></i> Inscription finalisée{% if child.classroom %} — classe {{ child.classroom.name }}{% endif %}</span></div>
        {% else %}
            <div class="pp-child-sub" style="margin-top:1rem;"><i class="fas fa-hourglass-half"></i> Votre demande est en cours de traitement par l'établissement. Vous serez notifié(e) dès sa validation.</div>
        {% endif %}
    </section>
{% endif %}

<div class="pp-grid cols-2">
    {# Résultats #}
    <section class="pp-card pp-reveal">
        <div class="pp-card-header">
            <span class="pp-card-title"><i class="fas fa-clipboard-check"></i> Résultats</span>
            <a href="{{ path('parent_child_grades', {id: child.id}) }}" class="pp-btn pp-btn-ghost" style="padding:.35rem .8rem;">Détail</a>
        </div>
        <div style="display:flex;align-items:center;gap:1.25rem;">
            <div class="pp-ring" style="--val:{{ ring }};--ring-color:{{ ring_color }};">
                <div class="pp-ring-label">
                    <div class="num">{{ avg is not null ? avg : '—' }}</div>
                    <div class="unit">/ 20</div>
                </div>
            </div>
            <div style="flex:1;">
                {% if academic.subjects is empty %}
                    <p class="pp-child-sub" style="margin:0;">Aucune note publiée pour le moment.</p>
                {% else %}
                    {% for row in academic.subjects|slice(0, 4) %}
                        <div style="display:flex;justify-content:space-between;padding:.35rem 0;border-bottom:1px solid #f1f4f9;">
                            <span style="font-size:.9rem;">{{ row.subject.name }}</span>
                            <strong>{{ row.average is not null ? row.average ~ '/20' : '—' }}</strong>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>
    </section>

    {# Assiduité #}
    <section class="pp-card pp-reveal">
        <div class="pp-card-header">
            <span class="pp-card-title"><i class="fas fa-calendar-check"></i> Assiduité</span>
            <a href="{{ path('parent_child_absences', {id: child.id}) }}" class="pp-btn pp-btn-ghost" style="padding:.35rem .8rem;">Détail</a>
        </div>
        <div class="pp-stats" style="grid-template-columns:repeat(4,1fr);">
            <div class="pp-stat"><div class="v">{{ attendance.total }}</div><div class="l">Total</div></div>
            <div class="pp-stat"><div class="v good">{{ attendance.justified }}</div><div class="l">Justifiées</div></div>
            <div class="pp-stat"><div class="v warn">{{ attendance.pending }}</div><div class="l">En attente</div></div>
            <div class="pp-stat"><div class="v bad">{{ attendance.unjustified }}</div><div class="l">Injustifiées</div></div>
        </div>
    </section>
</div>

{# Finances #}
<section class="pp-card pp-reveal" style="margin-top:1.1rem;">
    <div class="pp-card-header">
        <span class="pp-card-title"><i class="fas fa-wallet"></i> Situation financière</span>
        <a href="{{ path('parent_child_finance', {id: child.id}) }}" class="pp-btn pp-btn-ghost" style="padding:.35rem .8rem;">Détail</a>
    </div>
    {% set total = finance.total_tuition %}
    {% set paid = finance.total_paid %}
    {% set pct = total > 0 ? (paid / total * 100)|round : 100 %}
    <div class="pp-stats" style="margin-bottom:1rem;">
        <div class="pp-stat"><div class="v">{{ total|number_format(0, ',', ' ') }}</div><div class="l">Frais total</div></div>
        <div class="pp-stat"><div class="v good">{{ paid|number_format(0, ',', ' ') }}</div><div class="l">Payé</div></div>
        <div class="pp-stat"><div class="v {{ finance.remaining > 0 ? 'bad' : 'good' }}">{{ finance.remaining|number_format(0, ',', ' ') }}</div><div class="l">Reste à payer</div></div>
    </div>
    <div style="height:10px;background:#e6ebf2;border-radius:999px;overflow:hidden;">
        <div style="height:100%;width:{{ pct }}%;background:linear-gradient(90deg,#10b981,#059669);border-radius:999px;"></div>
    </div>
    <div class="pp-child-sub" style="margin-top:.4rem;">{{ pct }}% réglé</div>
</section>

{# Emploi du temps #}
<section class="pp-card pp-reveal" style="margin-top:1.1rem;">
    <div class="pp-card-header">
        <span class="pp-card-title"><i class="fas fa-calendar-week"></i> Emploi du temps</span>
        <a href="{{ path('parent_child_schedule', {id: child.id}) }}" class="pp-btn pp-btn-ghost" style="padding:.35rem .8rem;">Détail</a>
    </div>
    {% include 'parent/_schedule_grid.html.twig' %}
</section>
{% endblock %}
