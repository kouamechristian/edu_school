{% extends 'parent/base.html.twig' %}

{% block title %}Retour de paiement{% endblock %}

{% block breadcrumb %}
    <div class="pp-breadcrumb">
        <a href="{{ path('parent_dashboard') }}">Tableau de bord</a> /
        <a href="{{ path('parent_child_finance', {id: child.id}) }}">{{ child.fullName }}</a> / Paiement
    </div>
{% endblock %}
{% block page_title %}Paiement {{ payment.paymentNumber }}{% endblock %}

{% block body %}
{% set status = payment.status %}
{% set view = status == 'payé'
    ? {'icon': 'fa-circle-check', 'color': '#10b981', 'title': 'Paiement confirmé', 'msg': 'Votre paiement a bien été reçu. Le solde a été mis à jour.'}
    : (status == 'annulé'
        ? {'icon': 'fa-circle-xmark', 'color': '#ef4444', 'title': 'Paiement non abouti', 'msg': 'Le paiement a été annulé ou a échoué. Vous pouvez réessayer.'}
        : {'icon': 'fa-clock', 'color': '#f59e0b', 'title': 'Paiement en cours de confirmation', 'msg': 'Votre paiement est en cours de traitement. Le statut sera mis à jour automatiquement dès confirmation.'}) %}

<section class="pp-card pp-reveal" style="text-align:center;max-width:560px;margin:0 auto;">
    <i class="fas {{ view.icon }}" style="font-size:3.2rem;color:{{ view.color }};"></i>
    <h2 class="pp-section-title" style="margin-top:1rem;">{{ view.title }}</h2>
    <p class="pp-child-sub" style="margin-bottom:1.25rem;">{{ view.msg }}</p>

    <div class="pp-stats" style="margin-bottom:1.25rem;">
        <div class="pp-stat"><div class="v">{{ payment.amount|number_format(0, ',', ' ') }}</div><div class="l">Montant (F)</div></div>
        <div class="pp-stat"><div class="v">{{ payment.fee ? payment.fee.name : '—' }}</div><div class="l">Frais</div></div>
        <div class="pp-stat"><div class="v">{{ payment.paymentDate ? payment.paymentDate|date('d/m/Y') : '—' }}</div><div class="l">Date</div></div>
    </div>

    <div style="display:flex;gap:.6rem;justify-content:center;flex-wrap:wrap;">
        <a href="{{ path('parent_child_finance', {id: child.id}) }}" class="pp-btn pp-btn-primary"><i class="fas fa-wallet"></i> Retour aux finances</a>
        <a href="{{ path('parent_payments') }}" class="pp-btn pp-btn-ghost"><i class="fas fa-receipt"></i> Mes paiements</a>
    </div>
</section>

{% if status not in ['payé', 'annulé'] %}
<script>
    // Le statut définitif arrive via le webhook ; on rafraîchit une fois après quelques secondes.
    setTimeout(function () { window.location.reload(); }, 8000);
</script>
{% endif %}
{% endblock %}
