{% extends 'parent/base.html.twig' %}

{% block title %}Finances · {{ child.fullName }}{% endblock %}

{% block breadcrumb %}
    <div class="pp-breadcrumb"><a href="{{ path('parent_dashboard') }}">Tableau de bord</a> /
        <a href="{{ path('parent_child_show', {id: child.id}) }}">{{ child.fullName }}</a> / Finances</div>
{% endblock %}
{% block page_title %}Finances de {{ child.fullName }}{% endblock %}
{% block page_subtitle %}Frais de scolarité.{% endblock %}

{% block subnav %}{% include 'parent/_child_nav.html.twig' with {active: 'finances'} %}{% endblock %}
{% block bottomnav %}{% include 'parent/_child_bottomnav.html.twig' %}{% endblock %}

{% block body %}
{% set total = finance.total_tuition %}
{% set paid = finance.total_paid %}
{% set pct = total > 0 ? (paid / total * 100)|round : 100 %}

<section class="pp-card pp-reveal">
    <div class="pp-stats" style="margin-bottom:1.1rem;">
        <div class="pp-stat"><div class="v">{{ total|number_format(0, ',', ' ') }}</div><div class="l">Frais total</div></div>
        <div class="pp-stat"><div class="v good">{{ paid|number_format(0, ',', ' ') }}</div><div class="l">Payé</div></div>
        <div class="pp-stat"><div class="v {{ finance.remaining > 0 ? 'bad' : 'good' }}">{{ finance.remaining|number_format(0, ',', ' ') }}</div><div class="l">Reste à payer</div></div>
    </div>
    <div style="height:14px;background:#e6ebf2;border-radius:999px;overflow:hidden;">
        <div style="height:100%;width:{{ pct }}%;background:linear-gradient(90deg,#10b981,#059669);border-radius:999px;transition:width .6s ease;"></div>
    </div>
    <div class="pp-child-sub" style="margin-top:.5rem;">{{ pct }}% de la scolarité réglée</div>
</section>

{# ── Payer la scolarité (Mobile Money) ──────────────────────── #}
{% set unpaid_fees = (registration ? registration.studentFees : child.studentFees)|filter(sf => sf.remainingAmount > 0 and sf.fee.isActive) %}
{% if unpaid_fees|length > 0 %}
<section class="pp-card pp-reveal" style="margin-top:1.1rem;">
    <style>
        .pp-op-btn{border:none;border-radius:12px;padding:.85rem .5rem;color:#fff;font-weight:700;font-size:.95rem;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:.4rem;transition:transform .12s ease,box-shadow .12s ease;}
        .pp-op-btn:hover{transform:translateY(-2px);box-shadow:0 6px 16px rgba(30,58,95,.18);}
    </style>
    <div class="pp-card-title" style="margin-bottom:1rem;"><i class="fas fa-mobile-screen-button"></i> Payer la scolarité</div>

    <form method="post" action="{{ path('parent_child_pay', {id: child.id}) }}" id="pp-pay-form">
        <input type="hidden" name="_token" value="{{ csrf_token('parent_pay' ~ child.id) }}">

        <div style="margin-bottom:1rem;">
            <label for="pp-fee" class="pp-child-sub" style="display:block;margin-bottom:.4rem;font-weight:600;">Frais à régler</label>
            <select id="pp-fee" name="student_fee_id" required
                    style="width:100%;border:1px solid #e3e8f0;border-radius:12px;padding:.7rem 1rem;font-size:1rem;color:#1e3a5f;background:#fff;">
                {% for sf in unpaid_fees %}
                    <option value="{{ sf.id }}" data-remaining="{{ sf.remainingAmount }}">
                        {{ sf.fee.name }} — Reste à payer : {{ sf.remainingAmount|number_format(0, ',', ' ') }} F
                    </option>
                {% endfor %}
            </select>
        </div>

        <div style="margin-bottom:1rem;">
            <label for="pp-amount" class="pp-child-sub" style="display:block;margin-bottom:.4rem;font-weight:600;">Montant (F CFA)</label>
            <input type="number" id="pp-amount" name="amount" min="1" step="1" required
                   style="width:100%;border:1px solid #e3e8f0;border-radius:12px;padding:.7rem 1rem;font-size:1rem;color:#1e3a5f;background:#fff;">
        </div>

        {# Étape 1 — bouton qui révèle le choix de l'opérateur #}
        <button type="button" id="pp-pay-online" class="pp-btn pp-btn-primary pp-btn-block" style="margin-top:.4rem;">
            <i class="fas fa-lock"></i> Payer en ligne
        </button>

        {# Étape 2 — choix de l'opérateur Mobile Money (masqué au départ) #}
        <div id="pp-operators" style="display:none;margin-top:1rem;">
            <p class="pp-child-sub" style="margin-bottom:.6rem;font-weight:600;">Choisissez votre opérateur Mobile Money :</p>
            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:.6rem;">
                <button type="submit" name="operator" value="orange" class="pp-op-btn" style="background:#ff7900;"><i class="fas fa-mobile-screen-button"></i> Orange Money</button>
                <button type="submit" name="operator" value="mtn" class="pp-op-btn" style="background:#ffcc00;color:#1e3a5f;"><i class="fas fa-mobile-screen-button"></i> MTN MoMo</button>
                <button type="submit" name="operator" value="moov" class="pp-op-btn" style="background:#0a6cff;"><i class="fas fa-mobile-screen-button"></i> Moov Money</button>
                <button type="submit" name="operator" value="wave" class="pp-op-btn" style="background:#1dc6ff;color:#1e3a5f;"><i class="fas fa-mobile-screen-button"></i> Wave</button>
            </div>
        </div>

        <p class="pp-child-sub" style="margin-top:.8rem;">
            <i class="fas fa-shield-halved"></i> Paiement sécurisé par Mobile Money (Orange, MTN, Moov, Wave).
            Le solde est mis à jour automatiquement après confirmation du paiement.
        </p>
    </form>
</section>
{% endif %}

{# ── Mes paiements ──────────────────────────────────────────── #}
{% if payments is not empty %}
<section class="pp-card pp-reveal" style="margin-top:1.1rem;padding:0;overflow:hidden;">
    <div class="pp-card-header" style="padding:1rem 1.25rem;margin:0;background:#f8fafc;">
        <span class="pp-card-title"><i class="fas fa-receipt"></i> Mes paiements</span>
    </div>
    <table class="pp-table">
        <thead>
            <tr><th>N°</th><th>Frais</th><th class="text-end">Montant</th><th>Date</th><th class="text-center">Statut</th></tr>
        </thead>
        <tbody>
            {% for p in payments %}
                <tr>
                    <td><small>{{ p.paymentNumber }}</small></td>
                    <td>{{ p.fee ? p.fee.name : '—' }}</td>
                    <td class="text-end"><strong>{{ p.amount|number_format(0, ',', ' ') }} F</strong></td>
                    <td>{{ p.paymentDate ? p.paymentDate|date('d/m/Y') : '—' }}</td>
                    <td class="text-center">
                        {% set badge = {'success':'green','warning':'amber','danger':'red','info':'sky','secondary':'navy'}[p.statusColor] ?? 'navy' %}
                        <span class="pp-badge {{ badge }}">{{ p.statusLabel }}</span>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</section>
{% endif %}

<p class="pp-child-sub" style="margin-top:1rem;">
    <i class="fas fa-circle-info"></i> Vous pouvez régler en ligne ci-dessus ; tout paiement est validé par l'établissement.
    Vous pouvez également vous rapprocher de la caisse.
</p>
{% endblock %}

{% block javascripts %}
<script>
    (function () {
        var feeSelect = document.getElementById('pp-fee');
        var amount = document.getElementById('pp-amount');

        function syncAmount() {
            if (!feeSelect || !amount) return;
            var opt = feeSelect.options[feeSelect.selectedIndex];
            var remaining = opt ? parseInt(opt.getAttribute('data-remaining'), 10) : 0;
            if (remaining > 0) {
                amount.value = remaining;
                amount.max = remaining;
            }
        }
        if (feeSelect) {
            feeSelect.addEventListener('change', syncAmount);
            syncAmount();
        }

        // Étape 1 → Étape 2 : révèle le choix de l'opérateur Mobile Money.
        var payBtn = document.getElementById('pp-pay-online');
        var operators = document.getElementById('pp-operators');
        if (payBtn && operators) {
            payBtn.addEventListener('click', function () {
                operators.style.display = 'block';
                payBtn.style.display = 'none';
            });
        }
    })();
</script>
{% endblock %}
