{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Gestion des Cours{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Cours et Emplois du Temps',
        subtitle: 'Planification des cours par classe',
        icon: 'fa-calendar-alt',
        color: 'primary',
        breadcrumb: [ { label: 'Cours' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_course_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouveau Cours</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    {# Sélection de classe #}
    <div class="card filter-card mb-4">
        <div class="card-body">
            <form method="get" action="{{ path('admin_course_index') }}" class="row g-3 align-items-end">
                <div class="col-md-8">
                    <label class="form-label">Sélectionnez une classe</label>
                    <select name="classroom" class="form-select" onchange="this.form.submit()">
                        <option value="">— Choisir une classe —</option>
                        {% for classroom in classrooms %}
                            <option value="{{ classroom.id }}" {{ selected_classroom == classroom.id ? 'selected' : '' }}>{{ classroom.fullName }} - {{ classroom.schoolYear.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-4">
                    {% if selected_classroom %}
                        <a href="{{ path('admin_course_schedule', {'id': selected_classroom}) }}" class="btn btn-success w-100"><i class="fas fa-calendar me-1"></i> Voir l'emploi du temps</a>
                    {% endif %}
                </div>
            </form>
        </div>
    </div>

    {% if selected_classroom %}
        <div class="card table-card">
            <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Cours de la classe <span class="badge badge-soft ms-1">{{ courses|length }}</span></h6></div>
            <div class="card-body">
                {% if courses is empty %}
                    {{ empty_state('fa-calendar-xmark', 'Aucun cours', 'Aucun cours enregistré pour cette classe. Cliquez sur « Nouveau Cours » pour commencer.') }}
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr><th>Jour</th><th>Horaire</th><th>Matière</th><th>Enseignant</th><th>Salle</th><th>Durée</th><th class="text-end" width="160">Actions</th></tr>
                            </thead>
                            <tbody>
                                {% for course in courses %}
                                <tr>
                                    <td><strong>{{ course.dayOfWeekLabel }}</strong></td>
                                    <td>{{ course.startTime|date('H:i') }} – {{ course.endTime|date('H:i') }}</td>
                                    <td><span class="badge" style="background-color: {{ course.subject.color ?? '#6c757d' }}; color: #fff;">{{ course.subject.name }}</span></td>
                                    <td>{{ course.teacher ? course.teacher.fullName : '—' }}</td>
                                    <td>{{ course.room ? course.room.code : '—' }}</td>
                                    <td>{{ course.duration ? course.duration ~ ' min' : '—' }}</td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a href="{{ path('admin_course_show', {'id': course.id}) }}" class="btn btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a>
                                            <a href="{{ path('admin_course_edit', {'id': course.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                            <form method="post" action="{{ path('admin_course_delete', {'id': course.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce cours ?');" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ course.id) }}">
                                                <button type="submit" class="btn btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% include '_pagination.html.twig' with { pagination: courses } %}
                {% endif %}
            </div>
        </div>
    {% else %}
        <div class="alert alert-info"><i class="fas fa-arrow-up me-2"></i>Sélectionnez une classe ci-dessus pour voir ses cours.</div>
    {% endif %}
</div>
{% endblock %}
