{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state, avatar, badge_role %}

{% block title %}Gestion des Utilisateurs{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Gestion des Utilisateurs',
        subtitle: 'Comptes, rôles et accès',
        icon: 'fa-users',
        color: 'primary',
        breadcrumb: [ { label: 'Utilisateurs' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_user_new') }}" class="btn btn-primary"><i class="fas fa-user-plus me-1"></i> Nouvel Utilisateur</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    {% if stats is defined and stats is not empty %}
    <div class="row g-3 mb-4">
        {% for stat in stats %}
        <div class="col-6 col-md-2">
            <div class="stat-card primary h-100"><div class="card-body">
                <div class="stat-value">{{ stat.count }}</div>
                <div class="stat-label text-capitalize">{{ stat.userType ?? 'Non défini' }}</div>
            </div></div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

    {# Filtres #}
    <div class="card filter-card mb-4">
        <div class="card-body">
            <form method="get" action="{{ path('admin_user_index') }}" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Rechercher</label>
                    <input type="text" name="search" class="form-control" placeholder="Nom, email..." value="{{ search_term ?? '' }}">
                </div>
                <div class="col-md-4">
                    <label class="form-label">Type d'utilisateur</label>
                    <select name="type" class="form-select">
                        <option value="">Tous les types</option>
                        <option value="admin" {{ current_type == 'admin' ? 'selected' : '' }}>Administrateur</option>
                        <option value="directeur" {{ current_type == 'directeur' ? 'selected' : '' }}>Directeur</option>
                        <option value="enseignant" {{ current_type == 'enseignant' ? 'selected' : '' }}>Enseignant</option>
                        <option value="personnel" {{ current_type == 'personnel' ? 'selected' : '' }}>Personnel</option>
                        <option value="eleve" {{ current_type == 'eleve' ? 'selected' : '' }}>Élève</option>
                        <option value="parent" {{ current_type == 'parent' ? 'selected' : '' }}>Parent</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-filter me-1"></i> Filtrer</button>
                    <a href="{{ path('admin_user_index') }}" class="btn btn-light"><i class="fas fa-redo me-1"></i> Réinitialiser</a>
                </div>
            </form>
        </div>
    </div>

    {# Liste #}
    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des utilisateurs <span class="badge badge-soft ms-1">{{ users|length }}</span></h6></div>
        <div class="card-body">
            {% if users is empty %}
                {{ empty_state('fa-users', 'Aucun utilisateur', 'Aucun utilisateur ne correspond à vos critères.') }}
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr><th>Utilisateur</th><th>Email</th><th>Type</th><th>Groupe</th><th>Établissement(s)</th><th>Dernière connexion</th><th>Statut</th><th class="text-end" width="160">Actions</th></tr>
                        </thead>
                        <tbody>
                            {% for user in users %}
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        {{ avatar(user, 'sm') }}
                                        <div class="ms-2">
                                            <strong>{{ user.fullName }}</strong><br>
                                            <small class="text-muted">@{{ user.username }}</small>
                                        </div>
                                    </div>
                                </td>
                                <td>{{ user.email }}</td>
                                <td>{% if user.userType %}{{ badge_role(user.userType) }}{% else %}<span class="text-muted">—</span>{% endif %}</td>
                                <td>{% if user.schoolGroup %}<span class="badge badge-soft info" title="{{ user.schoolGroup.name }}">{{ user.schoolGroup.code }}</span>{% else %}<span class="text-muted">—</span>{% endif %}</td>
                                <td>
                                    {% if user.schools is not empty %}
                                        {% for school in user.schools %}<span class="badge badge-soft me-1" title="{{ school.name }}">{{ school.code }}</span>{% endfor %}
                                    {% else %}<span class="text-muted">—</span>{% endif %}
                                </td>
                                <td>{% if user.lastLogin %}<small class="text-muted">{{ user.lastLogin|date('d/m/Y H:i') }}</small>{% else %}<small class="text-muted">Jamais</small>{% endif %}</td>
                                <td><span class="badge badge-soft {{ user.isActive ? 'success' : 'danger' }}">{{ user.isActive ? 'Actif' : 'Inactif' }}</span></td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a href="{{ path('admin_user_show', {'id': user.id}) }}" class="btn btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a>
                                        <a href="{{ path('admin_user_edit', {'id': user.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                        <form method="post" action="{{ path('admin_user_toggle', {'id': user.id}) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ user.id) }}">
                                            <button type="submit" class="btn btn-outline-secondary" title="{{ user.isActive ? 'Désactiver' : 'Activer' }}"><i class="fas fa-{{ user.isActive ? 'ban' : 'check' }}"></i></button>
                                        </form>
                                        <form method="post" action="{{ path('admin_user_delete', {'id': user.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?');" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                            <button type="submit" class="btn btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
