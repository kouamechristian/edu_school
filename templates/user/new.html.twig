{% extends 'base.html.twig' %}

{% block title %}Nouvel Utilisateur{% endblock %}
{% block heading %}Nouvel Utilisateur{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: block('heading'),
        icon: 'fa-user-plus',
        color: 'primary',
        breadcrumb: [
            { label: 'Utilisateurs', path: path('admin_user_index') },
            { label: block('heading') }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_user_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="fw-bold text-primary mb-3"><i class="fas fa-key me-2"></i>Informations de connexion</h6>
                        <div class="mb-3">{{ form_row(form.username) }}</div>
                        <div class="mb-3">{{ form_row(form.email) }}</div>
                        <div class="mb-3">{{ form_row(form.plainPassword) }}</div>
                    </div>
                    <div class="col-md-6">
                        <h6 class="fw-bold text-primary mb-3"><i class="fas fa-user me-2"></i>Informations personnelles</h6>
                        <div class="mb-3">{{ form_row(form.firstName) }}</div>
                        <div class="mb-3">{{ form_row(form.lastName) }}</div>
                        <div class="row">
                            <div class="col-md-6 mb-3">{{ form_row(form.gender) }}</div>
                            <div class="col-md-6 mb-3">{{ form_row(form.dateOfBirth) }}</div>
                        </div>
                    </div>
                </div>

                <hr class="my-4">

                <div class="row">
                    <div class="col-md-6">
                        <h6 class="fw-bold text-primary mb-3"><i class="fas fa-shield-alt me-2"></i>Type et permissions</h6>
                        <div class="mb-3">{{ form_row(form.userType) }}</div>
                        <div class="mb-3">{{ form_row(form.schoolGroup) }}</div>
                        <div class="mb-3">{{ form_row(form.schools) }}</div>
                        <div class="mb-3">{{ form_row(form.roles) }}</div>
                        <div class="mb-3">{{ form_row(form.isActive) }}</div>
                    </div>
                    <div class="col-md-6">
                        <h6 class="fw-bold text-primary mb-3"><i class="fas fa-address-book me-2"></i>Coordonnées</h6>
                        <div class="mb-3">{{ form_row(form.phone) }}</div>
                        <div class="mb-3">{{ form_row(form.address) }}</div>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                    <a href="{{ path('admin_user_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Enregistrer</button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>

<style>.roles-checkboxes .form-check { margin-bottom: 0.5rem; }</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const groupSelect = document.getElementById('user_schoolGroup');
    const schoolsSelect = document.getElementById('user_schools');
    if (groupSelect && schoolsSelect) {
        const allOptions = Array.from(schoolsSelect.options);
        function filterSchools() {
            const selectedGroupId = groupSelect.value;
            schoolsSelect.innerHTML = '';
            allOptions.forEach(option => {
                const groupId = option.getAttribute('data-group-id');
                if (!selectedGroupId || groupId === selectedGroupId) {
                    schoolsSelect.appendChild(option.cloneNode(true));
                }
            });
            if (schoolsSelect.options.length === 0) {
                const emptyOption = document.createElement('option');
                emptyOption.text = selectedGroupId ? 'Aucun établissement dans ce groupe' : 'Aucun établissement disponible';
                emptyOption.disabled = true;
                schoolsSelect.appendChild(emptyOption);
            }
        }
        groupSelect.addEventListener('change', filterSchools);
        if (groupSelect.value) { filterSchools(); }
    }
});
</script>
{% endblock %}
