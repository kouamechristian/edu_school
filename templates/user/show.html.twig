{% extends 'base.html.twig' %}

{% block title %}{{ user.fullName }}{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="fas fa-user me-2"></i> {{ user.fullName }}
                    </h4>
                    <span class="badge {{ user.isActive ? 'bg-success' : 'bg-danger' }}">
                        {{ user.isActive ? 'Actif' : 'Inactif' }}
                    </span>
                </div>
                <div class="card-body">
                    {# Avatar et info de base #}
                    <div class="text-center mb-4">
                        <div class="user-avatar" style="width: 80px; height: 80px; font-size: 2rem; margin: 0 auto;">
                            {{ user.initials }}
                        </div>
                        <h3 class="mt-3 mb-1">{{ user.fullName }}</h3>
                        <p class="text-muted">@{{ user.username }}</p>
                        {% if user.userType %}
                            <span class="badge bg-secondary">{{ user.userTypeLabel }}</span>
                        {% endif %}
                    </div>

                    <hr>

                    {# Informations de contact #}
                    <h5 class="mb-3"><i class="fas fa-envelope me-2"></i> Contact</h5>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Email :</strong><br>
                            <a href="mailto:{{ user.email }}">{{ user.email }}</a>
                        </div>
                        {% if user.phone %}
                        <div class="col-md-6">
                            <strong>Téléphone :</strong><br>
                            <span>{{ user.phone }}</span>
                        </div>
                        {% endif %}
                    </div>

                    {% if user.address %}
                    <div class="mb-3">
                        <strong><i class="fas fa-map-marker-alt me-2"></i> Adresse :</strong><br>
                        <span class="text-muted">{{ user.address|nl2br }}</span>
                    </div>
                    {% endif %}

                    <hr>

                    {# Informations personnelles #}
                    <h5 class="mb-3"><i class="fas fa-info-circle me-2"></i> Informations Personnelles</h5>
                    <div class="row mb-3">
                        {% if user.dateOfBirth %}
                        <div class="col-md-6">
                            <strong>Date de naissance :</strong><br>
                            <span class="text-muted">{{ user.dateOfBirth|date('d/m/Y') }}</span>
                        </div>
                        {% endif %}
                        {% if user.gender %}
                        <div class="col-md-6">
                            <strong>Genre :</strong><br>
                            <span class="text-muted">{{ user.gender == 'M' ? 'Masculin' : 'Féminin' }}</span>
                        </div>
                        {% endif %}
                    </div>

                    <hr>

                    {# Groupe d'établissements #}
                    {% if user.schoolGroup %}
                    <h5 class="mb-3"><i class="fas fa-sitemap me-2"></i> Groupe d'Établissements</h5>
                    <div class="mb-3">
                        <a href="{{ path('admin_school_group_show', {'id': user.schoolGroup.id}) }}" class="badge bg-info">
                            {{ user.schoolGroup.name }}
                        </a>
                    </div>
                    <hr>
                    {% endif %}

                    {# Établissements #}
                    {% if user.schools is not empty %}
                    <h5 class="mb-3"><i class="fas fa-school me-2"></i> Établissement(s)</h5>
                    <div class="mb-3">
                        {% for school in user.schools %}
                            <span class="badge bg-secondary me-1">{{ school.name }}</span>
                        {% endfor %}
                    </div>
                    <hr>
                    {% endif %}

                    {# Rôles et permissions #}
                    <h5 class="mb-3"><i class="fas fa-shield-alt me-2"></i> Rôles et Permissions</h5>
                    <div class="mb-3">
                        {% for role in user.roles %}
                            <span class="badge bg-info me-1">{{ role }}</span>
                        {% endfor %}
                    </div>

                    <hr>

                    {# Activité #}
                    <h5 class="mb-3"><i class="fas fa-history me-2"></i> Activité</h5>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Inscrit le :</strong><br>
                            <span class="text-muted">{{ user.createdAt|date('d/m/Y à H:i') }}</span>
                        </div>
                        <div class="col-md-6">
                            <strong>Dernière connexion :</strong><br>
                            <span class="text-muted">
                                {% if user.lastLogin %}
                                    {{ user.lastLogin|date('d/m/Y à H:i') }}
                                {% else %}
                                    Jamais connecté
                                {% endif %}
                            </span>
                        </div>
                    </div>

                    <div class="mt-4 d-flex justify-content-between">
                        <a href="{{ path('admin_user_index') }}" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-2"></i> Retour
                        </a>
                        <div>
                            <a href="{{ path('admin_user_edit', {'id': user.id}) }}" class="btn btn-warning">
                                <i class="fas fa-edit me-2"></i> Modifier
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            {# Actions rapides #}
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="mb-0">Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        {% if is_granted('ROLE_SUPER_ADMIN') %}
                        <form method="post" action="{{ path('admin_user_reset_password', {'id': user.id}) }}"
                              onsubmit="return confirm('Êtes-vous sûr de vouloir réinitialiser le mot de passe ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('reset-password' ~ user.id) }}">
                            <button type="submit" class="btn btn-warning w-100">
                                <i class="fas fa-key me-2"></i> Réinitialiser MDP
                            </button>
                        </form>
                        {% endif %}

                        <form method="post" action="{{ path('admin_user_toggle', {'id': user.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ user.id) }}">
                            <button type="submit" class="btn btn-{{ user.isActive ? 'secondary' : 'success' }} w-100">
                                <i class="fas fa-{{ user.isActive ? 'ban' : 'check' }} me-2"></i>
                                {{ user.isActive ? 'Désactiver' : 'Activer' }}
                            </button>
                        </form>

                        <form method="post" action="{{ path('admin_user_delete', {'id': user.id}) }}"
                              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                            <button type="submit" class="btn btn-danger w-100">
                                <i class="fas fa-trash me-2"></i> Supprimer
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            {# Statistiques #}
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Statistiques</h5>
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <i class="fas fa-calendar me-2"></i>
                        Membre depuis {{ user.createdAt|date('d/m/Y') }}
                    </div>
                    <div class="mb-2">
                        <i class="fas fa-clock me-2"></i>
                        {% if user.lastLogin %}
                            Dernière connexion : {{ user.lastLogin|date('d/m/Y') }}
                        {% else %}
                            Jamais connecté
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

