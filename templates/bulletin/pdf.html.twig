<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Bulletin de Notes</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: Arial, sans-serif;
            font-size: 11px;
            line-height: 1.4;
            color: #333;
        }
        
        .container {
            width: 100%;
            padding: 20px;
        }
        
        /* En-tête */
        .header {
            text-align: center;
            border-bottom: 3px solid #0066cc;
            padding-bottom: 15px;
            margin-bottom: 20px;
        }
        
        .header h1 {
            color: #0066cc;
            font-size: 24px;
            margin-bottom: 5px;
        }
        
        .header p {
            font-size: 12px;
            color: #666;
        }
        
        /* Informations élève */
        .student-info {
            background-color: #f5f5f5;
            padding: 15px;
            margin-bottom: 20px;
            border-radius: 5px;
        }
        
        .student-info table {
            width: 100%;
        }
        
        .student-info td {
            padding: 5px;
        }
        
        .student-info td:first-child {
            font-weight: bold;
            width: 30%;
        }
        
        /* Tableau des notes */
        .grades-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }
        
        .grades-table th {
            background-color: #0066cc;
            color: white;
            padding: 10px;
            text-align: left;
            font-size: 10px;
        }
        
        .grades-table td {
            border: 1px solid #ddd;
            padding: 8px;
            font-size: 10px;
        }
        
        .grades-table tr:nth-child(even) {
            background-color: #f9f9f9;
        }
        
        .grades-table tr:hover {
            background-color: #f0f0f0;
        }
        
        /* Moyennes */
        .averages {
            background-color: #e8f4f8;
            padding: 10px;
            margin-bottom: 20px;
            border-left: 4px solid #0066cc;
        }
        
        .averages table {
            width: 100%;
        }
        
        .averages td {
            padding: 5px;
        }
        
        .averages .label {
            font-weight: bold;
        }
        
        .averages .value {
            text-align: right;
            font-size: 16px;
            font-weight: bold;
            color: #0066cc;
        }
        
        /* Appréciations */
        .appreciation {
            border: 2px solid #0066cc;
            padding: 15px;
            margin-bottom: 20px;
            border-radius: 5px;
        }
        
        .appreciation h3 {
            color: #0066cc;
            margin-bottom: 10px;
            font-size: 14px;
        }
        
        .appreciation .mention {
            background-color: #ffd700;
            padding: 8px;
            margin-top: 10px;
            text-align: center;
            font-weight: bold;
            border-radius: 3px;
        }
        
        /* Signatures */
        .signatures {
            display: table;
            width: 100%;
            margin-top: 30px;
        }
        
        .signature {
            display: table-cell;
            width: 33%;
            text-align: center;
            vertical-align: top;
        }
        
        .signature p {
            margin-bottom: 50px;
            font-weight: bold;
        }
        
        .signature .line {
            border-top: 1px solid #333;
            width: 80%;
            margin: 0 auto;
        }
        
        /* Footer */
        .footer {
            text-align: center;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #ddd;
            font-size: 9px;
            color: #999;
        }
        
        /* Styles pour les valeurs */
        .text-center { text-align: center; }
        .text-right { text-align: right; }
        .text-success { color: #28a745; }
        .text-danger { color: #dc3545; }
        .text-warning { color: #ffc107; }
        .fw-bold { font-weight: bold; }
    </style>
</head>
<body>
    <div class="container">
        <!-- En-tête -->
        <div class="header">
            <h1>BULLETIN DE NOTES</h1>
            <p>{{ period.schoolYear.name }} - {{ period.name }}</p>
            <p>{{ period.school.name }}</p>
        </div>
        
        <!-- Informations élève -->
        <div class="student-info">
            <table>
                <tr>
                    <td>Nom et Prénom :</td>
                    <td><strong>{{ student.fullName }}</strong></td>
                    <td>Date de naissance :</td>
                    <td>{{ student.dateOfBirth ? student.dateOfBirth|date('d/m/Y') : '-' }}</td>
                </tr>
                <tr>
                    <td>Classe :</td>
                    <td>{{ period.school.name }}</td> {# À adapter selon votre logique #}
                    <td>Numéro :</td>
                    <td>{{ student.id }}</td>
                </tr>
            </table>
        </div>
        
        <!-- Tableau des moyennes par matière -->
        <table class="grades-table">
            <thead>
                <tr>
                    <th style="width: 40%;">Matière</th>
                    <th style="width: 15%; text-align: center;">Moyenne</th>
                    <th style="width: 10%; text-align: center;">Coef.</th>
                    <th style="width: 15%; text-align: center;">Moy. Classe</th>
                    <th style="width: 20%;">Appréciation</th>
                </tr>
            </thead>
            <tbody>
                {% for subject_data in averages.subjects %}
                    <tr>
                        <td class="fw-bold">{{ subject_data.subject.name }}</td>
                        <td class="text-center">
                            <strong class="{{ subject_data.average >= 10 ? 'text-success' : 'text-danger' }}">
                                {{ subject_data.average|number_format(2, '.', '') }}
                            </strong> / 20
                        </td>
                        <td class="text-center">{{ subject_data.coefficient|number_format(0, '.', '') }}</td>
                        <td class="text-center">-</td> {# Moyenne de classe à calculer #}
                        <td>{{ getAppreciation(subject_data.average) }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center">Aucune note enregistrée pour cette période</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
        
        <!-- Résumé des moyennes -->
        {% if averages.general_average %}
            <div class="averages">
                <table>
                    <tr>
                        <td class="label">Moyenne Générale :</td>
                        <td class="value {{ averages.general_average >= 10 ? 'text-success' : 'text-danger' }}">
                            {{ averages.general_average|number_format(2, '.', '') }} / 20
                        </td>
                    </tr>
                    {% if ranking.rank %}
                        <tr>
                            <td class="label">Classement :</td>
                            <td class="value">
                                {{ ranking.rank }} / {{ ranking.total }}
                            </td>
                        </tr>
                    {% endif %}
                    {% if ranking.class_average %}
                        <tr>
                            <td class="label">Moyenne de la classe :</td>
                            <td class="value">
                                {{ ranking.class_average|number_format(2, '.', '') }} / 20
                            </td>
                        </tr>
                    {% endif %}
                </table>
            </div>
            
            <!-- Appréciations et mentions -->
            <div class="appreciation">
                <h3>Appréciation générale :</h3>
                <p>{{ getAppreciation(averages.general_average) }}</p>
                
                {% set mention = getMention(averages.general_average) %}
                {% if mention %}
                    <div class="mention">
                        {{ mention }}
                    </div>
                {% endif %}
            </div>
        {% endif %}
        
        <!-- Signatures -->
        <div class="signatures">
            <div class="signature">
                <p>Le Professeur Principal</p>
                <div class="line"></div>
            </div>
            <div class="signature">
                <p>Le Directeur</p>
                <div class="line"></div>
            </div>
            <div class="signature">
                <p>Signature des Parents</p>
                <div class="line"></div>
            </div>
        </div>
        
        <!-- Footer -->
        <div class="footer">
            <p>Document généré le {{ generated_at|date('d/m/Y à H:i') }}</p>
            <p>{{ period.school.name }} - EDU-SCHOOL</p>
        </div>
    </div>
</body>
</html>

