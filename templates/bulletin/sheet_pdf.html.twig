<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <style>
        @page { margin: 16px 18px; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 8px; color: #000; }
        table { border-collapse: collapse; width: 100%; }
        td, th { border: 0.7pt solid #000; padding: 2px 4px; vertical-align: top; }
        .noborder, .noborder td { border: 0; }
        b { font-weight: bold; }
        .title td { font-weight: bold; font-size: 9px; }
        .right { text-align: right; }
        .center { text-align: center; }
        .ident td { font-size: 8px; }
        .ident .name { font-weight: bold; font-size: 9px; }
        .photo { width: 70px; text-align: center; vertical-align: middle; }
        .photo img { max-height: 70px; max-width: 64px; }

        table.grades th { background: #f0f0f0; font-weight: bold; text-align: center; font-size: 7.5px; }
        table.grades td { font-size: 7.5px; }
        table.grades td.disc { text-align: left; }
        table.grades td.sub { padding-left: 10px; font-style: italic; }
        table.grades td.c { text-align: center; }
        table.grades tr.bilan td { background: #e9e9e9; font-weight: bold; }
        table.grades tr.total td { font-weight: bold; }

        .bottom td { vertical-align: top; }
        .bottom .head { font-weight: bold; text-decoration: underline; text-align: center; }
        .moy-big { text-align: center; font-weight: bold; font-size: 12px; }
        .chk { display: inline-block; width: 7px; height: 7px; border: 0.7pt solid #000; text-align: center; line-height: 7px; font-size: 7px; margin-right: 3px; }
        .underline { text-decoration: underline; }
    </style>
</head>
<body>
    {% set s = student %}

    {# ── Bandeau titre ── #}
    <table class="title">
        <tr>
            <td style="width:62%">BULLETIN DE NOTES : {{ period.code }} {{ period.name|upper }}</td>
            <td class="right">Année Scolaire : {{ school_year ? school_year.name : '' }}</td>
        </tr>
    </table>

    {# ── Identité ── #}
    <table class="ident">
        <tr>
            <td colspan="2" class="name">Nom et Prénom(s) : {{ s.lastName|upper }} {{ s.firstName|upper }}</td>
            <td class="photo" rowspan="2">{% if photo_data %}<img src="{{ photo_data }}" alt="">{% endif %}</td>
        </tr>
        <tr>
            <td style="width:48%">
                <b>Matricule :</b> {{ s.matriculeNational ?: (s.matriculeInterne ?: 'AUCUN') }}<br>
                <b>Date de naissance :</b> {{ s.dateOfBirth ? s.dateOfBirth|date('d/m/Y') : '' }}<br>
                <b>Sexe :</b> {{ s.gender == 'M' ? 'MASCULIN' : (s.gender == 'F' ? 'FEMININ' : '') }}<br>
                <b>Nationalité :</b> {{ s.nationality ?: '' }}
            </td>
            <td>
                <b>Classe :</b> {{ s.classroom ? s.classroom.name : '' }}<br>
                <b>Effectif :</b> {{ effectif }}<br>
                <b>Situation Scolaire :</b> {{ s.isRepeating ? 'Doublant' : 'Non Doublant' }}<br>
                <b>Affecté :</b> {{ s.status == 'affecte' ? 'Oui' : 'Non' }}
            </td>
        </tr>
    </table>

    {# ── Tableau des notes ── #}
    <table class="grades">
        <thead>
            <tr>
                <th style="width:30%">Disciplines</th>
                <th>Moy./20</th>
                <th>Coef.</th>
                <th>Moy Coef.</th>
                <th>Rang</th>
                <th style="width:22%">Professeurs</th>
                <th style="width:22%">Appréciations signatures</th>
            </tr>
        </thead>
        <tbody>
            {% for row in rows %}
                <tr>
                    <td class="disc">{{ row.name }}</td>
                    {% if row.nc %}
                        <td class="c">NC</td><td class="c">NC</td><td class="c">NC</td><td class="c">NC</td>
                        <td>{{ row.teacher ?: '' }}</td><td></td>
                    {% else %}
                        <td class="c">{{ row.moy|number_format(row.moy == row.moy|round ? 0 : 2, ',', ' ') }}</td>
                        <td class="c">{{ row.coef|number_format(row.coef == row.coef|round ? 0 : 2, ',', ' ') }}</td>
                        <td class="c">{{ row.moy_coef|number_format(2, ',', ' ') }}</td>
                        <td class="c">{{ row.rank }} {{ row.rank == 1 ? 'er' : 'è' }}{{ row.ex ? ' EX' : '' }}</td>
                        <td>{{ row.teacher ?: '' }}</td>
                        <td>{{ row.appreciation }}</td>
                    {% endif %}
                </tr>
            {% endfor %}
            <tr class="total">
                <td class="disc">TOTAUX TRIMESTRE</td>
                <td class="c"></td>
                <td class="c">{{ total_coef|number_format(total_coef == total_coef|round ? 0 : 2, ',', ' ') }}</td>
                <td class="c">{{ total_moy_coef|number_format(2, ',', ' ') }}</td>
                <td colspan="3"></td>
            </tr>
        </tbody>
    </table>

    {# ── Assiduité / Moyenne / Résultat classe ── #}
    <table class="bottom">
        <tr>
            <td class="head" style="width:34%">Assiduité</td>
            <td class="head" style="width:33%">Moyenne Trimestrielle</td>
            <td class="head">Resultat de la classe</td>
        </tr>
        <tr>
            <td>
                Total d'heures d'absence : <b>{{ absence_total ?? 0 }} H</b><br>
                Justifiées : <b>{{ absence_justified ?? 0 }} H</b><br>
                Non justifiées : <b>{{ absence_unjustified ?? 0 }} H</b>
            </td>
            <td>
                {% if general_average is not null %}
                    <div class="moy-big">{{ general_average|number_format(2, ',', ' ') }}/20</div>
                    <div class="center"><b>Rang : {{ general_rank }} {{ general_rank == 1 ? 'er' : 'è' }}{{ general_rank_ex ? ' EX' : '' }}/{{ effectif }}</b></div>
                {% else %}
                    <div class="moy-big">NC</div>
                {% endif %}
            </td>
            <td>
                Moy de classe : <b>{{ class_average is not null ? class_average|number_format(2, ',', ' ') : '—' }}</b><br>
                Moyenne mini : <b>{{ class_min is not null ? class_min|number_format(class_min == class_min|round ? 0 : 2, ',', ' ') : '—' }}</b><br>
                Moyenne maxi : <b>{{ class_max is not null ? class_max|number_format(class_max == class_max|round ? 0 : 2, ',', ' ') : '—' }}</b>
            </td>
        </tr>
    </table>

    {# ── Mention / Appréciation / Signatures ── #}
    <table class="bottom">
        <tr>
            <td class="head" style="width:34%">Mention du conseil de classe</td>
            <td class="head" style="width:33%">Appréciation du conseil de classe :</td>
            <td class="head">Nom / Signature et cachet du chef d'Etablissement</td>
        </tr>
        <tr>
            <td>
                <div class="center underline" style="margin:2px 0;">DISTINCTIONS</div>
                <div><span class="chk">{{ general_average is not null and general_average >= 16 ? 'X' : '' }}</span>Tableau d'honneur + Félicitations</div>
                <div><span class="chk">{{ general_average is not null and general_average >= 14 and general_average < 16 ? 'X' : '' }}</span>Tableau d'honneur + Encouragement</div>
                <div><span class="chk">{{ general_average is not null and general_average >= 12 and general_average < 14 ? 'X' : '' }}</span>Tableau d'honneur</div>
                <div class="center underline" style="margin:4px 0 2px;">SANCTIONS</div>
                <div><span class="chk">&nbsp;</span>Avertissement Travail</div>
                <div><span class="chk">&nbsp;</span>Avertissement Conduite</div>
                <div><span class="chk">&nbsp;</span>Blâme Travail</div>
                <div><span class="chk">&nbsp;</span>Blâme Conduite</div>
            </td>
            <td>
                <div style="min-height:60px;"></div>
                <div class="center">Nom / Signature du professeur principal</div>
            </td>
            <td>
                <div style="min-height:46px;"></div>
                <div class="right">{% if s.school and s.school.director %}{{ s.school.director }}{% if director_role %} — ({{ director_role }}){% endif %}{% elseif director_role %}({{ director_role }}){% endif %}</div>
                <div class="right">{{ city }} le {{ generated_at|date('d/m/Y') }}</div>
            </td>
        </tr>
    </table>
</body>
</html>
