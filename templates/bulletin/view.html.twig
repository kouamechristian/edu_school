{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Bulletin de {{ student.fullName }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {# ── En-tête ── #}
    {% embed 'components/page_header.html.twig' with {
        title: 'Bulletin de ' ~ student.fullName,
        subtitle: period.schoolYear.name ~ '  ·  ' ~ period.name,
        icon: 'fa-file-alt',
        color: 'primary',
        breadcrumb: [
            { label: 'Bulletins', path: path('admin_bulletin_index') },
            { label: student.fullName }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_bulletin_pdf', {'studentId': student.id, 'periodId': period.id}) }}" class="btn btn-danger" target="_blank"><i class="fas fa-file-pdf me-1"></i> Télécharger PDF</a>
            <a href="{{ path('admin_bulletin_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {# ── Bandeau bulletin ── #}
    <div class="card mb-4">
        <div class="card-header bg-primary text-white text-center py-3">
            <h4 class="mb-1" style="color:#fff;">BULLETIN DE NOTES</h4>
            <p class="mb-0 opacity-75">{{ period.schoolYear.name }} — {{ period.name }}</p>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6"><div class="info-list">
                    <div class="info-row"><div class="info-label">Élève</div><div class="info-value fw-bold">{{ student.fullName }}</div></div>
                    <div class="info-row"><div class="info-label">Date de naissance</div><div class="info-value">{{ student.dateOfBirth ? student.dateOfBirth|date('d/m/Y') : '—' }}</div></div>
                </div></div>
                <div class="col-md-6"><div class="info-list">
                    <div class="info-row"><div class="info-label">Période</div><div class="info-value">{{ period.name }}</div></div>
                    <div class="info-row"><div class="info-label">Établissement</div><div class="info-value">{{ period.school.name }}</div></div>
                </div></div>
            </div>
        </div>
    </div>

    {# ── Moyennes par matière ── #}
    <div class="card table-card mb-4">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-book me-2"></i>Moyennes par matière</h6></div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Matière</th>
                            <th class="text-center">Moyenne</th>
                            <th class="text-center">Coefficient</th>
                            <th>Appréciation</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for subject_data in averages.subjects %}
                            <tr>
                                <td class="fw-semibold">{{ subject_data.subject.name }}</td>
                                <td class="text-center">
                                    <span class="badge badge-soft {{ subject_data.average >= 10 ? 'success' : 'danger' }} fs-6">{{ subject_data.average|number_format(2, '.', '') }} / 20</span>
                                </td>
                                <td class="text-center"><span class="badge badge-soft secondary">{{ subject_data.coefficient|number_format(0, '.', '') }}</span></td>
                                <td>
                                    {% if subject_data.average >= 16 %}<span class="badge badge-soft success">Très bien</span>
                                    {% elseif subject_data.average >= 14 %}<span class="badge badge-soft info">Bien</span>
                                    {% elseif subject_data.average >= 12 %}<span class="badge badge-soft">Assez bien</span>
                                    {% elseif subject_data.average >= 10 %}<span class="badge badge-soft warning">Passable</span>
                                    {% else %}<span class="badge badge-soft danger">Insuffisant</span>{% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="4">{{ empty_state('fa-clipboard', 'Aucune note', 'Aucune note enregistrée pour cette période.') }}</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# ── Résumé général + mention ── #}
    {% if averages.general_average %}
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card card-accent info h-100">
                    <div class="card-header"><h6 class="m-0 fw-bold" style="color:#0284c7;"><i class="fas fa-chart-line me-2"></i>Résumé</h6></div>
                    <div class="card-body">
                        <div class="row text-center g-3">
                            <div class="col-md-4">
                                <div class="stat-label">Moyenne générale</div>
                                <h2 class="text-{{ averages.general_average >= 10 ? 'success' : 'danger' }} mb-0">{{ averages.general_average|number_format(2, '.', '') }}</h2>
                                <small class="text-muted">/ 20</small>
                            </div>
                            {% if ranking.rank %}
                                <div class="col-md-4">
                                    <div class="stat-label">Classement</div>
                                    <h2 class="text-primary mb-0">{{ ranking.rank }}</h2>
                                    <small class="text-muted">/ {{ ranking.total }}</small>
                                </div>
                            {% endif %}
                            {% if ranking.class_average %}
                                <div class="col-md-4">
                                    <div class="stat-label">Moyenne de classe</div>
                                    <h2 class="mb-0" style="color:var(--es-text-muted);">{{ ranking.class_average|number_format(2, '.', '') }}</h2>
                                    <small class="text-muted">/ 20</small>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card card-accent success h-100">
                    <div class="card-header"><h6 class="m-0 fw-bold text-success"><i class="fas fa-award me-2"></i>Mention</h6></div>
                    <div class="card-body text-center d-flex flex-column justify-content-center">
                        <h4 class="mb-3">
                            {% if averages.general_average >= 16 %}<i class="fas fa-star text-warning"></i> Très bien
                            {% elseif averages.general_average >= 14 %}<i class="fas fa-thumbs-up text-info"></i> Bien
                            {% elseif averages.general_average >= 12 %}<i class="fas fa-check text-primary"></i> Assez bien
                            {% elseif averages.general_average >= 10 %}<i class="fas fa-hand-paper text-warning"></i> Passable
                            {% else %}<i class="fas fa-exclamation-triangle text-danger"></i> Insuffisant{% endif %}
                        </h4>
                        {% if averages.general_average >= 18 %}
                            <div class="alert alert-warning mb-0"><strong>Félicitations du conseil de classe</strong></div>
                        {% elseif averages.general_average >= 16 %}
                            <div class="alert alert-info mb-0"><strong>Compliments du conseil de classe</strong></div>
                        {% elseif averages.general_average >= 14 %}
                            <div class="alert alert-info mb-0"><strong>Encouragements</strong></div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
