{% extends 'base.html.twig' %}

{% block title %}Bulletin de {{ student.fullName }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">Bulletin de {{ student.fullName }}</h1>
        <div>
            <a href="{{ path('admin_bulletin_pdf', {'studentId': student.id, 'periodId': period.id}) }}" 
               class="btn btn-danger me-2"
               target="_blank">
                <i class="fas fa-file-pdf"></i> Télécharger PDF
            </a>
            <a href="{{ path('admin_bulletin_index') }}" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Retour
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <!-- En-tête du bulletin -->
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0">BULLETIN DE NOTES</h4>
                    <p class="mb-0">{{ period.schoolYear.name }} - {{ period.name }}</p>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-4">Élève :</dt>
                                <dd class="col-sm-8"><strong>{{ student.fullName }}</strong></dd>

                                <dt class="col-sm-4">Date de naissance :</dt>
                                <dd class="col-sm-8">{{ student.dateOfBirth ? student.dateOfBirth|date('d/m/Y') : '-' }}</dd>
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-4">Période :</dt>
                                <dd class="col-sm-8">{{ period.name }}</dd>

                                <dt class="col-sm-4">Établissement :</dt>
                                <dd class="col-sm-8">{{ period.school.name }}</dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Moyennes par matière -->
            <div class="card shadow-sm mb-3">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-book"></i> Moyennes par Matière</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Matière</th>
                                    <th class="text-center">Moyenne</th>
                                    <th class="text-center">Coefficient</th>
                                    <th>Appréciation</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for subject_data in averages.subjects %}
                                    <tr>
                                        <td><strong>{{ subject_data.subject.name }}</strong></td>
                                        <td class="text-center">
                                            <span class="badge bg-{{ subject_data.average >= 10 ? 'success' : 'danger' }} fs-6">
                                                {{ subject_data.average|number_format(2, '.', '') }} / 20
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-secondary">{{ subject_data.coefficient|number_format(0, '.', '') }}</span>
                                        </td>
                                        <td>
                                            {% if subject_data.average >= 16 %}
                                                <span class="badge bg-success">Très bien</span>
                                            {% elseif subject_data.average >= 14 %}
                                                <span class="badge bg-info">Bien</span>
                                            {% elseif subject_data.average >= 12 %}
                                                <span class="badge bg-primary">Assez bien</span>
                                            {% elseif subject_data.average >= 10 %}
                                                <span class="badge bg-warning">Passable</span>
                                            {% else %}
                                                <span class="badge bg-danger">Insuffisant</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="4" class="text-center py-4">
                                            <i class="fas fa-info-circle text-muted"></i>
                                            Aucune note enregistrée pour cette période
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Résumé général -->
            {% if averages.general_average %}
                <div class="row">
                    <div class="col-md-8">
                        <div class="card shadow-sm">
                            <div class="card-header bg-info text-white">
                                <h5 class="mb-0"><i class="fas fa-chart-line"></i> Résumé</h5>
                            </div>
                            <div class="card-body">
                                <div class="row text-center">
                                    <div class="col-md-4">
                                        <h6>Moyenne Générale</h6>
                                        <h2 class="text-{{ averages.general_average >= 10 ? 'success' : 'danger' }}">
                                            {{ averages.general_average|number_format(2, '.', '') }}
                                        </h2>
                                        <p class="text-muted">/ 20</p>
                                    </div>
                                    {% if ranking.rank %}
                                        <div class="col-md-4">
                                            <h6>Classement</h6>
                                            <h2 class="text-primary">{{ ranking.rank }}</h2>
                                            <p class="text-muted">/ {{ ranking.total }}</p>
                                        </div>
                                    {% endif %}
                                    {% if ranking.class_average %}
                                        <div class="col-md-4">
                                            <h6>Moyenne de Classe</h6>
                                            <h2 class="text-secondary">{{ ranking.class_average|number_format(2, '.', '') }}</h2>
                                            <p class="text-muted">/ 20</p>
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card shadow-sm">
                            <div class="card-header bg-success text-white">
                                <h5 class="mb-0"><i class="fas fa-award"></i> Mention</h5>
                            </div>
                            <div class="card-body text-center">
                                <h4 class="mb-3">
                                    {% if averages.general_average >= 16 %}
                                        <i class="fas fa-star text-warning"></i>
                                        Très bien
                                    {% elseif averages.general_average >= 14 %}
                                        <i class="fas fa-thumbs-up text-info"></i>
                                        Bien
                                    {% elseif averages.general_average >= 12 %}
                                        <i class="fas fa-check text-primary"></i>
                                        Assez bien
                                    {% elseif averages.general_average >= 10 %}
                                        <i class="fas fa-hand-paper text-warning"></i>
                                        Passable
                                    {% else %}
                                        <i class="fas fa-exclamation-triangle text-danger"></i>
                                        Insuffisant
                                    {% endif %}
                                </h4>
                                {% if averages.general_average >= 18 %}
                                    <div class="alert alert-warning mb-0">
                                        <strong>Félicitations du conseil de classe</strong>
                                    </div>
                                {% elseif averages.general_average >= 16 %}
                                    <div class="alert alert-info mb-0">
                                        <strong>Compliments du conseil de classe</strong>
                                    </div>
                                {% elseif averages.general_average >= 14 %}
                                    <div class="alert alert-primary mb-0">
                                        <strong>Encouragements</strong>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

