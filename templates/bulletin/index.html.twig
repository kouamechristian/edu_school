{% extends 'base.html.twig' %}

{% block title %}Génération des Bulletins{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-2">Génération des Bulletins</h1>
            {% if current_school and current_year %}
                <p class="text-muted mb-0">
                    <i class="fas fa-school"></i> {{ current_school.name }}
                    <span class="mx-2">|</span>
                    <i class="fas fa-calendar"></i> {{ current_year.name }}
                </p>
            {% endif %}
        </div>
    </div>

    {% include '_flash.html.twig' %}

    {% if not current_school or not current_year %}
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle"></i>
            Veuillez sélectionner un établissement et une année scolaire.
        </div>
    {% else %}
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-primary text-white">
                <h6 class="mb-0">
                    <i class="fas fa-filter"></i> Sélection
                </h6>
            </div>
            <div class="card-body">
                <form method="get" class="row g-3">
                    <div class="col-md-5">
                        <label class="form-label">Classe <span class="text-danger">*</span></label>
                        <select name="classroom" class="form-select" onchange="this.form.submit()" required>
                            <option value="">-- Sélectionnez une classe --</option>
                            {% for classroom in classrooms %}
                                <option value="{{ classroom.id }}" {{ selected_classroom == classroom.id ? 'selected' : '' }}>
                                    {{ classroom.fullName }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Période <span class="text-danger">*</span></label>
                        <select name="period" class="form-select" onchange="this.form.submit()" required>
                            <option value="">-- Sélectionnez une période --</option>
                            {% for period in periods %}
                                <option value="{{ period.id }}" {{ selected_period == period.id ? 'selected' : '' }}>
                                    {{ period.name }} ({{ period.dateRange }})
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">&nbsp;</label>
                        <a href="{{ path('admin_bulletin_index') }}" class="btn btn-secondary w-100">
                            <i class="fas fa-redo"></i> Réinitialiser
                        </a>
                    </div>
                </form>
            </div>
        </div>

        {% if selected_classroom and selected_period %}
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">
                        <i class="fas fa-list"></i> Liste des Élèves
                        <span class="badge bg-primary ms-2">{{ students|length }} élève(s)</span>
                    </h6>
                    {% if students|length > 0 %}
                        <form method="post" action="{{ path('admin_bulletin_batch_generate') }}" style="display: inline;">
                            <input type="hidden" name="classroom" value="{{ selected_classroom }}">
                            <input type="hidden" name="period" value="{{ selected_period }}">
                            <button type="submit" class="btn btn-success btn-sm" onclick="return confirm('Générer tous les bulletins ?')">
                                <i class="fas fa-file-pdf"></i> Générer tous les bulletins
                            </button>
                        </form>
                    {% endif %}
                </div>
                <div class="card-body p-0">
                    {% if students is empty %}
                        <div class="text-center py-5">
                            <i class="fas fa-users fa-3x text-muted mb-3"></i>
                            <p class="text-muted">Aucun élève trouvé dans cette classe.</p>
                        </div>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 5%;">Rang</th>
                                        <th style="width: 40%;">Élève</th>
                                        <th style="width: 20%;">Moyenne générale</th>
                                        <th style="width: 20%;">Appréciation</th>
                                        <th style="width: 15%;" class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for index, item in students %}
                                        <tr>
                                            <td>
                                                <strong class="text-primary">#{{ index + 1 }}</strong>
                                            </td>
                                            <td>
                                                <strong>{{ item.student.fullName }}</strong>
                                            </td>
                                            <td>
                                                {% if item.average %}
                                                    <span class="badge bg-{{ item.average >= 10 ? 'success' : 'danger' }} fs-6">
                                                        {{ item.average|number_format(2, '.', '') }} / 20
                                                    </span>
                                                {% else %}
                                                    <span class="text-muted">-</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if item.average %}
                                                    {% if item.average >= 16 %}
                                                        <span class="badge bg-success">Très bien</span>
                                                    {% elseif item.average >= 14 %}
                                                        <span class="badge bg-info">Bien</span>
                                                    {% elseif item.average >= 12 %}
                                                        <span class="badge bg-primary">Assez bien</span>
                                                    {% elseif item.average >= 10 %}
                                                        <span class="badge bg-warning">Passable</span>
                                                    {% else %}
                                                        <span class="badge bg-danger">Insuffisant</span>
                                                    {% endif %}
                                                {% endif %}
                                            </td>
                                            <td class="text-end">
                                                <div class="btn-group btn-group-sm">
                                                    <a href="{{ path('admin_bulletin_generate', {'studentId': item.student.id, 'periodId': selected_period}) }}" 
                                                       class="btn btn-outline-info" 
                                                       title="Voir le bulletin"
                                                       target="_blank">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a href="{{ path('admin_bulletin_pdf', {'studentId': item.student.id, 'periodId': selected_period}) }}" 
                                                       class="btn btn-outline-danger" 
                                                       title="Télécharger PDF"
                                                       target="_blank">
                                                        <i class="fas fa-file-pdf"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% else %}
            <div class="alert alert-info text-center">
                <i class="fas fa-info-circle fa-2x mb-3"></i><br>
                <strong>Sélectionnez une classe et une période</strong> pour afficher la liste des élèves et générer les bulletins.
            </div>
        {% endif %}
    {% endif %}
</div>
{% endblock %}

