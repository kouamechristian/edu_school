{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Bulletins{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Bulletins',
        subtitle: (current_school and current_year) ? current_school.name ~ '  ·  ' ~ current_year.name : 'Bulletins par niveau et période',
        icon: 'fa-file-alt',
        color: 'primary',
        breadcrumb: [ { label: 'Bulletins' } ]
    } %}{% endembed %}

    {% include '_flash.html.twig' %}

    <div class="d-flex justify-content-end mb-3">
        <a href="{{ path('admin_bulletin_new') }}" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i> Nouveau
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            {% if bulletins is empty %}
                {{ empty_state('fa-file-alt', 'Aucun bulletin', 'Cliquez sur « Nouveau » pour créer un bulletin.') }}
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Libellé</th>
                                <th>Niveau</th>
                                <th>Période</th>
                                <th class="text-center">Moyenne sur</th>
                                <th>Créé le</th>
                                <th class="text-end" width="160">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for b in bulletins %}
                            <tr>
                                <td class="fw-semibold">{{ b.libelle }}</td>
                                <td>{{ b.level ? b.level.name : '—' }}</td>
                                <td>{{ b.period ? b.period.name : '—' }}</td>
                                <td class="text-center"><span class="badge badge-soft secondary">/ {{ b.moyenneSur }}</span></td>
                                <td>{{ b.createdAt ? b.createdAt|date('d/m/Y H:i') : '—' }}</td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a href="{{ path('admin_bulletin_show', {'id': b.id}) }}" class="btn btn-outline-primary" title="Ouvrir">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        {% if is_granted('ROLE_ADMIN') %}
                                        <form method="post" action="{{ path('admin_bulletin_delete', {'id': b.id}) }}" onsubmit="return confirm('Supprimer ce bulletin ?');" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ b.id) }}">
                                            <button class="btn btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                        </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
