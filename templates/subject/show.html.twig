{% extends 'base.html.twig' %}

{% block title %}{{ subject.name }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: subject.name,
        subtitle: 'Matière — ' ~ subject.code,
        icon: 'fa-book',
        color: 'primary',
        breadcrumb: [
            { label: 'Matières', path: path('admin_subject_index') },
            { label: subject.name }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_subject_edit', {'id': subject.id}) }}" class="btn btn-warning"><i class="fas fa-edit me-1"></i> Modifier</a>
            <a href="{{ path('admin_subject_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="m-0 fw-bold text-primary"><i class="fas fa-info-circle me-2"></i>Informations</h6>
                    <span class="badge badge-soft {{ subject.isActive ? 'success' : 'danger' }}">{{ subject.isActive ? 'Active' : 'Inactive' }}</span>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Code</div><div class="info-value">{{ subject.code }}</div></div>
                            <div class="info-row"><div class="info-label">Type</div><div class="info-value">{% if subject.type %}<span class="badge bg-info">{{ subject.typeLabel }}</span>{% else %}<span class="text-muted">Non défini</span>{% endif %}</div></div>
                            <div class="info-row"><div class="info-label">Établissement</div><div class="info-value">{% if subject.school %}<a href="{{ path('admin_school_show', {'id': subject.school.id}) }}">{{ subject.school.name }}</a>{% else %}<span class="badge badge-soft info">Matière globale</span>{% endif %}</div></div>
                            <div class="info-row"><div class="info-label">Niveau</div><div class="info-value">{% if subject.level %}{{ subject.level.name }}{% else %}<span class="badge badge-soft info">Tous niveaux</span>{% endif %}</div></div>
                        </div></div>
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Coefficient</div><div class="info-value">{{ subject.coefficient ?? 'Non défini' }}</div></div>
                            <div class="info-row"><div class="info-label">Heures/semaine</div><div class="info-value">{{ subject.hoursPerWeek ?? 'Non défini' }}h</div></div>
                            <div class="info-row"><div class="info-label">Couleur</div><div class="info-value">{% if subject.color %}<span class="badge" style="background-color: {{ subject.color }}; color: #fff;">{{ subject.color }}</span>{% else %}<span class="text-muted">Non définie</span>{% endif %}</div></div>
                        </div></div>
                    </div>
                    <div class="info-list mt-2"><div class="info-row"><div class="info-label">Équivalence</div><div class="info-value">
                        {% if subject.subjectEquivalent %}
                            {% set eq = subject.subjectEquivalent %}
                            <span class="badge badge-soft info me-1">{{ eq.code }} — {{ eq.libelle }}{% if eq.numeroOrdre is not null %} <small class="text-muted">(n°{{ eq.numeroOrdre }})</small>{% endif %}</span>
                        {% else %}
                            <span class="text-muted">Aucune équivalence</span>
                        {% endif %}
                    </div></div></div>
                    {% if subject.description %}
                        <div class="info-list mt-2"><div class="info-row"><div class="info-label">Description</div><div class="info-value">{{ subject.description|nl2br }}</div></div></div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-clock-rotate-left me-2"></i>Informations</h6></div>
                <div class="card-body">
                    <div class="info-list">
                        <div class="info-row"><div class="info-label">Créée le</div><div class="info-value">{{ subject.createdAt|date('d/m/Y') }}</div></div>
                        <div class="info-row"><div class="info-label">Modifiée le</div><div class="info-value">{{ subject.updatedAt|date('d/m/Y') }}</div></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
