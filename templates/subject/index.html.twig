{% extends 'base.html.twig' %}

{% block title %}Gestion des Matières{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h3 mb-3">
                <i class="fas fa-book me-2"></i> Gestion des Matières
            </h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="{{ path('admin_subject_new') }}" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i> Nouvelle Matière
            </a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('warning') %}
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Liste des Matières ({{ subjects|length }})</h5>
        </div>
        <div class="card-body">
            {% if subjects is empty %}
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    Aucune matière enregistrée. Cliquez sur "Nouvelle Matière" pour commencer.
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Nom</th>
                                <th>Niveau</th>
                                <th>Type</th>
                                <th>Coefficient</th>
                                <th>Heures/sem.</th>
                                <th>Couleur</th>
                                <th>Statut</th>
                                <th width="200">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for subject in subjects %}
                            <tr>
                                <td><strong>{{ subject.code }}</strong></td>
                                <td>{{ subject.name }}</td>
                                <td>
                                    {% if subject.level %}
                                        <span class="badge bg-secondary">{{ subject.level.name }}</span>
                                    {% else %}
                                        <span class="badge bg-info">Tous niveaux</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <span class="badge bg-{{ subject.type == 'obligatoire' ? 'danger' : (subject.type == 'optionnelle' ? 'warning' : 'info') }}">
                                        {{ subject.typeLabel }}
                                    </span>
                                </td>
                                <td>{{ subject.coefficient ?? '-' }}</td>
                                <td>{{ subject.hoursPerWeek ?? '-' }}h</td>
                                <td>
                                    {% if subject.color %}
                                        <span class="badge" style="background-color: {{ subject.color }}; color: white;">
                                            {{ subject.color }}
                                        </span>
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                                <td>
                                    {% if subject.isActive %}
                                        <span class="badge bg-success">Active</span>
                                    {% else %}
                                        <span class="badge bg-danger">Inactive</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a href="{{ path('admin_subject_show', {'id': subject.id}) }}" 
                                           class="btn btn-info" title="Voir">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="{{ path('admin_subject_edit', {'id': subject.id}) }}" 
                                           class="btn btn-warning" title="Modifier">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form method="post" action="{{ path('admin_subject_toggle', {'id': subject.id}) }}" 
                                              style="display:inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ subject.id) }}">
                                            <button type="submit" class="btn btn-secondary" 
                                                    title="{{ subject.isActive ? 'Désactiver' : 'Activer' }}">
                                                <i class="fas fa-{{ subject.isActive ? 'ban' : 'check' }}"></i>
                                            </button>
                                        </form>
                                        <form method="post" action="{{ path('admin_subject_delete', {'id': subject.id}) }}" 
                                              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette matière ?');"
                                              style="display:inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ subject.id) }}">
                                            <button type="submit" class="btn btn-danger" title="Supprimer">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

