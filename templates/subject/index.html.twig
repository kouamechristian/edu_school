{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Gestion des Matières{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Gestion des Matières',
        subtitle: 'Les matières sont organisées par niveau — entrez dans un niveau pour les gérer',
        icon: 'fa-book',
        color: 'primary',
        breadcrumb: [ { label: 'Matières' } ]
    } %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    {% if current_school is null %}
        {{ empty_state('fa-school', 'Aucun établissement', 'Sélectionnez un établissement pour voir les matières.') }}
    {% elseif levels is empty %}
        {{ empty_state('fa-layer-group', 'Aucun niveau', 'Créez d’abord des niveaux dans Configuration → Niveaux.') }}
    {% else %}
        <div class="row g-3">
            {% for item in levels %}
            <div class="col-md-6 col-xl-4">
                <a href="{{ path('admin_subject_by_level', {'id': item.level.id}) }}" class="card h-100 text-decoration-none text-reset border-0 shadow-sm subject-level-card">
                    <div class="card-body d-flex align-items-center">
                        <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center me-3" style="width:48px;height:48px;flex:0 0 48px;">
                            <i class="fas fa-layer-group"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h6 class="mb-1 fw-bold">{{ item.level.name }}</h6>
                            <span class="badge badge-soft secondary">{{ item.count }} matière{{ item.count > 1 ? 's' : '' }}</span>
                        </div>
                        <i class="fas fa-chevron-right text-muted"></i>
                    </div>
                </a>
            </div>
            {% endfor %}
        </div>
    {% endif %}
</div>

<style>
.subject-level-card { transition: transform .12s ease, box-shadow .12s ease; }
.subject-level-card:hover { transform: translateY(-2px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.1) !important; }
</style>
{% endblock %}
