{# Widget chatbot IA flottant — inclus dans base.html.twig #}
{% if app.user %}
{% set role_color = {
    'admin': '#6f42c1',
    'directeur': '#0d6efd',
    'enseignant': '#198754',
    'personnel': '#fd7e14',
    'eleve': '#0dcaf0',
    'parent': '#20c997'
}[app.user.userType] | default('#6c757d') %}

<style>
.chatbot-toggle {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: {{ role_color }};
    color: #fff;
    border: none;
    box-shadow: 0 4px 16px rgba(0,0,0,.25);
    cursor: pointer;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    transition: transform .2s, box-shadow .2s;
}
.chatbot-toggle:hover { transform: scale(1.1); box-shadow: 0 6px 24px rgba(0,0,0,.3); }
.chatbot-toggle .chatbot-unread {
    position: absolute;
    top: -2px;
    right: -2px;
    width: 18px;
    height: 18px;
    background: #dc3545;
    border-radius: 50%;
    font-size: .65rem;
    display: none;
    align-items: center;
    justify-content: center;
}

.chatbot-window {
    position: fixed;
    bottom: 90px;
    right: 24px;
    width: 380px;
    max-height: 520px;
    background: var(--bs-body-bg, #fff);
    border-radius: 16px;
    box-shadow: 0 8px 40px rgba(0,0,0,.2);
    z-index: 9998;
    display: none;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--bs-border-color, #dee2e6);
}
.chatbot-window.open { display: flex; }

.chatbot-header {
    background: {{ role_color }};
    color: #fff;
    padding: 14px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.chatbot-header h6 { margin: 0; font-weight: 600; }
.chatbot-header .btn-close-chat {
    background: none;
    border: none;
    color: rgba(255,255,255,.8);
    font-size: 1.1rem;
    cursor: pointer;
}
.chatbot-header .btn-close-chat:hover { color: #fff; }

.chatbot-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    max-height: 350px;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.chat-msg {
    max-width: 85%;
    padding: 10px 14px;
    border-radius: 14px;
    font-size: .875rem;
    line-height: 1.45;
    word-wrap: break-word;
}
.chat-msg.user {
    align-self: flex-end;
    background: {{ role_color }};
    color: #fff;
    border-bottom-right-radius: 4px;
}
.chat-msg.bot {
    align-self: flex-start;
    background: var(--bs-tertiary-bg, #f0f0f0);
    color: var(--bs-body-color, #212529);
    border-bottom-left-radius: 4px;
}
.chat-msg .msg-time {
    font-size: .7rem;
    opacity: .7;
    margin-top: 4px;
    display: block;
}

.chat-typing {
    display: none;
    align-self: flex-start;
    padding: 10px 14px;
    background: var(--bs-tertiary-bg, #f0f0f0);
    border-radius: 14px;
    border-bottom-left-radius: 4px;
    font-size: .8rem;
    color: var(--bs-secondary-color, #6c757d);
}
.chat-typing.show { display: block; }
.chat-typing span {
    display: inline-block;
    animation: typingDot 1.2s infinite;
}
.chat-typing span:nth-child(2) { animation-delay: .2s; }
.chat-typing span:nth-child(3) { animation-delay: .4s; }
@keyframes typingDot {
    0%, 60%, 100% { opacity: .3; transform: translateY(0); }
    30% { opacity: 1; transform: translateY(-3px); }
}

.chatbot-input {
    padding: 12px;
    border-top: 1px solid var(--bs-border-color, #dee2e6);
    display: flex;
    gap: 8px;
}
.chatbot-input input {
    flex: 1;
    border: 1px solid var(--bs-border-color, #dee2e6);
    border-radius: 20px;
    padding: 8px 16px;
    font-size: .875rem;
    outline: none;
    background: var(--bs-body-bg, #fff);
    color: var(--bs-body-color, #212529);
}
.chatbot-input input:focus { border-color: {{ role_color }}; }
.chatbot-input button {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: {{ role_color }};
    color: #fff;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}
.chatbot-input button:disabled { opacity: .5; cursor: not-allowed; }

@media (max-width: 480px) {
    .chatbot-window {
        right: 8px;
        left: 8px;
        bottom: 80px;
        width: auto;
        max-height: 70vh;
    }
}
</style>

{# Bouton flottant #}
<button class="chatbot-toggle" id="chatbot-toggle" title="Assistant IA EDU-BOT">
    <i class="fas fa-comment-dots"></i>
    <span class="chatbot-unread" id="chatbot-unread">1</span>
</button>

{# Fenêtre de chat #}
<div class="chatbot-window" id="chatbot-window">
    <div class="chatbot-header">
        <div>
            <h6><i class="fas fa-robot me-2"></i>EDU-BOT</h6>
            <small style="opacity:.8;font-size:.75rem">Assistant IA • {{ app.user.userType | capitalize }}</small>
        </div>
        <button class="btn-close-chat" id="chatbot-close" title="Fermer">
            <i class="fas fa-times"></i>
        </button>
    </div>

    <div class="chatbot-messages" id="chatbot-messages">
        <div class="chat-msg bot">
            Bonjour {{ app.user.firstName }} ! Je suis EDU-BOT, votre assistant scolaire.
            Comment puis-je vous aider ?
            <span class="msg-time">{{ "now"|date("H:i") }}</span>
        </div>
    </div>
    <div class="chat-typing" id="chatbot-typing">
        <span>●</span><span>●</span><span>●</span> EDU-BOT réfléchit...
    </div>

    <div class="chatbot-input">
        <input type="text" id="chatbot-input" placeholder="Posez votre question..." autocomplete="off">
        <button id="chatbot-send" title="Envoyer"><i class="fas fa-paper-plane"></i></button>
    </div>
</div>

<script>
(function() {
    const toggle = document.getElementById('chatbot-toggle');
    const chatWindow = document.getElementById('chatbot-window');
    const closeBtn = document.getElementById('chatbot-close');
    const input = document.getElementById('chatbot-input');
    const sendBtn = document.getElementById('chatbot-send');
    const messagesDiv = document.getElementById('chatbot-messages');
    const typingDiv = document.getElementById('chatbot-typing');
    const unreadBadge = document.getElementById('chatbot-unread');
    const chatbotUrl = '{{ path("ai_chatbot") }}';
    let conversationHistory = [];
    let isOpen = false;

    toggle.addEventListener('click', function() {
        isOpen = !isOpen;
        chatWindow.classList.toggle('open', isOpen);
        toggle.querySelector('i').className = isOpen ? 'fas fa-times' : 'fas fa-comment-dots';
        unreadBadge.style.display = 'none';
        if (isOpen) input.focus();
    });

    closeBtn.addEventListener('click', function() {
        isOpen = false;
        chatWindow.classList.remove('open');
        toggle.querySelector('i').className = 'fas fa-comment-dots';
    });

    function addMessage(text, isUser) {
        const msg = document.createElement('div');
        msg.className = 'chat-msg ' + (isUser ? 'user' : 'bot');
        const now = new Date();
        const time = now.getHours().toString().padStart(2,'0') + ':' + now.getMinutes().toString().padStart(2,'0');
        msg.innerHTML = escapeHtml(text) + '<span class="msg-time">' + time + '</span>';
        messagesDiv.appendChild(msg);
        messagesDiv.scrollTop = messagesDiv.scrollHeight;
    }

    function escapeHtml(str) {
        const d = document.createElement('div');
        d.textContent = str;
        return d.innerHTML.replace(/\n/g, '<br>');
    }

    function sendMessage() {
        const text = input.value.trim();
        if (!text) return;

        addMessage(text, true);
        conversationHistory.push({ role: 'user', content: text });
        input.value = '';
        sendBtn.disabled = true;
        typingDiv.classList.add('show');

        fetch(chatbotUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: text, history: conversationHistory.slice(-10) })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            typingDiv.classList.remove('show');
            sendBtn.disabled = false;
            const answer = data.answer || data.error || 'Erreur inconnue';
            addMessage(answer, false);
            conversationHistory.push({ role: 'assistant', content: answer });
            if (!isOpen) {
                unreadBadge.style.display = 'flex';
            }
        })
        .catch(function() {
            typingDiv.classList.remove('show');
            sendBtn.disabled = false;
            addMessage('Désolé, une erreur est survenue. Veuillez réessayer.', false);
        });
    }

    sendBtn.addEventListener('click', sendMessage);
    input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });
})();
</script>
{% endif %}
