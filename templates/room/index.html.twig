{% extends 'base.html.twig' %}

{% block title %}Gestion des Salles{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-2">Gestion des Salles</h1>
            {% if current_school %}
                <p class="text-muted mb-0">
                    <i class="fas fa-school"></i> {{ current_school.name }}
                    <span class="badge bg-primary ms-2">{{ rooms|length }} salle(s)</span>
                </p>
            {% endif %}
        </div>
        <a href="{{ path('admin_room_new') }}" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nouvelle Salle
        </a>
    </div>

    {% include '_flash.html.twig' %}

    {% if not current_school %}
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle"></i>
            Veuillez sélectionner un établissement pour voir les salles.
        </div>
    {% else %}
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <form method="get" class="row g-3">
                    <div class="col-md-6">
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="fas fa-search"></i>
                            </span>
                            <input type="text" 
                                   name="search" 
                                   class="form-control" 
                                   placeholder="Rechercher par nom ou code..." 
                                   value="{{ search|default('') }}">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <select name="type" class="form-select">
                            <option value="">Tous les types</option>
                            <option value="classroom" {% if type == 'classroom' %}selected{% endif %}>Salle de classe</option>
                            <option value="laboratory" {% if type == 'laboratory' %}selected{% endif %}>Laboratoire</option>
                            <option value="computer_room" {% if type == 'computer_room' %}selected{% endif %}>Salle informatique</option>
                            <option value="amphitheater" {% if type == 'amphitheater' %}selected{% endif %}>Amphithéâtre</option>
                            <option value="gym" {% if type == 'gym' %}selected{% endif %}>Salle de sport</option>
                            <option value="library" {% if type == 'library' %}selected{% endif %}>Bibliothèque</option>
                            <option value="meeting_room" {% if type == 'meeting_room' %}selected{% endif %}>Salle de réunion</option>
                            <option value="multipurpose" {% if type == 'multipurpose' %}selected{% endif %}>Salle polyvalente</option>
                            <option value="workshop" {% if type == 'workshop' %}selected{% endif %}>Atelier</option>
                            <option value="other" {% if type == 'other' %}selected{% endif %}>Autre</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-filter"></i> Filtrer
                        </button>
                    </div>
                </form>
            </div>

            <div class="card-body p-0">
                {% if rooms is empty %}
                    <div class="text-center py-5">
                        <i class="fas fa-door-open fa-3x text-muted mb-3"></i>
                        <p class="text-muted">Aucune salle trouvée.</p>
                    </div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Code</th>
                                    <th>Nom</th>
                                    <th>Type</th>
                                    <th>Localisation</th>
                                    <th>Capacité</th>
                                    <th>Statut</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for room in rooms %}
                                    <tr>
                                        <td>
                                            <strong class="text-primary">{{ room.code }}</strong>
                                        </td>
                                        <td>{{ room.name }}</td>
                                        <td>
                                            {% if room.type %}
                                                <span class="badge bg-secondary">
                                                    {{ room.type|replace({'_': ' '})|title }}
                                                </span>
                                            {% else %}
                                                <span class="text-muted">-</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if room.building or room.floor %}
                                                <small>
                                                    {% if room.building %}
                                                        <i class="fas fa-building"></i> Bât. {{ room.building }}
                                                    {% endif %}
                                                    {% if room.floor %}
                                                        <i class="fas fa-layer-group"></i> {{ room.floor }}
                                                    {% endif %}
                                                </small>
                                            {% else %}
                                                <span class="text-muted">-</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if room.capacity %}
                                                <i class="fas fa-users"></i> {{ room.capacity }}
                                            {% else %}
                                                <span class="text-muted">-</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if room.isActive %}
                                                <span class="badge bg-success">Active</span>
                                            {% else %}
                                                <span class="badge bg-danger">Inactive</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-end">
                                            <div class="btn-group btn-group-sm">
                                                <a href="{{ path('admin_room_show', {'id': room.id}) }}" 
                                                   class="btn btn-outline-info" 
                                                   title="Détails">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a href="{{ path('admin_room_edit', {'id': room.id}) }}" 
                                                   class="btn btn-outline-warning" 
                                                   title="Modifier">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <form method="post" 
                                                      action="{{ path('admin_room_toggle', {'id': room.id}) }}" 
                                                      style="display: inline;">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ room.id) }}">
                                                    <button type="submit" 
                                                            class="btn btn-outline-secondary" 
                                                            title="{{ room.isActive ? 'Désactiver' : 'Activer' }}">
                                                        <i class="fas fa-power-off"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}

