{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Gestion des Salles{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Gestion des Salles',
        subtitle: current_school ? current_school.name ~ '  ·  ' ~ rooms|length ~ ' salle(s)' : 'Salles et localisation',
        icon: 'fa-door-closed',
        color: 'primary',
        breadcrumb: [ { label: 'Salles' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_room_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouvelle Salle</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    {% if not current_school %}
        <div class="alert alert-warning"><i class="fas fa-exclamation-triangle me-2"></i>Veuillez sélectionner un établissement pour voir les salles.</div>
    {% else %}
        <div class="card filter-card mb-4">
            <div class="card-body">
                <form method="get" class="row g-3 align-items-end">
                    <div class="col-md-6">
                        <label class="form-label">Recherche</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-search"></i></span>
                            <input type="text" name="search" class="form-control" placeholder="Rechercher par nom ou code..." value="{{ search|default('') }}">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Type</label>
                        <select name="type" class="form-select">
                            <option value="">Tous les types</option>
                            <option value="classroom" {% if type == 'classroom' %}selected{% endif %}>Salle de classe</option>
                            <option value="laboratory" {% if type == 'laboratory' %}selected{% endif %}>Laboratoire</option>
                            <option value="computer_room" {% if type == 'computer_room' %}selected{% endif %}>Salle informatique</option>
                            <option value="amphitheater" {% if type == 'amphitheater' %}selected{% endif %}>Amphithéâtre</option>
                            <option value="gym" {% if type == 'gym' %}selected{% endif %}>Salle de sport</option>
                            <option value="library" {% if type == 'library' %}selected{% endif %}>Bibliothèque</option>
                            <option value="meeting_room" {% if type == 'meeting_room' %}selected{% endif %}>Salle de réunion</option>
                            <option value="multipurpose" {% if type == 'multipurpose' %}selected{% endif %}>Salle polyvalente</option>
                            <option value="workshop" {% if type == 'workshop' %}selected{% endif %}>Atelier</option>
                            <option value="other" {% if type == 'other' %}selected{% endif %}>Autre</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100"><i class="fas fa-filter me-1"></i> Filtrer</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card table-card">
            <div class="card-body">
                {% if rooms is empty %}
                    {{ empty_state('fa-door-open', 'Aucune salle', 'Aucune salle ne correspond à vos critères.') }}
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr><th>Code</th><th>Nom</th><th>Type</th><th>Localisation</th><th>Capacité</th><th>Statut</th><th class="text-end">Actions</th></tr>
                            </thead>
                            <tbody>
                                {% for room in rooms %}
                                    <tr>
                                        <td><strong class="text-primary">{{ room.code }}</strong></td>
                                        <td>{{ room.name }}</td>
                                        <td>{% if room.type %}<span class="badge badge-soft secondary">{{ room.type|replace({'_': ' '})|title }}</span>{% else %}<span class="text-muted">—</span>{% endif %}</td>
                                        <td>
                                            {% if room.building or room.floor %}
                                                <small>{% if room.building %}<i class="fas fa-building me-1 text-muted"></i>Bât. {{ room.building }}{% endif %}{% if room.floor %} <i class="fas fa-layer-group me-1 text-muted"></i>{{ room.floor }}{% endif %}</small>
                                            {% else %}<span class="text-muted">—</span>{% endif %}
                                        </td>
                                        <td>{% if room.capacity %}<i class="fas fa-users me-1 text-muted"></i>{{ room.capacity }}{% else %}<span class="text-muted">—</span>{% endif %}</td>
                                        <td><span class="badge badge-soft {{ room.isActive ? 'success' : 'danger' }}">{{ room.isActive ? 'Active' : 'Inactive' }}</span></td>
                                        <td class="text-end">
                                            <div class="btn-group btn-group-sm">
                                                <a href="{{ path('admin_room_show', {'id': room.id}) }}" class="btn btn-outline-info" title="Détails"><i class="fas fa-eye"></i></a>
                                                <a href="{{ path('admin_room_edit', {'id': room.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                                <form method="post" action="{{ path('admin_room_toggle', {'id': room.id}) }}" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ room.id) }}">
                                                    <button type="submit" class="btn btn-outline-secondary" title="{{ room.isActive ? 'Désactiver' : 'Activer' }}"><i class="fas fa-power-off"></i></button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% include '_pagination.html.twig' with { pagination: rooms } %}
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
