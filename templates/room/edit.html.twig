{% extends 'base.html.twig' %}

{% block title %}Modifier la Salle{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-xl-9">
            {% embed 'components/page_header.html.twig' with {
                title: 'Modifier la Salle',
                subtitle: room.code ~ ' — ' ~ room.name,
                icon: 'fa-door-closed',
                color: 'primary',
                breadcrumb: [
                    { label: 'Salles', path: path('admin_room_index') },
                    { label: room.code, path: path('admin_room_show', {'id': room.id}) },
                    { label: 'Modifier' }
                ]
            } %}
                {% block actions %}
                    <a href="{{ path('admin_room_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
                {% endblock %}
            {% endembed %}

            {% include '_flash.html.twig' %}

            <div class="card">
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="row">
                            <div class="col-md-6 mb-3">{{ form_row(form.code) }}</div>
                            <div class="col-md-6 mb-3">{{ form_row(form.name) }}</div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">{{ form_row(form.type) }}</div>
                            <div class="col-md-6 mb-3">{{ form_row(form.capacity) }}</div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">{{ form_row(form.building) }}</div>
                            <div class="col-md-4 mb-3">{{ form_row(form.floor) }}</div>
                            <div class="col-md-4 mb-3">
                                <div class="form-check mt-4 pt-2">{{ form_widget(form.isActive) }} {{ form_label(form.isActive) }}</div>
                            </div>
                        </div>
                        <div class="mb-3">{{ form_row(form.equipment) }}</div>
                        <div class="mb-3">{{ form_row(form.description) }}</div>
                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a href="{{ path('admin_room_index') }}" class="btn btn-light"><i class="fas fa-times me-1"></i> Annuler</a>
                            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Enregistrer les modifications</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>

            {# Zone dangereuse #}
            {% if is_granted('ROLE_ADMIN') %}
            <div class="card card-accent danger mt-4">
                <div class="card-body">
                    <h6 class="fw-bold text-danger"><i class="fas fa-exclamation-triangle me-2"></i>Zone dangereuse</h6>
                    <p class="text-muted small">La suppression de cette salle est irréversible. Assurez-vous qu'elle n'est pas utilisée dans des cours ou des classes.</p>
                    <form method="post" action="{{ path('admin_room_delete', {'id': room.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette salle ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ room.id) }}">
                        <button type="submit" class="btn btn-danger"><i class="fas fa-trash me-1"></i> Supprimer la salle</button>
                    </form>
                </div>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
