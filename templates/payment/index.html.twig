{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Gestion des Paiements{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Gestion des Paiements',
        subtitle: current_school ? current_school.name : 'Encaissements et suivi',
        icon: 'fa-credit-card',
        color: 'primary',
        breadcrumb: [ { label: 'Paiements' } ]
    } %}
        {% block actions %}
            {% if current_school %}
                {% if cash_register_open and cash_register_validated %}
                    <a href="{{ path('admin_payment_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouveau Paiement</a>
                {% else %}
                    <button type="button" class="btn btn-primary disabled" aria-disabled="true" title="Caisse non disponible"><i class="fas fa-plus me-1"></i> Nouveau Paiement</button>
                {% endif %}
            {% endif %}
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    {% if current_school and not cash_register_open %}
        <div class="alert alert-warning d-flex align-items-center">
            <i class="fas fa-triangle-exclamation me-2 fa-lg"></i>
            <div>
                Votre caisse n'est pas ouverte. Ouvrez votre caisse pour enregistrer des paiements.
                <a href="{{ path('admin_cash_register_open') }}" class="alert-link ms-1">Ouvrir ma caisse</a>
            </div>
        </div>
    {% elseif current_school and cash_register_open and not cash_register_validated %}
        <div class="alert alert-warning d-flex align-items-center">
            <i class="fas fa-lock me-2 fa-lg"></i>
            <div>
                Votre caisse n'a pas encore été validée par le fondateur. Aucun paiement n'est possible tant qu'elle n'est pas validée.
            </div>
        </div>
    {% endif %}

    {% if current_school %}
        {# ── Statistiques ── #}
        <div class="row g-3 mb-4">
            <div class="col-6 col-xl-3">
                <div class="stat-card primary h-100"><div class="card-body d-flex align-items-center justify-content-between">
                    <div><div class="stat-label mb-1">Total Paiements</div><div class="stat-value">{{ stats.total }}</div></div>
                    <div class="stat-icon"><i class="fas fa-credit-card"></i></div>
                </div></div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="stat-card success h-100"><div class="card-body d-flex align-items-center justify-content-between">
                    <div><div class="stat-label mb-1">Montant Total</div><div class="stat-value" style="font-size:1.1rem;">{{ stats.total_amount|number_format(0, ',', ' ') }} <small class="text-muted">FCFA</small></div></div>
                    <div class="stat-icon"><i class="fas fa-cash-register"></i></div>
                </div></div>
            </div>
            <a href="{{ path('admin_payment_pending') }}" class="col-6 col-xl-3 text-decoration-none">
                <div class="stat-card warning h-100"><div class="card-body d-flex align-items-center justify-content-between">
                    <div><div class="stat-label mb-1">En Attente</div><div class="stat-value">{{ all_payments|filter(payment => payment.status == 'en_attente')|length }}</div></div>
                    <div class="stat-icon"><i class="fas fa-clock"></i></div>
                </div></div>
            </a>
            <a href="{{ path('admin_payment_recent') }}" class="col-6 col-xl-3 text-decoration-none">
                <div class="stat-card info h-100"><div class="card-body d-flex align-items-center justify-content-between">
                    <div><div class="stat-label mb-1">Cette Semaine</div><div class="stat-value">{{ all_payments|filter(payment => payment.createdAt >= date('-7 days'))|length }}</div></div>
                    <div class="stat-icon"><i class="fas fa-calendar-alt"></i></div>
                </div></div>
            </a>
        </div>

        {# ── Filtres ── #}
        <div class="card filter-card mb-4">
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Recherche</label>
                        <input type="text" class="form-control" id="searchInput" placeholder="Rechercher..." value="{{ search_term }}">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Statut</label>
                        <select class="form-select" id="statusFilter">
                            <option value="">Tous les statuts</option>
                            <option value="en_attente" {{ current_status == 'en_attente' ? 'selected' : '' }}>En attente</option>
                            <option value="payé" {{ current_status == 'payé' ? 'selected' : '' }}>Payé</option>
                            <option value="partiellement_payé" {{ current_status == 'partiellement_payé' ? 'selected' : '' }}>Partiellement payé</option>
                            <option value="annulé" {{ current_status == 'annulé' ? 'selected' : '' }}>Annulé</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Méthode</label>
                        <select class="form-select" id="methodFilter">
                            <option value="">Toutes méthodes</option>
                            <option value="espèces" {{ current_method == 'espèces' ? 'selected' : '' }}>Espèces</option>
                            <option value="chèque" {{ current_method == 'chèque' ? 'selected' : '' }}>Chèque</option>
                            <option value="virement" {{ current_method == 'virement' ? 'selected' : '' }}>Virement</option>
                            <option value="carte" {{ current_method == 'carte' ? 'selected' : '' }}>Carte</option>
                            <option value="mobile_money" {{ current_method == 'mobile_money' ? 'selected' : '' }}>Mobile Money</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-primary w-100" onclick="applyFilters()"><i class="fas fa-filter me-1"></i> Filtrer</button>
                    </div>
                </div>
            </div>
        </div>

        {# ── Tableau ── #}
        <div class="card table-card">
            <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des paiements</h6></div>
            <div class="card-body">
                {# Recherche instantanée dans le tableau affiché #}
                <div class="mb-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                        <input type="text" id="paySearch" class="form-control" placeholder="Rechercher dans la page (N°, élève, frais, méthode…)…" autocomplete="off">
                        <button type="button" class="btn btn-light" id="paySearchClear" title="Effacer"><i class="fas fa-times"></i></button>
                    </div>
                    <div class="small text-muted mt-1" id="paySearchInfo" style="display:none;"></div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" id="paymentsTable">
                        <thead>
                            <tr><th>N° Paiement</th><th>Élève</th><th>Frais</th><th class="text-end">Montant</th><th>Date</th><th>Méthode</th><th>Statut</th><th class="text-end">Actions</th></tr>
                        </thead>
                        <tbody>
                            {% for payment in payments %}
                                <tr class="js-payment-row {{ payment.status == 'annulé' ? 'table-danger' : '' }}">
                                    <td>
                                        <span class="badge badge-soft secondary">{{ payment.paymentNumber }}</span>
                                        {% if payment.reference %}<br><small class="text-muted">{{ payment.reference }}</small>{% endif %}
                                    </td>
                                    <td><strong>{{ payment.student.fullName }}</strong><br><small class="text-muted">{{ payment.student.matriculeInterne }}</small></td>
                                    <td><span class="badge badge-soft info">{{ payment.fee.name }}</span></td>
                                    <td class="text-end fw-bold">{{ payment.amount|number_format(0, ',', ' ') }} FCFA</td>
                                    <td>
                                        <span class="{% if payment.paymentDate >= date('-1 day') %}text-success{% else %}text-muted{% endif %}">{{ payment.paymentDate|date('d/m/Y') }}</span>
                                        <br><small class="text-muted">{{ payment.createdAt|date('H:i') }}</small>
                                    </td>
                                    <td><span class="badge badge-soft secondary">{{ payment.paymentMethodLabel }}</span></td>
                                    <td><span class="badge bg-{{ payment.statusColor }}">{{ payment.statusLabel }}</span></td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a href="{{ path('admin_payment_show', {'id': payment.id}) }}" class="btn btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a>
                                            {% if payment.status == 'payé' %}
                                                <a href="{{ path('admin_payment_receipt', {'id': payment.id}) }}" target="_blank" rel="noopener" class="btn btn-outline-success" title="Reçu PDF"><i class="fas fa-file-pdf"></i></a>
                                            {% endif %}
                                            {% if payment.status == 'en_attente' or payment.status == 'partiellement_payé' %}
                                                <form method="post" action="{{ path('admin_payment_confirm', {'id': payment.id}) }}" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('confirm' ~ payment.id) }}">
                                                    <button type="submit" class="btn btn-outline-success" title="Confirmer"><i class="fas fa-check"></i></button>
                                                </form>
                                                <form method="post" action="{{ path('admin_payment_cancel', {'id': payment.id}) }}" class="d-inline"
                                                      data-confirm="Voulez-vous vraiment annuler le paiement <strong>{{ payment.paymentNumber }}</strong> de <strong>{{ payment.amount|number_format(0, ',', ' ') }} FCFA</strong> de l'élève <strong>{{ payment.student.fullName }}</strong> ?"
                                                      data-confirm-title="Annuler le paiement"
                                                      data-confirm-btn="Oui, annuler"
                                                      data-confirm-icon="warning">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ payment.id) }}">
                                                    <button type="submit" class="btn btn-outline-danger" title="Annuler"><i class="fas fa-times"></i></button>
                                                </form>
                                            {% endif %}
                                            {% if payment.status == 'payé' %}
                                            <form method="post" action="{{ path('admin_payment_cancel', {'id': payment.id}) }}" class="d-inline"
                                                  data-confirm="Voulez-vous vraiment annuler le paiement <strong>{{ payment.paymentNumber }}</strong> de <strong>{{ payment.amount|number_format(0, ',', ' ') }} FCFA</strong> de l'élève <strong>{{ payment.student.fullName }}</strong> ?<br><small class='text-muted'>Le montant sera retiré du frais de l'élève.</small>"
                                                  data-confirm-title="Annuler le paiement"
                                                  data-confirm-btn="Oui, annuler"
                                                  data-confirm-icon="warning">
                                                <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ payment.id) }}">
                                                <button type="submit" class="btn btn-outline-danger" title="Annuler le paiement"><i class="fas fa-ban"></i></button>
                                            </form>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr><td colspan="8">{{ empty_state('fa-credit-card', 'Aucun paiement', 'Aucun paiement ne correspond à vos critères.') }}</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% include '_pagination.html.twig' with { pagination: payments } %}
            </div>
        </div>
    {% else %}
        <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-school"></i></div>
            <h6>Sélectionnez un établissement</h6>
            <p>Veuillez sélectionner un établissement pour voir les paiements.</p>
            <a href="{{ path('admin_school_index') }}" class="btn btn-primary"><i class="fas fa-school me-1"></i> Gérer les Établissements</a>
        </div>
    {% endif %}
</div>

<script>
function applyFilters() {
    const search = document.getElementById('searchInput').value;
    const status = document.getElementById('statusFilter').value;
    const method = document.getElementById('methodFilter').value;
    let url = new URL(window.location.href);
    url.searchParams.set('search', search);
    url.searchParams.set('status', status);
    url.searchParams.set('method', method);
    window.location.href = url.toString();
}
document.getElementById('searchInput')?.addEventListener('keypress', function(e) {
    if (e.key === 'Enter') applyFilters();
});

// ── Recherche instantanée dans le tableau affiché ──
(function () {
    var input = document.getElementById('paySearch');
    var clearBtn = document.getElementById('paySearchClear');
    var info = document.getElementById('paySearchInfo');
    if (!input) return;

    function normalize(s) {
        return (s || '').toString().toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
    }

    function applyInstant() {
        var q = normalize(input.value.trim());
        var rows = document.querySelectorAll('#paymentsTable tbody tr.js-payment-row');
        var shown = 0;
        rows.forEach(function (tr) {
            var match = q === '' || normalize(tr.textContent).indexOf(q) !== -1;
            tr.style.display = match ? '' : 'none';
            if (match) shown++;
        });
        if (q === '') {
            info.style.display = 'none';
        } else {
            info.style.display = '';
            info.textContent = shown + ' résultat(s) sur cette page · pour chercher dans tous les paiements, utilisez le filtre « Recherche » ci-dessus.';
        }
    }

    input.addEventListener('input', applyInstant);
    if (clearBtn) clearBtn.addEventListener('click', function () { input.value = ''; applyInstant(); input.focus(); });
})();
</script>
{% endblock %}
