{% extends 'base.html.twig' %}

{% block title %}Détails Paiement{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Paiement ' ~ payment.paymentNumber,
        subtitle: payment.student.fullName,
        icon: 'fa-receipt',
        color: 'primary',
        breadcrumb: [
            { label: 'Paiements', path: path('admin_payment_index') },
            { label: payment.paymentNumber }
        ]
    } %}
        {% block actions %}
            {% if payment.status == 'payé' %}<a href="{{ path('admin_payment_receipt', {'id': payment.id}) }}" class="btn btn-success"><i class="fas fa-file-pdf me-1"></i> Reçu PDF</a>{% endif %}
            <a href="{{ path('admin_payment_edit', {'id': payment.id}) }}" class="btn btn-warning"><i class="fas fa-edit me-1"></i> Modifier</a>
            <a href="{{ path('admin_payment_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold text-primary"><i class="fas fa-receipt me-2"></i>Informations du paiement</h6>
            <span class="badge bg-{{ payment.statusColor }}">{{ payment.statusLabel }}</span>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6"><div class="info-list">
                    <div class="info-row"><div class="info-label">Élève</div><div class="info-value">{{ payment.student.fullName }} <small class="text-muted">({{ payment.student.matriculeInterne }})</small></div></div>
                    <div class="info-row"><div class="info-label">Frais</div><div class="info-value">{{ payment.fee.name }}</div></div>
                    <div class="info-row"><div class="info-label">Date</div><div class="info-value">{{ payment.paymentDate ? payment.paymentDate|date('d/m/Y') : '—' }}</div></div>
                    <div class="info-row"><div class="info-label">Méthode</div><div class="info-value"><span class="badge badge-soft secondary">{{ payment.paymentMethodLabel }}</span></div></div>
                </div></div>
                <div class="col-md-6"><div class="info-list">
                    <div class="info-row"><div class="info-label">Montant</div><div class="info-value fw-bold text-primary">{{ payment.amount|number_format(0, ',', ' ') }} F</div></div>
                    <div class="info-row"><div class="info-label">Référence</div><div class="info-value">{{ payment.reference ?: '—' }}</div></div>
                    <div class="info-row"><div class="info-label">Caissière</div><div class="info-value">{{ payment.recordedBy ? payment.recordedBy.fullName : '—' }}</div></div>
                    <div class="info-row"><div class="info-label">Caisse</div><div class="info-value">{{ payment.cashRegister ? payment.cashRegister.cashier.fullName : '—' }}</div></div>
                </div></div>
            </div>
            {% if payment.notes %}
                <div class="info-list mt-2"><div class="info-row"><div class="info-label">Notes</div><div class="info-value">{{ payment.notes|nl2br }}</div></div></div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
