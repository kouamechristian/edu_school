<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Reçu {{ payment.paymentNumber }}</title>
    <style>
        body { font-family: Arial, sans-serif; font-size: 12px; color: #111; }
        .header { text-align: center; margin-bottom: 12px; border-bottom: 2px solid #1e3a5f; padding-bottom: 8px; }
        .header .title { font-size: 18px; font-weight: bold; color: #1e3a5f; }
        .amount { color: #1e3a5f; }
        .muted { color: #666; }
        .box { border: 1px solid #ddd; padding: 10px; border-radius: 6px; }
        .row { display: table; width: 100%; }
        .col { display: table-cell; vertical-align: top; width: 50%; }
        .kv { margin: 0 0 6px 0; }
        .kv strong { display: inline-block; min-width: 120px; }
        .amount { font-size: 16px; font-weight: bold; }
        .footer { margin-top: 12px; text-align: center; font-size: 10px; }
        hr { border: 0; border-top: 1px solid #eee; margin: 10px 0; }
    </style>
</head>
<body>
    <div class="header">
        <div class="title">Reçu de paiement</div>
        <div class="muted">N° {{ payment.paymentNumber }}{% if payment.reference %} — Réf. {{ payment.reference }}{% endif %}</div>
    </div>

    <div class="box">
        <div class="row">
            <div class="col">
                <p class="kv"><strong>Élève</strong> {{ payment.student.fullName }}{% if payment.student.matriculeInterne %} ({{ payment.student.matriculeInterne }}){% endif %}</p>
                <p class="kv"><strong>Frais</strong> {{ payment.fee.name }}</p>
                <p class="kv"><strong>Date</strong> {{ payment.paymentDate ? payment.paymentDate|date('d/m/Y') : '-' }}</p>
                <p class="kv"><strong>Méthode</strong> {{ payment.paymentMethodLabel }}</p>
            </div>
            <div class="col">
                <p class="kv"><strong>Statut</strong> {{ payment.statusLabel }}</p>
                <p class="kv"><strong>Montant</strong> <span class="amount">{{ payment.amount|number_format(0, ',', ' ') }} F CFA</span></p>
                <p class="kv"><strong>Caissière</strong> {{ payment.recordedBy ? payment.recordedBy.fullName : '-' }}</p>
                <p class="kv"><strong>Caisse</strong> {{ payment.cashRegister ? payment.cashRegister.cashier.fullName : '-' }}</p>
            </div>
        </div>

        {% if payment.notes %}
            <hr>
            <p class="kv"><strong>Notes</strong> {{ payment.notes }}</p>
        {% endif %}
    </div>

    <div class="footer muted">
        Document généré le {{ "now"|date('d/m/Y H:i') }}
    </div>
</body>
</html>

