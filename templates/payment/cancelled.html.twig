{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Paiements annulés{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Paiements annulés',
        subtitle: total ~ ' paiement(s) annulé(s)',
        icon: 'fa-ban',
        color: 'danger',
        breadcrumb: [
            { label: 'Paiements', path: path('admin_payment_index') },
            { label: 'Annulés' }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_payment_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-danger"><i class="fas fa-ban me-2"></i>Liste des paiements annulés</h6></div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr><th>N° Paiement</th><th>Élève</th><th>Frais</th><th class="text-end">Montant</th><th>Date</th><th>Méthode</th><th class="text-end">Actions</th></tr>
                    </thead>
                    <tbody>
                        {% for payment in payments %}
                            <tr class="table-danger">
                                <td>
                                    <span class="badge badge-soft secondary">{{ payment.paymentNumber }}</span>
                                    {% if payment.reference %}<br><small class="text-muted">{{ payment.reference }}</small>{% endif %}
                                </td>
                                <td><strong>{{ payment.student.fullName }}</strong><br><small class="text-muted">{{ payment.student.matriculeInterne }}</small></td>
                                <td><span class="badge badge-soft info">{{ payment.fee.name }}</span></td>
                                <td class="text-end fw-bold">{{ payment.amount|number_format(0, ',', ' ') }} FCFA</td>
                                <td class="text-muted">{{ payment.paymentDate|date('d/m/Y') }}</td>
                                <td><span class="badge badge-soft secondary">{{ payment.paymentMethodLabel }}</span></td>
                                <td class="text-end"><a href="{{ path('admin_payment_show', {'id': payment.id}) }}" class="btn btn-sm btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a></td>
                            </tr>
                        {% else %}
                            <tr><td colspan="7">{{ empty_state('fa-ban', 'Aucun paiement annulé', 'Aucun paiement n\'a été annulé.') }}</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% include '_pagination.html.twig' with { pagination: payments } %}
        </div>
    </div>
</div>
{% endblock %}
