{% extends 'base.html.twig' %}

{% block title %}Nouveau Paiement{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Nouveau Paiement',
        icon: 'fa-credit-card',
        color: 'primary',
        breadcrumb: [
            { label: 'Paiements', path: path('admin_payment_index') },
            { label: 'Nouveau' }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_payment_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-credit-card me-2"></i>Enregistrer un paiement</h6></div>
        <div class="card-body">
            {{ form_start(form, {'attr': {'id': 'paymentForm'}}) }}
                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_row(form.student) }}
                        <div class="mt-2" id="studentSummary" data-summary-url="{{ path('admin_payment_student_summary', {id: 0}) }}" style="display:none;">
                            <div class="card card-accent success mb-0">
                                <div class="card-body py-2">
                                    <div class="row g-2 small">
                                        <div class="col-md-6"><strong>Nom</strong> : <span data-field="nom">—</span></div>
                                        <div class="col-md-6"><strong>Prénom</strong> : <span data-field="prenom">—</span></div>
                                        <div class="col-md-6"><strong>Classe</strong> : <span data-field="classe">—</span></div>
                                        <div class="col-md-6"><strong>Montant scolarité</strong> : <span data-field="montantScolarite">—</span></div>
                                        <div class="col-md-6"><strong>Montant payé</strong> : <span data-field="montantPaye">—</span></div>
                                        <div class="col-md-6"><strong>Montant restant</strong> : <span data-field="montantRestant" class="fw-bold text-danger">—</span></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3" id="fee-wrap">{{ form_row(form.fee) }}</div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3" id="amount-wrap">{{ form_row(form.amount) }}</div>
                    <div class="col-md-4 mb-3">{{ form_row(form.paymentDate) }}</div>
                    <div class="col-md-4 mb-3">{{ form_row(form.paymentMethod) }}</div>
                </div>

                {# Imputation par échéancier : aperçu de la répartition du montant saisi #}
                <div class="row" id="imputation-wrap" style="display:none;">
                    <div class="col-12 mb-3">
                        <div class="card card-accent info mb-0">
                            <div class="card-header py-2"><strong><i class="fas fa-list-ol me-1"></i> Imputation par échéancier</strong></div>
                            <div class="card-body py-2">
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle mb-0" id="imputation-table">
                                        <thead>
                                            <tr>
                                                <th>N°</th><th>Échéance</th>
                                                <th class="text-end">Montant</th>
                                                <th class="text-end">Reste</th>
                                                <th class="text-end">Imputé</th>
                                                <th class="text-end">Nouveau solde</th>
                                            </tr>
                                        </thead>
                                        <tbody></tbody>
                                    </table>
                                </div>
                                <div class="small text-muted mt-2" id="imputation-note"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="alert alert-info py-2 mb-0"><i class="fas fa-info-circle me-1"></i>La référence / N° de transaction est générée automatiquement.</div>
                    </div>
                </div>

                <div class="mb-3">{{ form_row(form.notes) }}</div>

                <div class="pt-3 border-top">
                    <button type="submit" class="btn btn-success"><i class="fas fa-check me-1"></i> Enregistrer</button>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var el = document.querySelector('.js-student-select');
            if (!el) return;

            function formatMoneyXof(value) {
                if (value === null || value === undefined || value === '') return '—';
                var n = Number(value);
                if (Number.isNaN(n)) return String(value);
                return n.toLocaleString('fr-FR', { maximumFractionDigits: 0 }) + ' F CFA';
            }

            async function loadStudentSummary(studentId) {
                var box = document.getElementById('studentSummary');
                if (!box) return;
                if (!studentId) { box.style.display = 'none'; return; }
                var baseUrl = box.getAttribute('data-summary-url') || '';
                var url = baseUrl.replace('/0/', '/' + String(studentId) + '/');
                try {
                    var res = await fetch(url, { headers: { 'Accept': 'application/json' } });
                    if (!res.ok) throw new Error('HTTP ' + res.status);
                    var data = await res.json();
                    box.style.display = '';
                    box.querySelector('[data-field="nom"]').textContent = data.nom ?? '—';
                    box.querySelector('[data-field="prenom"]').textContent = data.prenom ?? '—';
                    box.querySelector('[data-field="classe"]').textContent = data.classe ?? '—';
                    box.querySelector('[data-field="montantScolarite"]').textContent = formatMoneyXof(data.montantScolarite);
                    box.querySelector('[data-field="montantPaye"]').textContent = formatMoneyXof(data.montantPaye);
                    box.querySelector('[data-field="montantRestant"]').textContent = formatMoneyXof(data.montantRestant);
                } catch (e) {
                    box.style.display = 'none';
                    box.querySelector('[data-field="nom"]').textContent = '—';
                    box.querySelector('[data-field="prenom"]').textContent = '—';
                    box.querySelector('[data-field="classe"]').textContent = '—';
                    box.querySelector('[data-field="montantScolarite"]').textContent = '—';
                    box.querySelector('[data-field="montantPaye"]').textContent = '—';
                    box.querySelector('[data-field="montantRestant"]').textContent = '—';
                }
            }

            // ── Frais en cascade : ne proposer que les frais de l'élève sélectionné ──
            // Données embarquées (aucun appel réseau) : { studentId: [ {id,name,remaining} ] }.
            var feesByStudent = {{ fees_by_student|json_encode|raw }};

            function loadStudentFees(studentId) {
                var sel = document.querySelector('#fee-wrap select');
                if (!sel) return;

                var previous = sel.value;
                sel.innerHTML = '';

                if (!studentId) {
                    sel.appendChild(new Option('Sélectionnez d\'abord un élève', ''));
                    return;
                }

                var fees = feesByStudent[studentId] || [];
                if (fees.length === 0) {
                    sel.appendChild(new Option('Aucun frais à payer pour cet élève', ''));
                    return;
                }

                sel.appendChild(new Option('Sélectionnez un frais', ''));
                fees.forEach(function (f) {
                    var opt = new Option(f.name + ' — Reste : ' + formatMoneyXof(f.remaining), f.id);
                    opt.setAttribute('data-remaining', f.remaining);
                    sel.appendChild(opt);
                });

                if (previous) { sel.value = previous; }
            }

            // Pré-remplir le montant avec le reste dû du frais choisi.
            var feeSelect = document.querySelector('#fee-wrap select');
            var amountInput = document.querySelector('#amount-wrap input');
            if (feeSelect) {
                feeSelect.addEventListener('change', function () {
                    var opt = feeSelect.options[feeSelect.selectedIndex];
                    var remaining = opt ? parseFloat(opt.getAttribute('data-remaining')) : NaN;
                    if (amountInput && !Number.isNaN(remaining) && remaining > 0) {
                        amountInput.value = Math.round(remaining);
                    }
                    renderImputation();
                });
            }
            if (amountInput) {
                amountInput.addEventListener('input', renderImputation);
            }

            // ── Aperçu de l'imputation par échéancier ──
            function selectedFeeSchedules() {
                if (!feeSelect || !el.value || !feeSelect.value) return null;
                var fees = feesByStudent[el.value] || [];
                var fee = fees.find(function (f) { return String(f.id) === String(feeSelect.value); });
                return fee ? (fee.schedules || []) : null;
            }

            function renderImputation() {
                var wrap = document.getElementById('imputation-wrap');
                var tbody = document.querySelector('#imputation-table tbody');
                var note = document.getElementById('imputation-note');
                if (!wrap || !tbody) return;

                var schedules = selectedFeeSchedules();
                if (!schedules || schedules.length === 0) { wrap.style.display = 'none'; return; }

                var amount = parseFloat(amountInput ? amountInput.value : 0) || 0;
                var left = amount, totalImputed = 0, totalRem = 0;
                tbody.innerHTML = '';

                schedules.forEach(function (s) {
                    var rem = Number(s.remaining);
                    totalRem += rem;
                    var imp = Math.max(0, Math.min(left, rem));
                    left -= imp; totalImputed += imp;
                    var tr = document.createElement('tr');
                    if (imp > 0) tr.classList.add('table-success');
                    tr.innerHTML =
                        '<td>' + s.order + '</td>' +
                        '<td>' + (s.due || 'À l\'inscription') + '</td>' +
                        '<td class="text-end">' + formatMoneyXof(s.amount) + '</td>' +
                        '<td class="text-end">' + formatMoneyXof(rem) + '</td>' +
                        '<td class="text-end fw-bold text-success">' + (imp > 0 ? formatMoneyXof(imp) : '—') + '</td>' +
                        '<td class="text-end">' + formatMoneyXof(rem - imp) + '</td>';
                    tbody.appendChild(tr);
                });

                wrap.style.display = '';
                var msg = 'Total imputé : ' + formatMoneyXof(totalImputed) + ' sur ' + formatMoneyXof(amount) + ' saisi(s).';
                if (left > 0.009) {
                    msg += ' ⚠ Surplus de ' + formatMoneyXof(left) + ' : le montant dépasse le reste dû de ce frais (' + formatMoneyXof(totalRem) + ').';
                }
                note.textContent = msg;
            }

            // Le select élève est rendu recherchable par l'enhancer TomSelect global de
            // base.html.twig (qui déclenche l'événement « change » natif sur le select).
            // On y branche la cascade ; le select frais reste natif (classe no-search).
            el.addEventListener('change', function () {
                loadStudentSummary(el.value);
                loadStudentFees(el.value);
                renderImputation();
            });

            loadStudentSummary(el.value);
            loadStudentFees(el.value);
            renderImputation();

            // ── Confirmation SweetAlert avant d'enregistrer le paiement ──
            var form = document.getElementById('paymentForm');
            var confirmedSubmit = false;
            if (form && typeof Swal !== 'undefined') {
                form.addEventListener('submit', function (e) {
                    if (confirmedSubmit) return;         // déjà confirmé
                    if (!form.checkValidity()) return;   // laisse la validation native s'afficher
                    e.preventDefault();

                    // Nom complet de l'élève : d'abord le récapitulatif chargé, sinon l'option sélectionnée.
                    var box = document.getElementById('studentSummary');
                    var nom = box ? (box.querySelector('[data-field="nom"]').textContent || '').trim() : '';
                    var prenom = box ? (box.querySelector('[data-field="prenom"]').textContent || '').trim() : '';
                    var fullName = (nom + ' ' + prenom).replace(/—/g, '').trim();
                    if (!fullName && el.options && el.selectedIndex >= 0) {
                        fullName = el.options[el.selectedIndex].text;
                    }

                    var amount = amountInput ? amountInput.value : '';

                    Swal.fire({
                        title: 'Confirmer le paiement',
                        html: 'Êtes-vous sûr de vouloir effectuer un paiement de <strong>' + formatMoneyXof(amount) + '</strong>'
                            + ' sur l\'élève <strong>' + (fullName || '—') + '</strong> ?',
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonText: 'Oui, enregistrer',
                        cancelButtonText: 'Annuler',
                        confirmButtonColor: '#198754',
                        cancelButtonColor: '#6c757d',
                        reverseButtons: true
                    }).then(function (result) {
                        if (result.isConfirmed) {
                            confirmedSubmit = true;
                            if (typeof form.requestSubmit === 'function') {
                                form.requestSubmit();
                            } else {
                                form.submit();
                            }
                        }
                    });
                });
            }
        });
    </script>
{% endblock %}
