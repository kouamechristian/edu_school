{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Paiements en attente{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Paiements en attente',
        icon: 'fa-clock',
        color: 'warning',
        breadcrumb: [
            { label: 'Paiements', path: path('admin_payment_index') },
            { label: 'En attente' }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_payment_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    <div class="card table-card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr><th>N°</th><th>Élève</th><th>Frais</th><th class="text-end">Montant</th><th>Date</th><th class="text-end">Actions</th></tr>
                    </thead>
                    <tbody>
                        {% for payment in payments %}
                            <tr>
                                <td><span class="badge badge-soft secondary">{{ payment.paymentNumber }}</span></td>
                                <td class="fw-semibold">{{ payment.student.fullName }}</td>
                                <td>{{ payment.fee.name }}</td>
                                <td class="text-end fw-bold">{{ payment.amount|number_format(0, ',', ' ') }} F</td>
                                <td class="text-muted">{{ payment.paymentDate|date('d/m/Y') }}</td>
                                <td class="text-end"><a href="{{ path('admin_payment_show', {'id': payment.id}) }}" class="btn btn-sm btn-outline-info"><i class="fas fa-eye"></i></a></td>
                            </tr>
                        {% else %}
                            <tr><td colspan="6">{{ empty_state('fa-clock', 'Aucun paiement en attente', 'Tous les paiements ont été traités.') }}</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
