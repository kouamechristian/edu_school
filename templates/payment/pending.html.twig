{% extends 'base.html.twig' %}

{% block title %}Paiements en attente{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Paiements en attente</h1>
        <a href="{{ path('admin_payment_index') }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Retour
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>N°</th>
                            <th>Élève</th>
                            <th>Frais</th>
                            <th class="text-end">Montant</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for payment in payments %}
                            <tr>
                                <td><span class="badge bg-secondary">{{ payment.paymentNumber }}</span></td>
                                <td>{{ payment.student.fullName }}</td>
                                <td>{{ payment.fee.name }}</td>
                                <td class="text-end fw-bold">{{ payment.amount|number_format(0, ',', ' ') }} F</td>
                                <td>{{ payment.paymentDate|date('d/m/Y') }}</td>
                                <td>
                                    <a href="{{ path('admin_payment_show', {'id': payment.id}) }}" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">Aucun paiement en attente.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}

