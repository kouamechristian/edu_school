{% extends 'base.html.twig' %}

{% block title %}Factures en retard{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Factures en retard</h1>
        <a href="{{ path('admin_invoice_index') }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Retour
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>N°</th>
                            <th>Élève</th>
                            <th>Frais</th>
                            <th class="text-end">Reste</th>
                            <th>Échéance</th>
                            <th>Statut</th>
                            <th width="90">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for invoice in invoices %}
                            <tr>
                                <td><span class="badge bg-secondary">{{ invoice.invoiceNumber }}</span></td>
                                <td>{{ invoice.student.fullName }}</td>
                                <td>{{ invoice.fee.name }}</td>
                                <td class="text-end fw-bold text-danger">{{ invoice.remainingAmount|number_format(0, ',', ' ') }} F</td>
                                <td>{{ invoice.dueDate ? invoice.dueDate|date('d/m/Y') : '-' }}</td>
                                <td><span class="badge bg-{{ invoice.statusColor }}">{{ invoice.statusLabel }}</span></td>
                                <td>
                                    <a href="{{ path('admin_invoice_show', {'id': invoice.id}) }}" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    Aucune facture en retard.
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}

