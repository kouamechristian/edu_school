{% extends 'base.html.twig' %}

{% block title %}Gestion des Factures{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Gestion des Factures</h1>
        <div>
            <a href="{{ path('admin_invoice_new') }}" class="btn btn-primary">
                <i class="fas fa-plus"></i> Nouvelle facture
            </a>
        </div>
    </div>

    {% if current_school %}
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">
                    Factures - {{ current_school.name }}
                </h6>
                <span class="badge bg-primary">{{ stats.total ?? 0 }}</span>
            </div>
            <div class="card-body">
                <form method="get" class="row g-2 mb-3">
                    <div class="col-md-4">
                        <input type="text" class="form-control" name="search" placeholder="Rechercher par numéro..." value="{{ search_term }}">
                    </div>
                    <div class="col-md-3">
                        <select class="form-select" name="status">
                            <option value="">Tous les statuts</option>
                            {% set st = current_status %}
                            <option value="brouillon" {{ st == 'brouillon' ? 'selected' : '' }}>Brouillon</option>
                            <option value="envoyée" {{ st == 'envoyée' ? 'selected' : '' }}>Envoyée</option>
                            <option value="payée" {{ st == 'payée' ? 'selected' : '' }}>Payée</option>
                            <option value="partiellement_payée" {{ st == 'partiellement_payée' ? 'selected' : '' }}>Partiellement payée</option>
                            <option value="en_retard" {{ st == 'en_retard' ? 'selected' : '' }}>En retard</option>
                            <option value="annulée" {{ st == 'annulée' ? 'selected' : '' }}>Annulée</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-outline-secondary w-100" type="submit">
                            <i class="fas fa-filter"></i> Filtrer
                        </button>
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>N°</th>
                                <th>Élève</th>
                                <th>Frais</th>
                                <th class="text-end">Total</th>
                                <th class="text-end">Payé</th>
                                <th class="text-end">Reste</th>
                                <th>Émission</th>
                                <th>Échéance</th>
                                <th>Statut</th>
                                <th width="120">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for invoice in invoices %}
                                <tr>
                                    <td><span class="badge bg-secondary">{{ invoice.invoiceNumber }}</span></td>
                                    <td>
                                        <strong>{{ invoice.student.fullName }}</strong><br>
                                        <small class="text-muted">{{ invoice.student.studentNumber }}</small>
                                    </td>
                                    <td><span class="badge bg-info">{{ invoice.fee.name }}</span></td>
                                    <td class="text-end fw-bold">{{ invoice.totalAmount|number_format(0, ',', ' ') }} F</td>
                                    <td class="text-end text-success">{{ invoice.paidAmount|number_format(0, ',', ' ') }} F</td>
                                    <td class="text-end {{ (invoice.remainingAmount ?? 0) > 0 ? 'text-danger fw-bold' : 'text-success' }}">
                                        {{ invoice.remainingAmount|number_format(0, ',', ' ') }} F
                                    </td>
                                    <td>{{ invoice.issueDate ? invoice.issueDate|date('d/m/Y') : '-' }}</td>
                                    <td>{{ invoice.dueDate ? invoice.dueDate|date('d/m/Y') : '-' }}</td>
                                    <td><span class="badge bg-{{ invoice.statusColor }}">{{ invoice.statusLabel }}</span></td>
                                    <td>
                                        <a href="{{ path('admin_invoice_show', {'id': invoice.id}) }}" class="btn btn-sm btn-outline-primary" title="Voir">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="{{ path('admin_invoice_edit', {'id': invoice.id}) }}" class="btn btn-sm btn-outline-secondary" title="Modifier">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form method="post" action="{{ path('admin_invoice_delete', {'id': invoice.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer cette facture ?')">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ invoice.id) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="10" class="text-center text-muted py-4">
                                        <i class="fas fa-info-circle"></i> Aucune facture trouvée
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {% else %}
        <div class="alert alert-warning">
            Veuillez sélectionner un établissement pour voir les factures.
        </div>
    {% endif %}
</div>
{% endblock %}

