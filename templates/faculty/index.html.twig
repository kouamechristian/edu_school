{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Filieres{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Gestion des Filieres',
        subtitle: 'Filieres rattachées aux cycles',
        icon: 'fa-building-columns',
        color: 'primary',
        breadcrumb: [ { label: 'Filieres' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_faculty_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouvelle Filiere</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des filieres <span class="badge badge-soft ms-1">{{ faculties|length }}</span></h6></div>
        <div class="card-body">
            {% if faculties is empty %}
                {{ empty_state('fa-building-columns', 'Aucune filiere', 'Cliquez sur « Nouvelle Filiere » pour commencer.') }}
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr><th>Libellé</th><th>Cycle</th><th class="text-end" width="160">Actions</th></tr>
                        </thead>
                        <tbody>
                            {% for faculty in faculties %}
                            <tr>
                                <td><strong>{{ faculty.libelle }}</strong></td>
                                <td>{% if faculty.cycle %}<span class="badge badge-soft info">{{ faculty.cycle.libelle }}</span>{% else %}<span class="text-muted">—</span>{% endif %}</td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a href="{{ path('admin_faculty_show', {'id': faculty.id}) }}" class="btn btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a>
                                        <a href="{{ path('admin_faculty_edit', {'id': faculty.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                        <form method="post" action="{{ path('admin_faculty_delete', {'id': faculty.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette faculté ?');" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ faculty.id) }}">
                                            <button type="submit" class="btn btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
