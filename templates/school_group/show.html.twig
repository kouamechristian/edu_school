{% extends 'base.html.twig' %}

{% block title %}{{ school_group.name }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: school_group.name,
        subtitle: 'Groupe — ' ~ school_group.code,
        icon: 'fa-sitemap',
        color: 'primary',
        breadcrumb: [
            { label: 'Groupes d\'établissements', path: path('admin_school_group_index') },
            { label: school_group.name }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_school_group_edit', {'id': school_group.id}) }}" class="btn btn-warning"><i class="fas fa-edit me-1"></i> Modifier</a>
            <a href="{{ path('admin_school_group_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="m-0 fw-bold text-primary"><i class="fas fa-info-circle me-2"></i>Informations</h6>
                    <span class="badge badge-soft {{ school_group.isActive ? 'success' : 'danger' }}">{{ school_group.isActive ? 'Actif' : 'Inactif' }}</span>
                </div>
                <div class="card-body">
                    <div class="info-list mb-3">
                        <div class="info-row"><div class="info-label">Code</div><div class="info-value">{{ school_group.code }}</div></div>
                        <div class="info-row"><div class="info-label">Créé le</div><div class="info-value">{{ school_group.createdAt|date('d/m/Y à H:i') }}</div></div>
                        {% if school_group.description %}<div class="info-row"><div class="info-label">Description</div><div class="info-value">{{ school_group.description|nl2br }}</div></div>{% endif %}
                    </div>

                    {% if school_group.schools is not empty %}
                        <hr>
                        <h6 class="text-muted mb-3"><i class="fas fa-school me-2"></i>Établissements du groupe ({{ school_group.schools|length }})</h6>
                        <div class="list-group list-group-flush">
                            {% for school in school_group.schools %}
                            <a href="{{ path('admin_school_show', {'id': school.id}) }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                                <div>
                                    <strong>{{ school.name }}</strong><br>
                                    <small class="text-muted"><i class="fas fa-barcode me-1"></i>{{ school.code }} · <i class="fas fa-tag me-1"></i>{{ school.typeLabel }}{% if school.director %} · <i class="fas fa-user-tie me-1"></i>{{ school.director }}{% endif %}</small>
                                </div>
                                <span class="badge badge-soft {{ school.isActive ? 'success' : 'secondary' }}">{{ school.isActive ? 'Actif' : 'Inactif' }}</span>
                            </a>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="alert alert-warning mb-0"><i class="fas fa-exclamation-triangle me-2"></i>Aucun établissement dans ce groupe. Ajoutez des établissements depuis leur page de modification.</div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-chart-simple me-2"></i>Informations</h6></div>
                <div class="card-body">
                    <div class="info-list">
                        <div class="info-row"><div class="info-label">Établissements</div><div class="info-value fw-bold text-primary">{{ school_group.schools|length }}</div></div>
                        <div class="info-row"><div class="info-label">Créé le</div><div class="info-value">{{ school_group.createdAt|date('d/m/Y') }}</div></div>
                        <div class="info-row"><div class="info-label">Modifié le</div><div class="info-value">{{ school_group.updatedAt|date('d/m/Y') }}</div></div>
                    </div>
                </div>
            </div>
            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-bolt me-2"></i>Actions rapides</h6></div>
                <div class="card-body d-grid gap-2">
                    <a href="{{ path('admin_school_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Ajouter un établissement</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
