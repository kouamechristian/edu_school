{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Groupes d'Établissements{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Groupes d\'Établissements',
        subtitle: 'Réseaux et organisations multi-écoles',
        icon: 'fa-sitemap',
        color: 'primary',
        breadcrumb: [ { label: 'Groupes d\'établissements' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_school_group_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouveau Groupe</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des groupes</h6></div>
        <div class="card-body">
            {% if school_groups is empty %}
                {{ empty_state('fa-sitemap', 'Aucun groupe', 'Cliquez sur « Nouveau Groupe » pour commencer.') }}
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr><th>Code</th><th>Nom</th><th>Description</th><th>Établissements</th><th>Statut</th><th class="text-end" width="160">Actions</th></tr>
                        </thead>
                        <tbody>
                            {% for group in school_groups %}
                            <tr>
                                <td><strong>{{ group.code }}</strong></td>
                                <td>{{ group.name }}</td>
                                <td class="text-muted">{% if group.description %}{{ group.description|length > 50 ? group.description|slice(0, 50) ~ '...' : group.description }}{% else %}—{% endif %}</td>
                                <td><span class="badge badge-soft info">{{ group.schools|length }} établissement(s)</span></td>
                                <td><span class="badge badge-soft {{ group.isActive ? 'success' : 'danger' }}">{{ group.isActive ? 'Actif' : 'Inactif' }}</span></td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a href="{{ path('admin_school_group_show', {'id': group.id}) }}" class="btn btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a>
                                        <a href="{{ path('admin_school_group_edit', {'id': group.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                        <form method="post" action="{{ path('admin_school_group_toggle', {'id': group.id}) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ group.id) }}">
                                            <button type="submit" class="btn btn-outline-secondary" title="{{ group.isActive ? 'Désactiver' : 'Activer' }}"><i class="fas fa-{{ group.isActive ? 'ban' : 'check' }}"></i></button>
                                        </form>
                                        <form method="post" action="{{ path('admin_school_group_delete', {'id': group.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce groupe ?');" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ group.id) }}">
                                            <button type="submit" class="btn btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% include '_pagination.html.twig' with { pagination: school_groups } %}
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
