{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Gestion des Classes{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Gestion des Classes',
        subtitle: 'Classes, capacités et professeurs principaux',
        icon: 'fa-door-open',
        color: 'primary',
        breadcrumb: [ { label: 'Classes' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_classroom_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouvelle Classe</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des classes <span class="badge badge-soft ms-1">{{ classrooms|length }}</span></h6></div>
        <div class="card-body">
            {% if classrooms is empty %}
                {{ empty_state('fa-door-open', 'Aucune classe', 'Cliquez sur « Nouvelle Classe » pour commencer.') }}
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr><th>Code</th><th>Nom</th><th>Niveau</th><th>Année</th><th>Prof. Principal</th><th>Salle</th><th>Capacité</th><th>Statut</th><th class="text-end" width="200">Actions</th></tr>
                        </thead>
                        <tbody>
                            {% for classroom in classrooms %}
                            <tr>
                                <td><strong>{{ classroom.code }}</strong></td>
                                <td>{{ classroom.name }}</td>
                                <td><span class="badge badge-soft secondary">{{ classroom.level.name }}</span></td>
                                <td class="text-muted">{{ classroom.schoolYear.name }}</td>
                                <td>{{ classroom.mainTeacher ? classroom.mainTeacher.fullName : '—' }}</td>
                                <td>{{ classroom.room ? classroom.room.code : '—' }}</td>
                                <td>{% if classroom.capacity %}<span class="badge badge-soft info">{{ classroom.capacity }} élèves</span>{% else %}—{% endif %}</td>
                                <td><span class="badge badge-soft {{ classroom.isActive ? 'success' : 'danger' }}">{{ classroom.isActive ? 'Active' : 'Inactive' }}</span></td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a href="{{ path('admin_classroom_show', {'id': classroom.id}) }}" class="btn btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a>
                                        <a href="{{ path('admin_course_schedule', {'id': classroom.id}) }}" class="btn btn-outline-primary" title="Emploi du temps"><i class="fas fa-calendar"></i></a>
                                        <a href="{{ path('admin_classroom_edit', {'id': classroom.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                        <form method="post" action="{{ path('admin_classroom_toggle', {'id': classroom.id}) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ classroom.id) }}">
                                            <button type="submit" class="btn btn-outline-secondary" title="{{ classroom.isActive ? 'Désactiver' : 'Activer' }}"><i class="fas fa-{{ classroom.isActive ? 'ban' : 'check' }}"></i></button>
                                        </form>
                                        <form method="post" action="{{ path('admin_classroom_delete', {'id': classroom.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette classe ?');" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ classroom.id) }}">
                                            <button type="submit" class="btn btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
