{% extends 'base.html.twig' %}

{% block title %}{{ school.name }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: school.name,
        subtitle: 'Établissement — ' ~ school.code,
        icon: 'fa-school',
        color: 'primary',
        breadcrumb: [
            { label: 'Établissements', path: path('admin_school_index') },
            { label: school.name }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_school_edit', {'id': school.id}) }}" class="btn btn-warning"><i class="fas fa-edit me-1"></i> Modifier</a>
            <a href="{{ path('admin_school_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="m-0 fw-bold text-primary"><i class="fas fa-info-circle me-2"></i>Informations</h6>
                    <span class="badge badge-soft {{ school.isActive ? 'success' : 'danger' }}">{{ school.isActive ? 'Actif' : 'Inactif' }}</span>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Code</div><div class="info-value">{{ school.code }}</div></div>
                            <div class="info-row"><div class="info-label">Type</div><div class="info-value"><span class="badge badge-soft secondary">{{ school.typeLabel }}</span></div></div>
                            <div class="info-row"><div class="info-label">Groupe</div><div class="info-value">{% if school.schoolGroup %}<a href="{{ path('admin_school_group_show', {'id': school.schoolGroup.id}) }}">{{ school.schoolGroup.name }}</a>{% else %}<span class="text-muted">Aucun</span>{% endif %}</div></div>
                            {% if school.director %}<div class="info-row"><div class="info-label">Directeur</div><div class="info-value">{{ school.director }}</div></div>{% endif %}
                        </div></div>
                        <div class="col-md-6"><div class="info-list">
                            {% if school.phone %}<div class="info-row"><div class="info-label">Téléphone</div><div class="info-value">{{ school.phone }}</div></div>{% endif %}
                            {% if school.email %}<div class="info-row"><div class="info-label">Email</div><div class="info-value"><a href="mailto:{{ school.email }}">{{ school.email }}</a></div></div>{% endif %}
                            <div class="info-row"><div class="info-label">Créé le</div><div class="info-value">{{ school.createdAt|date('d/m/Y à H:i') }}</div></div>
                            <div class="info-row"><div class="info-label">Modifié le</div><div class="info-value">{{ school.updatedAt|date('d/m/Y à H:i') }}</div></div>
                        </div></div>
                    </div>
                    {% if school.address %}
                        <div class="info-list mt-2"><div class="info-row"><div class="info-label">Adresse</div><div class="info-value">{{ school.address|nl2br }}</div></div></div>
                    {% endif %}

                    {% if school.logo or school.cachetDirection or school.badgeBackgroundColor %}
                        <hr>
                        <h6 class="text-muted mb-3"><i class="fas fa-image me-2"></i>Identité visuelle</h6>
                        <div class="row g-3 align-items-end">
                            {% if school.logo %}
                                <div class="col-auto text-center">
                                    <span class="d-block small text-muted mb-1">Logo</span>
                                    <img src="{{ asset(school.logo) }}" alt="Logo {{ school.name }}" style="max-height: 90px;" class="img-thumbnail">
                                </div>
                            {% endif %}
                            {% if school.cachetDirection %}
                                <div class="col-auto text-center">
                                    <span class="d-block small text-muted mb-1">Cachet de la direction</span>
                                    <img src="{{ asset(school.cachetDirection) }}" alt="Cachet" style="max-height: 90px;" class="img-thumbnail">
                                </div>
                            {% endif %}
                            {% if school.badgeBackgroundColor %}
                                <div class="col-auto text-center">
                                    <span class="d-block small text-muted mb-1">Couleur du badge</span>
                                    <span class="badge" style="background-color: {{ school.badgeBackgroundColor }}; padding: .6rem 1rem;">{{ school.code }}</span>
                                    <span class="d-block small text-muted mt-1">{{ school.badgeBackgroundColor }}</span>
                                </div>
                            {% endif %}
                        </div>
                    {% endif %}

                    {% if school.schoolYears is not empty %}
                    <hr>
                    <h6 class="text-muted mb-3"><i class="fas fa-calendar-alt me-2"></i>Années scolaires</h6>
                    <div class="list-group list-group-flush">
                        {% for schoolYear in school.schoolYears %}
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                            {{ schoolYear.name }}
                            {% if schoolYear.isCurrent %}<span class="badge badge-soft success">En cours</span>{% endif %}
                        </div>
                        {% endfor %}
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-bolt me-2"></i>Actions rapides</h6></div>
                <div class="card-body d-grid gap-2">
                    <a href="{{ path('admin_school_year_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Ajouter une année scolaire</a>
                    <a href="{{ path('admin_level_new') }}" class="btn btn-success"><i class="fas fa-plus me-1"></i> Ajouter un niveau</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
