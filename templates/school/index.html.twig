{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Gestion des Établissements{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Gestion des Établissements',
        subtitle: 'Écoles, contacts et directions',
        icon: 'fa-school',
        color: 'primary',
        breadcrumb: [ { label: 'Établissements' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_school_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouvel Établissement</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    {% if stats is defined and stats is not empty %}
    <div class="row g-3 mb-4">
        {% for stat in stats %}
        <div class="col-6 col-md-2">
            <div class="stat-card primary h-100"><div class="card-body">
                <div class="stat-value">{{ stat.count }}</div>
                <div class="stat-label text-capitalize">{{ stat.type }}</div>
            </div></div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des établissements</h6></div>
        <div class="card-body">
            {% if schools is empty %}
                {{ empty_state('fa-school', 'Aucun établissement', 'Cliquez sur « Nouvel Établissement » pour commencer.') }}
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr><th>Code</th><th>Nom</th><th>Groupe</th><th>Type</th><th>Directeur</th><th>Contact</th><th>Statut</th><th class="text-end" width="160">Actions</th></tr>
                        </thead>
                        <tbody>
                            {% for school in schools %}
                            <tr>
                                <td><strong>{{ school.code }}</strong></td>
                                <td>{{ school.name }}</td>
                                <td>{% if school.schoolGroup %}<span class="badge badge-soft info" title="{{ school.schoolGroup.name }}">{{ school.schoolGroup.code }}</span>{% else %}<span class="text-muted">—</span>{% endif %}</td>
                                <td><span class="badge badge-soft secondary">{{ school.typeLabel }}</span></td>
                                <td>{{ school.director ?? '—' }}</td>
                                <td>
                                    <small class="text-muted">
                                        {% if school.phone %}<i class="fas fa-phone me-1"></i>{{ school.phone }}<br>{% endif %}
                                        {% if school.email %}<i class="fas fa-envelope me-1"></i>{{ school.email }}{% endif %}
                                    </small>
                                </td>
                                <td><span class="badge badge-soft {{ school.isActive ? 'success' : 'danger' }}">{{ school.isActive ? 'Actif' : 'Inactif' }}</span></td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a href="{{ path('admin_school_show', {'id': school.id}) }}" class="btn btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a>
                                        <a href="{{ path('admin_school_edit', {'id': school.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                        <form method="post" action="{{ path('admin_school_toggle', {'id': school.id}) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ school.id) }}">
                                            <button type="submit" class="btn btn-outline-secondary" title="{{ school.isActive ? 'Désactiver' : 'Activer' }}"><i class="fas fa-{{ school.isActive ? 'ban' : 'check' }}"></i></button>
                                        </form>
                                        <form method="post" action="{{ path('admin_school_delete', {'id': school.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet établissement ?');" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ school.id) }}">
                                            <button type="submit" class="btn btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% include '_pagination.html.twig' with { pagination: schools } %}
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
