{% extends 'base.html.twig' %}

{% block title %}Modifier le type d'absence{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box">
                <div class="page-title-right">
                    <ol class="breadcrumb m-0">
                        <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                        <li class="breadcrumb-item"><a href="{{ path('admin_absence_index') }}">Absences</a></li>
                        <li class="breadcrumb-item"><a href="{{ path('admin_absence_type_index') }}">Types d'absence</a></li>
                        <li class="breadcrumb-item active">Modifier</li>
                    </ol>
                </div>
                <h4 class="page-title">Modifier le type d'absence</h4>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Modifier le type d'absence</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    {{ form_label(form.name, 'Nom du type', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(form.name) }}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    {{ form_label(form.code, 'Code', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.code, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(form.code) }}
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.description) }}
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    {{ form_label(form.type, 'Type', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.type, {'attr': {'class': 'form-select'}}) }}
                                    {{ form_errors(form.type) }}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    {{ form_label(form.color, 'Couleur', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.color, {'attr': {'class': 'form-control form-control-color'}}) }}
                                    {{ form_errors(form.color) }}
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <div class="form-check">
                                        {{ form_widget(form.requiresJustification, {'attr': {'class': 'form-check-input'}}) }}
                                        {{ form_label(form.requiresJustification, 'Nécessite une justification', {'label_attr': {'class': 'form-check-label'}}) }}
                                    </div>
                                    {{ form_errors(form.requiresJustification) }}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <div class="form-check">
                                        {{ form_widget(form.countsAsAbsence, {'attr': {'class': 'form-check-input'}}) }}
                                        {{ form_label(form.countsAsAbsence, 'Compte comme une absence', {'label_attr': {'class': 'form-check-label'}}) }}
                                    </div>
                                    {{ form_errors(form.countsAsAbsence) }}
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    {{ form_label(form.penaltyPoints, 'Points de pénalité', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.penaltyPoints, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(form.penaltyPoints) }}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <div class="form-check mt-4">
                                        {{ form_widget(form.isActive, {'attr': {'class': 'form-check-input'}}) }}
                                        {{ form_label(form.isActive, 'Type actif', {'label_attr': {'class': 'form-check-label'}}) }}
                                    </div>
                                    {{ form_errors(form.isActive) }}
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="mdi mdi-check"></i> Enregistrer
                            </button>
                            <a href="{{ path('admin_absence_type_index') }}" class="btn btn-secondary">
                                <i class="mdi mdi-arrow-left"></i> Annuler
                            </a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Informations actuelles</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-5">Nom :</dt>
                        <dd class="col-sm-7">{{ absence_type.name }}</dd>

                        <dt class="col-sm-5">Code :</dt>
                        <dd class="col-sm-7"><code>{{ absence_type.code }}</code></dd>

                        <dt class="col-sm-5">Type :</dt>
                        <dd class="col-sm-7">
                            <span class="badge bg-secondary">{{ absence_type.typeLabel }}</span>
                        </dd>

                        {% if absence_type.color %}
                            <dt class="col-sm-5">Couleur :</dt>
                            <dd class="col-sm-7">
                                <span class="badge" style="background-color: {{ absence_type.color }}">
                                    {{ absence_type.color }}
                                </span>
                            </dd>
                        {% endif %}

                        <dt class="col-sm-5">Statut :</dt>
                        <dd class="col-sm-7">
                            {% if absence_type.isActive %}
                                <span class="badge bg-success">Actif</span>
                            {% else %}
                                <span class="badge bg-secondary">Inactif</span>
                            {% endif %}
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

