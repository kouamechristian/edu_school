{% extends 'base.html.twig' %}

{% block title %}Modifier le type d'absence{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Modifier le type d\'absence',
        subtitle: absence_type.name,
        icon: 'fa-cog',
        color: 'primary',
        breadcrumb: [
            { label: 'Absences', path: path('admin_absence_index') },
            { label: 'Types d\'absence', path: path('admin_absence_type_index') },
            { label: 'Modifier' }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_absence_type_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-edit me-2"></i>Modifier le type d'absence</h6></div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.name, 'Nom du type', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.name) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.code, 'Code', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.code, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.code) }}
                            </div>
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.description) }}
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.type, 'Type', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.type, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(form.type) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.color, 'Couleur', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.color, {'attr': {'class': 'form-control form-control-color'}}) }}
                                {{ form_errors(form.color) }}
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-check">
                                    {{ form_widget(form.requiresJustification, {'attr': {'class': 'form-check-input'}}) }}
                                    {{ form_label(form.requiresJustification, 'Nécessite une justification', {'label_attr': {'class': 'form-check-label'}}) }}
                                </div>
                                {{ form_errors(form.requiresJustification) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-check">
                                    {{ form_widget(form.countsAsAbsence, {'attr': {'class': 'form-check-input'}}) }}
                                    {{ form_label(form.countsAsAbsence, 'Compte comme une absence', {'label_attr': {'class': 'form-check-label'}}) }}
                                </div>
                                {{ form_errors(form.countsAsAbsence) }}
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.penaltyPoints, 'Points de pénalité', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.penaltyPoints, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.penaltyPoints) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-check mt-4">
                                    {{ form_widget(form.isActive, {'attr': {'class': 'form-check-input'}}) }}
                                    {{ form_label(form.isActive, 'Type actif', {'label_attr': {'class': 'form-check-label'}}) }}
                                </div>
                                {{ form_errors(form.isActive) }}
                            </div>
                        </div>
                        <div class="d-flex gap-2 pt-3 border-top">
                            <button type="submit" class="btn btn-success"><i class="fas fa-check me-1"></i> Enregistrer</button>
                            <a href="{{ path('admin_absence_type_index') }}" class="btn btn-light"><i class="fas fa-times me-1"></i> Annuler</a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-clock-rotate-left me-2"></i>Informations actuelles</h6></div>
                <div class="card-body">
                    <div class="info-list">
                        <div class="info-row"><div class="info-label">Nom</div><div class="info-value">{{ absence_type.name }}</div></div>
                        <div class="info-row"><div class="info-label">Code</div><div class="info-value"><code>{{ absence_type.code }}</code></div></div>
                        <div class="info-row"><div class="info-label">Type</div><div class="info-value"><span class="badge badge-soft secondary">{{ absence_type.typeLabel }}</span></div></div>
                        {% if absence_type.color %}<div class="info-row"><div class="info-label">Couleur</div><div class="info-value"><span class="badge" style="background-color: {{ absence_type.color }}; color:#fff;">{{ absence_type.color }}</span></div></div>{% endif %}
                        <div class="info-row"><div class="info-label">Statut</div><div class="info-value"><span class="badge badge-soft {{ absence_type.isActive ? 'success' : 'secondary' }}">{{ absence_type.isActive ? 'Actif' : 'Inactif' }}</span></div></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
