{% extends 'base.html.twig' %}

{% block title %}Nouveau type d'absence{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box">
                <div class="page-title-right">
                    <ol class="breadcrumb m-0">
                        <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                        <li class="breadcrumb-item"><a href="{{ path('admin_absence_index') }}">Absences</a></li>
                        <li class="breadcrumb-item"><a href="{{ path('admin_absence_type_index') }}">Types d'absence</a></li>
                        <li class="breadcrumb-item active">Nouveau type</li>
                    </ol>
                </div>
                <h4 class="page-title">Créer un nouveau type d'absence</h4>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Informations du type d'absence</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    {{ form_label(form.name, 'Nom du type', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(form.name) }}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    {{ form_label(form.code, 'Code', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.code, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(form.code) }}
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.description) }}
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    {{ form_label(form.type, 'Type', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.type, {'attr': {'class': 'form-select'}}) }}
                                    {{ form_errors(form.type) }}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    {{ form_label(form.color, 'Couleur', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.color, {'attr': {'class': 'form-control form-control-color'}}) }}
                                    {{ form_errors(form.color) }}
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <div class="form-check">
                                        {{ form_widget(form.requiresJustification, {'attr': {'class': 'form-check-input'}}) }}
                                        {{ form_label(form.requiresJustification, 'Nécessite une justification', {'label_attr': {'class': 'form-check-label'}}) }}
                                    </div>
                                    {{ form_errors(form.requiresJustification) }}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <div class="form-check">
                                        {{ form_widget(form.countsAsAbsence, {'attr': {'class': 'form-check-input'}}) }}
                                        {{ form_label(form.countsAsAbsence, 'Compte comme une absence', {'label_attr': {'class': 'form-check-label'}}) }}
                                    </div>
                                    {{ form_errors(form.countsAsAbsence) }}
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    {{ form_label(form.penaltyPoints, 'Points de pénalité', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.penaltyPoints, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(form.penaltyPoints) }}
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <div class="form-check mt-4">
                                        {{ form_widget(form.isActive, {'attr': {'class': 'form-check-input'}}) }}
                                        {{ form_label(form.isActive, 'Type actif', {'label_attr': {'class': 'form-check-label'}}) }}
                                    </div>
                                    {{ form_errors(form.isActive) }}
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="mdi mdi-check"></i> Créer le type
                            </button>
                            <a href="{{ path('admin_absence_type_index') }}" class="btn btn-secondary">
                                <i class="mdi mdi-arrow-left"></i> Annuler
                            </a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Conseils</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <h6 class="alert-heading">Types d'absence</h6>
                        <ul class="mb-0">
                            <li><strong>Absence :</strong> Absence complète de l'élève</li>
                            <li><strong>Retard :</strong> Arrivée en retard</li>
                            <li><strong>Sortie anticipée :</strong> Départ avant la fin des cours</li>
                        </ul>
                    </div>

                    <div class="alert alert-warning">
                        <h6 class="alert-heading">Configuration</h6>
                        <ul class="mb-0">
                            <li>Le <strong>code</strong> doit être unique</li>
                            <li>Les <strong>points de pénalité</strong> affectent le comportement</li>
                            <li>La <strong>couleur</strong> aide à identifier visuellement le type</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
