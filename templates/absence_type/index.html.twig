{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Types d'absence{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Types d\'absence',
        subtitle: current_school ? 'Configuration pour ' ~ current_school.name : 'Configuration des types d\'absence',
        icon: 'fa-cog',
        color: 'primary',
        breadcrumb: [
            { label: 'Absences', path: path('admin_absence_index') },
            { label: 'Types d\'absence' }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_absence_type_new') }}" class="btn btn-success"><i class="fas fa-plus me-1"></i> Nouveau type</a>
            <a href="{{ path('admin_absence_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des types</h6></div>
        <div class="card-body">
            {% if absence_types is empty %}
                <div class="empty-state">
                    <div class="empty-icon"><i class="fas fa-cog"></i></div>
                    <h6>Aucun type d'absence configuré</h6>
                    <p>Commencez par créer des types d'absence pour votre établissement.</p>
                    <a href="{{ path('admin_absence_type_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Créer un type d'absence</a>
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr><th>Nom</th><th>Code</th><th>Type</th><th>Couleur</th><th class="text-center">Justification</th><th class="text-center">Compte</th><th class="text-center">Pénalité</th><th>Statut</th><th class="text-end">Actions</th></tr>
                        </thead>
                        <tbody>
                            {% for absenceType in absence_types %}
                                <tr>
                                    <td>
                                        <strong>{{ absenceType.name }}</strong>
                                        {% if absenceType.description %}<br><small class="text-muted">{{ absenceType.description }}</small>{% endif %}
                                    </td>
                                    <td><code>{{ absenceType.code }}</code></td>
                                    <td><span class="badge badge-soft secondary">{{ absenceType.typeLabel }}</span></td>
                                    <td>{% if absenceType.color %}<span class="badge" style="background-color: {{ absenceType.color }}; color:#fff;">{{ absenceType.color }}</span>{% else %}<span class="text-muted">—</span>{% endif %}</td>
                                    <td class="text-center">{% if absenceType.requiresJustification %}<span class="badge badge-soft warning">Oui</span>{% else %}<span class="badge badge-soft info">Non</span>{% endif %}</td>
                                    <td class="text-center">{% if absenceType.countsAsAbsence %}<span class="badge badge-soft danger">Oui</span>{% else %}<span class="badge badge-soft success">Non</span>{% endif %}</td>
                                    <td class="text-center">{% if absenceType.penaltyPoints %}<span class="badge badge-soft secondary">{{ absenceType.penaltyPoints }} pts</span>{% else %}<span class="text-muted">—</span>{% endif %}</td>
                                    <td><span class="badge badge-soft {{ absenceType.isActive ? 'success' : 'secondary' }}">{{ absenceType.isActive ? 'Actif' : 'Inactif' }}</span></td>
                                    <td class="text-end">
                                        <a href="{{ path('admin_absence_type_edit', {'id': absenceType.id}) }}" class="btn btn-sm btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
