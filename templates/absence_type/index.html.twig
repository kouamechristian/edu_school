{% extends 'base.html.twig' %}

{% block title %}Types d'absence{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box">
                <div class="page-title-right">
                    <ol class="breadcrumb m-0">
                        <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                        <li class="breadcrumb-item"><a href="{{ path('admin_absence_index') }}">Absences</a></li>
                        <li class="breadcrumb-item active">Types d'absence</li>
                    </ol>
                </div>
                <h4 class="page-title">Gestion des types d'absence</h4>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <h5 class="card-title mb-0">Types d'absence</h5>
                            <p class="text-muted mb-0">Configuration des types d'absence pour {{ current_school.name }}</p>
                        </div>
                        <div class="col-md-6 text-end">
                            <a href="{{ path('admin_absence_type_new') }}" class="btn btn-success">
                                <i class="mdi mdi-plus"></i> Nouveau type
                            </a>
                            <a href="{{ path('admin_absence_index') }}" class="btn btn-secondary">
                                <i class="mdi mdi-arrow-left"></i> Retour aux absences
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    {% if absence_types is empty %}
                        <div class="text-center py-5">
                            <i class="mdi mdi-cog-outline display-4 text-muted"></i>
                            <h5 class="mt-3">Aucun type d'absence configuré</h5>
                            <p class="text-muted">Commencez par créer des types d'absence pour votre établissement.</p>
                            <a href="{{ path('admin_absence_type_new') }}" class="btn btn-primary">
                                <i class="mdi mdi-plus"></i> Créer un type d'absence
                            </a>
                        </div>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Nom</th>
                                        <th>Code</th>
                                        <th>Type</th>
                                        <th>Couleur</th>
                                        <th>Justification</th>
                                        <th>Compte comme absence</th>
                                        <th>Points de pénalité</th>
                                        <th>Statut</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for absenceType in absence_types %}
                                        <tr>
                                            <td>
                                                <strong>{{ absenceType.name }}</strong>
                                                {% if absenceType.description %}
                                                    <br><small class="text-muted">{{ absenceType.description }}</small>
                                                {% endif %}
                                            </td>
                                            <td>
                                                <code>{{ absenceType.code }}</code>
                                            </td>
                                            <td>
                                                <span class="badge bg-secondary">{{ absenceType.typeLabel }}</span>
                                            </td>
                                            <td>
                                                {% if absenceType.color %}
                                                    <span class="badge" style="background-color: {{ absenceType.color }}">
                                                        {{ absenceType.color }}
                                                    </span>
                                                {% else %}
                                                    <span class="text-muted">-</span>
                                                {% endif %}
                                            </td>
                                            <td class="text-center">
                                                {% if absenceType.requiresJustification %}
                                                    <span class="badge bg-warning">Oui</span>
                                                {% else %}
                                                    <span class="badge bg-info">Non</span>
                                                {% endif %}
                                            </td>
                                            <td class="text-center">
                                                {% if absenceType.countsAsAbsence %}
                                                    <span class="badge bg-danger">Oui</span>
                                                {% else %}
                                                    <span class="badge bg-success">Non</span>
                                                {% endif %}
                                            </td>
                                            <td class="text-center">
                                                {% if absenceType.penaltyPoints %}
                                                    <span class="badge bg-dark">{{ absenceType.penaltyPoints }} pts</span>
                                                {% else %}
                                                    <span class="text-muted">-</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if absenceType.isActive %}
                                                    <span class="badge bg-success">Actif</span>
                                                {% else %}
                                                    <span class="badge bg-secondary">Inactif</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a href="{{ path('admin_absence_type_edit', {'id': absenceType.id}) }}" 
                                                       class="btn btn-sm btn-outline-warning" title="Modifier">
                                                        <i class="mdi mdi-pencil"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
