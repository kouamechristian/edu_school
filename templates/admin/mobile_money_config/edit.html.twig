{% extends 'base.html.twig' %}

{% block title %}Identifiants Mobile Money — {{ school.name }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-xl-8">
            {% embed 'components/page_header.html.twig' with {
                title: 'Identifiants Mobile Money',
                subtitle: school.name,
                icon: 'fa-key',
                color: 'primary',
                breadcrumb: [
                    { label: 'Administration' },
                    { label: 'Identifiants Mobile Money', path: path('admin_mobile_money_config_index') },
                    { label: school.name }
                ]
            } %}
                {% block actions %}
                    <a href="{{ path('admin_mobile_money_config_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
                {% endblock %}
            {% endembed %}

            {% include '_flash.html.twig' %}

            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-key me-2"></i>Clés de la passerelle</h6></div>
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="mb-3">{{ form_row(form.apiKey) }}</div>
                        <div class="row">
                            <div class="col-md-6 mb-3">{{ form_row(form.apiSecret) }}</div>
                            <div class="col-md-6 mb-3">{{ form_row(form.webhookSecret) }}</div>
                        </div>
                        <div class="mb-3">{{ form_row(form.baseUrl) }}</div>
                        <div class="mb-3 form-check">
                            {{ form_widget(form.isActive, {'attr': {'class': 'form-check-input'}}) }}
                            {{ form_label(form.isActive, null, {'label_attr': {'class': 'form-check-label'}}) }}
                        </div>

                        {% if config.id and config.updatedAt %}
                            <p class="text-muted small"><i class="fas fa-clock me-1"></i> Dernière modification : {{ config.updatedAt|date('d/m/Y à H:i') }}</p>
                        {% endif %}

                        <div class="alert alert-warning py-2 small">
                            <i class="fas fa-shield-halved me-1"></i> Les clés secrètes ne sont jamais réaffichées.
                            Laissez les champs secrets vides pour conserver les valeurs déjà enregistrées.
                        </div>

                        <div class="d-flex justify-content-between mt-3 pt-3 border-top">
                            <a href="{{ path('admin_mobile_money_config_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
                            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Enregistrer</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
