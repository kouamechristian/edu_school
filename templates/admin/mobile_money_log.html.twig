{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Logs Mobile Money{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Logs de paiement — Mobile Money',
        subtitle: current_school ? current_school.name : 'Tous les établissements',
        icon: 'fa-mobile-screen-button',
        color: 'primary',
        breadcrumb: [ { label: 'Administration' }, { label: 'Logs Mobile Money' } ]
    } %}{% endembed %}

    {% include '_flash.html.twig' %}

    {# ── Statistiques ── #}
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="stat-card primary h-100"><div class="card-body d-flex align-items-center justify-content-between">
                <div><div class="stat-label mb-1">Transactions</div><div class="stat-value">{{ stats.total }}</div></div>
                <div class="stat-icon"><i class="fas fa-mobile-screen-button"></i></div>
            </div></div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card success h-100"><div class="card-body d-flex align-items-center justify-content-between">
                <div><div class="stat-label mb-1">Payés</div><div class="stat-value">{{ stats.paid_count }}</div></div>
                <div class="stat-icon"><i class="fas fa-circle-check"></i></div>
            </div></div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card warning h-100"><div class="card-body d-flex align-items-center justify-content-between">
                <div><div class="stat-label mb-1">En attente</div><div class="stat-value">{{ stats.pending_count }}</div></div>
                <div class="stat-icon"><i class="fas fa-clock"></i></div>
            </div></div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card info h-100"><div class="card-body d-flex align-items-center justify-content-between">
                <div><div class="stat-label mb-1">Total encaissé</div><div class="stat-value">{{ stats.total_paid|number_format(0, ',', ' ') }}</div></div>
                <div class="stat-icon"><i class="fas fa-coins"></i></div>
            </div></div>
        </div>
    </div>

    {# ── Filtre statut ── #}
    <div class="card filter-card mb-4">
        <div class="card-body">
            <form method="GET" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label for="status" class="form-label">Statut</label>
                    <select name="status" id="status" class="form-select">
                        <option value="">Tous</option>
                        <option value="payé" {{ current_status == 'payé' ? 'selected' : '' }}>Payé</option>
                        <option value="en_attente" {{ current_status == 'en_attente' ? 'selected' : '' }}>En attente</option>
                        <option value="annulé" {{ current_status == 'annulé' ? 'selected' : '' }}>Annulé</option>
                        <option value="remboursé" {{ current_status == 'remboursé' ? 'selected' : '' }}>Remboursé</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100"><i class="fas fa-filter me-1"></i> Filtrer</button>
                </div>
            </form>
        </div>
    </div>

    {# ── Liste ── #}
    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Transactions Mobile Money <span class="badge badge-soft ms-1">{{ payments|length }}</span></h6></div>
        <div class="card-body">
            {% if payments is empty %}
                {{ empty_state('fa-mobile-screen-button', 'Aucune transaction', 'Aucun paiement Mobile Money pour ce filtre.') }}
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>N° paiement</th>
                                <th>Élève</th>
                                <th>Téléphone payeur</th>
                                <th>Établissement</th>
                                <th>Frais</th>
                                <th class="text-end">Montant</th>
                                <th>Réf. transaction</th>
                                <th>Origine</th>
                                <th class="text-center">Statut</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for p in payments %}
                                <tr>
                                    <td class="text-muted">{{ p.createdAt ? p.createdAt|date('d/m/Y H:i') : '—' }}</td>
                                    <td><span class="fw-semibold">{{ p.paymentNumber }}</span></td>
                                    <td>{{ p.student ? p.student.fullName : '—' }}</td>
                                    <td>
                                        {% set mmPhone = p.payerPhone %}
                                        {% set phone = mmPhone ?: (p.student ? (p.student.parentPhone ?: (p.recordedBy ? p.recordedBy.phone : null)) : null) %}
                                        {% if phone %}
                                            <i class="fas fa-phone text-muted me-1"></i>{{ phone }}
                                            {% if mmPhone %}<span class="badge bg-success-subtle text-success-emphasis ms-1" title="Numéro Mobile Money réel de la transaction">MM</span>{% endif %}
                                        {% else %}<span class="text-muted">—</span>{% endif %}
                                    </td>
                                    <td>{{ p.student and p.student.school ? p.student.school.name : '—' }}</td>
                                    <td>{{ p.fee ? p.fee.name : '—' }}</td>
                                    <td class="text-end fw-bold">{{ p.amount|number_format(0, ',', ' ') }} F</td>
                                    <td><small class="text-muted">{{ p.providerTransactionId ?: '—' }}</small></td>
                                    <td>
                                        {% if p.provider %}
                                            <span class="badge bg-info-subtle text-info-emphasis">{{ p.provider|capitalize }}</span>
                                        {% else %}
                                            <span class="badge bg-secondary-subtle text-secondary-emphasis">Caisse</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-center"><span class="badge bg-{{ p.statusColor }}">{{ p.statusLabel }}</span></td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
