{% extends 'base.html.twig' %}

{% block title %}Cycle — {{ cycle.libelle }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-xl-8">
            {% embed 'components/page_header.html.twig' with {
                title: cycle.libelle,
                icon: 'fa-sitemap',
                color: 'primary',
                breadcrumb: [
                    { label: 'Cycles', path: path('admin_cycle_index') },
                    { label: cycle.libelle }
                ]
            } %}
                {% block actions %}
                    <a href="{{ path('admin_cycle_edit', {'id': cycle.id}) }}" class="btn btn-primary"><i class="fas fa-edit me-1"></i> Modifier</a>
                    <a href="{{ path('admin_cycle_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
                {% endblock %}
            {% endembed %}

            {% include '_flash.html.twig' %}

            <div class="card">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-layer-group me-2"></i>Niveaux rattachés <span class="badge badge-soft ms-1">{{ cycle.levels|length }}</span></h6></div>
                <div class="card-body">
                    {% if cycle.levels|length > 0 %}
                        <ul class="list-group list-group-flush">
                            {% for level in cycle.levels %}
                                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                    <span><strong>{{ level.name }}</strong>{% if level.school %} <small class="text-muted">— {{ level.school.name }}</small>{% endif %}</span>
                                    <span class="badge badge-soft {{ level.isActive ? 'success' : 'danger' }}">{{ level.isActive ? 'Actif' : 'Inactif' }}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p class="text-muted mb-0">Aucun niveau n'est rattaché à ce cycle.</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
