{% extends 'base.html.twig' %}

{% block title %}Nouveau Cycle{% endblock %}
{% block heading %}Nouveau Cycle{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-xl-8">
            {% embed 'components/page_header.html.twig' with {
                title: block('heading'),
                icon: 'fa-sitemap',
                color: 'primary',
                breadcrumb: [
                    { label: 'Cycles', path: path('admin_cycle_index') },
                    { label: block('heading') }
                ]
            } %}
                {% block actions %}
                    <a href="{{ path('admin_cycle_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
                {% endblock %}
            {% endembed %}

            {% include '_flash.html.twig' %}

            <div class="card">
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="mb-3">{{ form_row(form.libelle) }}</div>
                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a href="{{ path('admin_cycle_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
                            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Enregistrer</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
