{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Cycles{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Gestion des Cycles',
        subtitle: 'Cycles regroupant les niveaux',
        icon: 'fa-sitemap',
        color: 'primary',
        breadcrumb: [ { label: 'Cycles' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_cycle_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouveau Cycle</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des cycles <span class="badge badge-soft ms-1">{{ cycles|length }}</span></h6></div>
        <div class="card-body">
            {% if cycles is empty %}
                {{ empty_state('fa-sitemap', 'Aucun cycle', 'Cliquez sur « Nouveau Cycle » pour commencer.') }}
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr><th>Libellé</th><th>Niveaux rattachés</th><th class="text-end" width="160">Actions</th></tr>
                        </thead>
                        <tbody>
                            {% for cycle in cycles %}
                            <tr>
                                <td><strong>{{ cycle.libelle }}</strong></td>
                                <td>
                                    {% if cycle.levels|length > 0 %}
                                        {% for level in cycle.levels %}
                                            <span class="badge badge-soft secondary">{{ level.name }}</span>
                                        {% endfor %}
                                    {% else %}
                                        <span class="text-muted">Aucun niveau</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a href="{{ path('admin_cycle_show', {'id': cycle.id}) }}" class="btn btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a>
                                        <a href="{{ path('admin_cycle_edit', {'id': cycle.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                        {% if is_granted('ROLE_ADMIN') %}
                                        <form method="post" action="{{ path('admin_cycle_delete', {'id': cycle.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce cycle ?');" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cycle.id) }}">
                                            <button type="submit" class="btn btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                        </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% include '_pagination.html.twig' with { pagination: cycles } %}
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
