{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Séries{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Gestion des Séries',
        subtitle: 'Séries rattachées aux cycles',
        icon: 'fa-stream',
        color: 'primary',
        breadcrumb: [ { label: 'Séries' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_round_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouvelle Série</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des séries <span class="badge badge-soft ms-1">{{ rounds|length }}</span></h6></div>
        <div class="card-body">
            {% if rounds is empty %}
                {{ empty_state('fa-stream', 'Aucune série', 'Cliquez sur « Nouvelle Série » pour commencer.') }}
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr><th>Libellé</th><th>Cycle</th><th class="text-end" width="160">Actions</th></tr>
                        </thead>
                        <tbody>
                            {% for round in rounds %}
                            <tr>
                                <td><strong>{{ round.libelle }}</strong></td>
                                <td>{% if round.cycle %}<span class="badge badge-soft info">{{ round.cycle.libelle }}</span>{% else %}<span class="text-muted">—</span>{% endif %}</td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a href="{{ path('admin_round_show', {'id': round.id}) }}" class="btn btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a>
                                        <a href="{{ path('admin_round_edit', {'id': round.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                        <form method="post" action="{{ path('admin_round_delete', {'id': round.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette série ?');" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ round.id) }}">
                                            <button type="submit" class="btn btn-outline-danger" title="Supprimer"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
