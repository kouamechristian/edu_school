{% extends 'base.html.twig' %}

{% block title %}Validation des caisses{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Validation des caisses',
        subtitle: 'Valider les caisses créées par les caissiers',
        icon: 'fa-cash-register',
        color: 'primary',
        breadcrumb: [
            { label: 'Espace Fondateur', path: path('fondateur_index') },
            { label: 'Validation des caisses' }
        ]
    } %}
        {% block actions %}<a href="{{ path('fondateur_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>{% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Caisses</h6></div>
        <div class="card-body">
            {% if cash_registers|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr><th>Caissier</th><th>Établissement</th><th>Statut caisse</th><th>Ouverte le</th><th>Validation</th><th class="text-end">Action</th></tr>
                        </thead>
                        <tbody>
                            {% for cr in cash_registers %}
                                <tr>
                                    <td class="fw-bold">{{ cr.cashier ? cr.cashier.fullName : '—' }}</td>
                                    <td>{{ cr.school ? cr.school.name : '—' }}</td>
                                    <td><span class="badge bg-{{ cr.status == 'open' ? 'success' : 'secondary' }}">{{ cr.status == 'open' ? 'Ouverte' : 'Fermée' }}</span></td>
                                    <td class="text-muted">{{ cr.openedAt ? cr.openedAt|date('d/m/Y H:i') : '—' }}</td>
                                    <td>
                                        {% if cr.isValidated %}
                                            <span class="badge bg-success"><i class="fas fa-check me-1"></i>Validée</span>
                                            <small class="d-block text-muted">{{ cr.validatedBy ? cr.validatedBy.fullName : '' }} · {{ cr.validatedAt ? cr.validatedAt|date('d/m/Y') : '' }}</small>
                                        {% else %}
                                            <span class="badge bg-warning text-dark">En attente</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        {% if not cr.isValidated %}
                                            <form method="post" action="{{ path('fondateur_valider_caisse', {'id': cr.id}) }}" class="d-inline" onsubmit="return confirm('Valider cette caisse ?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('valider' ~ cr.id) }}">
                                                <button type="submit" class="btn btn-sm btn-success"><i class="fas fa-check me-1"></i> Valider</button>
                                            </form>
                                        {% else %}
                                            <span class="text-muted small">—</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center text-muted py-4"><i class="fas fa-info-circle me-1"></i> Aucune caisse.</div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
