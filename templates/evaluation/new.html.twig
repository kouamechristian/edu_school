{% extends 'base.html.twig' %}

{% block title %}Nouvelle Évaluation{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3">Nouvelle Évaluation</h1>
                <a href="{{ path('admin_evaluation_index') }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>

            {% include '_flash.html.twig' %}

            {% if form.vars.errors|length > 0 %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <h6 class="alert-heading">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        <strong>Erreur de validation</strong>
                    </h6>
                    <ul class="mb-0">
                        {% for error in form.vars.errors %}
                            <li><strong>{{ error.message }}</strong></li>
                        {% endfor %}
                    </ul>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endif %}

            <div class="card shadow-sm">
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.classroom) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.subject) }}
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.period) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.teacher) }}
                            </div>
                        </div>

                        <div class="mb-3">
                            {{ form_row(form.name) }}
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.type) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.date) }}
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.maxGrade) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_row(form.coefficient) }}
                            </div>
                        </div>

                        <div class="mb-3">
                            {{ form_row(form.description) }}
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-check">
                                    {{ form_widget(form.isPublished) }}
                                    {{ form_label(form.isPublished) }}
                                    <div class="form-text">{{ form_help(form.isPublished) }}</div>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-check">
                                    {{ form_widget(form.isActive) }}
                                    {{ form_label(form.isActive) }}
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="{{ path('admin_evaluation_index') }}" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Annuler
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Enregistrer et saisir les notes
                            </button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

