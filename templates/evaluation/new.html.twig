{% extends 'base.html.twig' %}

{% block title %}Nouvelle Évaluation{% endblock %}

{# Surchargés par edit.html.twig #}
{% block heading %}Nouvelle Évaluation{% endblock %}
{% block submit_label %}Enregistrer et saisir les notes{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            {% embed 'components/page_header.html.twig' with {
                title: block('heading'),
                icon: 'fa-clipboard-list',
                color: 'primary',
                breadcrumb: [
                    { label: 'Évaluations', path: path('admin_evaluation_index') },
                    { label: block('heading') }
                ]
            } %}
                {% block actions %}
                    <a href="{{ path('admin_evaluation_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
                {% endblock %}
            {% endembed %}

            {% include '_flash.html.twig' %}

            {% if form.vars.errors|length > 0 %}
                <div class="form-error-message">
                    <strong><i class="fas fa-exclamation-circle me-2"></i>Erreur de validation</strong>
                    <ul class="mt-2">
                        {% for error in form.vars.errors %}<li>{{ error.message }}</li>{% endfor %}
                    </ul>
                </div>
            {% endif %}

            <div class="card">
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="row">
                            <div class="col-md-6 mb-3">{{ form_row(form.classroom) }}</div>
                            <div class="col-md-6 mb-3">{{ form_row(form.subject) }}</div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">{{ form_row(form.period) }}</div>
                            <div class="col-md-6 mb-3">{{ form_row(form.teacher) }}</div>
                        </div>
                        <div class="mb-3">{{ form_row(form.name) }}</div>
                        <div class="row">
                            <div class="col-md-6 mb-3">{{ form_row(form.type) }}</div>
                            <div class="col-md-6 mb-3">{{ form_row(form.date) }}</div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">{{ form_row(form.maxGrade) }}</div>
                            <div class="col-md-6 mb-3">{{ form_row(form.coefficient) }}</div>
                        </div>
                        <div class="mb-3">{{ form_row(form.description) }}</div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-check">
                                    {{ form_widget(form.isPublished) }}
                                    {{ form_label(form.isPublished) }}
                                    <div class="form-text">{{ form_help(form.isPublished) }}</div>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-check">
                                    {{ form_widget(form.isActive) }}
                                    {{ form_label(form.isActive) }}
                                </div>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a href="{{ path('admin_evaluation_index') }}" class="btn btn-light"><i class="fas fa-times me-1"></i> Annuler</a>
                            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> {{ block('submit_label') }}</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

{% include 'evaluation/_subject_cascade.html.twig' %}
{% endblock %}
