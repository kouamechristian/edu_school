{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Détails de l'Évaluation{% endblock %}

{% block body %}
<div class="container-fluid">
    {# ── En-tête ── #}
    {% embed 'components/page_header.html.twig' with {
        title: evaluation.name,
        subtitle: evaluation.classroom.fullName ~ '  ·  ' ~ evaluation.subject.name,
        icon: 'fa-clipboard-list',
        color: 'primary',
        breadcrumb: [
            { label: 'Évaluations', path: path('admin_evaluation_index') },
            { label: evaluation.name }
        ]
    } %}
        {% block actions %}
            {% if evaluation.isEditable %}
                <a href="{{ path('admin_evaluation_grades', {'id': evaluation.id}) }}" class="btn btn-success"><i class="fas fa-keyboard me-1"></i> Saisir les notes</a>
            {% elseif evaluation.isValidated and not evaluation.lockedByBulletin %}
                <form method="post" action="{{ path('admin_evaluation_grades_cancel', {'id': evaluation.id}) }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('cancel_validation' ~ evaluation.id) }}">
                    <button type="submit" class="btn btn-success"><i class="fas fa-pen me-1"></i> Annuler la validation pour modifier</button>
                </form>
            {% endif %}
            <a href="{{ path('admin_evaluation_edit', {'id': evaluation.id}) }}" class="btn btn-warning"><i class="fas fa-edit me-1"></i> Modifier</a>
            <a href="{{ path('admin_evaluation_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <h6 class="m-0 fw-bold text-primary"><i class="fas fa-info-circle me-2"></i>Informations</h6>
                    <div class="d-flex gap-1">
                        <span class="badge badge-soft {{ evaluation.statusColor }}">{{ evaluation.statusLabel }}</span>
                        {% if evaluation.isPublished and not evaluation.lockedByBulletin %}
                            <span class="badge badge-soft info" title="Résultats publiés"><i class="fas fa-eye me-1"></i>Publiée</span>
                        {% endif %}
                        {% if evaluation.isActive %}
                            <span class="badge badge-soft secondary">Active</span>
                        {% else %}
                            <span class="badge badge-soft danger">Inactive</span>
                        {% endif %}
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Classe</div><div class="info-value">{{ evaluation.classroom.fullName }}</div></div>
                            <div class="info-row"><div class="info-label">Matière</div><div class="info-value">{{ evaluation.subject.name }}</div></div>
                            <div class="info-row"><div class="info-label">Période</div><div class="info-value">{{ evaluation.period.name }}</div></div>
                            <div class="info-row"><div class="info-label">Enseignant</div><div class="info-value">{{ evaluation.teacher ? evaluation.teacher.fullName : '—' }}</div></div>
                        </div></div>
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Type</div><div class="info-value"><span class="badge badge-soft secondary">{{ evaluation.typeLabel }}</span></div></div>
                            <div class="info-row"><div class="info-label">Date</div><div class="info-value">{{ evaluation.date|date('d/m/Y') }}</div></div>
                            <div class="info-row"><div class="info-label">Note max</div><div class="info-value">{{ evaluation.maxGrade }}</div></div>
                            <div class="info-row"><div class="info-label">Coefficient</div><div class="info-value">{{ evaluation.coefficient }}</div></div>
                        </div></div>
                    </div>

                    {% if evaluation.description %}
                        <div class="alert alert-info mt-3 mb-0">
                            <strong><i class="fas fa-info-circle me-1"></i>Description</strong>
                            <p class="mb-0 mt-2">{{ evaluation.description|nl2br }}</p>
                        </div>
                    {% endif %}

                    <div class="mt-4">
                        <form method="post" action="{{ path('admin_evaluation_publish', {'id': evaluation.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('publish' ~ evaluation.id) }}">
                            <button type="submit" class="btn {{ evaluation.isPublished ? 'btn-warning' : 'btn-success' }}">
                                <i class="fas fa-{{ evaluation.isPublished ? 'eye-slash' : 'eye' }} me-1"></i>
                                {{ evaluation.isPublished ? 'Dépublier' : 'Publier' }} les résultats
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            {# Aperçu des notes #}
            {% if grades|length > 0 %}
                <div class="card table-card">
                    <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Aperçu des notes</h6></div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead><tr><th>#</th><th>Élève</th><th>Note</th><th>Appréciation</th></tr></thead>
                                <tbody>
                                    {% for index, grade in grades %}
                                        <tr>
                                            <td class="text-muted">{{ index + 1 }}</td>
                                            <td class="fw-semibold">{{ grade.student.fullName }}</td>
                                            <td><strong>{{ grade.displayValue }}</strong></td>
                                            <td>
                                                {% if grade.value is not null %}
                                                    <span class="badge badge-soft secondary">{{ getAppreciation(grade.value / evaluation.maxGrade * 20) }}</span>
                                                {% else %}
                                                    <span class="text-muted">—</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>

        <div class="col-lg-4">
            {# Statistiques de classe #}
            <div class="card card-accent success mb-4">
                <div class="card-header"><h6 class="m-0 fw-bold text-success"><i class="fas fa-chart-bar me-2"></i>Statistiques de classe</h6></div>
                <div class="card-body">
                    {% if statistics.count > 0 %}
                        <div class="text-center mb-3">
                            <h2 class="text-primary mb-0">{{ statistics.average|number_format(2, '.', '') }}</h2>
                            <small class="text-muted">Moyenne de la classe / {{ evaluation.maxGrade }}</small>
                        </div>
                        <div class="info-list">
                            <div class="info-row"><div class="info-label">Note minimale</div><div class="info-value text-danger fw-bold">{{ statistics.min|number_format(2, '.', '') }}</div></div>
                            <div class="info-row"><div class="info-label">Note maximale</div><div class="info-value text-success fw-bold">{{ statistics.max|number_format(2, '.', '') }}</div></div>
                            <div class="info-row"><div class="info-label">Élèves notés</div><div class="info-value">{{ statistics.count }}</div></div>
                        </div>
                    {% else %}
                        {{ empty_state('fa-chart-bar', 'Aucune statistique', 'Les notes n\'ont pas encore été saisies.') }}
                    {% endif %}
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <div class="info-list">
                        <div class="info-row"><div class="info-label">Créée le</div><div class="info-value">{{ evaluation.createdAt|date('d/m/Y H:i') }}</div></div>
                        {% if evaluation.updatedAt %}
                        <div class="info-row"><div class="info-label">Modifiée le</div><div class="info-value">{{ evaluation.updatedAt|date('d/m/Y H:i') }}</div></div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
