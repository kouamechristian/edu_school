{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Gestion des Évaluations{% endblock %}

{% block body %}
<div class="container-fluid">
    {# ── En-tête ── #}
    {% embed 'components/page_header.html.twig' with {
        title: 'Gestion des Évaluations',
        subtitle: (current_school and current_year) ? current_school.name ~ '  ·  ' ~ current_year.name : 'Évaluations et notes',
        icon: 'fa-clipboard-list',
        color: 'primary',
        breadcrumb: [ { label: 'Évaluations' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_evaluation_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouvelle Évaluation</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    {% if not current_school or not current_year %}
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle me-2"></i>
            Veuillez sélectionner un établissement et une année scolaire.
        </div>
    {% else %}
        {# ── Filtres ── #}
        <div class="card filter-card mb-4">
            <div class="card-body">
                <form method="get" class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label">Classe</label>
                        <select name="classroom" class="form-select" onchange="this.form.submit()">
                            <option value="">Toutes les classes</option>
                            {% for classroom in classrooms %}
                                <option value="{{ classroom.id }}" {{ selected_classroom == classroom.id ? 'selected' : '' }}>{{ classroom.fullName }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Période</label>
                        <select name="period" class="form-select" onchange="this.form.submit()">
                            <option value="">Toutes les périodes</option>
                            {% for period in periods %}
                                <option value="{{ period.id }}" {{ selected_period == period.id ? 'selected' : '' }}>{{ period.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-2">
                        <a href="{{ path('admin_evaluation_index') }}" class="btn btn-light w-100"><i class="fas fa-redo me-1"></i> Réinitialiser</a>
                    </div>
                </form>
            </div>
        </div>

        {# ── Liste ── #}
        <div class="card table-card">
            <div class="card-body">
                {% if evaluations is empty %}
                    {{ empty_state('fa-clipboard-list', 'Aucune évaluation', (selected_classroom or selected_period) ? 'Aucune évaluation ne correspond à ces filtres.' : 'Aucune évaluation pour le moment. Cliquez sur « Nouvelle évaluation » pour en créer une.') }}
                {% else %}
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Classe</th>
                                        <th>Matière</th>
                                        <th>Nom</th>
                                        <th>Type</th>
                                        <th>Date</th>
                                        <th>Note / Coef</th>
                                        <th>Statut</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for evaluation in evaluations %}
                                        <tr>
                                            <td class="text-muted">{{ evaluation.classroom.name }}</td>
                                            <td class="fw-semibold">{{ evaluation.subject.name }}</td>
                                            <td>{{ evaluation.name }}</td>
                                            <td><span class="badge badge-soft secondary">{{ evaluation.typeLabel }}</span></td>
                                            <td class="text-muted">{{ evaluation.date|date('d/m/Y') }}</td>
                                            <td>
                                                <span class="badge badge-soft info">/ {{ evaluation.maxGrade }}</span>
                                                <span class="badge badge-soft warning">x{{ evaluation.coefficient }}</span>
                                            </td>
                                            <td>
                                                <span class="badge badge-soft {{ evaluation.statusColor }}">{{ evaluation.statusLabel }}</span>
                                                {% if evaluation.isPublished and not evaluation.lockedByBulletin %}<span class="badge badge-soft info" title="Résultats publiés"><i class="fas fa-eye"></i></span>{% endif %}
                                            </td>
                                            <td class="text-end">
                                                <div class="btn-group btn-group-sm">
                                                    {% if evaluation.isEditable %}
                                                        <a href="{{ path('admin_evaluation_grades', {'id': evaluation.id}) }}" class="btn btn-success" title="Saisir les notes"><i class="fas fa-keyboard"></i></a>
                                                    {% endif %}
                                                    <a href="{{ path('admin_evaluation_show', {'id': evaluation.id}) }}" class="btn btn-outline-info" title="Détails"><i class="fas fa-eye"></i></a>
                                                    <a href="{{ path('admin_evaluation_edit', {'id': evaluation.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        {% include '_pagination.html.twig' with { pagination: evaluations } %}
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
