{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Saisie des Notes{% endblock %}

{% block body %}
<div class="container-fluid">
    {# ── En-tête ── #}
    {% embed 'components/page_header.html.twig' with {
        title: 'Saisie des Notes',
        subtitle: evaluation.name ~ '  ·  ' ~ evaluation.classroom.name ~ '  ·  ' ~ evaluation.subject.name ~ '  ·  ' ~ evaluation.period.name,
        icon: 'fa-keyboard',
        color: 'success',
        breadcrumb: [
            { label: 'Évaluations', path: path('admin_evaluation_index') },
            { label: evaluation.name, path: path('admin_evaluation_show', {'id': evaluation.id}) },
            { label: 'Saisie des notes' }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_evaluation_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="row g-4">
        <div class="col-lg-9">
            <div class="card table-card">
                <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <h6 class="m-0 fw-bold text-primary"><i class="fas fa-keyboard me-2"></i>Notes des élèves</h6>
                    <div class="d-flex gap-1">
                        <span class="badge badge-soft info"><i class="fas fa-star me-1"></i>/ {{ evaluation.maxGrade }}</span>
                        <span class="badge badge-soft warning">Coef : {{ evaluation.coefficient }}</span>
                    </div>
                </div>
                <div class="card-body">
                    {% if evaluation.lockedByBulletin %}
                        <div class="alert alert-secondary d-flex align-items-center"><i class="fas fa-lock me-2"></i> Les notes sont <strong class="mx-1">verrouillées</strong> : un bulletin a été généré pour cette classe/période. Elles ne sont plus modifiables.</div>
                    {% elseif evaluation.isValidated %}
                        <div class="alert alert-success d-flex align-items-center"><i class="fas fa-check-circle me-2"></i> Évaluation <strong class="mx-1">validée</strong>. Cliquez sur « Annuler » pour modifier à nouveau les notes.</div>
                    {% endif %}

                    <form method="post" id="gradesForm">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th style="width: 5%;">#</th>
                                        <th style="width: 45%;">Élève</th>
                                        <th style="width: 22%;">Note (/ {{ evaluation.maxGrade }})</th>
                                        <th style="width: 28%;">Appréciation</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for index, student in students %}
                                        {% set grade = grades[student.id] ?? null %}
                                        <tr>
                                            <td class="text-muted">{{ index + 1 }}</td>
                                            <td class="fw-semibold">{{ student.fullName }}</td>
                                            <td>
                                                <input type="number" name="grades[{{ student.id }}][value]"
                                                       class="form-control form-control-sm grade-input" step="0.25" min="0"
                                                       max="{{ evaluation.maxGrade }}"
                                                       data-target="appr-{{ student.id }}"
                                                       {% if not editable %}readonly{% endif %}
                                                       value="{{ grade and grade.value is not null ? grade.value : '' }}" placeholder="Ex : 15.50">
                                            </td>
                                            <td>
                                                <span id="appr-{{ student.id }}" class="badge badge-soft secondary fs-6">{{ (grade and grade.value is not null) ? getAppreciation(grade.value / evaluation.maxGrade * 20) : '—' }}</span>
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr><td colspan="4">{{ empty_state('fa-user-slash', 'Aucun élève', 'Aucun élève trouvé dans cette classe.') }}</td></tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </form>

                    {% if students|length > 0 %}
                        <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top flex-wrap gap-2">
                            <div class="text-muted"><i class="fas fa-info-circle me-1"></i><strong>{{ students|length }}</strong> élève(s) dans cette classe</div>
                            <div class="d-flex gap-2 align-items-center">
                                {% if evaluation.lockedByBulletin %}
                                    <span class="badge bg-secondary py-2 px-3"><i class="fas fa-lock me-1"></i> Verrouillée (bulletin généré)</span>
                                {% elseif evaluation.isValidated %}
                                    <span class="badge bg-success py-2 px-3"><i class="fas fa-check me-1"></i> Validée</span>
                                    <form method="post" action="{{ path('admin_evaluation_grades_cancel', {'id': evaluation.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('cancel_validation' ~ evaluation.id) }}">
                                        <button type="submit" class="btn btn-outline-warning"><i class="fas fa-pen me-1"></i> Annuler pour modifier</button>
                                    </form>
                                {% else %}
                                    <button type="submit" form="gradesForm" class="btn btn-success"><i class="fas fa-check me-1"></i> Valider</button>
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-3">
            {# Informations #}
            <div class="card mb-3">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-info-circle me-2"></i>Informations</h6></div>
                <div class="card-body">
                    <div class="info-list">
                        <div class="info-row"><div class="info-label">Date</div><div class="info-value">{{ evaluation.date|date('d/m/Y') }}</div></div>
                        <div class="info-row"><div class="info-label">Type</div><div class="info-value"><span class="badge badge-soft secondary">{{ evaluation.typeLabel }}</span></div></div>
                        <div class="info-row"><div class="info-label">Note max</div><div class="info-value">{{ evaluation.maxGrade }}</div></div>
                        <div class="info-row"><div class="info-label">Coefficient</div><div class="info-value">{{ evaluation.coefficient }}</div></div>
                        <div class="info-row"><div class="info-label">Statut</div><div class="info-value">
                            {% if evaluation.isPublished %}<span class="badge badge-soft success">Publiée</span>{% else %}<span class="badge badge-soft warning">Brouillon</span>{% endif %}
                        </div></div>
                    </div>
                </div>
            </div>

            {# Statistiques #}
            <div class="card card-accent success mb-3">
                <div class="card-header"><h6 class="m-0 fw-bold text-success"><i class="fas fa-chart-bar me-2"></i>Statistiques</h6></div>
                <div class="card-body">
                    {% if statistics.count > 0 %}
                        <div class="info-list">
                            <div class="info-row"><div class="info-label">Moyenne</div><div class="info-value"><strong class="text-primary">{{ statistics.average|number_format(2, '.', '') }}</strong> / {{ evaluation.maxGrade }}</div></div>
                            <div class="info-row"><div class="info-label">Note min</div><div class="info-value text-danger fw-bold">{{ statistics.min|number_format(2, '.', '') }}</div></div>
                            <div class="info-row"><div class="info-label">Note max</div><div class="info-value text-success fw-bold">{{ statistics.max|number_format(2, '.', '') }}</div></div>
                            <div class="info-row"><div class="info-label">Notés</div><div class="info-value"><strong>{{ statistics.count }}</strong> / {{ students|length }}</div></div>
                        </div>
                    {% else %}
                        <p class="text-muted mb-0 small"><i class="fas fa-info-circle me-1"></i>Aucune note saisie pour le moment.</p>
                    {% endif %}
                </div>
            </div>

            {# Aide #}
            <div class="card card-accent warning">
                <div class="card-header"><h6 class="m-0 fw-bold" style="color:#d97706;"><i class="fas fa-question-circle me-2"></i>Aide</h6></div>
                <div class="card-body">
                    <p class="small mb-2"><strong>Saisie des notes :</strong></p>
                    <ul class="small mb-0 ps-3">
                        <li>Saisissez la note de l'élève (sur {{ evaluation.maxGrade }})</li>
                        <li>L'appréciation est calculée automatiquement</li>
                        <li>Utilisez 0.25 pour les quarts de points</li>
                        <li>Laissez vide si l'élève n'est pas encore noté</li>
                        <li>Cliquez sur « Enregistrer » pour sauvegarder</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    var maxGrade = parseFloat('{{ evaluation.maxGrade }}') || 20;

    function appreciation(raw) {
        if (raw === '' || raw === null || isNaN(raw)) {
            return '—';
        }
        var n = parseFloat(raw);
        if (maxGrade > 0) {
            n = n / maxGrade * 20;
        }
        if (n >= 18) return 'Excellent';
        if (n >= 16) return 'Très bien';
        if (n >= 14) return 'Bien';
        if (n >= 12) return 'Assez bien';
        if (n >= 10) return 'Passable';
        if (n >= 8) return 'Insuffisant';
        return 'Très insuffisant';
    }

    document.querySelectorAll('.grade-input').forEach(function (input) {
        input.addEventListener('input', function () {
            var span = document.getElementById(input.dataset.target);
            if (span) {
                span.textContent = appreciation(input.value);
            }
        });
    });
})();
</script>
{% endblock %}
