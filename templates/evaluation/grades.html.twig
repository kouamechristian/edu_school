{% extends 'base.html.twig' %}

{% block title %}Saisie des Notes{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-2">Saisie des Notes</h1>
            <p class="text-muted mb-0">
                <strong>{{ evaluation.name }}</strong> - 
                {{ evaluation.classroom.name }} - 
                {{ evaluation.subject.name }} - 
                {{ evaluation.period.name }}
            </p>
        </div>
        <a href="{{ path('admin_evaluation_index') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Retour
        </a>
    </div>

    {% include '_flash.html.twig' %}

    <div class="row">
        <div class="col-md-9">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-keyboard"></i> Notes des Élèves
                    </h5>
                    <div>
                        <span class="badge bg-light text-dark">
                            <i class="fas fa-star"></i> / {{ evaluation.maxGrade }}
                        </span>
                        <span class="badge bg-warning text-dark">
                            Coef: {{ evaluation.coefficient }}
                        </span>
                    </div>
                </div>
                <div class="card-body p-0">
                    <form method="post">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 5%;">#</th>
                                        <th style="width: 30%;">Élève</th>
                                        <th style="width: 15%;">Note (/ {{ evaluation.maxGrade }})</th>
                                        <th style="width: 20%;">Statut</th>
                                        <th style="width: 30%;">Commentaire</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for index, student in students %}
                                        {% set grade = grades[student.id] ?? null %}
                                        <tr>
                                            <td>{{ index + 1 }}</td>
                                            <td>
                                                <strong>{{ student.fullName }}</strong>
                                            </td>
                                            <td>
                                                <input type="number" 
                                                       name="grades[{{ student.id }}][value]" 
                                                       class="form-control form-control-sm" 
                                                       step="0.25" 
                                                       min="0" 
                                                       max="{{ evaluation.maxGrade }}"
                                                       value="{{ grade ? grade.value : '' }}"
                                                       placeholder="Ex: 15.50">
                                            </td>
                                            <td>
                                                <select name="grades[{{ student.id }}][status]" 
                                                        class="form-select form-select-sm">
                                                    <option value="">-</option>
                                                    <option value="absent" {{ grade and grade.status == 'absent' ? 'selected' : '' }}>
                                                        Absent
                                                    </option>
                                                    <option value="dispense" {{ grade and grade.status == 'dispense' ? 'selected' : '' }}>
                                                        Dispensé
                                                    </option>
                                                    <option value="non_rendu" {{ grade and grade.status == 'non_rendu' ? 'selected' : '' }}>
                                                        Non rendu
                                                    </option>
                                                </select>
                                            </td>
                                            <td>
                                                <input type="text" 
                                                       name="grades[{{ student.id }}][comment]" 
                                                       class="form-control form-control-sm" 
                                                       value="{{ grade ? grade.comment : '' }}"
                                                       placeholder="Commentaire...">
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr>
                                            <td colspan="5" class="text-center py-4">
                                                <i class="fas fa-info-circle text-muted"></i>
                                                Aucun élève trouvé dans cette classe.
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>

                        {% if students|length > 0 %}
                            <div class="card-footer bg-white">
                                <div class="d-flex justify-content-between">
                                    <div class="text-muted">
                                        <i class="fas fa-info-circle"></i>
                                        <strong>{{ students|length }}</strong> élève(s) dans cette classe
                                    </div>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-save"></i> Enregistrer toutes les notes
                                    </button>
                                </div>
                            </div>
                        {% endif %}
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-info text-white">
                    <h6 class="mb-0">
                        <i class="fas fa-info-circle"></i> Informations
                    </h6>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-6">Date :</dt>
                        <dd class="col-sm-6">{{ evaluation.date|date('d/m/Y') }}</dd>

                        <dt class="col-sm-6">Type :</dt>
                        <dd class="col-sm-6">
                            <span class="badge bg-secondary">{{ evaluation.typeLabel }}</span>
                        </dd>

                        <dt class="col-sm-6">Note max :</dt>
                        <dd class="col-sm-6"><strong>{{ evaluation.maxGrade }}</strong></dd>

                        <dt class="col-sm-6">Coefficient :</dt>
                        <dd class="col-sm-6"><strong>{{ evaluation.coefficient }}</strong></dd>

                        <dt class="col-sm-6">Statut :</dt>
                        <dd class="col-sm-6">
                            {% if evaluation.isPublished %}
                                <span class="badge bg-success">Publiée</span>
                            {% else %}
                                <span class="badge bg-warning">Brouillon</span>
                            {% endif %}
                        </dd>
                    </dl>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h6 class="mb-0">
                        <i class="fas fa-chart-bar"></i> Statistiques
                    </h6>
                </div>
                <div class="card-body">
                    {% if statistics.count > 0 %}
                        <dl class="row mb-0">
                            <dt class="col-sm-6">Moyenne :</dt>
                            <dd class="col-sm-6">
                                <strong class="text-primary">{{ statistics.average|number_format(2, '.', '') }}</strong> / {{ evaluation.maxGrade }}
                            </dd>

                            <dt class="col-sm-6">Note min :</dt>
                            <dd class="col-sm-6">
                                <strong class="text-danger">{{ statistics.min|number_format(2, '.', '') }}</strong>
                            </dd>

                            <dt class="col-sm-6">Note max :</dt>
                            <dd class="col-sm-6">
                                <strong class="text-success">{{ statistics.max|number_format(2, '.', '') }}</strong>
                            </dd>

                            <dt class="col-sm-6">Notés :</dt>
                            <dd class="col-sm-6">
                                <strong>{{ statistics.count }}</strong> / {{ students|length }}
                            </dd>
                        </dl>
                    {% else %}
                        <p class="text-muted mb-0">
                            <i class="fas fa-info-circle"></i>
                            Aucune note saisie pour le moment.
                        </p>
                    {% endif %}
                </div>
            </div>

            <div class="card shadow-sm mt-3">
                <div class="card-header bg-warning text-dark">
                    <h6 class="mb-0">
                        <i class="fas fa-question-circle"></i> Aide
                    </h6>
                </div>
                <div class="card-body">
                    <p class="small mb-2">
                        <strong>Saisie des notes :</strong>
                    </p>
                    <ul class="small mb-0">
                        <li>Saisissez une note OU un statut</li>
                        <li>Utilisez 0.25 pour les quarts de points</li>
                        <li>Laissez vide si pas encore noté</li>
                        <li>Cliquez sur "Enregistrer" pour sauvegarder</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

