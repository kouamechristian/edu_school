<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Changer de mot de passe — EDU-SCHOOL</title>

    <link rel="icon" type="image/png" href="{{ asset('images/logo-edu-school.png') }}">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --navy: #1e3a5f;
            --navy-dark: #14273f;
            --emerald: #10b981;
            --emerald-dark: #059669;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            background: #0f1729;
            position: relative;
            overflow: hidden;
        }
        body::before, body::after {
            content: "";
            position: absolute;
            border-radius: 50%;
            filter: blur(90px);
            opacity: 0.45;
            z-index: 0;
        }
        body::before { width: 480px; height: 480px; background: #1e3a5f; top: -120px; left: -120px; }
        body::after  { width: 420px; height: 420px; background: #10b981; bottom: -140px; right: -100px; opacity: 0.3; }

        .card-shell {
            position: relative;
            z-index: 1;
            background: #fff;
            border-radius: 22px;
            box-shadow: 0 30px 80px rgba(0, 0, 0, 0.45);
            overflow: hidden;
            max-width: 460px;
            width: 100%;
            padding: 48px 44px;
            animation: rise 0.6s ease-out;
        }
        @keyframes rise { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }

        .lock-badge {
            width: 64px; height: 64px; border-radius: 18px;
            background: linear-gradient(135deg, var(--navy) 0%, var(--navy-dark) 100%);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.6rem; color: #fff; margin: 0 auto 1.25rem;
            box-shadow: 0 10px 24px rgba(30,58,95,0.35);
        }
        .title { font-family: 'Poppins', sans-serif; font-size: 1.6rem; font-weight: 600; color: var(--navy); text-align: center; margin-bottom: 0.35rem; }
        .subtitle { color: #94a3b8; text-align: center; margin-bottom: 1.75rem; font-size: 0.92rem; }

        .form-label { font-weight: 500; color: #1e293b; font-size: 0.85rem; margin-bottom: 0.4rem; }
        .form-control { height: 50px; border-radius: 12px; border: 1.5px solid #e2e8f0; padding: 0 18px; font-size: 0.95rem; }
        .form-control:focus { border-color: var(--navy); box-shadow: none; }

        .btn-submit {
            height: 50px; border-radius: 12px;
            background: linear-gradient(135deg, var(--emerald) 0%, var(--emerald-dark) 100%);
            border: none; color: #fff; font-weight: 600; font-size: 1rem;
            transition: transform 0.2s, box-shadow 0.2s; width: 100%;
            display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        }
        .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 12px 24px rgba(16,185,129,0.35); color: #fff; }

        .alert { border-radius: 12px; border: none; border-left: 4px solid; font-size: 0.9rem; }
        .alert-warning { background: rgba(245,158,11,0.10); border-left-color: #f59e0b; color: #92400e; }
        .alert-danger { background: rgba(239,68,68,0.08); border-left-color: #ef4444; color: #991b1b; }

        .text-muted-sm { font-size: 0.8rem; color: #94a3b8; }
    </style>
</head>
<body>
    <div class="card-shell">
        <div class="lock-badge"><i class="fas fa-key"></i></div>
        <h1 class="title">Changer votre mot de passe</h1>
        <p class="subtitle">
            {% if forced %}
                Pour des raisons de sécurité, vous devez définir un nouveau mot de passe avant de continuer.
            {% else %}
                Définissez un nouveau mot de passe pour votre compte.
            {% endif %}
        </p>

        {% if forced %}
            <div class="alert alert-warning mb-3">
                <i class="fas fa-shield-halved me-2"></i>
                Connecté en tant que <strong>{{ app.user.userIdentifier }}</strong>. Ce changement est obligatoire.
            </div>
        {% endif %}

        {{ form_start(changePasswordForm) }}
            {% if not changePasswordForm.vars.valid %}
                <div class="alert alert-danger mb-3">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Veuillez corriger les erreurs ci-dessous.
                </div>
            {% endif %}

            <div class="mb-3">
                {{ form_label(changePasswordForm.plainPassword.first) }}
                {{ form_widget(changePasswordForm.plainPassword.first, {'attr': {'class': 'form-control', 'placeholder': 'Au moins 8 caractères'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(changePasswordForm.plainPassword.first) }}</div>
            </div>

            <div class="mb-3">
                {{ form_label(changePasswordForm.plainPassword.second) }}
                {{ form_widget(changePasswordForm.plainPassword.second, {'attr': {'class': 'form-control', 'placeholder': 'Confirmez le mot de passe'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(changePasswordForm.plainPassword.second) }}</div>
            </div>

            <button type="submit" class="btn-submit mt-2">
                <i class="fas fa-check"></i> Enregistrer le nouveau mot de passe
            </button>
        {{ form_end(changePasswordForm) }}

        <div class="text-center mt-3">
            <a href="{{ path('app_logout') }}" class="text-muted-sm"><i class="fas fa-sign-out-alt me-1"></i> Se déconnecter</a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
