<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <style>
        @page { margin: 22px 24px; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 8.5px; color: #000; }
        .header { width: 100%; border-bottom: 1px solid #999; padding-bottom: 6px; margin-bottom: 8px; }
        .header td { vertical-align: middle; }
        .header .logo { width: 72px; }
        .header .logo img { max-height: 58px; max-width: 66px; }
        .header .school { text-align: center; }
        .header .school .name { font-weight: bold; font-size: 14px; }
        .header .school .ministry { font-size: 9px; }
        .title-main { text-align: center; font-weight: bold; font-size: 13px; margin: 4px 0; }
        .sub { text-align: center; font-size: 9px; margin-bottom: 8px; }
        table.rec { width: 60%; border-collapse: collapse; margin: 0 auto 10px; }
        table.rec td { border: 1px solid #000; padding: 4px 8px; font-size: 10px; }
        table.rec .k { background: #f2f2f2; font-weight: bold; }
        table.rec .num { text-align: right; font-weight: bold; }
        table.det { width: 100%; border-collapse: collapse; }
        table.det th, table.det td { border: 1px solid #000; padding: 2px 4px; font-size: 7.5px; }
        table.det th { background: #f2f2f2; text-align: center; }
        td.num { text-align: right; }
        tr.tot td { font-weight: bold; background: #f7f7f7; }
        .sec { font-weight: bold; font-size: 10px; margin: 8px 0 3px; }
    </style>
</head>
<body>
    <table class="header">
        <tr>
            <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
            <td class="school">
                <div class="name">{{ school ? school.name|upper : '' }}</div>
                <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                <div class="ministry">Tel: {{ school ? school.phone : '' }}</div>
            </td>
            <td class="logo"></td>
        </tr>
    </table>

    <div class="title-main">ÉTAT DES COTISATIONS À REVERSER</div>
    <div class="sub">Période : {{ period.label }} — édité le {{ generated_at|date('d/m/Y') }}</div>

    <table class="rec">
        <tr><td class="k">CNPS (salarié + patronal + prestations + accident)</td><td class="num">{{ cnps_total|number_format(0, ',', ' ') }}</td></tr>
        <tr><td class="k">CMU (salarié + employeur)</td><td class="num">{{ cmu_total|number_format(0, ',', ' ') }}</td></tr>
        <tr><td class="k">ITS (DGI)</td><td class="num">{{ its_total|number_format(0, ',', ' ') }}</td></tr>
        <tr><td class="k">TOTAL À REVERSER</td><td class="num">{{ grand_total|number_format(0, ',', ' ') }}</td></tr>
    </table>

    <div class="sec">Détail des composantes</div>
    <table class="det">
        <thead><tr><th>Composante</th><th>Organisme</th><th style="width:20%">Montant</th></tr></thead>
        <tbody>
            <tr><td>CNPS retraite — part salariale</td><td>CNPS</td><td class="num">{{ sum.cnps_employee|number_format(0, ',', ' ') }}</td></tr>
            <tr><td>CNPS retraite — part patronale</td><td>CNPS</td><td class="num">{{ sum.cnps_employer|number_format(0, ',', ' ') }}</td></tr>
            <tr><td>Prestations familiales</td><td>CNPS</td><td class="num">{{ sum.family_benefit|number_format(0, ',', ' ') }}</td></tr>
            <tr><td>Accident du travail</td><td>CNPS</td><td class="num">{{ sum.work_accident|number_format(0, ',', ' ') }}</td></tr>
            <tr><td>CMU — part salariale</td><td>CMU</td><td class="num">{{ sum.cmu_employee|number_format(0, ',', ' ') }}</td></tr>
            <tr><td>CMU — part employeur</td><td>CMU</td><td class="num">{{ sum.cmu_employer|number_format(0, ',', ' ') }}</td></tr>
            <tr><td>ITS (impôt sur salaires)</td><td>DGI</td><td class="num">{{ sum.its|number_format(0, ',', ' ') }}</td></tr>
        </tbody>
    </table>

    <div class="sec">Détail par employé</div>
    <table class="det">
        <thead>
            <tr>
                <th>Employé</th>
                <th style="width:12%">CNPS sal.</th><th style="width:12%">CNPS pat.</th>
                <th style="width:11%">Prest. fam.</th><th style="width:11%">Acc. trav.</th>
                <th style="width:11%">CMU</th><th style="width:12%">ITS</th>
            </tr>
        </thead>
        <tbody>
            {% for ps in payslips %}
                <tr>
                    <td>{{ ps.employee.fullName }}</td>
                    <td class="num">{{ ps.cnpsEmployee|number_format(0, ',', ' ') }}</td>
                    <td class="num">{{ ps.cnpsEmployer|number_format(0, ',', ' ') }}</td>
                    <td class="num">{{ ps.familyBenefit|number_format(0, ',', ' ') }}</td>
                    <td class="num">{{ ps.workAccident|number_format(0, ',', ' ') }}</td>
                    <td class="num">{{ (ps.cmuEmployee + ps.cmuEmployer)|number_format(0, ',', ' ') }}</td>
                    <td class="num">{{ ps.its|number_format(0, ',', ' ') }}</td>
                </tr>
            {% endfor %}
            <tr class="tot">
                <td>TOTAUX</td>
                <td class="num">{{ sum.cnps_employee|number_format(0, ',', ' ') }}</td>
                <td class="num">{{ sum.cnps_employer|number_format(0, ',', ' ') }}</td>
                <td class="num">{{ sum.family_benefit|number_format(0, ',', ' ') }}</td>
                <td class="num">{{ sum.work_accident|number_format(0, ',', ' ') }}</td>
                <td class="num">{{ cmu_total|number_format(0, ',', ' ') }}</td>
                <td class="num">{{ sum.its|number_format(0, ',', ' ') }}</td>
            </tr>
        </tbody>
    </table>
</body>
</html>
