{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Paie — {{ period.label }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Paie — ' ~ period.label,
        subtitle: current_school.name,
        icon: 'fa-money-check-dollar',
        color: 'primary',
        breadcrumb: [
            { label: 'Paie', path: path('admin_payroll_index') },
            { label: period.label }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_payroll_book_pdf', {'id': period.id}) }}" target="_blank" rel="noopener" class="btn btn-outline-danger"><i class="fas fa-file-pdf me-1"></i> Livre de paie</a>
            <a href="{{ path('admin_payroll_book_xlsx', {'id': period.id}) }}" class="btn btn-outline-success"><i class="fas fa-file-excel me-1"></i> Excel</a>
            <a href="{{ path('admin_payroll_cotisations', {'id': period.id}) }}" class="btn btn-outline-primary"><i class="fas fa-file-invoice-dollar me-1"></i> Cotisations</a>
            {% if period.draft %}
                <form method="post" action="{{ path('admin_payroll_period_generate', {'id': period.id}) }}" class="d-inline"
                      data-confirm="Regénérer tous les bulletins de {{ period.label }} ? Les ajustements manuels seront perdus." data-confirm-title="Regénérer" data-confirm-btn="Oui, regénérer" data-confirm-icon="warning">
                    <input type="hidden" name="_token" value="{{ csrf_token('generate' ~ period.id) }}">
                    <button class="btn btn-outline-primary"><i class="fas fa-rotate me-1"></i> Regénérer</button>
                </form>
                <form method="post" action="{{ path('admin_payroll_period_validate', {'id': period.id}) }}" class="d-inline"
                      data-confirm="Valider la période {{ period.label }} ? Les bulletins seront figés." data-confirm-title="Valider la période" data-confirm-btn="Oui, valider" data-confirm-icon="question">
                    <input type="hidden" name="_token" value="{{ csrf_token('validate' ~ period.id) }}">
                    <button class="btn btn-success"><i class="fas fa-lock me-1"></i> Valider</button>
                </form>
            {% elseif period.validated and is_granted('ROLE_CAISSE') %}
                <form method="post" action="{{ path('admin_payroll_period_pay', {'id': period.id}) }}" class="d-inline"
                      data-confirm="Payer les salaires de {{ period.label }} ({{ period.totalNet|number_format(0, ',', ' ') }} F) ? Une dépense de caisse (catégorie salaire) sera créée et portée au journal comptable." data-confirm-title="Payer les salaires" data-confirm-btn="Oui, payer" data-confirm-icon="question">
                    <input type="hidden" name="_token" value="{{ csrf_token('pay' ~ period.id) }}">
                    <select name="payment_method" class="form-select form-select-sm d-inline-block w-auto align-middle me-1">
                        <option value="virement">Virement</option>
                        <option value="espèces">Espèces</option>
                        <option value="chèque">Chèque</option>
                        <option value="mobile_money">Mobile Money</option>
                    </select>
                    <button class="btn btn-success"><i class="fas fa-money-bill-wave me-1"></i> Payer les salaires</button>
                </form>
            {% endif %}
            <a href="{{ path('admin_payroll_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    {% if period.paid %}
        <div class="alert alert-success d-flex justify-content-between align-items-center">
            <div>
                <i class="fas fa-circle-check me-1"></i>
                <strong>Salaires payés</strong> le {{ period.paidAt|date('d/m/Y') }}
                {% if period.paymentMethod %}par {{ period.paymentMethod }}{% endif %}.
                {% if period.paymentDepense %}
                    Dépense de caisse : <span class="badge badge-soft secondary">{{ period.paymentDepense.numero }}</span>
                    (statut : {{ period.paymentDepense.statusLabel }}).
                {% endif %}
            </div>
            {% if is_granted('ROLE_ADMIN') %}
                <form method="post" action="{{ path('admin_payroll_period_cancel_payment', {'id': period.id}) }}" class="d-inline"
                      data-confirm="Annuler le paiement de {{ period.label }} ? La dépense de caisse sera annulée (retrait de l'écriture comptable) et la période repassera en « validée »." data-confirm-title="Annuler le paiement" data-confirm-btn="Oui, annuler" data-confirm-icon="warning">
                    <input type="hidden" name="_token" value="{{ csrf_token('cancelpay' ~ period.id) }}">
                    <button class="btn btn-sm btn-outline-danger"><i class="fas fa-rotate-left me-1"></i> Annuler le paiement</button>
                </form>
            {% endif %}
        </div>
    {% endif %}

    <div class="row g-2 mb-3">
        <div class="col"><div class="card"><div class="card-body py-2"><div class="small text-muted">Statut</div><span class="badge bg-{{ period.statusColor }}">{{ period.statusLabel }}</span></div></div></div>
        <div class="col"><div class="card"><div class="card-body py-2"><div class="small text-muted">Total brut</div><div class="fw-bold">{{ period.totalGross|number_format(0, ',', ' ') }} F</div></div></div></div>
        <div class="col"><div class="card"><div class="card-body py-2"><div class="small text-muted">Total net</div><div class="fw-bold text-success">{{ period.totalNet|number_format(0, ',', ' ') }} F</div></div></div></div>
        <div class="col"><div class="card"><div class="card-body py-2"><div class="small text-muted">Charges patronales</div><div class="fw-bold text-muted">{{ period.totalEmployer|number_format(0, ',', ' ') }} F</div></div></div></div>
    </div>

    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-users me-2"></i>Bulletins ({{ payslips|length }})</h6></div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Réf.</th><th>Employé</th>
                            <th class="text-end">Base</th><th class="text-end">Brut</th>
                            <th class="text-end">CNPS</th><th class="text-end">ITS</th>
                            <th class="text-end">Net</th><th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for ps in payslips %}
                            <tr>
                                <td><span class="badge badge-soft secondary">{{ ps.reference }}</span></td>
                                <td><strong>{{ ps.employee.fullName }}</strong><br><small class="text-muted">{{ ps.employee.employeeTypeLabel }}</small></td>
                                <td class="text-end">{{ ps.baseSalary|number_format(0, ',', ' ') }}</td>
                                <td class="text-end">{{ ps.grossTotal|number_format(0, ',', ' ') }}</td>
                                <td class="text-end text-danger">{{ ps.cnpsEmployee|number_format(0, ',', ' ') }}</td>
                                <td class="text-end text-danger">{{ ps.its|number_format(0, ',', ' ') }}</td>
                                <td class="text-end fw-bold text-success">{{ ps.netPay|number_format(0, ',', ' ') }}</td>
                                <td class="text-end">
                                    <a href="{{ path('admin_payroll_payslip_show', {'id': ps.id}) }}" class="btn btn-sm btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a>
                                    <a href="{{ path('admin_payroll_payslip_pdf', {'id': ps.id}) }}" target="_blank" rel="noopener" class="btn btn-sm btn-outline-danger" title="Bulletin PDF"><i class="fas fa-file-pdf"></i></a>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="8">{{ empty_state('fa-users', 'Aucun bulletin', 'Aucun employé actif avec salaire. Vérifiez les contrats puis regénérez.') }}</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {% if period.status == 'draft' and is_granted('ROLE_ADMIN') %}
        <div class="mt-3">
            <form method="post" action="{{ path('admin_payroll_period_delete', {'id': period.id}) }}" class="d-inline"
                  data-confirm="Supprimer la période {{ period.label }} et tous ses bulletins ?" data-confirm-title="Confirmer la suppression" data-confirm-btn="Oui, supprimer">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_period' ~ period.id) }}">
                <button class="btn btn-outline-danger btn-sm"><i class="fas fa-trash me-1"></i> Supprimer la période</button>
            </form>
        </div>
    {% endif %}
</div>
{% endblock %}
