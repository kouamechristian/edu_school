{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Paie — Périodes{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Paie',
        subtitle: current_school.name,
        icon: 'fa-money-check-dollar',
        color: 'primary',
        breadcrumb: [ { label: 'Paie' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_payroll_components') }}" class="btn btn-outline-primary"><i class="fas fa-list me-1"></i> Rubriques</a>
            <a href="{{ path('admin_payroll_settings') }}" class="btn btn-outline-primary"><i class="fas fa-gear me-1"></i> Paramètres</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="card mb-3">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-calendar-plus me-2"></i>Nouvelle période de paie</h6></div>
        <div class="card-body">
            <form method="post" action="{{ path('admin_payroll_period_new') }}" class="row g-2 align-items-end">
                <input type="hidden" name="_token" value="{{ csrf_token('new_period') }}">
                <div class="col-md-4">
                    <label class="form-label small">Mois</label>
                    <select name="month" class="form-select">
                        {% for num, label in months %}
                            <option value="{{ num }}" {{ num == current_month ? 'selected' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small">Année</label>
                    <input type="number" name="year" value="{{ current_year }}" min="2000" max="2100" class="form-control">
                </div>
                <div class="col-md-4 d-grid">
                    <button class="btn btn-primary"><i class="fas fa-bolt me-1"></i> Créer et générer les bulletins</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-calendar me-2"></i>Périodes</h6></div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Période</th><th>Statut</th>
                            <th class="text-end">Brut</th><th class="text-end">Retenues</th>
                            <th class="text-end">Net à payer</th><th class="text-end">Charges patronales</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for p in periods %}
                            <tr>
                                <td class="fw-semibold">{{ p.label }}</td>
                                <td><span class="badge bg-{{ p.statusColor }}">{{ p.statusLabel }}</span></td>
                                <td class="text-end">{{ p.totalGross|number_format(0, ',', ' ') }}</td>
                                <td class="text-end text-danger">{{ p.totalDeductions|number_format(0, ',', ' ') }}</td>
                                <td class="text-end fw-bold text-success">{{ p.totalNet|number_format(0, ',', ' ') }}</td>
                                <td class="text-end text-muted">{{ p.totalEmployer|number_format(0, ',', ' ') }}</td>
                                <td class="text-end">
                                    <a href="{{ path('admin_payroll_period_show', {'id': p.id}) }}" class="btn btn-sm btn-outline-info" title="Ouvrir"><i class="fas fa-eye"></i></a>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="7">{{ empty_state('fa-money-check-dollar', 'Aucune période', 'Créez votre première période de paie ci-dessus.') }}</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
