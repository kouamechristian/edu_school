{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Bulletins — {{ employee.fullName }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Historique de paie',
        subtitle: employee.fullName,
        icon: 'fa-clock-rotate-left',
        color: 'primary',
        breadcrumb: [
            { label: 'Employés', path: path('admin_employee_index') },
            { label: employee.fullName, path: path('admin_employee_show', {'id': employee.id}) },
            { label: 'Historique de paie' }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_employee_show', {'id': employee.id}) }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour à la fiche</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    <div class="row g-2 mb-3">
        <div class="col-md-4"><div class="card"><div class="card-body py-2"><div class="small text-muted">Bulletins</div><div class="fw-bold">{{ payslips|length }}</div></div></div></div>
        <div class="col-md-4"><div class="card"><div class="card-body py-2"><div class="small text-muted">Cumul brut</div><div class="fw-bold">{{ total_gross|number_format(0, ',', ' ') }} F</div></div></div></div>
        <div class="col-md-4"><div class="card"><div class="card-body py-2"><div class="small text-muted">Cumul net</div><div class="fw-bold text-success">{{ total_net|number_format(0, ',', ' ') }} F</div></div></div></div>
    </div>

    <div class="card table-card">
        <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-receipt me-2"></i>Bulletins de paie</h6></div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Période</th><th>Réf.</th><th>Statut</th>
                            <th class="text-end">Brut</th><th class="text-end">CNPS</th><th class="text-end">ITS</th>
                            <th class="text-end">Net</th><th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for ps in payslips %}
                            <tr>
                                <td class="fw-semibold">{{ ps.period.label }}</td>
                                <td><span class="badge badge-soft secondary">{{ ps.reference }}</span></td>
                                <td><span class="badge bg-{{ ps.period.statusColor }}">{{ ps.period.statusLabel }}</span></td>
                                <td class="text-end">{{ ps.grossTotal|number_format(0, ',', ' ') }}</td>
                                <td class="text-end text-danger">{{ ps.cnpsEmployee|number_format(0, ',', ' ') }}</td>
                                <td class="text-end text-danger">{{ ps.its|number_format(0, ',', ' ') }}</td>
                                <td class="text-end fw-bold text-success">{{ ps.netPay|number_format(0, ',', ' ') }}</td>
                                <td class="text-end">
                                    <a href="{{ path('admin_payroll_payslip_show', {'id': ps.id}) }}" class="btn btn-sm btn-outline-info" title="Voir"><i class="fas fa-eye"></i></a>
                                    <a href="{{ path('admin_payroll_payslip_pdf', {'id': ps.id}) }}" target="_blank" rel="noopener" class="btn btn-sm btn-outline-danger" title="Bulletin PDF"><i class="fas fa-file-pdf"></i></a>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="8">{{ empty_state('fa-receipt', 'Aucun bulletin', 'Aucun bulletin de paie pour cet employé.') }}</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
