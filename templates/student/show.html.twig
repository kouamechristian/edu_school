{% extends 'base.html.twig' %}

{% block title %}Détails de l'élève - {{ student.firstName }} {{ student.lastName }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {# ── En-tête de page ── #}
    {% embed 'components/page_header.html.twig' with {
        title: student.firstName ~ ' ' ~ student.lastName,
        subtitle: 'N° ' ~ student.matriculeInterne,
        icon: 'fa-user-graduate',
        color: 'primary',
        breadcrumb: [
            { label: 'Élèves', path: path('admin_student_index') },
            { label: student.firstName ~ ' ' ~ student.lastName }
        ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_student_edit', {'id': student.id}) }}" class="btn btn-warning"><i class="fas fa-edit me-1"></i> Modifier</a>
            <a href="{{ path('admin_student_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        {% endblock %}
    {% endembed %}

    {# ── Bandeau profil ── #}
    <div class="card mb-4">
        <div class="card-body">
            <div class="profile-hero">
                <div class="profile-avatar" style="background: linear-gradient(135deg, #1e3a5f, #2c5282);">
                    {{ student.firstName|first }}{{ student.lastName|first }}
                </div>
                <div class="flex-grow-1">
                    <h4 class="mb-1">{{ student.firstName }} {{ student.lastName }}</h4>
                    <div class="d-flex flex-wrap gap-2 align-items-center">
                        <span class="badge badge-soft"><i class="fas fa-hashtag me-1"></i>{{ student.matriculeInterne }}</span>
                        {% if student.level %}<span class="badge badge-soft info"><i class="fas fa-layer-group me-1"></i>{{ student.level.name }}</span>{% endif %}
                        <span class="badge bg-{{ student.statusColor }}">{{ student.statusLabel }}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            {# Informations personnelles #}
            <div class="card mb-4">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-id-card me-2"></i>Informations personnelles</h6></div>
                <div class="card-body">
                    <div class="row">
                        {% if student.photo %}
                        <div class="col-md-3 text-center mb-3">
                            <img src="{{ asset(student.photo) }}" alt="Photo de {{ student.firstName }}" class="img-thumbnail" style="max-height: 140px;">
                        </div>
                        {% endif %}
                        <div class="{{ student.photo ? 'col-md-5' : 'col-md-6' }}">
                            <div class="info-list">
                                <div class="info-row"><div class="info-label">Prénom</div><div class="info-value">{{ student.firstName }}</div></div>
                                <div class="info-row"><div class="info-label">Nom</div><div class="info-value">{{ student.lastName }}</div></div>
                                <div class="info-row"><div class="info-label">Date de naissance</div><div class="info-value">{{ student.dateOfBirth ? student.dateOfBirth|date('d/m/Y') : '—' }}</div></div>
                                <div class="info-row"><div class="info-label">Lieu de naissance</div><div class="info-value">{{ student.placeOfBirth ?: '—' }}</div></div>
                                <div class="info-row"><div class="info-label">Genre</div><div class="info-value">{{ student.gender == 'M' ? 'Masculin' : 'Féminin' }}</div></div>
                                <div class="info-row"><div class="info-label">Nationalité</div><div class="info-value">{{ student.nationality ?: '—' }}</div></div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="info-list">
                                <div class="info-row"><div class="info-label">Matricule interne</div><div class="info-value">{{ student.matriculeInterne }}</div></div>
                                <div class="info-row"><div class="info-label">Matricule national</div><div class="info-value">{{ student.matriculeNational ?: '—' }}</div></div>
                                <div class="info-row"><div class="info-label">N° extrait de naissance</div><div class="info-value">{{ student.birthCertificateNumber ?: '—' }}</div></div>
                                <div class="info-row"><div class="info-label">N° CMU</div><div class="info-value">{{ student.cmuNumber ?: '—' }}</div></div>
                                <div class="info-row"><div class="info-label">Téléphone</div><div class="info-value">{{ student.phone ?: '—' }}</div></div>
                                <div class="info-row"><div class="info-label">Email</div><div class="info-value">{{ student.email ?: '—' }}</div></div>
                                <div class="info-row"><div class="info-label">Statut</div><div class="info-value"><span class="badge bg-{{ student.statusColor }}">{{ student.statusLabel }}</span></div></div>
                            </div>
                        </div>
                    </div>
                    {% if student.address %}
                    <div class="info-list mt-2">
                        <div class="info-row"><div class="info-label">Adresse</div><div class="info-value">{{ student.address|nl2br }}</div></div>
                    </div>
                    {% endif %}
                </div>
            </div>

            {# Informations scolaires #}
            <div class="card mb-4">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-school me-2"></i>Informations scolaires</h6></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Niveau</div><div class="info-value">{{ student.level ? student.level.name : '—' }}</div></div>
                            <div class="info-row"><div class="info-label">Année scolaire</div><div class="info-value">{{ student.schoolYear ? student.schoolYear.name : '—' }}</div></div>
                        </div></div>
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">École</div><div class="info-value">{{ student.school ? student.school.name : '—' }}</div></div>
                            <div class="info-row"><div class="info-label">Doublant</div><div class="info-value">{{ student.isRepeating ? 'Oui' : 'Non' }}</div></div>
                            <div class="info-row"><div class="info-label">Dernière école fréquentée</div><div class="info-value">{{ student.lastSchoolAttended ?: '—' }}</div></div>
                            <div class="info-row"><div class="info-label">Date d'inscription</div><div class="info-value">{{ student.createdAt ? student.createdAt|date('d/m/Y') : '—' }}</div></div>
                        </div></div>
                    </div>
                </div>
            </div>

            {# Informations du parent/tuteur #}
            <div class="card mb-4">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-user-friends me-2"></i>Parent / Tuteur</h6></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Nom</div><div class="info-value">{{ student.parentName ?: '—' }}</div></div>
                            <div class="info-row"><div class="info-label">Téléphone</div><div class="info-value">{{ student.parentPhone ?: '—' }}</div></div>
                        </div></div>
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Email</div><div class="info-value">{{ student.parentEmail ?: '—' }}</div></div>
                            <div class="info-row"><div class="info-label">Fonction</div><div class="info-value">{{ student.parentFunction ?: '—' }}</div></div>
                        </div></div>
                    </div>
                    {% if student.parentAddress %}
                    <div class="info-list mt-2">
                        <div class="info-row"><div class="info-label">Domicile</div><div class="info-value">{{ student.parentAddress|nl2br }}</div></div>
                    </div>
                    {% endif %}
                </div>
            </div>

            {# Contact d'urgence #}
            <div class="card mb-4">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-phone-alt me-2"></i>Contact d'urgence</h6></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Contact</div><div class="info-value">{{ student.emergencyContact ?: '—' }}</div></div>
                        </div></div>
                        <div class="col-md-6"><div class="info-list">
                            <div class="info-row"><div class="info-label">Téléphone</div><div class="info-value">{{ student.emergencyPhone ?: '—' }}</div></div>
                        </div></div>
                    </div>
                </div>
            </div>

            {% if student.medicalInfo %}
            <div class="card mb-4">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-notes-medical me-2"></i>Informations médicales</h6></div>
                <div class="card-body"><p class="mb-0">{{ student.medicalInfo|nl2br }}</p></div>
            </div>
            {% endif %}

            {% if student.notes %}
            <div class="card mb-4">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-sticky-note me-2"></i>Notes</h6></div>
                <div class="card-body"><p class="mb-0">{{ student.notes|nl2br }}</p></div>
            </div>
            {% endif %}

            {# Historique des transferts de classe #}
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="m-0 fw-bold text-primary"><i class="fas fa-exchange-alt me-2"></i>Transferts de classe</h6>
                    <span class="badge bg-primary">{{ transfers is defined ? transfers|length : 0 }}</span>
                </div>
                <div class="card-body">
                    {% if transfers is defined and transfers|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover table-sm mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>Origine</th>
                                        <th>Destination</th>
                                        <th>Motif</th>
                                        <th>Document</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for t in transfers %}
                                        <tr>
                                            <td>{{ t.createdAt ? t.createdAt|date('d/m/Y') : '-' }}</td>
                                            <td>{{ t.fromClassroom ? t.fromClassroom.name : '—' }}</td>
                                            <td class="fw-bold">{{ t.toClassroom ? t.toClassroom.name : '—' }}</td>
                                            <td>{{ t.motif }}</td>
                                            <td>
                                                {% if t.documentPath %}
                                                    <a href="{{ asset(t.documentPath) }}" target="_blank" class="btn btn-sm btn-outline-primary" title="Voir le document">
                                                        <i class="fas fa-file"></i>
                                                    </a>
                                                {% else %}
                                                    <span class="text-muted">—</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <p class="text-muted mb-0"><i class="fas fa-info-circle me-1"></i> Aucun transfert enregistré pour cet élève.</p>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            {# Situation financière #}
            <div class="card card-accent mb-4">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-money-bill-wave me-2"></i>Scolarité</h6></div>
                <div class="card-body">
                    {% set totalTuition = student.totalTuition %}
                    {% set totalPaid = student.totalPaid %}
                    {% set remaining = student.remainingTuition %}
                    {% set percentage = totalTuition > 0 ? ((totalPaid / totalTuition) * 100)|round : 0 %}

                    <div class="text-center mb-3">
                        <h4 class="fw-bold text-primary mb-0">{{ totalTuition|number_format(0, ',', ' ') }} <small class="text-muted fs-6">FCFA</small></h4>
                        <small class="text-muted">Total scolarité</small>
                    </div>

                    <div class="progress mb-3">
                        <div class="progress-bar bg-{{ percentage >= 100 ? 'success' : (percentage >= 50 ? 'info' : 'warning') }}" style="width: {{ percentage }}%"></div>
                    </div>

                    <div class="row text-center">
                        <div class="col-6">
                            <strong class="text-success d-block">{{ totalPaid|number_format(0, ',', ' ') }}</strong>
                            <small class="text-muted">Payé</small>
                        </div>
                        <div class="col-6">
                            <strong class="text-{{ remaining > 0 ? 'danger' : 'success' }} d-block">{{ remaining|number_format(0, ',', ' ') }}</strong>
                            <small class="text-muted">Reste</small>
                        </div>
                    </div>

                    {% if student.studentFees|length > 0 %}
                        <hr>
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead><tr><th>Frais</th><th class="text-end">Montant</th><th width="40"></th></tr></thead>
                                <tbody>
                                    {% for sf in student.studentFees %}
                                        <tr>
                                            <td>
                                                <strong>{{ sf.fee.name }}</strong><br>
                                                <span class="badge bg-{{ sf.fee.categoryColor }}">{{ sf.fee.categoryLabel }}</span>
                                                <span class="badge bg-{{ sf.statusColor }}">{{ sf.statusLabel }}</span>
                                            </td>
                                            <td class="text-end align-middle">
                                                <strong>{{ sf.amount|number_format(0, ',', ' ') }} F</strong>
                                                {% if sf.paidAmount > 0 %}<br><small class="text-success">Payé : {{ sf.paidAmount|number_format(0, ',', ' ') }} F</small>{% endif %}
                                            </td>
                                            <td class="align-middle">
                                                {% if sf.status == 'non_paye' %}
                                                    <form method="post" action="{{ path('admin_student_remove_fee', {'id': student.id, 'studentFeeId': sf.id}) }}"
                                                          onsubmit="return confirm('Retirer ce frais ?');" class="d-inline">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('remove_fee' ~ sf.id) }}">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Retirer"><i class="fas fa-times"></i></button>
                                                    </form>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <hr>
                        <div class="text-center text-muted py-2"><small>Aucun frais affecté</small></div>
                    {% endif %}

                    {% if payments is defined and payments|length > 0 %}
                        <hr>
                        <h6 class="text-muted mb-2"><i class="fas fa-receipt me-1"></i>Historique des paiements</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-striped mb-0">
                                <thead><tr><th>N°</th><th>Frais</th><th class="text-end">Montant</th><th>Date</th><th>Caissière</th></tr></thead>
                                <tbody>
                                    {% for p in payments %}
                                        {% if p.status != 'annulé' %}
                                            <tr>
                                                <td><small class="text-muted">{{ p.paymentNumber }}</small></td>
                                                <td>{{ p.fee ? p.fee.name : '-' }}</td>
                                                <td class="text-end fw-bold">{{ p.amount|number_format(0, ',', ' ') }} F</td>
                                                <td>{{ p.paymentDate ? p.paymentDate|date('d/m/Y') : '-' }}</td>
                                                <td>{{ p.recordedBy ? p.recordedBy.fullName : '-' }}</td>
                                            </tr>
                                        {% endif %}
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}

                    {% if available_fees|length > 0 %}
                        <hr>
                        <h6 class="text-muted mb-2"><i class="fas fa-plus-circle me-1"></i>Ajouter un frais</h6>
                        <form method="post" action="{{ path('admin_student_add_fee', {'id': student.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('add_fee' ~ student.id) }}">
                            <div class="list-group list-group-flush mb-2" style="max-height: 200px; overflow-y: auto;">
                                {% for fee in available_fees %}
                                    <label class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-2 py-1">
                                        <div>
                                            <input type="checkbox" name="fee_ids[]" value="{{ fee.id }}" class="form-check-input me-1">
                                            {{ fee.name }}
                                            <span class="badge bg-{{ fee.categoryColor }} ms-1">{{ fee.categoryLabel }}</span>
                                        </div>
                                        <small class="text-muted">{{ fee.amount|number_format(0, ',', ' ') }} F</small>
                                    </label>
                                {% endfor %}
                            </div>
                            <button type="submit" class="btn btn-sm btn-primary w-100"><i class="fas fa-plus me-1"></i>Ajouter les frais sélectionnés</button>
                        </form>
                    {% endif %}
                </div>
            </div>


            {# Actions rapides #}
            <div class="card mb-4">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-bolt me-2"></i>Actions rapides</h6></div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        <a href="{{ path('admin_student_edit', {'id': student.id}) }}" class="list-group-item list-group-item-action border-0 px-0"><i class="fas fa-edit me-2 text-warning"></i>Modifier les informations</a>
                        <a href="#" class="list-group-item list-group-item-action border-0 px-0"><i class="fas fa-graduation-cap me-2 text-primary"></i>Voir les notes</a>
                        <a href="#" class="list-group-item list-group-item-action border-0 px-0"><i class="fas fa-calendar-alt me-2 text-info"></i>Voir les absences</a>
                        <a href="#" class="list-group-item list-group-item-action border-0 px-0"><i class="fas fa-file-alt me-2 text-success"></i>Générer un rapport</a>
                    </div>
                </div>
            </div>

            {% if student.preRegistration %}
            <div class="card mb-4">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-clipboard-check me-2"></i>Préinscription</h6></div>
                <div class="card-body">
                    <div class="info-list mb-3">
                        <div class="info-row"><div class="info-label">Statut</div><div class="info-value"><span class="badge bg-{{ student.preRegistration.status == 'enrolled' ? 'success' : 'warning' }}">{{ student.preRegistration.status == 'enrolled' ? 'Inscrit' : student.preRegistration.status }}</span></div></div>
                        <div class="info-row"><div class="info-label">Date</div><div class="info-value">{{ student.preRegistration.createdAt|date('d/m/Y') }}</div></div>
                        {% if student.preRegistration.validatedAt %}
                        <div class="info-row"><div class="info-label">Validée le</div><div class="info-value">{{ student.preRegistration.validatedAt|date('d/m/Y') }}</div></div>
                        {% endif %}
                    </div>
                    <a href="{{ path('admin_pre_registration_show', {'id': student.preRegistration.id}) }}" class="btn btn-sm btn-outline-primary w-100"><i class="fas fa-eye me-1"></i> Voir la préinscription</a>
                </div>
            </div>
            {% endif %}

            {# Historique #}
            <div class="card mb-4">
                <div class="card-header"><h6 class="m-0 fw-bold text-primary"><i class="fas fa-clock-rotate-left me-2"></i>Historique</h6></div>
                <div class="card-body">
                    <div class="info-list">
                        <div class="info-row"><div class="info-label">Créé le</div><div class="info-value">{{ student.createdAt|date('d/m/Y à H:i') }}</div></div>
                        <div class="info-row"><div class="info-label">Modifié le</div><div class="info-value">{{ student.updatedAt|date('d/m/Y à H:i') }}</div></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
