{% extends 'base.html.twig' %}

{% block title %}Détails de l'élève - {{ student.firstName }} {{ student.lastName }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            {{ student.firstName }} {{ student.lastName }}
            <small class="text-muted">({{ student.studentNumber }})</small>
        </h1>
        <div>
            <a href="{{ path('admin_student_edit', {'id': student.id}) }}" class="btn btn-warning">
                <i class="fas fa-edit"></i> Modifier
            </a>
            <a href="{{ path('admin_student_index') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Retour à la liste
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <!-- Informations personnelles -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Informations personnelles</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Prénom :</strong> {{ student.firstName }}</p>
                            <p><strong>Nom :</strong> {{ student.lastName }}</p>
                            <p><strong>Date de naissance :</strong> {{ student.dateOfBirth ? student.dateOfBirth|date('d/m/Y') : 'Non renseignée' }}</p>
                            <p><strong>Genre :</strong> {{ student.gender == 'M' ? 'Masculin' : 'Féminin' }}</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Numéro d'élève :</strong> {{ student.studentNumber }}</p>
                            <p><strong>Téléphone :</strong> {{ student.phone ?: 'Non renseigné' }}</p>
                            <p><strong>Email :</strong> {{ student.email ?: 'Non renseigné' }}</p>
                            <p><strong>Statut :</strong> 
                                <span class="badge badge-{{ student.status == 'active' ? 'success' : (student.status == 'inactive' ? 'warning' : 'info') }}">
                                    {{ student.status == 'active' ? 'Actif' : (student.status == 'inactive' ? 'Inactif' : (student.status == 'graduated' ? 'Diplômé' : 'Transféré')) }}
                                </span>
                            </p>
                        </div>
                    </div>
                    {% if student.address %}
                    <div class="row">
                        <div class="col-12">
                            <p><strong>Adresse :</strong><br>{{ student.address|nl2br }}</p>
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>

            <!-- Informations scolaires -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Informations scolaires</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Niveau :</strong> {{ student.level ? student.level.name : 'Non renseigné' }}</p>
                            <p><strong>Année scolaire :</strong> {{ student.schoolYear ? student.schoolYear.name : 'Non renseignée' }}</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>École :</strong> {{ student.school ? student.school.name : 'Non renseignée' }}</p>
                            <p><strong>Date d'inscription :</strong> {{ student.createdAt ? student.createdAt|date('d/m/Y') : 'Non renseignée' }}</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Informations du parent/tuteur -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Informations du parent/tuteur</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Nom :</strong> {{ student.parentName ?: 'Non renseigné' }}</p>
                            <p><strong>Téléphone :</strong> {{ student.parentPhone ?: 'Non renseigné' }}</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Email :</strong> {{ student.parentEmail ?: 'Non renseigné' }}</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact d'urgence -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Contact d'urgence</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Contact :</strong> {{ student.emergencyContact ?: 'Non renseigné' }}</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Téléphone :</strong> {{ student.emergencyPhone ?: 'Non renseigné' }}</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Informations médicales -->
            {% if student.medicalInfo %}
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Informations médicales</h6>
                </div>
                <div class="card-body">
                    <p>{{ student.medicalInfo|nl2br }}</p>
                </div>
            </div>
            {% endif %}

            <!-- Notes -->
            {% if student.notes %}
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Notes</h6>
                </div>
                <div class="card-body">
                    <p>{{ student.notes|nl2br }}</p>
                </div>
            </div>
            {% endif %}
        </div>

        <div class="col-lg-4">
            <!-- Actions rapides -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Actions rapides</h6>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        <a href="{{ path('admin_student_edit', {'id': student.id}) }}" class="list-group-item list-group-item-action">
                            <i class="fas fa-edit"></i> Modifier les informations
                        </a>
                        <a href="#" class="list-group-item list-group-item-action">
                            <i class="fas fa-graduation-cap"></i> Voir les notes
                        </a>
                        <a href="#" class="list-group-item list-group-item-action">
                            <i class="fas fa-calendar-alt"></i> Voir les absences
                        </a>
                        <a href="#" class="list-group-item list-group-item-action">
                            <i class="fas fa-file-alt"></i> Générer un rapport
                        </a>
                    </div>
                </div>
            </div>

            <!-- Informations de préinscription -->
            {% if student.preRegistration %}
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Préinscription</h6>
                </div>
                <div class="card-body">
                    <p><strong>Statut :</strong> 
                        <span class="badge badge-{{ student.preRegistration.status == 'enrolled' ? 'success' : 'warning' }}">
                            {{ student.preRegistration.status == 'enrolled' ? 'Inscrit' : student.preRegistration.status }}
                        </span>
                    </p>
                    <p><strong>Date de préinscription :</strong> {{ student.preRegistration.createdAt|date('d/m/Y') }}</p>
                    {% if student.preRegistration.validatedAt %}
                    <p><strong>Date de validation :</strong> {{ student.preRegistration.validatedAt|date('d/m/Y') }}</p>
                    {% endif %}
                    <a href="{{ path('admin_pre_registration_show', {'id': student.preRegistration.id}) }}" 
                       class="btn btn-sm btn-outline-primary">
                        <i class="fas fa-eye"></i> Voir la préinscription
                    </a>
                </div>
            </div>
            {% endif %}

            <!-- Historique -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Historique</h6>
                </div>
                <div class="card-body">
                    <p><strong>Créé le :</strong> {{ student.createdAt|date('d/m/Y à H:i') }}</p>
                    <p><strong>Modifié le :</strong> {{ student.updatedAt|date('d/m/Y à H:i') }}</p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
