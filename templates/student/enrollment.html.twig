{% extends 'base.html.twig' %}

{% block title %}Inscriptions des Élèves{% endblock %}

{% block body %}
<div class="container-fluid">
    <!-- En-tête avec statistiques -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">
                <i class="fas fa-graduation-cap text-primary me-2"></i>
                Inscriptions des Élèves
            </h1>
            <p class="text-muted mb-0">Gérer les inscriptions des élèves à partir des préinscriptions validées</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('admin_pre_registration_index') }}" class="btn btn-outline-info">
                <i class="fas fa-clipboard-list"></i> Préinscriptions
            </a>
            <a href="{{ path('admin_student_index') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Retour à la liste
            </a>
        </div>
    </div>

    <!-- Statistiques rapides -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                Préinscriptions validées
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ preRegistrations|length }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-clipboard-check fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                Classes disponibles
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ classrooms|length }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-door-open fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                Niveaux disponibles
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ levels|length }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-layer-group fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                Prêt pour inscription
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800" id="readyCount">{{ preRegistrations|length }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-user-check fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {% if preRegistrations|length > 0 %}
    <!-- Formulaire d'inscription -->
    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-list-check me-2"></i>
                        Préinscriptions validées prêtes pour l'inscription
                    </h6>
                    <div class="d-flex align-items-center">
                        <span class="badge bg-primary me-2" id="selectedBadge">0 sélectionné(s)</span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="clearSelection">
                            <i class="fas fa-times"></i> Effacer
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <form method="POST" id="enrollmentForm">
                        <!-- Tableau des préinscriptions -->
                        <div class="table-responsive">
                            <table class="table table-hover" id="enrollmentTable">
                                <thead class="table-light">
                                    <tr>
                                        <th width="50">
                                            <div class="form-check">
                                                <input type="checkbox" id="selectAll" class="form-check-input">
                                                <label for="selectAll" class="form-check-label"></label>
                                            </div>
                                        </th>
                                        <th>
                                            <i class="fas fa-user me-1"></i> Nom complet
                                        </th>
                                        <th>
                                            <i class="fas fa-calendar me-1"></i> Date de naissance
                                        </th>
                                        <th>
                                            <i class="fas fa-layer-group me-1"></i> Niveau demandé
                                        </th>
                                        <th>
                                            <i class="fas fa-check-circle me-1"></i> Date de validation
                                        </th>
                                        <th width="100">
                                            <i class="fas fa-cog me-1"></i> Actions
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for preRegistration in preRegistrations %}
                                    <tr class="enrollment-row" data-id="{{ preRegistration.id }}">
                                        <td>
                                            <div class="form-check">
                                                <input type="checkbox" name="students[]" value="{{ preRegistration.id }}" 
                                                       class="form-check-input student-checkbox" id="student_{{ preRegistration.id }}">
                                                <label for="student_{{ preRegistration.id }}" class="form-check-label"></label>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-sm bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3">
                                                    {{ preRegistration.firstName|first|upper }}{{ preRegistration.lastName|first|upper }}
                                                </div>
                                                <div>
                                                    <div class="fw-bold">{{ preRegistration.lastName }} {{ preRegistration.firstName }}</div>
                                                    <small class="text-muted">{{ preRegistration.genderLabel }}</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge bg-light text-dark">
                                                {{ preRegistration.dateOfBirth|date('d/m/Y') }}
                                            </span>
                                        </td>
                                        <td>
                                            {% if preRegistration.requestedLevel %}
                                                <span class="badge bg-info">{{ preRegistration.requestedLevel.name }}</span>
                                            {% else %}
                                                <span class="text-muted">Non renseigné</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <span class="badge bg-success">
                                                {{ preRegistration.validatedAt ? preRegistration.validatedAt|date('d/m/Y') : 'Non validé' }}
                                            </span>
                                        </td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a href="{{ path('admin_pre_registration_show', {'id': preRegistration.id}) }}" 
                                                   class="btn btn-sm btn-outline-primary" title="Voir la préinscription">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <button type="button" class="btn btn-sm btn-outline-info" 
                                                        title="Informations" data-bs-toggle="tooltip" 
                                                        data-bs-placement="top">
                                                    <i class="fas fa-info"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>

                        <!-- Configuration d'inscription -->
                        <div class="row mt-4">
                            <div class="col-12">
                                <div class="card border-0 bg-light">
                                    <div class="card-body">
                                        <h6 class="card-title text-primary mb-3">
                                            <i class="fas fa-cog me-2"></i>
                                            Configuration de l'inscription
                                        </h6>
                                        
                                        <div class="row">
                                            <div class="col-12">
                                                <div class="mb-3">
                                                    <label for="class_id" class="form-label fw-bold">
                                                        <i class="fas fa-door-open me-1"></i>
                                                        Classe d'affectation
                                                    </label>
                                                    <select class="form-select" id="class_id" name="class_id">
                                                        <option value="">Sélectionner une classe (optionnel)</option>
                                                        <!-- Les classes seront chargées dynamiquement selon le niveau de l'élève sélectionné -->
                                                    </select>
                                                    <div class="form-text">Sélectionnez d'abord un élève pour voir les classes disponibles pour son niveau</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <div class="d-flex align-items-center">
                                <button type="submit" class="btn btn-success btn-lg" id="enrollButton" disabled>
                                    <i class="fas fa-graduation-cap me-2"></i>
                                    Inscrire les élèves sélectionnés
                                </button>
                                <div class="ms-3">
                                    <div class="text-muted" id="selectedCount">Aucun élève sélectionné</div>
                                    <small class="text-muted">Sélectionnez au moins un élève pour continuer</small>
                                </div>
                            </div>
                            
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-outline-secondary" id="selectAllBtn">
                                    <i class="fas fa-check-double me-1"></i>
                                    Tout sélectionner
                                </button>
                                <button type="button" class="btn btn-outline-warning" id="deselectAllBtn" disabled>
                                    <i class="fas fa-times me-1"></i>
                                    Tout désélectionner
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    {% else %}
    <!-- État vide -->
    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow">
                <div class="card-body text-center py-5">
                    <div class="mb-4">
                        <i class="fas fa-clipboard-list fa-4x text-muted"></i>
                    </div>
                    <h4 class="text-muted mb-3">Aucune préinscription validée</h4>
                    <p class="text-muted mb-4">
                        Il n'y a actuellement aucune préinscription validée prête pour l'inscription.<br>
                        Les préinscriptions doivent être validées avant de pouvoir inscrire les élèves.
                    </p>
                    <div class="d-flex justify-content-center gap-3">
                        <a href="{{ path('admin_pre_registration_index') }}" class="btn btn-primary">
                            <i class="fas fa-clipboard-list me-2"></i>
                            Voir les préinscriptions
                        </a>
                        <a href="{{ path('admin_pre_registration_new') }}" class="btn btn-outline-primary">
                            <i class="fas fa-plus me-2"></i>
                            Nouvelle préinscription
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}
</div>

<style>
.avatar-sm {
    width: 40px;
    height: 40px;
    font-size: 14px;
    font-weight: bold;
}

.enrollment-row:hover {
    background-color: #f8f9fa;
}

.enrollment-row.selected {
    background-color: #e3f2fd;
}

.border-left-primary {
    border-left: 0.25rem solid #4e73df !important;
}

.border-left-success {
    border-left: 0.25rem solid #1cc88a !important;
}

.border-left-info {
    border-left: 0.25rem solid #36b9cc !important;
}

.border-left-warning {
    border-left: 0.25rem solid #f6c23e !important;
}

.text-xs {
    font-size: 0.7rem;
}

#enrollButton:disabled {
    opacity: 0.6;
    cursor: not-allowed;
}

#selectedBadge {
    font-size: 0.8rem;
    padding: 0.5rem 0.75rem;
}

.table-hover tbody tr:hover {
    background-color: rgba(0, 0, 0, 0.075);
}

.form-check-input:checked {
    background-color: #198754;
    border-color: #198754;
}

.btn-group .btn {
    border-radius: 0.375rem;
}

.btn-group .btn:not(:last-child) {
    margin-right: 0.25rem;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Éléments DOM
    const selectAllCheckbox = document.getElementById('selectAll');
    const studentCheckboxes = document.querySelectorAll('.student-checkbox');
    const enrollButton = document.getElementById('enrollButton');
    const selectedCount = document.getElementById('selectedCount');
    const selectedBadge = document.getElementById('selectedBadge');
    const selectAllBtn = document.getElementById('selectAllBtn');
    const deselectAllBtn = document.getElementById('deselectAllBtn');
    const clearSelectionBtn = document.getElementById('clearSelection');
    const enrollmentForm = document.getElementById('enrollmentForm');
    const enrollmentRows = document.querySelectorAll('.enrollment-row');

    // Initialisation
    updateUI();

    // Gestion de la sélection globale via checkbox
    selectAllCheckbox.addEventListener('change', function() {
        const isChecked = this.checked;
        studentCheckboxes.forEach(checkbox => {
            checkbox.checked = isChecked;
        });
        updateUI();
    });

    // Gestion de la sélection individuelle
    studentCheckboxes.forEach(checkbox => {
        checkbox.addEventListener('change', function() {
            updateUI();
            loadClassesForSelectedStudents();
        });
    });

    // Bouton "Tout sélectionner"
    selectAllBtn.addEventListener('click', function() {
        studentCheckboxes.forEach(checkbox => {
            checkbox.checked = true;
        });
        selectAllCheckbox.checked = true;
        updateUI();
    });

    // Bouton "Tout désélectionner"
    deselectAllBtn.addEventListener('click', function() {
        studentCheckboxes.forEach(checkbox => {
            checkbox.checked = false;
        });
        selectAllCheckbox.checked = false;
        updateUI();
    });

    // Bouton "Effacer"
    clearSelectionBtn.addEventListener('click', function() {
        studentCheckboxes.forEach(checkbox => {
            checkbox.checked = false;
        });
        selectAllCheckbox.checked = false;
        updateUI();
    });

    // Mise à jour de l'interface
    function updateUI() {
        const selected = document.querySelectorAll('.student-checkbox:checked').length;
        const total = studentCheckboxes.length;
        
        // Mise à jour des compteurs
        selectedCount.textContent = selected === 0 ? 'Aucun élève sélectionné' : `${selected} élève(s) sélectionné(s)`;
        selectedBadge.textContent = `${selected} sélectionné(s)`;
        
        // Mise à jour du bouton d'inscription
        enrollButton.disabled = selected === 0;
        
        // Mise à jour des boutons de sélection
        selectAllBtn.disabled = selected === total;
        deselectAllBtn.disabled = selected === 0;
        clearSelectionBtn.disabled = selected === 0;
        
        // Mise à jour de l'état de la checkbox "Tout sélectionner"
        if (selected === 0) {
            selectAllCheckbox.indeterminate = false;
            selectAllCheckbox.checked = false;
        } else if (selected === total) {
            selectAllCheckbox.indeterminate = false;
            selectAllCheckbox.checked = true;
        } else {
            selectAllCheckbox.indeterminate = true;
            selectAllCheckbox.checked = false;
        }
        
        // Mise à jour visuelle des lignes sélectionnées
        enrollmentRows.forEach(row => {
            const checkbox = row.querySelector('.student-checkbox');
            if (checkbox.checked) {
                row.classList.add('selected');
            } else {
                row.classList.remove('selected');
            }
        });
    }

    // Validation du formulaire
    enrollmentForm.addEventListener('submit', function(e) {
        const selectedStudents = document.querySelectorAll('.student-checkbox:checked').length;
        const classId = document.getElementById('class_id').value;

        // Validation des élèves sélectionnés
        if (selectedStudents === 0) {
            e.preventDefault();
            showAlert('Veuillez sélectionner au moins un élève.', 'warning');
            return;
        }

        // Validation des options (au moins une doit être sélectionnée)
        if (!classId) {
            e.preventDefault();
            showAlert('Veuillez sélectionner une classe.', 'warning');
            return;
        }

        // Confirmation finale
        if (!confirm(`Êtes-vous sûr de vouloir inscrire ${selectedStudents} élève(s) ?\n\nCette action est définitive.`)) {
            e.preventDefault();
        }
    });

    // Fonction d'alerte personnalisée
    function showAlert(message, type = 'info') {
        // Créer une alerte Bootstrap
        const alertDiv = document.createElement('div');
        alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
        alertDiv.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
        alertDiv.innerHTML = `
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        
        document.body.appendChild(alertDiv);
        
        // Supprimer automatiquement après 5 secondes
        setTimeout(() => {
            if (alertDiv.parentNode) {
                alertDiv.remove();
            }
        }, 5000);
    }

    // Initialisation des tooltips Bootstrap
    const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });

    // Données des préinscriptions et classes
    const preRegistrationsData = {{ preRegistrationsData|json_encode|raw }};
    const classroomsByLevel = {{ classroomsByLevel|json_encode|raw }};

    // Fonction pour charger les classes selon les élèves sélectionnés
    function loadClassesForSelectedStudents() {
        const selectedCheckboxes = document.querySelectorAll('.student-checkbox:checked');
        const classSelect = document.getElementById('class_id');
        
        // Vider les options existantes (garder la première option)
        classSelect.innerHTML = '<option value="">Sélectionner une classe (optionnel)</option>';
        
        if (selectedCheckboxes.length === 0) {
            return;
        }
        
        // Récupérer les niveaux des élèves sélectionnés
        const selectedLevels = new Set();
        selectedCheckboxes.forEach(checkbox => {
            const preRegId = parseInt(checkbox.value);
            const preRegData = preRegistrationsData.find(p => p.id === preRegId);
            if (preRegData && preRegData.levelId) {
                selectedLevels.add(preRegData.levelId);
            }
        });
        
        // Charger les classes pour les niveaux sélectionnés
        selectedLevels.forEach(levelId => {
            if (classroomsByLevel[levelId]) {
                classroomsByLevel[levelId].forEach(classroom => {
                    const option = document.createElement('option');
                    option.value = classroom.id;
                    option.textContent = classroom.name;
                    classSelect.appendChild(option);
                });
            }
        });
        
        // Si aucune classe trouvée, afficher un message
        if (classSelect.children.length === 1) {
            const option = document.createElement('option');
            option.value = '';
            option.textContent = 'Aucune classe disponible pour ce(s) niveau(x)';
            option.disabled = true;
            classSelect.appendChild(option);
        }
    }

    // Animation d'entrée pour les cartes de statistiques
    const statCards = document.querySelectorAll('.card.border-left-primary, .card.border-left-success, .card.border-left-info, .card.border-left-warning');
    statCards.forEach((card, index) => {
        card.style.opacity = '0';
        card.style.transform = 'translateY(20px)';
        setTimeout(() => {
            card.style.transition = 'all 0.5s ease';
            card.style.opacity = '1';
            card.style.transform = 'translateY(0)';
        }, index * 100);
    });
});
</script>
{% endblock %}
