{% extends 'base.html.twig' %}

{% block title %}Inscriptions des Élèves{% endblock %}

{% block body %}
<div class="container-fluid">
    <!-- En-tête -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">
                <i class="fas fa-graduation-cap text-primary me-2"></i>
                Inscriptions des Élèves
            </h1>
            <p class="text-muted mb-0">Inscrivez chaque élève validé, un par un, dans sa classe</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('admin_pre_registration_index') }}" class="btn btn-outline-info">
                <i class="fas fa-clipboard-list"></i> Préinscriptions
            </a>
            <a href="{{ path('admin_student_index') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Retour à la liste
            </a>
        </div>
    </div>

    <!-- Statistiques rapides -->
    <div class="row mb-4">
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Prêt pour inscription</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ preRegistrations|length }}</div>
                        </div>
                        <div class="col-auto"><i class="fas fa-user-check fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Classes disponibles</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ classrooms|length }}</div>
                        </div>
                        <div class="col-auto"><i class="fas fa-door-open fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Niveaux disponibles</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ levels|length }}</div>
                        </div>
                        <div class="col-auto"><i class="fas fa-layer-group fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {% if preRegistrations|length > 0 %}
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">
                <i class="fas fa-list-check me-2"></i>
                Préinscriptions validées — inscription individuelle
            </h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th><i class="fas fa-user me-1"></i> Élève</th>
                            <th><i class="fas fa-calendar me-1"></i> Date de naissance</th>
                            <th><i class="fas fa-layer-group me-1"></i> Niveau demandé</th>
                            <th style="min-width: 320px;"><i class="fas fa-graduation-cap me-1"></i> Inscription</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for preRegistration in preRegistrations %}
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3">
                                        {{ preRegistration.firstName|first|upper }}{{ preRegistration.lastName|first|upper }}
                                    </div>
                                    <div>
                                        <div class="fw-bold">{{ preRegistration.lastName }} {{ preRegistration.firstName }}</div>
                                        <small class="text-muted">{{ preRegistration.genderLabel }} · {{ preRegistration.matriculeInterne ?: '—' }}</small>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge bg-light text-dark">{{ preRegistration.dateOfBirth ? preRegistration.dateOfBirth|date('d/m/Y') : '—' }}</span></td>
                            <td>
                                {% if preRegistration.requestedLevel %}
                                    <span class="badge bg-info">{{ preRegistration.requestedLevel.name }}</span>
                                {% else %}
                                    <span class="text-muted">Non renseigné</span>
                                {% endif %}
                            </td>
                            <td>
                                {% set choices = enrollChoices[preRegistration.id] %}
                                {% if choices is empty %}
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="text-danger small"><i class="fas fa-exclamation-triangle me-1"></i>Aucune classe disponible</span>
                                        <a href="{{ path('admin_classroom_new') }}" class="btn btn-sm btn-outline-primary">Créer une classe</a>
                                    </div>
                                {% else %}
                                    <form method="post" action="{{ path('admin_student_enrollment') }}" class="d-flex gap-2 align-items-center"
                                          onsubmit="return confirm('Inscrire {{ preRegistration.lastName }} {{ preRegistration.firstName }} dans la classe sélectionnée ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('enroll' ~ preRegistration.id) }}">
                                        <input type="hidden" name="pre_registration_id" value="{{ preRegistration.id }}">
                                        <select name="class_id" class="form-select form-select-sm" required style="min-width: 160px;">
                                            <option value="">Choisir une classe…</option>
                                            {% for c in choices %}
                                                <option value="{{ c.id }}">{{ c.name }}</option>
                                            {% endfor %}
                                        </select>
                                        <a href="{{ path('admin_pre_registration_show', {'id': preRegistration.id}) }}" class="btn btn-sm btn-outline-secondary" title="Voir la préinscription"><i class="fas fa-eye"></i></a>
                                        <button type="submit" class="btn btn-sm btn-success"><i class="fas fa-user-graduate me-1"></i> Inscrire</button>
                                    </form>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    {% else %}
    <div class="card shadow mb-4">
        <div class="card-body text-center py-5">
            <div class="mb-4"><i class="fas fa-clipboard-list fa-4x text-muted"></i></div>
            <h4 class="text-muted mb-3">Aucune préinscription validée</h4>
            <p class="text-muted mb-4">
                Il n'y a actuellement aucune préinscription validée prête pour l'inscription.<br>
                Les préinscriptions doivent être validées avant de pouvoir inscrire les élèves.
            </p>
            <div class="d-flex justify-content-center gap-3">
                <a href="{{ path('admin_pre_registration_index') }}" class="btn btn-primary">
                    <i class="fas fa-clipboard-list me-2"></i> Voir les préinscriptions
                </a>
                <a href="{{ path('admin_pre_registration_new') }}" class="btn btn-outline-primary">
                    <i class="fas fa-plus me-2"></i> Nouvelle préinscription
                </a>
            </div>
        </div>
    </div>
    {% endif %}

    {# Liste des inscriptions de l'année en cours #}
    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">
                <i class="fas fa-list me-2"></i>
                Inscriptions de l'année en cours
                {% if current_school_year %}<span class="badge bg-light text-dark ms-2">{{ current_school_year.name }}</span>{% endif %}
            </h6>
            <span class="badge bg-primary">{{ enrollments_this_year|length }}</span>
        </div>
        <div class="card-body">
            {% if enrollments_this_year|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-bordered table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Mat. interne</th>
                                <th>Mat. national</th>
                                <th>Nom &amp; Prénoms</th>
                                <th>Classe</th>
                                <th>Statut</th>
                                <th class="text-end">Mt. général</th>
                                <th class="text-end">Mt. payé</th>
                                <th class="text-end">Mt. annulé</th>
                                <th class="text-end">Mt. restant</th>
                                <th>Date insc.</th>
                                <th width="90">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for s in enrollments_this_year %}
                                {% set fin = enrollment_financials[s.id] ?? {'total': 0, 'paid': 0, 'cancelled': 0, 'remaining': 0} %}
                                <tr>
                                    <td>{{ s.matriculeInterne ?: '-' }}</td>
                                    <td>{{ s.matriculeNational ?: '-' }}</td>
                                    <td class="fw-bold">{{ s.lastName }} {{ s.firstName }}</td>
                                    <td>{{ s.classroom ? s.classroom.name : '-' }}</td>
                                    <td><span class="badge bg-{{ s.statusColor }}">{{ s.statusLabel }}</span></td>
                                    <td class="text-end">{{ fin.total|number_format(0, ',', ' ') }} F</td>
                                    <td class="text-end">{{ fin.paid|number_format(0, ',', ' ') }} F</td>
                                    <td class="text-end">{{ fin.cancelled|number_format(0, ',', ' ') }} F</td>
                                    <td class="text-end fw-bold">{{ fin.remaining|number_format(0, ',', ' ') }} F</td>
                                    <td>{{ s.createdAt ? s.createdAt|date('d/m/Y') : '-' }}</td>
                                    <td>
                                        <a href="{{ path('admin_student_show', {'id': s.id}) }}" class="btn btn-sm btn-outline-primary" title="Voir"><i class="fas fa-eye"></i></a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center text-muted py-3">
                    <i class="fas fa-info-circle me-1"></i> Aucune inscription trouvée pour l'année en cours.
                </div>
            {% endif %}
        </div>
    </div>
</div>

<style>
.avatar-sm { width: 40px; height: 40px; font-size: 14px; font-weight: bold; }
.border-left-primary { border-left: 0.25rem solid #4e73df !important; }
.border-left-success { border-left: 0.25rem solid #1cc88a !important; }
.border-left-info { border-left: 0.25rem solid #36b9cc !important; }
.border-left-warning { border-left: 0.25rem solid #f6c23e !important; }
.text-xs { font-size: 0.7rem; }
</style>
{% endblock %}
