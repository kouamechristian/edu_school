{% extends 'base.html.twig' %}

{% block title %}Gestion des Élèves{% endblock %}

{% block body %}
<div class="container-fluid">
    {# ── En-tête ── #}
    {% embed 'components/page_header.html.twig' with {
        title: 'Gestion des Élèves',
        subtitle: 'Liste, inscriptions et suivi de scolarité',
        icon: 'fa-user-graduate',
        color: 'primary',
        breadcrumb: [ { label: 'Élèves' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_registration_index') }}" class="btn btn-success"><i class="fas fa-user-graduate me-1"></i> Inscription</a>
            <a href="{{ path('admin_pre_registration_choose') }}" class="btn btn-primary"><i class="fas fa-user-plus me-1"></i> Préinscription</a>
        {% endblock %}
    {% endembed %}

    {# ── Statistiques ── #}
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-card primary h-100">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div><div class="stat-label mb-1">Total</div><div class="stat-value">{{ stats.total }}</div></div>
                    <div class="stat-icon"><i class="fas fa-users"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card success h-100">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div><div class="stat-label mb-1">Affectés</div><div class="stat-value">{{ stats.affecte }}</div></div>
                    <div class="stat-icon"><i class="fas fa-user-check"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card warning h-100">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div><div class="stat-label mb-1">Non affectés</div><div class="stat-value">{{ stats.non_affecte }}</div></div>
                    <div class="stat-icon"><i class="fas fa-user-times"></i></div>
                </div>
            </div>
        </div>
    </div>

    {# ── Filtres ── #}
    <div class="card filter-card mb-4">
        <div class="card-body">
            <form method="GET" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label for="search" class="form-label">Recherche</label>
                    <input type="text" class="form-control" id="search" name="search" value="{{ search }}" placeholder="Nom, prénom ou numéro d'élève">
                </div>
                <div class="col-md-3">
                    <label for="status" class="form-label">Statut</label>
                    <select class="form-select" id="status" name="status">
                        <option value="">Tous</option>
                        <option value="affecte" {{ status == 'affecte' ? 'selected' : '' }}>Affecté</option>
                        <option value="non_affecte" {{ status == 'non_affecte' ? 'selected' : '' }}>Non affecté</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="level" class="form-label">Niveau</label>
                    <select class="form-select" id="level" name="level">
                        <option value="">Tous</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100"><i class="fas fa-filter me-1"></i> Filtrer</button>
                </div>
            </form>
        </div>
    </div>

    {# ── Liste des élèves ── #}
    <div class="card table-card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Liste des Élèves</h6>
            <div class="d-flex gap-2">
                <a href="{{ path('admin_student_export', {'search': search, 'status': status, 'level': level}) }}" class="btn btn-outline-success btn-sm"><i class="fas fa-file-excel me-1"></i> Exporter Excel</a>
                <button type="button" class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#importModal"><i class="fas fa-file-import me-1"></i> Importer Excel</button>
                <a href="{{ path('admin_registration_index') }}" class="btn btn-success btn-sm"><i class="fas fa-graduation-cap me-1"></i> Inscriptions</a>
                <a href="{{ path('admin_student_archive') }}" class="btn btn-light btn-sm"><i class="fas fa-archive me-1"></i> Archives</a>
            </div>
        </div>
        <div class="card-body">
            {# Recherche instantanée dans le tableau affiché #}
            <div class="mb-3">
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" id="stuSearch" class="form-control" placeholder="Rechercher dans la page (nom, matricule, établissement)…" autocomplete="off">
                    <button type="button" class="btn btn-light" id="stuSearchClear" title="Effacer"><i class="fas fa-times"></i></button>
                </div>
                <div class="small text-muted mt-1" id="stuSearchInfo" style="display:none;"></div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Mle interne</th>
                            <th>Mle national</th>
                            <th>Nom &amp; Prénoms</th>
                            <th>Établissement</th>
                            <th class="text-center">Préinscriptions</th>
                            <th class="text-center">Inscriptions</th>
                            <th>Statut</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for student in students %}
                        <tr class="js-student-row">
                            <td><span class="fw-semibold text-primary">{{ student.matriculeInterne ?: '—' }}</span></td>
                            <td><span class="text-muted">{{ student.matriculeNational ?: '—' }}</span></td>
                            <td class="fw-semibold">{{ student.lastName }} {{ student.firstName }}</td>
                            <td>{{ student.school ? student.school.name : '—' }}</td>
                            <td class="text-center">
                                <span class="badge bg-info-subtle text-info-emphasis rounded-pill" title="Préinscriptions effectuées depuis sa venue">
                                    {{ preregistration_counts[student.id] ?? 0 }}
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-success-subtle text-success-emphasis rounded-pill" title="Nombre d'inscriptions (années scolaires)">
                                    {{ student.registrations|length }}
                                </span>
                            </td>
                            <td><span class="badge bg-{{ student.getStatusColor() }}">{{ student.getStatusLabel() }}</span></td>
                            <td>
                                <div class="btn-group btn-group-sm float-end" role="group">
                                    {% set next_status = student.getStatus() == 'affecte' ? 'non_affecte' : 'affecte' %}
                                    {% set next_label = next_status == 'affecte' ? 'Affecté' : 'Non affecté' %}
                                    <form method="post" action="{{ path('admin_student_set_status', {'id': student.id}) }}"
                                          onsubmit="return confirm('Passer {{ student.lastName }} {{ student.firstName }} en « {{ next_label }} » ? Les frais de scolarité seront adaptés en conséquence.')" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('set_status' ~ student.id) }}">
                                        <input type="hidden" name="status" value="{{ next_status }}">
                                        <button class="btn btn-outline-warning" title="Changer le statut (→ {{ next_label }})"><i class="fas fa-right-left"></i></button>
                                    </form>
                                    <a href="{{ path('admin_student_edit', {'id': student.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                    <form method="post" action="{{ path('admin_student_do_archive', {'id': student.id}) }}"
                                          onsubmit="return confirm('Archiver cet élève ? Il quittera la liste active et sera déplacé dans les archives.')" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('archive' ~ student.id) }}">
                                        <button class="btn btn-outline-danger" title="Archiver"><i class="fas fa-box-archive"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="9">
                                {% from 'components/macros.html.twig' import empty_state %}
                                {{ empty_state('fa-user-slash', 'Aucun élève trouvé', 'Aucun élève ne correspond à vos critères de recherche.') }}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% include '_pagination.html.twig' with { pagination: students } %}
        </div>
    </div>

    {# ── Modale d'import Excel ── #}
    <div class="modal fade" id="importModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" action="{{ path('admin_student_import') }}" enctype="multipart/form-data">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="fas fa-file-import me-2 text-primary"></i>Importer des élèves (Excel)</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small">
                            Importez un fichier <strong>.xlsx</strong>, <strong>.xls</strong> ou <strong>.csv</strong>.
                            L'import alimente le <strong>référentiel élève</strong> (l'affectation à une classe se fait ensuite via le module d'inscription).
                            Respectez l'ordre des colonnes du modèle : Matricule interne, Matricule national, Nom, Prénom,
                            Genre (M/F), Date de naissance, Lieu de naissance, Nationalité, N° extrait de naissance, N° CMU,
                            Téléphone, Email, Adresse, Dernière école fréquentée, Statut (Affecté/Non affecté),
                            Nom parent, Téléphone parent, Email parent, Fonction parent, Domicile parent, Photo.
                            Le <strong>Nom</strong> et le <strong>Prénom</strong> sont obligatoires ; le matricule interne est
                            généré automatiquement s'il est vide. Les élèves sont rattachés à l'établissement courant.
                            (La colonne Photo n'est pas importée — téléversez la photo depuis la fiche de l'élève.)
                        </p>
                        <div class="mb-3">
                            <a href="{{ path('admin_student_import_template') }}" class="btn btn-outline-secondary btn-sm">
                                <i class="fas fa-download me-1"></i> Télécharger le modèle
                            </a>
                        </div>
                        <div class="mb-2">
                            <label for="importFile" class="form-label">Fichier à importer</label>
                            <input type="file" class="form-control" id="importFile" name="file" accept=".xlsx,.xls,.csv" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Annuler</button>
                        <button type="submit" class="btn btn-primary"><i class="fas fa-upload me-1"></i> Importer</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        var input = document.getElementById('stuSearch');
        var clearBtn = document.getElementById('stuSearchClear');
        var info = document.getElementById('stuSearchInfo');
        if (!input) return;

        function normalize(s) {
            return (s || '').toString().toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
        }

        function applyFilter() {
            var q = normalize(input.value.trim());
            var rows = document.querySelectorAll('#dataTable tbody tr.js-student-row');
            var shown = 0;
            rows.forEach(function (tr) {
                var match = q === '' || normalize(tr.textContent).indexOf(q) !== -1;
                tr.style.display = match ? '' : 'none';
                if (match) shown++;
            });
            if (q === '') {
                info.style.display = 'none';
            } else {
                info.style.display = '';
                info.textContent = shown + ' résultat(s) sur cette page · pour chercher dans tous les élèves, utilisez le filtre « Recherche » ci-dessus.';
            }
        }

        input.addEventListener('input', applyFilter);
        if (clearBtn) clearBtn.addEventListener('click', function () { input.value = ''; applyFilter(); input.focus(); });
    })();
</script>
{% endblock %}
