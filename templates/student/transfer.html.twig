{% extends 'base.html.twig' %}

{% block title %}Transferts d'Élèves{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Transferts d'Élèves</h1>
        <a href="{{ path('admin_student_index') }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Retour à la liste
        </a>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Fonctionnalité en cours de développement</h6>
                </div>
                <div class="card-body">
                    <div class="text-center py-5">
                        <i class="fas fa-exchange-alt fa-3x text-muted mb-3"></i>
                        <h5 class="text-muted">Transferts d'élèves</h5>
                        <p class="text-muted">Cette fonctionnalité permettra de transférer des élèves entre différentes classes ou établissements.</p>
                        <p class="text-muted">Elle sera disponible dans une prochaine version.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
