<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    {% set accent = school and school.badgeBackgroundColor ? school.badgeBackgroundColor : '#1b3aa0' %}
    <style>
        @page { margin: 0; }
        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; }
        body { font-family: Helvetica, Arial, sans-serif; color: #111; }

        .card { width: 156pt; height: 105pt; overflow: hidden; position: relative; }
        .band { width: 100%; height: 3pt; background: {{ accent }}; }
        .band-bottom { position: absolute; bottom: 0; left: 0; }

        .header { width: 100%; padding: 1.5pt 7pt 0 7pt; }
        .header td { vertical-align: middle; }
        .header .center { text-align: center; }
        .header .center .school { font-size: 6pt; font-weight: bold; color: {{ accent }}; line-height: 1.05; }
        .header .center .tel { font-size: 5pt; font-weight: bold; color: {{ accent }}; }
        .header .logo { width: 28pt; text-align: center; }
        .header .logo img { max-height: 16pt; max-width: 26pt; }
        .header .logo .year { font-size: 4.5pt; font-weight: bold; color: {{ accent }}; white-space: nowrap; }

        .divider { border: 0; border-top: 0.6pt solid #bbb; margin: 1.5pt 0; }

        .title { text-align: center; font-size: 7pt; font-weight: bold; color: {{ accent }}; margin: 0 0 1pt 0; }

        .body { width: 100%; padding: 0 7pt; }
        .body td { vertical-align: top; }

        .photo-cell { width: 38pt; }
        .photo { width: 36pt; height: 44pt; border: 0.6pt solid #999; }
        .photo-empty { width: 36pt; height: 44pt; border: 0.6pt dashed #999; text-align: center; color: #999; font-size: 4.5pt; line-height: 44pt; }

        .info-cell { padding-left: 5pt; }
        .info-cell .label { font-size: 4pt; font-weight: bold; color: #222; line-height: 1.1; }
        .info-cell .value { font-size: 4.6pt; color: #000; line-height: 1.1; margin-bottom: 0.6pt; }

        .right-cell { width: 38pt; text-align: center; }
        .right-cell .qr { width: 34pt; height: 34pt; }
        .right-cell .cachet { max-width: 38pt; max-height: 20pt; margin-top: 1pt; }
    </style>
</head>
<body>
    <div class="card">
        <div class="band"></div>

        <table class="header">
            <tr>
                <td class="center">
                    <div class="school">{{ school ? school.name|upper : '' }}</div>
                    <div class="tel">Tél: {{ school and school.phone ? school.phone : '—' }}</div>
                </td>
                <td class="logo">
                    {% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}
                    <div class="year">{{ student.schoolYear ? student.schoolYear.name : '' }}</div>
                </td>
            </tr>
        </table>

        <hr class="divider">

        <div class="title">CARTE D'ACCÈS</div>

        <table class="body">
            <tr>
                <td class="photo-cell">
                    {% if photo_data %}
                        <img class="photo" src="{{ photo_data }}" alt="Photo">
                    {% else %}
                        <div class="photo-empty">Photo</div>
                    {% endif %}
                </td>
                <td class="info-cell">
                    <div class="label">NOM &amp; PRÉNOMS</div>
                    <div class="value">{{ student.lastName|upper }} {{ student.firstName|upper }}</div>
                    <div class="label">MATRICULE INTERNE / NATIONAL</div>
                    <div class="value">{{ student.matriculeInterne ?: 'AUCUN' }} / {{ student.matriculeNational ?: 'AUCUN' }}</div>
                    <div class="label">CLASSE</div>
                    <div class="value">{{ student.classroom ? student.classroom.name : '—' }}</div>
                    <div class="label">CONTACT PARENTS</div>
                    <div class="value">{{ student.parentPhone ?: '—' }}</div>
                </td>
                <td class="right-cell">
                    {% if qr_data %}<img class="qr" src="{{ qr_data }}" alt="QR">{% endif %}
                    {% if cachet_data %}<img class="cachet" src="{{ cachet_data }}" alt="Cachet">{% endif %}
                </td>
            </tr>
        </table>

        <div class="band band-bottom"></div>
    </div>
</body>
</html>
