{% extends 'base.html.twig' %}

{% block title %}Élèves — {{ classroom.name }}{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800"><i class="fas fa-users text-primary me-2"></i>Élèves de la classe {{ classroom.name }}</h1>
            <p class="text-muted mb-0">
                {% if classroom.level %}Niveau : {{ classroom.level.name }} · {% endif %}
                {{ students|length }} élève(s){% if classroom.capacity %} / {{ classroom.capacity }} places{% endif %}
            </p>
        </div>
        <div class="d-flex gap-2 no-print">
            <button type="button" class="btn btn-outline-secondary" onclick="window.print()"><i class="fas fa-print me-1"></i> Imprimer la liste</button>
            <a href="{{ path('admin_student_dashboard') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        </div>
    </div>

    <div class="card table-card">
        <div class="card-body">
            <div class="text-center mb-3 d-none d-print-block">
                <h4>Liste des élèves — Classe {{ classroom.name }}</h4>
                {% if classroom.school %}<div>{{ classroom.school.name }}</div>{% endif %}
                {% if classroom.schoolYear %}<div>Année scolaire : {{ classroom.schoolYear.name }}</div>{% endif %}
            </div>
            {% if students|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-bordered align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:50px;">N°</th>
                                <th>Matricule</th>
                                <th>Nom &amp; Prénom</th>
                                <th>Genre</th>
                                <th>Date de naissance</th>
                                <th class="no-print text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for student in students %}
                                <tr>
                                    <td>{{ loop.index }}</td>
                                    <td>{{ student.matriculeInterne ?: '—' }}</td>
                                    <td class="fw-bold">{{ student.lastName }} {{ student.firstName }}</td>
                                    <td>{{ student.gender == 'M' ? 'M' : (student.gender == 'F' ? 'F' : '—') }}</td>
                                    <td>{{ student.dateOfBirth ? student.dateOfBirth|date('d/m/Y') : '—' }}</td>
                                    <td class="no-print text-end">
                                        <a href="{{ path('admin_student_show', {'id': student.id}) }}" class="btn btn-sm btn-outline-info"><i class="fas fa-eye"></i></a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center text-muted py-4"><i class="fas fa-info-circle me-1"></i> Aucun élève inscrit dans cette classe.</div>
            {% endif %}
        </div>
    </div>
</div>

<style>
@media print {
    .sidebar, .topbar, .footer, .no-print { display: none !important; }
    .content-wrapper { margin: 0 !important; padding: 0 !important; }
    .card { border: none !important; box-shadow: none !important; }
    .d-print-block { display: block !important; }
}
</style>
{% endblock %}
