{% extends 'base.html.twig' %}

{% block title %}Tableau de bord — Élèves{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800"><i class="fas fa-gauge text-primary me-2"></i>Tableau de bord — Élèves</h1>
            <p class="text-muted mb-0">{{ current_school.name }}{% if current_school_year %} — {{ current_school_year.name }}{% endif %}</p>
        </div>
        <div class="d-flex gap-2 no-print">
            <a href="{{ path('admin_student_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
        </div>
    </div>

    {# ── Statistiques ── #}
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-left-primary shadow-sm h-100">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div class="text-uppercase text-primary fw-bold small mb-1">Classes</div>
                        <div class="h3 mb-0 text-gray-800">{{ stats.classes }}</div>
                    </div>
                    <i class="fas fa-door-open fa-2x text-gray-300"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-left-success shadow-sm h-100">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div class="text-uppercase text-success fw-bold small mb-1">Élèves inscrits</div>
                        <div class="h3 mb-0 text-gray-800">{{ stats.students }}</div>
                    </div>
                    <i class="fas fa-user-graduate fa-2x text-gray-300"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-left-warning shadow-sm h-100">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div class="text-uppercase text-warning fw-bold small mb-1">Sans extrait de naissance</div>
                        <div class="h3 mb-0 text-gray-800">{{ stats.without_birth_certificate }}</div>
                    </div>
                    <i class="fas fa-id-card fa-2x text-gray-300"></i>
                </div>
            </div>
        </div>
    </div>

    {# ── Tableau des classes ── #}
    <div class="card table-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold text-primary"><i class="fas fa-list me-2"></i>Répartition par classe</h6>
            <span class="badge bg-primary">{{ classrooms|length }}</span>
        </div>
        <div class="card-body">
            <div class="text-center mb-3 d-none d-print-block">
                <h4>Liste des classes — {{ current_school.name }}</h4>
                {% if current_school_year %}<div>Année scolaire : {{ current_school_year.name }}</div>{% endif %}
            </div>
            {% if classrooms|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Classe</th>
                                <th class="text-center">Capacité</th>
                                <th class="text-center">Inscrits</th>
                                <th class="text-end no-print">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for classroom in classrooms %}
                                {% set enrolled = count_by_classroom[classroom.id] ?? 0 %}
                                <tr>
                                    <td class="fw-bold">{{ classroom.name }}{% if classroom.level %} <small class="text-muted">({{ classroom.level.name }})</small>{% endif %}</td>
                                    <td class="text-center">{{ classroom.capacity ?? '—' }}</td>
                                    <td class="text-center">
                                        <span class="badge bg-{{ classroom.capacity and enrolled > classroom.capacity ? 'danger' : 'secondary' }}">{{ enrolled }}{% if classroom.capacity %} / {{ classroom.capacity }}{% endif %}</span>
                                    </td>
                                    <td class="text-end no-print">
                                        <a href="{{ path('admin_student_classroom_students', {'id': classroom.id}) }}" class="btn btn-sm btn-success" title="Voir les élèves de la classe">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center text-muted py-4"><i class="fas fa-info-circle me-1"></i> Aucune classe pour cet établissement.</div>
            {% endif %}
        </div>
    </div>
</div>

<style>
.border-left-primary { border-left: 0.25rem solid #4e73df !important; }
.border-left-success { border-left: 0.25rem solid #1cc88a !important; }
.border-left-warning { border-left: 0.25rem solid #f6c23e !important; }
@media print {
    .sidebar, .topbar, .footer, .no-print { display: none !important; }
    .content-wrapper { margin: 0 !important; padding: 0 !important; }
    .card { border: none !important; box-shadow: none !important; }
    .d-print-block { display: block !important; }
}
</style>
{% endblock %}
