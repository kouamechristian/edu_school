{% extends 'base.html.twig' %}

{% block title %}Détails de la Bourse{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-graduation-cap me-2"></i>Détails de la Bourse
        </h1>
        <div>
            <a href="{{ path('admin_scholarship_edit', {'id': scholarship.id}) }}" class="btn btn-warning">
                <i class="fas fa-edit me-2"></i>Modifier
            </a>
            <a href="{{ path('admin_scholarship_index') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-2"></i>Retour à la liste
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">{{ scholarship.name }}</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <strong>Type de bourse:</strong>
                            <p>{{ scholarship.type }}</p>
                        </div>
                        <div class="col-md-6">
                            <strong>Montant:</strong>
                            <p>{{ scholarship.amount|number_format(0, ',', ' ') }} FCFA</p>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <strong>Statut:</strong>
                            <p>
                                <span class="badge badge-{{ scholarship.status == 'active' ? 'success' : 'secondary' }}">
                                    {{ scholarship.status|title }}
                                </span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <strong>Date de début:</strong>
                            <p>{{ scholarship.startDate ? scholarship.startDate|date('d/m/Y') : 'Non définie' }}</p>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <strong>Date de fin:</strong>
                            <p>{{ scholarship.endDate ? scholarship.endDate|date('d/m/Y') : 'Non définie' }}</p>
                        </div>
                        <div class="col-md-6">
                            <strong>Date de création:</strong>
                            <p>{{ scholarship.createdAt ? scholarship.createdAt|date('d/m/Y H:i') : 'Non définie' }}</p>
                        </div>
                    </div>

                    {% if scholarship.description %}
                        <div class="row">
                            <div class="col-12">
                                <strong>Description:</strong>
                                <p>{{ scholarship.description }}</p>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Actions</h6>
                </div>
                <div class="card-body">
                    <a href="{{ path('admin_scholarship_edit', {'id': scholarship.id}) }}" class="btn btn-warning btn-block mb-2">
                        <i class="fas fa-edit me-2"></i>Modifier la bourse
                    </a>
                    
                    <form method="post" action="{{ path('admin_scholarship_delete', {'id': scholarship.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette bourse ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ scholarship.id) }}">
                        <button type="submit" class="btn btn-danger btn-block">
                            <i class="fas fa-trash me-2"></i>Supprimer
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
