{% extends 'base.html.twig' %}

{% block title %}Nouvel Employé{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-xl-9">
            {% embed 'components/page_header.html.twig' with {
                title: 'Nouvel Employé',
                icon: 'fa-id-badge',
                color: 'primary',
                breadcrumb: [
                    { label: 'Employés', path: path('admin_employee_index') },
                    { label: 'Nouveau' }
                ]
            } %}
                {% block actions %}
                    <a href="{{ path('admin_employee_index') }}" class="btn btn-light"><i class="fas fa-arrow-left me-1"></i> Retour</a>
                {% endblock %}
            {% endembed %}

            {% include '_flash.html.twig' %}

            <div class="card">
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="mb-3">{{ form_row(form.email) }}</div>
                        <hr>
                        <div class="row">
                            <div class="col-md-6 mb-3">{{ form_row(form.firstName) }}</div>
                            <div class="col-md-6 mb-3">{{ form_row(form.lastName) }}</div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">{{ form_row(form.employeeType) }}</div>
                            <div class="col-md-4 mb-3">{{ form_row(form.position) }}</div>
                            <div class="col-md-4 mb-3">{{ form_row(form.department) }}</div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">{{ form_row(form.phone) }}</div>
                            <div class="col-md-4 mb-3">{{ form_row(form.gender) }}</div>
                            <div class="col-md-4 mb-3">{{ form_row(form.dateOfBirth) }}</div>
                        </div>
                        <div class="mb-3">{{ form_row(form.address) }}</div>
                        <div class="row">
                            <div class="col-md-4 mb-3">{{ form_row(form.salary) }}</div>
                            <div class="col-md-4 mb-3">{{ form_row(form.hireDate) }}</div>
                            <div class="col-md-4 mb-3">{{ form_row(form.terminationDate) }}</div>
                        </div>
                        <div class="form-check mb-3">{{ form_widget(form.isActive) }} {{ form_label(form.isActive) }}</div>
                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a href="{{ path('admin_employee_index') }}" class="btn btn-light"><i class="fas fa-times me-1"></i> Annuler</a>
                            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Enregistrer</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
