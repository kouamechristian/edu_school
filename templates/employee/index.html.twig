{% extends 'base.html.twig' %}
{% from 'components/macros.html.twig' import empty_state %}

{% block title %}Gestion des Employés{% endblock %}

{% block body %}
<div class="container-fluid">
    {% embed 'components/page_header.html.twig' with {
        title: 'Gestion des Employés',
        subtitle: current_school ? current_school.name ~ '  ·  ' ~ employees|length ~ ' employé(s)' : 'Ressources Humaines',
        icon: 'fa-id-badge',
        color: 'primary',
        breadcrumb: [ { label: 'Ressources Humaines' }, { label: 'Employés' } ]
    } %}
        {% block actions %}
            <a href="{{ path('admin_employee_new') }}" class="btn btn-primary"><i class="fas fa-plus me-1"></i> Nouvel Employé</a>
        {% endblock %}
    {% endembed %}

    {% include '_flash.html.twig' %}

    {% if not current_school %}
        <div class="alert alert-warning"><i class="fas fa-exclamation-triangle me-2"></i>Veuillez sélectionner un établissement pour voir les employés.</div>
    {% else %}
        <div class="card filter-card mb-4">
            <div class="card-body">
                <form method="get" class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Type d'employé</label>
                        <select name="type" class="form-select">
                            <option value="">Tous les types</option>
                            <option value="enseignant" {% if type == 'enseignant' %}selected{% endif %}>Enseignants ({{ counts.enseignant ?? 0 }})</option>
                            <option value="personnel" {% if type == 'personnel' %}selected{% endif %}>Personnel ({{ counts.personnel ?? 0 }})</option>
                            <option value="directeur" {% if type == 'directeur' %}selected{% endif %}>Directeurs ({{ counts.directeur ?? 0 }})</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100"><i class="fas fa-filter me-1"></i> Filtrer</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card table-card">
            <div class="card-body">
                {% if employees is empty %}
                    {{ empty_state('fa-id-badge', 'Aucun employé', 'Aucun employé ne correspond à vos critères.') }}
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr><th>Nom</th><th>Type</th><th>Poste</th><th>Département</th><th>Contrat actif</th><th>Statut</th><th class="text-end">Actions</th></tr>
                            </thead>
                            <tbody>
                                {% for employee in employees %}
                                    <tr>
                                        <td><strong>{{ employee.fullName }}</strong></td>
                                        <td><span class="badge badge-soft secondary">{{ employee.employeeTypeLabel }}</span></td>
                                        <td>{{ employee.position ?: '—' }}</td>
                                        <td>{{ employee.department ?: '—' }}</td>
                                        <td>
                                            {% set ac = employee.activeContract %}
                                            {% if ac %}<span class="badge badge-soft success">{{ ac.contractTypeLabel }}</span>{% else %}<span class="text-muted">Aucun</span>{% endif %}
                                        </td>
                                        <td><span class="badge badge-soft {{ employee.isActive ? 'success' : 'danger' }}">{{ employee.isActive ? 'Actif' : 'Inactif' }}</span></td>
                                        <td class="text-end">
                                            <div class="btn-group btn-group-sm">
                                                <a href="{{ path('admin_employee_show', {'id': employee.id}) }}" class="btn btn-outline-info" title="Détails"><i class="fas fa-eye"></i></a>
                                                <a href="{{ path('admin_employee_edit', {'id': employee.id}) }}" class="btn btn-outline-primary" title="Modifier"><i class="fas fa-edit"></i></a>
                                                <form method="post" action="{{ path('admin_employee_toggle', {'id': employee.id}) }}" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ employee.id) }}">
                                                    <button type="submit" class="btn btn-outline-secondary" title="{{ employee.isActive ? 'Désactiver' : 'Activer' }}"><i class="fas fa-power-off"></i></button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
