<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <style>
        @page { margin: 18px 20px; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 8px; color: #000; }
        .header { width: 100%; border-bottom: 1px solid #999; padding-bottom: 4px; margin-bottom: 8px; }
        .header td { vertical-align: middle; }
        .header .logo { width: 56px; }
        .header .logo img { max-height: 46px; max-width: 52px; }
        .header .school { text-align: center; }
        .header .school .name { font-weight: bold; font-size: 11px; }
        .header .school .ministry { font-size: 8px; }
        .header .school .tel { font-size: 7px; }
        .title-row { width: 100%; margin-bottom: 5px; }
        .title-row td { font-size: 10px; }
        .title-row .right { text-align: right; }
        .title-row b { font-weight: bold; }
        table.bord { width: 100%; border-collapse: collapse; }
        table.bord th, table.bord td { border: 1px solid #000; padding: 2px 2px; font-size: 7px; }
        table.bord th { text-align: center; font-weight: bold; background: #f2f2f2; }
        table.bord td.center { text-align: center; }
        table.bord td.name { text-align: left; white-space: nowrap; }
        table.bord th.vert { writing-mode: vertical-rl; }
        table.bord .gen { background: #eef3f8; font-weight: bold; }
        .footer { width: 100%; margin-top: 10px; font-size: 8px; }
        .footer td { vertical-align: top; }
        .footer .sign { text-align: right; text-decoration: underline; }
    </style>
</head>
<body>
    <table class="header">
        <tr>
            <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
            <td class="school">
                <div class="name">{{ school ? school.name|upper : '' }}</div>
                <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                <div class="tel">Tel: {{ school ? school.phone : '' }}</div>
            </td>
            <td class="logo"></td>
        </tr>
    </table>

    <table class="title-row">
        <tr>
            <td><b>BORDEREAU ANNUEL</b> — {{ classroom.name }}{% if classroom.level %} ({{ classroom.level.name }}){% endif %}</td>
            <td class="right"><b>Année Scolaire:</b> {{ classroom.schoolYear ? classroom.schoolYear.name : '—' }}</td>
        </tr>
    </table>

    <table class="bord">
        <thead>
            <tr>
                <th>N°</th>
                <th class="name">Nom &amp; Prénoms</th>
                {% for subject in subjects %}<th>{{ subject.code ?: subject.name }}</th>{% endfor %}
                <th>Moy. Gén.</th>
                <th>Rang</th>
            </tr>
        </thead>
        <tbody>
            {% for row in rows %}
                <tr>
                    <td class="center">{{ loop.index }}</td>
                    <td class="name">{{ row.student.lastName|upper }} {{ row.student.firstName }}</td>
                    {% for subject in subjects %}
                        <td class="center">{{ row.subjects[subject.id] is defined ? row.subjects[subject.id]|number_format(2, ',', ' ') : '—' }}</td>
                    {% endfor %}
                    <td class="center gen">{{ row.general is not null ? row.general|number_format(2, ',', ' ') : '—' }}</td>
                    <td class="center">{{ row.rank ?? '—' }}</td>
                </tr>
            {% else %}
                <tr><td class="center" colspan="{{ subjects|length + 4 }}">Aucun élève</td></tr>
            {% endfor %}
        </tbody>
    </table>

    <table class="footer">
        <tr>
            <td>le {{ generated_at|date('d/m/Y H:i:s') }}</td>
            <td class="sign">Le Professeur Principal</td>
        </tr>
    </table>
</body>
</html>
