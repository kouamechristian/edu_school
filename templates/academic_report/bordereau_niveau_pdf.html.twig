<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <style>
        @page { margin: 22px 26px; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 9px; color: #000; }
        .header { width: 100%; border-bottom: 1px solid #999; padding-bottom: 6px; margin-bottom: 6px; }
        .header td { vertical-align: middle; }
        .header .logo { width: 74px; }
        .header .logo img { max-height: 60px; max-width: 68px; }
        .header .school { text-align: center; }
        .header .school .name { font-weight: bold; font-size: 13px; }
        .header .school .ministry { font-size: 9px; }
        .title-main { text-align: center; font-weight: bold; font-size: 13px; margin: 4px 0 0; }
        .title-year { text-align: center; font-size: 10px; margin-bottom: 6px; }
        .class-name { font-weight: bold; font-size: 12px; margin: 4px 0 4px; }
        table.list { width: 100%; border-collapse: collapse; }
        table.list th, table.list td { border: 1px solid #000; padding: 3px 5px; font-size: 8.5px; }
        table.list th { text-align: center; font-weight: bold; background: #f2f2f2; }
        td.c { text-align: center; }
        .class-block { page-break-after: always; }
        .class-block:last-child { page-break-after: auto; }
    </style>
</head>
<body>
    {% for class in classes %}
        <div class="class-block">
            <table class="header">
                <tr>
                    <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
                    <td class="school">
                        <div class="name">{{ school ? school.name|upper : '' }}</div>
                        <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                        <div class="ministry">Tel: {{ school ? school.phone : '' }}</div>
                    </td>
                    <td class="logo"></td>
                </tr>
            </table>

            <div class="title-main">BORDEREAU ANNUEL</div>
            <div class="title-year">{{ school_year ? school_year.name : '' }}</div>
            <div class="class-name">{{ class.label }}</div>

            <table class="list">
                <thead>
                    <tr>
                        <th style="width:5%">N°</th>
                        <th>NOM ET PRENOMS</th>
                        <th style="width:12%">TOTAL</th>
                        <th style="width:10%">MOY</th>
                        <th style="width:10%">RANG</th>
                        <th style="width:16%">OBS</th>
                    </tr>
                </thead>
                <tbody>
                    {% for r in class.rows %}
                        <tr>
                            <td class="c">{{ r.seq }}</td>
                            <td>{{ r.nom }}</td>
                            <td class="c">{{ r.total is not null ? r.total|number_format(2, ',', ' ') : 'NC' }}</td>
                            <td class="c">{{ r.moy is not null ? r.moy|number_format(2, ',', ' ') : 'NC' }}</td>
                            <td class="c">{{ r.rank }}</td>
                            <td>{{ r.obs }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="6" class="c">Aucun élève dans cette classe.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <table class="header">
            <tr>
                <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
                <td class="school">
                    <div class="name">{{ school ? school.name|upper : '' }}</div>
                    <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                </td>
                <td class="logo"></td>
            </tr>
        </table>
        <p>Aucune classe pour ce niveau.</p>
    {% endfor %}
</body>
</html>
