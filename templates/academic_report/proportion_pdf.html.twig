<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <style>
        @page { margin: 16px 18px; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 7px; color: #000; }
        .header { width: 100%; border-bottom: 1px solid #999; padding-bottom: 4px; margin-bottom: 4px; }
        .header td { vertical-align: middle; }
        .header .logo { width: 60px; }
        .header .logo img { max-height: 48px; max-width: 56px; }
        .header .school { text-align: center; }
        .header .school .name { font-weight: bold; font-size: 12px; }
        .header .school .ministry { font-size: 8px; }
        .title-main { text-align: center; font-weight: bold; font-size: 10px; margin: 3px 0 6px; }
        table.grid { width: 100%; border-collapse: collapse; }
        table.grid th, table.grid td { border: 1px solid #000; padding: 1px 2px; font-size: 6.5px; text-align: center; }
        table.grid th { background: #f2f2f2; font-weight: bold; }
        td.niv { font-weight: bold; background: #eef2f7; }
        td.gen { text-align: left; }
        tr.ens td { background: #f7f7f7; font-weight: bold; }
    </style>
</head>
<body>
    <table class="header">
        <tr>
            <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
            <td class="school">
                <div class="name">{{ school ? school.name|upper : '' }}</div>
                <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                <div class="ministry">Tel: {{ school ? school.phone : '' }}</div>
            </td>
            <td class="logo"></td>
        </tr>
    </table>

    <div class="title-main">PROPORTION D'ÉLÈVES N'AYANT PAS OBTENU LA MOYENNE — {{ period ? period.name|upper : '' }} {{ school_year ? school_year.name : '' }}</div>

    <table class="grid">
        <thead>
            <tr>
                <th rowspan="2" style="width:6%">NIVEAU</th>
                <th rowspan="2" style="width:6%">GENRE</th>
                {% for col in columns %}
                    <th colspan="3">{{ col.name }}</th>
                {% endfor %}
            </tr>
            <tr>
                {% for col in columns %}
                    <th>Eff. classé</th>
                    <th>Eff. &lt;10</th>
                    <th>% &lt;10</th>
                {% endfor %}
            </tr>
        </thead>
        <tbody>
            {% for row in rows %}
                {% for g in row.genders %}
                    <tr class="{{ g.label == 'Ensemble' ? 'ens' : '' }}">
                        {% if loop.first %}
                            <td class="niv" rowspan="3">{{ row.level }}</td>
                        {% endif %}
                        <td class="gen">{{ g.label }}</td>
                        {% for c in g.cells %}
                            <td>{{ c.classe }}</td>
                            <td>{{ c.below }}</td>
                            <td>{{ c.pct > 0 ? c.pct|number_format(2, ',', ' ') : '0' }}</td>
                        {% endfor %}
                    </tr>
                {% endfor %}
            {% else %}
                <tr><td colspan="{{ 2 + columns|length * 3 }}">Aucune donnée pour cette période.</td></tr>
            {% endfor %}
        </tbody>
    </table>

    <div style="font-size:7px; color:#666; margin-top:5px;">
        Eff. classé : élèves notés dans la matière · Eff. &lt;10 : élèves ayant une moyenne inférieure à 10 · % &lt;10 : proportion. Édité le {{ generated_at|date('d/m/Y H:i') }}.
    </div>
</body>
</html>
