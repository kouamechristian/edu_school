<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <style>
        @page { margin: 22px 24px; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 9px; color: #000; }
        .header { width: 100%; border-bottom: 1px solid #999; padding-bottom: 6px; margin-bottom: 10px; }
        .header td { vertical-align: middle; }
        .header .logo { width: 66px; }
        .header .logo img { max-height: 56px; max-width: 60px; }
        .header .school { text-align: center; }
        .header .school .name { font-weight: bold; font-size: 12px; }
        .header .school .ministry { font-size: 9px; }
        .header .school .tel { font-size: 8px; }
        .title-row { width: 100%; margin-bottom: 8px; }
        .title-row td { font-size: 11px; }
        .title-row .right { text-align: right; }
        .title-row b { font-weight: bold; }
        .title-main { text-align: center; font-weight: bold; font-size: 10px; text-decoration: underline; margin-bottom: 8px; }
        table.list { width: 100%; border-collapse: collapse; }
        table.list th, table.list td { border: 1px solid #000; padding: 3px 4px; font-size: 8.5px; }
        table.list th { text-align: center; font-weight: bold; background: #f2f2f2; }
        table.list td.center { text-align: center; }
        table.list .grp-g { background: #eaf2fb; }
        table.list .grp-f { background: #fbeef4; }
        table.list .grp-t { background: #eef7ee; }
        table.list tr.grand td { background: #dfe6ee; font-weight: bold; }
        .note { font-size: 8px; color: #666; margin-top: 5px; }
        .footer { width: 100%; margin-top: 14px; font-size: 9px; }
        .footer td { vertical-align: top; }
        .footer .sign { text-align: right; text-decoration: underline; }
        .footer .date .line { border-bottom: 1px solid #000; display: inline-block; width: 130px; }
    </style>
</head>
<body>
    <table class="header">
        <tr>
            <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
            <td class="school">
                <div class="name">{{ school ? school.name|upper : '' }}</div>
                <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                <div class="tel">Tel: {{ school ? school.phone : '' }}</div>
            </td>
            <td class="logo"></td>
        </tr>
    </table>

    <div class="title-main">STATISTIQUE DES ÉLÈVES EN SITUATION D'ADMISSION, DE REDOUBLEMENT ET D'EXCLUSION AVEC L'APPROCHE GENRE{% if period %} DU {{ period.name|upper }}{% endif %} {{ school_year ? school_year.name : '' }}</div>

    <table class="list">
        <thead>
            <tr>
                <th colspan="16">ELEVES EN SITUATION</th>
                <th rowspan="4">TOTAL GENERAL :<br>(d'Exclusion)</th>
            </tr>
            <tr>
                <th rowspan="3" style="width:14%">NIVEAU</th>
                <th colspan="3" class="grp-g">D'ADMISSION</th>
                <th colspan="3" class="grp-f">DE REDOUBLEMENT</th>
                <th colspan="9" class="grp-t">D'EXCLUSION</th>
            </tr>
            <tr>
                <th colspan="3" class="grp-g">Non Red et Red ayant MG &gt;= 10</th>
                <th colspan="3" class="grp-f">Non Red ayant :<br>10 &gt; MG &gt;= 8,5</th>
                <th colspan="3" class="grp-t">Red ayant :<br>10 &gt; MG &gt;= 8,5</th>
                <th colspan="3" class="grp-t">Non Red ayant :<br>MG &lt; 8,5</th>
                <th colspan="3" class="grp-t">Red ayant :<br>MG &lt; 8,5</th>
            </tr>
            <tr>
                <th class="grp-g">G</th><th class="grp-g">F</th><th class="grp-g">T</th>
                <th class="grp-f">G</th><th class="grp-f">F</th><th class="grp-f">T</th>
                <th class="grp-t">G</th><th class="grp-t">F</th><th class="grp-t">S/T</th>
                <th class="grp-t">G</th><th class="grp-t">F</th><th class="grp-t">S/T</th>
                <th class="grp-t">G</th><th class="grp-t">F</th><th class="grp-t">S/T</th>
            </tr>
        </thead>
        <tbody>
            {% macro cells(row) %}
                <td class="center">{{ row.adm_g }}</td><td class="center">{{ row.adm_f }}</td><td class="center">{{ row.adm_t }}</td>
                <td class="center">{{ row.red_g }}</td><td class="center">{{ row.red_f }}</td><td class="center">{{ row.red_t }}</td>
                <td class="center">{{ row.exc1_g }}</td><td class="center">{{ row.exc1_f }}</td><td class="center">{{ row.exc1_t }}</td>
                <td class="center">{{ row.exc2_g }}</td><td class="center">{{ row.exc2_f }}</td><td class="center">{{ row.exc2_t }}</td>
                <td class="center">{{ row.exc3_g }}</td><td class="center">{{ row.exc3_f }}</td><td class="center">{{ row.exc3_t }}</td>
                <td class="center">{{ row.exc_total }}</td>
            {% endmacro %}
            {% import _self as tbl %}
            {% for section in sections %}
                {% for row in section.rows %}
                    <tr>
                        <td>{{ row.label }}</td>
                        {{ tbl.cells(row) }}
                    </tr>
                {% endfor %}
                <tr class="grand">
                    <td>{{ section.subtotal.label }}</td>
                    {{ tbl.cells(section.subtotal) }}
                </tr>
            {% else %}
                <tr><td colspan="17" class="center">Aucune donnée disponible</td></tr>
            {% endfor %}
            {% if sections is not empty %}
                <tr class="grand">
                    <td>{{ grand.label }}</td>
                    {{ tbl.cells(grand) }}
                </tr>
            {% endif %}
        </tbody>
    </table>

    <div class="note">
        Situation calculée sur la moyenne générale (MG) de la période : Admission si MG &gt;= 10 ;
        Redoublement si 8,5 &lt;= MG &lt; 10 (non-redoublant) ; Exclusion pour les autres cas selon
        le statut redoublant. Le total général correspond aux effectifs en situation d'exclusion.
    </div>

    <table class="footer">
        <tr>
            <td class="date"><span class="line">&nbsp;</span> le {{ generated_at|date('d/m/Y H:i:s') }}</td>
            <td class="sign">Signature</td>
        </tr>
    </table>
</body>
</html>
