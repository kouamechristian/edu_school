<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <style>
        @page { margin: 20px 22px; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 9px; color: #000; }
        .header { width: 100%; border-bottom: 1px solid #999; padding-bottom: 6px; margin-bottom: 10px; }
        .header td { vertical-align: middle; }
        .header .logo { width: 80px; }
        .header .logo img { max-height: 66px; max-width: 72px; }
        .header .school { text-align: center; }
        .header .school .name { font-weight: bold; font-size: 14px; }
        .header .school .ministry { font-size: 11px; }
        .header .school .tel { font-size: 10px; }
        .title-row { width: 100%; margin-bottom: 8px; }
        .title-row td { font-size: 11px; }
        .title-row .right { text-align: right; }
        .title-row b { font-weight: bold; }
        .title-main { text-align: center; font-weight: bold; font-size: 12px; text-decoration: underline; margin-bottom: 6px; }
        table.list { width: 100%; border-collapse: collapse; }
        table.list th, table.list td { border: 1px solid #000; padding: 3px 4px; font-size: 8px; }
        table.list th { text-align: center; font-weight: bold; background: #f2f2f2; }
        table.list td.center { text-align: center; }
        table.list tr.sep td { border-left: 1px solid #000; border-right: 1px solid #000; border-top: none; border-bottom: none; height: 6px; padding: 0; }
        .footer { width: 100%; margin-top: 20px; font-size: 10px; }
        .footer td { vertical-align: top; }
        .footer .sign { text-align: right; text-decoration: underline; }
        .footer .date .line { border-bottom: 1px solid #000; display: inline-block; width: 150px; }
    </style>
</head>
<body>
    <table class="header">
        <tr>
            <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
            <td class="school">
                <div class="name">{{ school ? school.name|upper : '' }}</div>
                <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                <div class="tel">Tel: {{ school ? school.phone : '' }}</div>
            </td>
            <td class="logo"></td>
        </tr>
    </table>

    <div class="title-main">LISTE DES MAJORS DE CLASSE{% if period %} DU {{ period.name|upper }}{% endif %} ({{ top }} par classe)</div>
    <table class="title-row">
        <tr>
            <td><b>Période :</b> {{ period ? period.name|upper : '—' }}</td>
            <td class="right"><b>Année Scolaire :</b> {{ school_year ? school_year.name : '—' }}</td>
        </tr>
    </table>

    <table class="list">
        <thead>
            <tr>
                <th style="width:3%">N°</th>
                <th style="width:11%">MATRICULE</th>
                <th>NOM ET PRENOMS</th>
                <th style="width:9%">Age<br>Né(e) le</th>
                <th style="width:5%">Genre</th>
                <th style="width:4%">Nat</th>
                <th style="width:5%">LV2</th>
                <th style="width:7%">MOY/20</th>
                <th style="width:5%">Rang</th>
                <th style="width:7%">Classe</th>
                <th style="width:12%">OBSERVATIONS</th>
            </tr>
        </thead>
        <tbody>
            {% for class in classes %}
                {% for row in class.rows %}
                    <tr>
                        <td class="center">{{ row.seq }}</td>
                        <td>{{ row.matricule }}</td>
                        <td>{{ row.name }}</td>
                        <td class="center">{{ row.birthDate ? row.birthDate|date('d/m/Y') : '' }}</td>
                        <td class="center">{{ row.genre }}</td>
                        <td class="center">{{ row.nat }}</td>
                        <td class="center">{{ row.lv2 ?? '' }}</td>
                        <td class="center">{{ row.average|number_format(2, ',', ' ') }}</td>
                        <td class="center">{{ row.rank }}</td>
                        <td class="center">{{ row.classe }}</td>
                        <td></td>
                    </tr>
                {% else %}
                    <tr><td class="center">—</td><td colspan="10">{{ class.label }} : aucun élève noté</td></tr>
                {% endfor %}
                <tr class="sep"><td colspan="11"></td></tr>
            {% else %}
                <tr><td colspan="11" class="center">Aucune classe disponible</td></tr>
            {% endfor %}
        </tbody>
    </table>

    <table class="footer">
        <tr>
            <td class="date"><span class="line">&nbsp;</span> le {{ generated_at|date('d/m/Y H:i:s') }}</td>
            <td class="sign">Signature</td>
        </tr>
    </table>
</body>
</html>
