<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <style>
        @page { margin: 20px 22px; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 8px; color: #000; }
        .header { width: 100%; border-bottom: 1px solid #999; padding-bottom: 6px; margin-bottom: 8px; }
        .header td { vertical-align: middle; }
        .header .logo { width: 76px; }
        .header .logo img { max-height: 62px; max-width: 70px; }
        .header .school { text-align: center; }
        .header .school .name { font-weight: bold; font-size: 13px; }
        .header .school .ministry { font-size: 10px; }
        .header .school .tel { font-size: 9px; }
        .title-main { text-align: center; font-weight: bold; font-size: 11px; margin-bottom: 2px; }
        .class-name { font-weight: bold; font-size: 10px; margin: 4px 0 6px; }
        table.list { width: 100%; border-collapse: collapse; }
        table.list th, table.list td { border: 1px solid #000; padding: 2px 3px; font-size: 7.5px; }
        table.list th { text-align: center; font-weight: bold; background: #f2f2f2; }
        table.list td.center { text-align: center; }
        table.list td.estab { text-align: center; font-weight: bold; vertical-align: middle; }
        .class-block { page-break-after: always; }
        .class-block:last-child { page-break-after: auto; }
    </style>
</head>
<body>
    {% for class in classes %}
        <div class="class-block">
            <table class="header">
                <tr>
                    <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
                    <td class="school">
                        <div class="name">{{ school ? school.name|upper : '' }}</div>
                        <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                        <div class="tel">Tel: {{ school ? school.phone : '' }}</div>
                    </td>
                    <td class="logo"></td>
                </tr>
            </table>

            <div class="title-main">Récapitulatif des résultats des élèves par niveau et par classe {{ school_year ? school_year.name : '' }}</div>
            <div class="class-name">Classe de : {{ class.label }}</div>

            <table class="list">
                <thead>
                    <tr>
                        <th style="width:3%">N°</th>
                        <th style="width:11%">ETABLISSEMENT</th>
                        <th style="width:3%">N°</th>
                        <th style="width:9%">MATRICULE</th>
                        <th>NOM ET PRENOMS</th>
                        <th style="width:8%">AGE<br>(Né(e) le)</th>
                        <th style="width:5%">Genre</th>
                        <th style="width:4%">Nat</th>
                        <th style="width:5%">Red</th>
                        <th style="width:7%">Statut<br>Aff/NAff</th>
                        <th style="width:5%">N°&nbsp;déc.<br>Aff</th>
                        <th style="width:4%">LV2</th>
                        <th style="width:6%">M/20</th>
                        <th style="width:6%">Rang</th>
                        <th style="width:6%">Classe</th>
                        <th style="width:9%">OBSERVATIONS</th>
                    </tr>
                </thead>
                <tbody>
                    {% for r in class.rows %}
                        <tr>
                            {% if loop.first %}
                                <td rowspan="{{ class.total }}" class="center">1</td>
                                <td rowspan="{{ class.total }}" class="estab">{{ school ? school.name|upper : '' }}</td>
                            {% endif %}
                            <td class="center">{{ r.seq }}</td>
                            <td>{{ r.matric }}</td>
                            <td>{{ r.nom }} {{ r.prenoms }}</td>
                            <td class="center">{{ r.ne ? r.ne|date('d/m/Y') : '' }}</td>
                            <td class="center">{{ r.genre }}</td>
                            <td class="center">{{ r.nat }}</td>
                            <td class="center">{{ r.red }}</td>
                            <td class="center">{{ r.qualite }}</td>
                            <td class="center"></td>
                            <td class="center">{{ r.lv2 ?? '' }}</td>
                            <td class="center">{{ r.moy is not null ? r.moy|number_format(2, ',', ' ') : 'NC' }}</td>
                            <td class="center">{{ r.rank }}</td>
                            <td class="center">{{ r.classe }}</td>
                            <td></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <table class="header">
            <tr>
                <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
                <td class="school">
                    <div class="name">{{ school ? school.name|upper : '' }}</div>
                    <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                    <div class="tel">Tel: {{ school ? school.phone : '' }}</div>
                </td>
                <td class="logo"></td>
            </tr>
        </table>
        <p>Aucune donnée disponible.</p>
    {% endfor %}
</body>
</html>
