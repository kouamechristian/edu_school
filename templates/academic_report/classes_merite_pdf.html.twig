<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <style>
        @page { margin: 24px 26px; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 9px; color: #000; }
        .header { width: 100%; border-bottom: 1px solid #999; padding-bottom: 6px; margin-bottom: 10px; }
        .header td { vertical-align: middle; }
        .header .logo { width: 76px; }
        .header .logo img { max-height: 62px; max-width: 70px; }
        .header .school { text-align: center; }
        .header .school .name { font-weight: bold; font-size: 13px; }
        .header .school .ministry { font-size: 10px; }
        .header .school .tel { font-size: 9px; }
        .title-main { text-align: center; font-weight: bold; font-size: 12px; margin-bottom: 2px; }
        .class-name { text-align: center; font-size: 11px; margin-bottom: 8px; }
        table.list { width: 100%; border-collapse: collapse; }
        table.list th, table.list td { border: 1px solid #000; padding: 3px 4px; font-size: 8px; }
        table.list th { text-align: center; font-weight: bold; background: #f2f2f2; }
        table.list td.center { text-align: center; }
        .stats { margin-top: 6px; font-size: 9px; }
        .stats div { margin: 1px 0; }
        .stats b { font-weight: bold; }
        .class-block { page-break-after: always; }
        .class-block:last-child { page-break-after: auto; }
    </style>
</head>
<body>
    {% for class in classes %}
        <div class="class-block">
            <table class="header">
                <tr>
                    <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
                    <td class="school">
                        <div class="name">{{ school ? school.name|upper : '' }}</div>
                        <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                        <div class="tel">Tel: {{ school ? school.phone : '' }}</div>
                    </td>
                    <td class="logo"></td>
                </tr>
            </table>

            <div class="title-main">LISTE DES CLASSES PAR ORDRE DE MÉRITE{% if period %} DU {{ period.name|upper }}{% endif %}</div>
            <div class="class-name">{{ class.label }}</div>

            <table class="list">
                <thead>
                    <tr>
                        <th style="width:3%">N°</th>
                        <th style="width:10%">Matric</th>
                        <th style="width:16%">Nom</th>
                        <th>Prénoms</th>
                        <th style="width:5%">Genre</th>
                        <th style="width:10%">Né(é) le</th>
                        <th style="width:6%">Nat</th>
                        <th style="width:7%">Qualité</th>
                        <th style="width:6%">Red</th>
                        <th style="width:7%">Moy</th>
                        <th style="width:8%">Rang</th>
                    </tr>
                </thead>
                <tbody>
                    {% for r in class.rows %}
                        <tr>
                            <td class="center">{{ r.seq }}</td>
                            <td>{{ r.matric }}</td>
                            <td>{{ r.nom }}</td>
                            <td>{{ r.prenoms }}</td>
                            <td class="center">{{ r.genre }}</td>
                            <td class="center">{{ r.ne ? r.ne|date('d/m/Y') : '' }}</td>
                            <td class="center">{{ r.nat }}</td>
                            <td class="center">{{ r.qualite }}</td>
                            <td class="center">{{ r.red }}</td>
                            <td class="center">{{ r.moy is not null ? r.moy|number_format(2, ',', ' ') : 'NC' }}</td>
                            <td class="center">{{ r.rank }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="11" class="center">Aucun élève dans cette classe</td></tr>
                    {% endfor %}
                </tbody>
            </table>

            <div class="stats">
                <div>Moyenne la plus élevée : <b>{{ class.high|number_format(2, ',', ' ') }}</b></div>
                <div>Moyenne la plus faible : <b>{{ class.low|number_format(2, ',', ' ') }}</b></div>
                <div>Moyenne de la classe : <b>{{ class.class_avg|number_format(2, ',', ' ') }}</b></div>
            </div>
        </div>
    {% else %}
        <table class="header">
            <tr>
                <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
                <td class="school">
                    <div class="name">{{ school ? school.name|upper : '' }}</div>
                    <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                    <div class="tel">Tel: {{ school ? school.phone : '' }}</div>
                </td>
                <td class="logo"></td>
            </tr>
        </table>
        <p>Aucune classe disponible.</p>
    {% endfor %}
</body>
</html>
