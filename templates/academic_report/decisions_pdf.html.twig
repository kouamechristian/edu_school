<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <style>
        @page { margin: 18px 20px; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 8px; color: #000; }
        .header { width: 100%; border-bottom: 1px solid #999; padding-bottom: 5px; margin-bottom: 6px; }
        .header td { vertical-align: middle; }
        .header .logo { width: 70px; }
        .header .logo img { max-height: 56px; max-width: 64px; }
        .header .school { text-align: center; }
        .header .school .name { font-weight: bold; font-size: 13px; }
        .header .school .ministry { font-size: 9px; }
        .title-main { text-align: center; font-weight: bold; font-size: 12px; margin: 4px 0 0; }
        .title-year { text-align: center; font-size: 10px; margin-bottom: 4px; }
        .class-title { background: #1e3a5f; color: #fff; font-weight: bold; font-size: 10px; padding: 3px 8px; margin: 8px 0 2px; }
        table.list { width: 100%; border-collapse: collapse; margin-bottom: 4px; }
        table.list th, table.list td { border: 1px solid #000; padding: 2px 3px; font-size: 7.5px; }
        table.list th { text-align: center; font-weight: bold; background: #f2f2f2; }
        td.c { text-align: center; }
        .adm { color: #0a7d2c; font-weight: bold; }
        .rd { color: #b00; font-weight: bold; }
    </style>
</head>
<body>
    <table class="header">
        <tr>
            <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
            <td class="school">
                <div class="name">{{ school ? school.name|upper : '' }}</div>
                <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                <div class="ministry">Tel: {{ school ? school.phone : '' }}</div>
            </td>
            <td class="logo"></td>
        </tr>
    </table>

    <div class="title-main">LISTE DES ÉLÈVES AVEC DÉCISION DE FIN D'ANNÉE</div>
    <div class="title-year">{{ school_year ? school_year.name : '' }}</div>

    {% for class in classes %}
        <div class="class-title">{{ class.label }}</div>
        <table class="list">
            <thead>
                <tr>
                    <th style="width:3%">N°</th>
                    <th>NOM ET PRENOMS</th>
                    <th style="width:9%">MATRICULE</th>
                    <th style="width:5%">Genre</th>
                    <th style="width:10%">Nationalité</th>
                    <th style="width:5%">Red.</th>
                    <th style="width:5%">LV2</th>
                    <th style="width:8%">Date naiss.</th>
                    <th style="width:5%">Statut</th>
                    <th style="width:9%">Classe</th>
                    <th style="width:7%">Moy. ann.</th>
                    <th style="width:6%">Rang ann.</th>
                    <th style="width:11%">Décision fin d'année</th>
                </tr>
            </thead>
            <tbody>
                {% for e in class.entries %}
                    <tr>
                        <td class="c">{{ loop.index }}</td>
                        <td>{{ e.student.lastName|upper }} {{ e.student.firstName }}</td>
                        <td>{{ e.student.matriculeNational ?: (e.student.matriculeInterne ?: 'AUCUN') }}</td>
                        <td class="c">{{ e.student.gender }}</td>
                        <td>{{ e.student.nationality ?: '' }}</td>
                        <td class="c">{{ e.red }}</td>
                        <td class="c">{{ e.lv2 }}</td>
                        <td class="c">{{ e.student.dateOfBirth ? e.student.dateOfBirth|date('d/m/Y') : '' }}</td>
                        <td class="c">{{ e.student.status == 'affecte' ? 'Aff' : (e.student.status == 'non_affecte' ? 'NAff' : '') }}</td>
                        <td>{{ class.label }}</td>
                        <td class="c">{{ e.average is not null ? e.average|number_format(2, ',', ' ') : 'NC' }}</td>
                        <td class="c">{{ e.rank ?? 'NC' }}</td>
                        <td class="c {{ e.average is null ? '' : (e.average >= 10 ? 'adm' : 'rd') }}">{{ e.decision }}</td>
                    </tr>
                {% else %}
                    <tr><td colspan="13" class="c">Aucun élève</td></tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>Aucune donnée disponible.</p>
    {% endfor %}

    <div style="font-size:8px; color:#666; margin-top:6px;">Décision calculée sur la moyenne annuelle : Admis si moyenne &gt;= 10/20, sinon Redouble. « NC » : élève non noté.</div>
</body>
</html>
