<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <style>
        @page { margin: 18px 20px; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 8px; color: #000; }
        .header { width: 100%; border-bottom: 1px solid #999; padding-bottom: 6px; margin-bottom: 12px; }
        .header td { vertical-align: middle; }
        .header .logo { width: 70px; }
        .header .logo img { max-height: 60px; max-width: 66px; }
        .header .school { text-align: center; }
        .header .school .name { font-weight: bold; font-size: 13px; }
        .header .school .ministry { font-size: 10px; }
        .header .school .tel { font-size: 9px; }
        .title-row { width: 100%; margin-bottom: 8px; }
        .title-row td { font-size: 12px; }
        .title-row .right { text-align: right; }
        .title-row b { font-weight: bold; }
        table.list { width: 100%; border-collapse: collapse; }
        table.list th, table.list td { border: 1px solid #000; padding: 2px 3px; font-size: 7px; }
        table.list th { text-align: center; font-weight: bold; background: #f2f2f2; }
        table.list td.center { text-align: center; }
        table.list td.band { text-align: left; font-weight: bold; }
        table.list th.ens, table.list td.ens { background: #dfe6ee; }
        table.list tr.total td { background: #eef2f6; font-weight: bold; }
        table.list tr.total td.ens { background: #dfe6ee; }
        .footer { width: 100%; margin-top: 20px; font-size: 10px; }
        .footer td { vertical-align: top; }
        .footer .sign { text-align: right; text-decoration: underline; }
        .footer .date .line { border-bottom: 1px solid #000; display: inline-block; width: 140px; }
    </style>
</head>
<body>
    <table class="header">
        <tr>
            <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
            <td class="school">
                <div class="name">{{ school ? school.name|upper : '' }}</div>
                <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                <div class="tel">Tel: {{ school ? school.phone : '' }}</div>
            </td>
            <td class="logo"></td>
        </tr>
    </table>

    <table class="title-row">
        <tr>
            <td><b>RÉPARTITION DES ÉLÈVES PAR NIVEAU ET PAR ÂGE</b></td>
            <td class="right"><b>Année Scolaire:</b> {{ school_year ? school_year.name : '—' }}</td>
        </tr>
    </table>

    <table class="list">
        <thead>
            <tr>
                <th rowspan="2">AGE</th>
                {% for level in levels %}<th colspan="2">{{ level.label }}</th>{% endfor %}
                <th colspan="2" class="ens">Ensemble</th>
            </tr>
            <tr>
                {% for level in levels %}<th>Total</th><th>Fille</th>{% endfor %}
                <th class="ens">Total</th><th class="ens">Fille</th>
            </tr>
        </thead>
        <tbody>
            {% for band in bands %}
                <tr>
                    <td class="band">{{ band.label }}</td>
                    {% for level in levels %}
                        <td class="center">{{ level.bands[band.key].total }}</td>
                        <td class="center">{{ level.bands[band.key].girls }}</td>
                    {% endfor %}
                    <td class="center ens">{{ ensemble.bands[band.key].total }}</td>
                    <td class="center ens">{{ ensemble.bands[band.key].girls }}</td>
                </tr>
            {% endfor %}
            <tr class="total">
                <td class="band">Total élève par niveau</td>
                {% for level in levels %}
                    <td class="center">{{ level.total }}</td>
                    <td class="center">{{ level.girls }}</td>
                {% endfor %}
                <td class="center ens">{{ ensemble.total }}</td>
                <td class="center ens">{{ ensemble.girls }}</td>
            </tr>
            <tr class="total">
                <td class="band">Dont redoublant</td>
                {% for level in levels %}
                    <td class="center">{{ level.redTotal }}</td>
                    <td class="center">{{ level.redGirls }}</td>
                {% endfor %}
                <td class="center ens">{{ ensemble.redTotal }}</td>
                <td class="center ens">{{ ensemble.redGirls }}</td>
            </tr>
        </tbody>
    </table>

    <table class="footer">
        <tr>
            <td class="date"><span class="line">&nbsp;</span> le {{ generated_at|date('d/m/Y H:i:s') }}</td>
            <td class="sign">Signature</td>
        </tr>
    </table>
</body>
</html>
