<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <style>
        @page { margin: 26px 30px; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 11px; color: #000; }
        .booklet { page-break-after: always; }
        .booklet:last-child { page-break-after: auto; }
        .header { width: 100%; border-bottom: 1px solid #999; padding-bottom: 6px; margin-bottom: 10px; }
        .header td { vertical-align: middle; }
        .header .logo { width: 76px; }
        .header .logo img { max-height: 62px; max-width: 70px; }
        .header .school { text-align: center; }
        .header .school .name { font-weight: bold; font-size: 14px; }
        .header .school .ministry { font-size: 10px; }
        .header .school .tel { font-size: 9px; }
        .doc-title { text-align: center; font-weight: bold; font-size: 13px; color: #1e3a5f; margin: 4px 0 8px; }
        .ident { width: 100%; background: #eef3f8; margin-bottom: 8px; }
        .ident td { padding: 4px 8px; font-size: 11px; }
        .ident b { font-weight: bold; }
        table.grades { width: 100%; border-collapse: collapse; }
        table.grades th, table.grades td { border: 1px solid #000; padding: 4px 6px; font-size: 10px; }
        table.grades th { text-align: center; font-weight: bold; background: #f2f2f2; }
        table.grades td.center { text-align: center; }
        table.grades tr.total td { background: #eef3f8; font-weight: bold; }
        .summary { width: 100%; margin-top: 8px; }
        .summary td { padding: 4px 8px; font-size: 11px; vertical-align: top; }
        .summary .box { border: 1px solid #1e3a5f; padding: 5px 8px; }
        .summary b { font-weight: bold; }
        .footer { width: 100%; margin-top: 14px; font-size: 10px; }
        .footer td { vertical-align: top; width: 50%; }
        .footer .sign { text-align: center; }
        .footer .line { border-bottom: 1px solid #000; height: 30px; }
    </style>
</head>
<body>
    {% for b in booklets %}
        <div class="booklet">
            <table class="header">
                <tr>
                    <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
                    <td class="school">
                        <div class="name">{{ school ? school.name|upper : '' }}</div>
                        <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                        <div class="tel">Tel: {{ school ? school.phone : '' }}</div>
                    </td>
                    <td class="logo"></td>
                </tr>
            </table>

            <div class="doc-title">LIVRET SCOLAIRE — BILAN ANNUEL</div>

            <table class="ident">
                <tr>
                    <td><b>Élève :</b> {{ b.student.lastName|upper }} {{ b.student.firstName }}</td>
                    <td><b>Matricule :</b> {{ b.student.matriculeInterne ?: '—' }}</td>
                </tr>
                <tr>
                    <td><b>Classe :</b> {{ classroom.name }}{% if classroom.level %} ({{ classroom.level.name }}){% endif %}</td>
                    <td><b>Année scolaire :</b> {{ school_year ? school_year.name : '—' }}</td>
                </tr>
            </table>

            <table class="grades">
                <thead>
                    <tr>
                        <th style="text-align:left">Matière</th>
                        <th style="width:12%">Coef.</th>
                        <th style="width:16%">Moyenne /20</th>
                        <th>Appréciation</th>
                    </tr>
                </thead>
                <tbody>
                    {% for line in b.lines %}
                        <tr>
                            <td>{{ line.subject }}</td>
                            <td class="center">{{ line.coefficient|number_format(line.coefficient == line.coefficient|round ? 0 : 2, ',', ' ') }}</td>
                            <td class="center">{{ line.average|number_format(2, ',', ' ') }}</td>
                            <td>{{ line.appreciation }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="4" class="center">Aucune note disponible pour cet élève.</td></tr>
                    {% endfor %}
                    {% if b.general is not null %}
                        <tr class="total">
                            <td colspan="2">MOYENNE GÉNÉRALE</td>
                            <td class="center">{{ b.general|number_format(2, ',', ' ') }}</td>
                            <td>{{ b.mention ?: '' }}</td>
                        </tr>
                    {% endif %}
                </tbody>
            </table>

            <table class="summary">
                <tr>
                    <td style="width:50%"><div class="box"><b>Rang :</b> {{ b.rank ?? '—' }}{% if b.total %} / {{ b.total }}{% endif %}</div></td>
                    <td style="width:50%"><div class="box"><b>Décision de fin d'année :</b> {{ b.decision }}</div></td>
                </tr>
            </table>

            <table class="footer">
                <tr>
                    <td class="sign"><div>Le Professeur Principal</div><div class="line"></div></td>
                    <td class="sign"><div>Le Chef d'Établissement</div><div class="line"></div></td>
                </tr>
            </table>
        </div>
    {% else %}
        <p>Aucun élève dans cette classe.</p>
    {% endfor %}
</body>
</html>
