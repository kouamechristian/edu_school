<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <style>
        @page { margin: 20px 22px; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 8px; color: #000; }
        .header { width: 100%; border-bottom: 1px solid #999; padding-bottom: 6px; margin-bottom: 6px; }
        .header td { vertical-align: middle; }
        .header .logo { width: 70px; }
        .header .logo img { max-height: 58px; max-width: 66px; }
        .header .school { text-align: center; }
        .header .school .name { font-weight: bold; font-size: 13px; }
        .header .school .ministry { font-size: 9px; }
        .title-main { text-align: center; font-weight: bold; font-size: 11px; margin: 4px 0; }
        .subrow { width: 100%; margin-bottom: 6px; }
        .subrow td { font-size: 9px; font-weight: bold; }
        .subrow .right { text-align: right; }
        table.list { width: 100%; border-collapse: collapse; }
        table.list th, table.list td { border: 1px solid #000; padding: 2px 3px; font-size: 7.5px; }
        table.list th { text-align: center; font-weight: bold; background: #f2f2f2; }
        td.c { text-align: center; }
        .footer { margin-top: 8px; font-size: 8px; }
    </style>
</head>
<body>
    <table class="header">
        <tr>
            <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
            <td class="school">
                <div class="name">{{ school ? school.name|upper : '' }}</div>
                <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                <div class="ministry">Tel: {{ school ? school.phone : '' }}</div>
            </td>
            <td class="logo"></td>
        </tr>
    </table>

    <div class="title-main">LISTE DES ÉLÈVES AYANT OBTENU UNE MOYENNE &gt;= {{ min|number_format(2, ',', ' ') }}/20</div>

    <table class="subrow">
        <tr>
            <td>Période : {{ period ? period.name|upper : '' }}</td>
            <td class="right">Année Scolaire : {{ school_year ? school_year.name : '—' }}</td>
        </tr>
    </table>

    <table class="list">
        <thead>
            <tr>
                <th style="width:3%">N°</th>
                <th style="width:11%">MATRICULE</th>
                <th>NOM ET PRENOMS</th>
                <th style="width:9%">Age<br>(Né(e) le)</th>
                <th style="width:5%">Genre</th>
                <th style="width:5%">Nat</th>
                <th style="width:5%">Red</th>
                <th style="width:5%">LV2</th>
                <th style="width:8%">MOY/20</th>
                <th style="width:8%">Rang</th>
                <th style="width:8%">Classe</th>
            </tr>
        </thead>
        <tbody>
            {% for r in rows %}
                <tr>
                    <td class="c">{{ r.seq }}</td>
                    <td>{{ r.matric }}</td>
                    <td>{{ r.nom }}</td>
                    <td class="c">{{ r.ne ? r.ne|date('d/m/Y') : '' }}</td>
                    <td class="c">{{ r.genre }}</td>
                    <td class="c">{{ r.nat }}</td>
                    <td class="c">{{ r.red }}</td>
                    <td class="c">{{ r.lv2 }}</td>
                    <td class="c">{{ r.moy|number_format(2, ',', ' ') }}</td>
                    <td class="c">{{ r.rank }}</td>
                    <td class="c">{{ r.classe }}</td>
                </tr>
            {% else %}
                <tr><td colspan="11" class="c">Aucun élève n'a obtenu cette moyenne pour la période choisie.</td></tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="footer">Total : <b>{{ rows|length }}</b> élève(s) &nbsp;·&nbsp; édité le {{ generated_at|date('d/m/Y H:i') }}</div>
</body>
</html>
