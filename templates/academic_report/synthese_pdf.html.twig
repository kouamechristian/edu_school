<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <style>
        @page { margin: 26px 30px; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 11px; color: #000; }
        .header { width: 100%; border-bottom: 1px solid #999; padding-bottom: 6px; margin-bottom: 14px; }
        .header td { vertical-align: middle; }
        .header .logo { width: 80px; }
        .header .logo img { max-height: 70px; max-width: 75px; }
        .header .school { text-align: center; }
        .header .school .name { font-weight: bold; font-size: 14px; }
        .header .school .ministry { font-size: 11px; }
        .header .school .tel { font-size: 10px; }
        .title-row { width: 100%; margin-bottom: 12px; }
        .title-row td { font-size: 13px; }
        .title-row .right { text-align: right; }
        .title-row b { font-weight: bold; }
        .title-main { text-align: center; font-weight: bold; font-size: 12px; text-decoration: underline; margin-bottom: 12px; }
        table.cards { width: 100%; border-collapse: separate; border-spacing: 6px; margin-bottom: 12px; }
        table.cards td { border: 1px solid #ccc; border-radius: 4px; padding: 8px 10px; text-align: center; background: #f7f9fb; width: 25%; }
        table.cards .v { font-size: 16px; font-weight: bold; color: #1e3a5f; }
        table.cards .l { font-size: 9px; color: #555; }
        table.list { width: 100%; border-collapse: collapse; }
        table.list th, table.list td { border: 1px solid #000; padding: 4px 6px; font-size: 10px; }
        table.list th { text-align: center; font-weight: bold; background: #f2f2f2; }
        table.list td.center { text-align: center; }
        table.list tr.grand td { background: #dfe6ee; font-weight: bold; }
        .footer { width: 100%; margin-top: 22px; font-size: 11px; }
        .footer td { vertical-align: top; }
        .footer .sign { text-align: right; text-decoration: underline; }
        .footer .date .line { border-bottom: 1px solid #000; display: inline-block; width: 150px; }
    </style>
</head>
<body>
    <table class="header">
        <tr>
            <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
            <td class="school">
                <div class="name">{{ school ? school.name|upper : '' }}</div>
                <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                <div class="tel">Tel: {{ school ? school.phone : '' }}</div>
            </td>
            <td class="logo"></td>
        </tr>
    </table>

    <div class="title-main">SYNTHÈSE GÉNÉRALE DES RÉSULTATS SCOLAIRES {{ scope_title|default('ANNUELS') }} {{ school_year ? school_year.name : '' }}</div>

    <table class="list">
        <thead>
            <tr>
                <th rowspan="2" style="width:18%">NIVEAU</th>
                <th rowspan="2">Nbre<br>de Classes</th>
                <th colspan="3">EFFECTIF</th>
                <th colspan="2">Moy &gt;= 10</th>
                <th colspan="2">10 &gt; Moy &gt;= 8,5</th>
                <th colspan="2">Moy &lt; 8,5</th>
                <th rowspan="2">Moyenne<br>ETABLISSEMENT</th>
            </tr>
            <tr>
                <th>Total</th>
                <th>Classé</th>
                <th>Non<br>classé</th>
                <th>NOMBRE</th>
                <th>%</th>
                <th>NOMBRE</th>
                <th>%</th>
                <th>NOMBRE</th>
                <th>%</th>
            </tr>
        </thead>
        <tbody>
            {% for lvl in levels %}
                <tr>
                    <td>{{ lvl.label }}</td>
                    <td class="center">{{ lvl.classes }}</td>
                    <td class="center">{{ lvl.count }}</td>
                    <td class="center">{{ lvl.graded }}</td>
                    <td class="center">{{ lvl.count - lvl.graded }}</td>
                    <td class="center">{{ lvl.b10 }}</td>
                    <td class="center">{{ (lvl.graded > 0 ? lvl.b10 / lvl.graded * 100 : 0)|number_format(2, '.', '') }}</td>
                    <td class="center">{{ lvl.b85 }}</td>
                    <td class="center">{{ (lvl.graded > 0 ? lvl.b85 / lvl.graded * 100 : 0)|number_format(2, '.', '') }}</td>
                    <td class="center">{{ lvl.blow }}</td>
                    <td class="center">{{ (lvl.graded > 0 ? lvl.blow / lvl.graded * 100 : 0)|number_format(2, '.', '') }}</td>
                    <td class="center">{{ lvl.average is not null ? lvl.average|number_format(2, ',', ' ') : '0,00' }}</td>
                </tr>
            {% endfor %}
            <tr class="grand">
                <td>Total Général</td>
                <td class="center">{{ overall.classes }}</td>
                <td class="center">{{ overall.count }}</td>
                <td class="center">{{ overall.graded }}</td>
                <td class="center">{{ overall.count - overall.graded }}</td>
                <td class="center">{{ overall.b10 }}</td>
                <td class="center">{{ (overall.graded > 0 ? overall.b10 / overall.graded * 100 : 0)|number_format(2, '.', '') }}</td>
                <td class="center">{{ overall.b85 }}</td>
                <td class="center">{{ (overall.graded > 0 ? overall.b85 / overall.graded * 100 : 0)|number_format(2, '.', '') }}</td>
                <td class="center">{{ overall.blow }}</td>
                <td class="center">{{ (overall.graded > 0 ? overall.blow / overall.graded * 100 : 0)|number_format(2, '.', '') }}</td>
                <td class="center">{{ overall.average is not null ? overall.average|number_format(2, ',', ' ') : '0,00' }}</td>
            </tr>
        </tbody>
    </table>

    <table class="footer">
        <tr>
            <td class="date"><span class="line">&nbsp;</span> le {{ generated_at|date('d/m/Y H:i:s') }}</td>
            <td class="sign">Le Directeur des Études</td>
        </tr>
    </table>
</body>
</html>
