<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <style>
        @page { margin: 20px 22px; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 8px; color: #000; }
        .header { width: 100%; border-bottom: 1px solid #999; padding-bottom: 6px; margin-bottom: 6px; }
        .header td { vertical-align: middle; }
        .header .logo { width: 76px; }
        .header .logo img { max-height: 62px; max-width: 70px; }
        .header .school { text-align: center; }
        .header .school .name { font-weight: bold; font-size: 13px; }
        .header .school .ministry { font-size: 10px; }
        .header .school .tel { font-size: 9px; }
        .title-main { text-align: center; font-weight: bold; font-size: 11px; margin-bottom: 4px; }
        .class-name { font-weight: bold; font-size: 11px; margin: 4px 0 2px; }
        .subject-name { font-weight: bold; font-size: 10px; margin: 2px 0 4px; text-transform: uppercase; }
        table.list { width: 100%; border-collapse: collapse; }
        table.list th, table.list td { border: 1px solid #000; padding: 2px 3px; font-size: 7.5px; }
        table.list th { text-align: center; font-weight: bold; background: #f2f2f2; }
        table.list td.center { text-align: center; }
        .subject-block { page-break-after: always; }
        .subject-block:last-child { page-break-after: auto; }
    </style>
</head>
<body>
    {% for class in classes %}
        {% for subject in class.subjects %}
            <div class="subject-block">
                <table class="header">
                    <tr>
                        <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
                        <td class="school">
                            <div class="name">{{ school ? school.name|upper : '' }}</div>
                            <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                            <div class="tel">Tel: {{ school ? school.phone : '' }}</div>
                        </td>
                        <td class="logo"></td>
                    </tr>
                </table>

                <div class="title-main">TABLEAU RÉCAPITULATIF DES MOYENNES PAR MATIÈRE {{ school_year ? school_year.name : '' }}</div>
                <div class="class-name">{{ class.label }}</div>
                <div class="subject-name">{{ subject.name }}</div>

                <table class="list">
                    <thead>
                        <tr>
                            <th style="width:4%" rowspan="2">N°</th>
                            <th style="width:12%" rowspan="2">MATRICULE</th>
                            <th rowspan="2">NOM ET PRENOMS</th>
                            <th colspan="2">{{ period ? period.name|upper : 'PÉRIODE' }}</th>
                            <th colspan="2">Moyenne Annuelle</th>
                        </tr>
                        <tr>
                            <th style="width:9%">Moy</th>
                            <th style="width:9%">Rang</th>
                            <th style="width:9%">Moy</th>
                            <th style="width:9%">Rang</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for r in subject.rows %}
                            <tr>
                                <td class="center">{{ r.seq }}</td>
                                <td>{{ r.matric }}</td>
                                <td>{{ r.nom }}</td>
                                <td class="center">{{ r.moy is not null ? r.moy|number_format(2, ',', ' ') : 'NC' }}</td>
                                <td class="center">{{ r.rank }}</td>
                                <td class="center">{{ r.annual is not null ? r.annual|number_format(2, ',', ' ') : '0' }}</td>
                                <td class="center"></td>
                            </tr>
                        {% else %}
                            <tr><td colspan="7" class="center">Aucun élève dans cette classe</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endfor %}
    {% else %}
        <table class="header">
            <tr>
                <td class="logo">{% if logo_data %}<img src="{{ logo_data }}" alt="Logo">{% endif %}</td>
                <td class="school">
                    <div class="name">{{ school ? school.name|upper : '' }}</div>
                    <div class="ministry">{{ school ? school.sousTutelle : '' }}</div>
                    <div class="tel">Tel: {{ school ? school.phone : '' }}</div>
                </td>
                <td class="logo"></td>
            </tr>
        </table>
        <p>Aucune donnée disponible.</p>
    {% endfor %}
</body>
</html>
