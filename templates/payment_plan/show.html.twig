{% extends 'base.html.twig' %}

{% block title %}Détails du Plan de Paiement{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-calendar-check me-2"></i>Détails du Plan de Paiement
        </h1>
        <div>
            <a href="{{ path('admin_payment_plan_edit', {'id': payment_plan.id}) }}" class="btn btn-warning">
                <i class="fas fa-edit me-2"></i>Modifier
            </a>
            <a href="{{ path('admin_payment_plan_index') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-2"></i>Retour à la liste
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">{{ payment_plan.name }}</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <strong>Montant total:</strong>
                            <p>{{ payment_plan.totalAmount|number_format(0, ',', ' ') }} FCFA</p>
                        </div>
                        <div class="col-md-6">
                            <strong>Nombre d'échéances:</strong>
                            <p>{{ payment_plan.installmentCount }}</p>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <strong>Montant par échéance:</strong>
                            <p>{{ payment_plan.installmentAmount|number_format(0, ',', ' ') }} FCFA</p>
                        </div>
                        <div class="col-md-6">
                            <strong>Statut:</strong>
                            <p>
                                <span class="badge badge-{{ payment_plan.isActive ? 'success' : 'secondary' }}">
                                    {{ payment_plan.isActive ? 'Actif' : 'Inactif' }}
                                </span>
                            </p>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <strong>Date de début:</strong>
                            <p>{{ payment_plan.startDate ? payment_plan.startDate|date('d/m/Y') : 'Non définie' }}</p>
                        </div>
                        <div class="col-md-6">
                            <strong>Date de fin:</strong>
                            <p>{{ payment_plan.endDate ? payment_plan.endDate|date('d/m/Y') : 'Non définie' }}</p>
                        </div>
                    </div>

                    {% if payment_plan.description %}
                        <div class="row">
                            <div class="col-12">
                                <strong>Description:</strong>
                                <p>{{ payment_plan.description }}</p>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Actions</h6>
                </div>
                <div class="card-body">
                    <a href="{{ path('admin_payment_plan_edit', {'id': payment_plan.id}) }}" class="btn btn-warning btn-block mb-2">
                        <i class="fas fa-edit me-2"></i>Modifier le plan
                    </a>
                    
                    <form method="post" action="{{ path('admin_payment_plan_delete', {'id': payment_plan.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce plan de paiement ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ payment_plan.id) }}">
                        <button type="submit" class="btn btn-danger btn-block">
                            <i class="fas fa-trash me-2"></i>Supprimer
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
