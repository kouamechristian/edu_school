{% extends 'base.html.twig' %}

{% block title %}Plans de Paiement{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-calendar-check me-2"></i>Plans de Paiement
        </h1>
        <a href="{{ path('admin_payment_plan_new') }}" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Nouveau Plan
        </a>
    </div>

    <div class="card shadow">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Liste des Plans de Paiement</h6>
        </div>
        <div class="card-body">
            {% if payment_plans|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Nom</th>
                                <th>Montant Total</th>
                                <th>Nombre d'échéances</th>
                                <th>Montant par échéance</th>
                                <th>Statut</th>
                                <th>Date de début</th>
                                <th>Date de fin</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for payment_plan in payment_plans %}
                                <tr>
                                    <td>{{ payment_plan.name }}</td>
                                    <td>{{ payment_plan.totalAmount|number_format(0, ',', ' ') }} FCFA</td>
                                    <td>{{ payment_plan.installmentCount }}</td>
                                    <td>{{ payment_plan.installmentAmount|number_format(0, ',', ' ') }} FCFA</td>
                                    <td>
                                        <span class="badge badge-{{ payment_plan.isActive ? 'success' : 'secondary' }}">
                                            {{ payment_plan.isActive ? 'Actif' : 'Inactif' }}
                                        </span>
                                    </td>
                                    <td>{{ payment_plan.startDate ? payment_plan.startDate|date('d/m/Y') : '' }}</td>
                                    <td>{{ payment_plan.endDate ? payment_plan.endDate|date('d/m/Y') : '' }}</td>
                                    <td>
                                        <a href="{{ path('admin_payment_plan_show', {'id': payment_plan.id}) }}" class="btn btn-info btn-sm">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="{{ path('admin_payment_plan_edit', {'id': payment_plan.id}) }}" class="btn btn-warning btn-sm">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-4">
                    <i class="fas fa-calendar-check fa-3x text-muted mb-3"></i>
                    <p class="text-muted">Aucun plan de paiement trouvé</p>
                    <a href="{{ path('admin_payment_plan_new') }}" class="btn btn-primary">
                        <i class="fas fa-plus me-2"></i>Créer le premier plan
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
